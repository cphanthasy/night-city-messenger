{{!-- Message Composer Template (FIXED) --}}
{{!-- Uses canonical header structure --}}

<div class="ncm-composer__container">
  
  {{!-- CANONICAL HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-wifi"></i> {{networkName}}
      </div>
      <div class="ncm-header__title">COMPOSE MESSAGE</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">From: {{senderEmail}}</span>
      {{#if scheduled}}
      <span class="ncm-header__badge">SCHEDULED</span>
      {{/if}}
    </div>
  </div>
  
  {{!-- Header Fields Section --}}
  <div class="ncm-composer__header-section">
    
    {{!-- Recipient Field --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">To:</label>
      <div class="ncm-composer__field-content">
        <div class="ncm-composer__recipient-wrapper">
          <input 
            type="text" 
            class="ncm-composer__recipient-input" 
            name="to" 
            value="{{to}}"
            placeholder="recipient@example.net"
            data-field="to"
            autocomplete="off"
          />
          {{!-- Email suggestions dropdown appears here via JS --}}
          <div class="ncm-composer__suggestions"></div>
        </div>
        <button class="ncm-btn ncm-btn--small" data-action="select-contact">
          <i class="fas fa-address-book"></i> Contacts
        </button>
      </div>
    </div>
    
    {{!-- Subject Field --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">Subject:</label>
      <div class="ncm-composer__field-content">
        <input 
          type="text" 
          class="ncm-composer__subject-input" 
          name="subject" 
          value="{{subject}}"
          placeholder="Message subject..."
          data-field="subject"
        />
      </div>
    </div>
  </div>
  
  {{!-- Editor Section --}}
  <div class="ncm-composer__editor-section">
    
    {{!-- Editor Toolbar --}}
    <div class="ncm-composer__toolbar">
      <button class="ncm-composer__toolbar-btn" data-action="bold" title="Bold">
        <i class="fas fa-bold"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="italic" title="Italic">
        <i class="fas fa-italic"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="underline" title="Underline">
        <i class="fas fa-underline"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      <button class="ncm-composer__toolbar-btn" data-action="list" title="List">
        <i class="fas fa-list-ul"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="link" title="Link">
        <i class="fas fa-link"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="code" title="Code">
        <i class="fas fa-code"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      <button class="ncm-composer__toolbar-btn" data-action="template" title="Templates">
        <i class="fas fa-file-alt"></i>
      </button>
    </div>
    
    {{!-- Message Editor --}}
    <div class="ncm-composer__editor" contenteditable="true" data-field="content">
      {{{content}}}
    </div>
  </div>
  
  {{!-- Footer Actions --}}
  <div class="ncm-composer__footer">
    <div class="ncm-composer__footer-left">
      <span class="ncm-composer__char-count">
        <span class="ncm-composer__char-count-value">{{charCount}}</span> / 10000
      </span>
    </div>
    
    <div class="ncm-composer__footer-right">
      <button class="ncm-btn" data-action="save-draft">
        <i class="fas fa-save"></i> Save Draft
      </button>
      
      <button class="ncm-btn ncm-btn--secondary" data-action="schedule">
        <i class="fas fa-clock"></i> Schedule
      </button>
      
      <button class="ncm-btn ncm-btn--primary ncm-composer__send-btn" data-action="send">
        <i class="fas fa-paper-plane"></i> Send
      </button>
      
      <button class="ncm-btn" data-action="cancel">
        <i class="fas fa-times"></i> Cancel
      </button>
    </div>
  </div>
</div>