{{!-- Message Composer Template (FIXED) --}}
{{!-- Uses canonical header structure --}}

<div class="ncm-composer__container">
  
  {{!-- CANONICAL HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-wifi"></i> {{networkName}}
      </div>
      <div class="ncm-header__title">COMPOSE MESSAGE</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">From: {{senderEmail}}</span>
      {{#if scheduled}}
      <span class="ncm-header__badge">SCHEDULED</span>
      {{/if}}
    </div>
  </div>
  
  {{!-- Header Fields Section --}}
  <div class="ncm-composer__header-section">
    
    {{!-- Recipient Field --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">To:</label>
      <div class="ncm-composer__field-content">
        <div class="ncm-composer__recipient-wrapper">
          <input 
            type="text" 
            class="ncm-composer__recipient-input" 
            name="to" 
            value="{{to}}"
            placeholder="recipient@example.net"
            data-field="to"
            autocomplete="off"
          />
          {{!-- Email suggestions dropdown appears here via JS --}}
          <div class="ncm-composer__suggestions"></div>
        </div>
        <button class="ncm-btn ncm-btn--small" data-action="select-contact">
          <i class="fas fa-address-book"></i> Contacts
        </button>
      </div>
    </div>
    
    {{!-- Subject Field --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">Subject:</label>
      <div class="ncm-composer__field-content">
        <input 
          type="text" 
          class="ncm-composer__subject-input" 
          name="subject" 
          value="{{subject}}"
          placeholder="Message subject..."
          data-field="subject"
        />
      </div>
    </div>
  </div>
  
  {{!-- Editor Section --}}
  <div class="ncm-composer__editor-section">
    
  {{!-- Comprehensive Email Toolbar --}}
  <div class="ncm-composer__toolbar">
    
    {{!-- Row 1: Text Formatting --}}
    <div class="ncm-composer__toolbar-row">
      
      {{!-- Font Family --}}
      <select class="ncm-composer__toolbar-select" data-action="font-family">
        <option value="">Font</option>
        <option value="Arial">Arial</option>
        <option value="Courier New">Courier New</option>
        <option value="Georgia">Georgia</option>
        <option value="Times New Roman">Times New Roman</option>
        <option value="Verdana">Verdana</option>
        <option value="Rajdhani">Rajdhani</option>
        <option value="Orbitron">Orbitron</option>
        <option value="Signika">Signika</option>
      </select>
      
      {{!-- Font Size --}}
      <select class="ncm-composer__toolbar-select" data-action="font-size">
        <option value="">Size</option>
        <option value="1">Small</option>
        <option value="3">Normal</option>
        <option value="5">Large</option>
        <option value="7">Huge</option>
      </select>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Basic Formatting --}}
      <button class="ncm-composer__toolbar-btn" data-format="bold" title="Bold (Ctrl+B)" type="button">
        <i class="fas fa-bold"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="italic" title="Italic (Ctrl+I)" type="button">
        <i class="fas fa-italic"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="underline" title="Underline (Ctrl+U)" type="button">
        <i class="fas fa-underline"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="strikeThrough" title="Strikethrough" type="button">
        <i class="fas fa-strikethrough"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Colors --}}
      <div class="ncm-composer__toolbar-color-wrapper">
        <button class="ncm-composer__toolbar-btn" data-action="text-color" title="Text Color" type="button">
          <i class="fas fa-font"></i>
          <i class="fas fa-caret-down"></i>
        </button>
        <input type="color" class="ncm-composer__color-picker" data-color-type="text" style="display:none;" />
      </div>
      
      <div class="ncm-composer__toolbar-color-wrapper">
        <button class="ncm-composer__toolbar-btn" data-action="highlight-color" title="Highlight Color" type="button">
          <i class="fas fa-highlighter"></i>
          <i class="fas fa-caret-down"></i>
        </button>
        <input type="color" class="ncm-composer__color-picker" data-color-type="background" style="display:none;" />
      </div>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Alignment --}}
      <button class="ncm-composer__toolbar-btn" data-format="justifyLeft" title="Align Left" type="button">
        <i class="fas fa-align-left"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="justifyCenter" title="Align Center" type="button">
        <i class="fas fa-align-center"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="justifyRight" title="Align Right" type="button">
        <i class="fas fa-align-right"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="justifyFull" title="Justify" type="button">
        <i class="fas fa-align-justify"></i>
      </button>
    </div>
    
    {{!-- Row 2: Lists, Indents, Special --}}
    <div class="ncm-composer__toolbar-row">
      
      {{!-- Lists --}}
      <button class="ncm-composer__toolbar-btn" data-format="insertUnorderedList" title="Bullet List" type="button">
        <i class="fas fa-list-ul"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="insertOrderedList" title="Numbered List" type="button">
        <i class="fas fa-list-ol"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Indents --}}
      <button class="ncm-composer__toolbar-btn" data-format="indent" title="Increase Indent" type="button">
        <i class="fas fa-indent"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="outdent" title="Decrease Indent" type="button">
        <i class="fas fa-outdent"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Special Formatting --}}
      <button class="ncm-composer__toolbar-btn" data-format="formatBlock" data-block-type="blockquote" title="Quote" type="button">
        <i class="fas fa-quote-left"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="insertHorizontalRule" title="Horizontal Line" type="button">
        <i class="fas fa-minus"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Insert Items --}}
      <button class="ncm-composer__toolbar-btn" data-action="insert-link" title="Insert Link" type="button">
        <i class="fas fa-link"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="insert-image" title="Insert Image" type="button">
        <i class="fas fa-image"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-action="insert-emoji" title="Insert Emoji" type="button">
        <i class="fas fa-smile"></i>
      </button>
      
      <div class="ncm-composer__toolbar-separator"></div>
      
      {{!-- Utilities --}}
      <button class="ncm-composer__toolbar-btn" data-format="removeFormat" title="Clear Formatting" type="button">
        <i class="fas fa-remove-format"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="undo" title="Undo" type="button">
        <i class="fas fa-undo"></i>
      </button>
      <button class="ncm-composer__toolbar-btn" data-format="redo" title="Redo" type="button">
        <i class="fas fa-redo"></i>
      </button>
      
    </div>
    
  </div>
    
    {{!-- Simple contenteditable editor --}}
    <div class="ncm-composer__editor" 
         contenteditable="true" 
         data-field="content"
         placeholder="Type your message here...">
      {{{content}}}
    </div>
  </div>
  
  {{!-- Footer Actions --}}
  <div class="ncm-composer__footer">
    <div class="ncm-composer__footer-left">
      <span class="ncm-composer__char-count">
        <span class="ncm-composer__char-count-value">{{charCount}}</span> / 10000
      </span>
    </div>
    
    <div class="ncm-composer__footer-right">
      <button class="ncm-btn" data-action="save-draft">
        <i class="fas fa-save"></i> Save Draft
      </button>
      
      <button class="ncm-btn ncm-btn--secondary" data-action="schedule">
        <i class="fas fa-clock"></i> Schedule
      </button>
      
      <button class="ncm-btn ncm-btn--primary ncm-composer__send-btn" data-action="send">
        <i class="fas fa-paper-plane"></i> Send
      </button>
      
      <button class="ncm-btn" data-action="cancel">
        <i class="fas fa-times"></i> Cancel
      </button>
    </div>
  </div>
</div>