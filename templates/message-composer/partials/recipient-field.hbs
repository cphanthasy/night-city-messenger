{{!-- Recipient Field Partial --}}
{{!-- File: templates/message-composer/partials/recipient-field.hbs --}}

<div class="ncm-composer__field">
  <label class="ncm-composer__label">To:</label>
  <div class="ncm-composer__field-content">
    <div class="ncm-composer__recipient-wrapper">
      <input 
        type="text" 
        class="ncm-composer__recipient-input" 
        name="to" 
        value="{{to}}"
        placeholder="recipient@example.net"
        data-field="to"
        autocomplete="off"
      />
      
      {{!-- Email suggestions dropdown (populated via JS) --}}
      <div class="ncm-composer__suggestions" style="display: none;">
        {{!-- Dynamically populated with matching contacts --}}
      </div>
    </div>
    
    <button class="ncm-btn ncm-btn--small" data-action="select-contact">
      <i class="fas fa-address-book"></i> Contacts
    </button>
  </div>
</div>