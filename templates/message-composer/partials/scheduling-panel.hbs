{{!-- Scheduling Panel Partial --}}
{{!-- File: templates/message-composer/partials/scheduling-panel.hbs --}}

<div class="ncm-composer__schedule-panel" style="{{#unless showScheduling}}display: none;{{/unless}}">
  <div class="ncm-composer__schedule-input">
    <label class="ncm-dialog__label">Schedule Date & Time</label>
    <input 
      type="datetime-local" 
      class="ncm-dialog__input" 
      name="scheduleTime"
      value="{{scheduleTime}}"
      data-field="scheduleTime"
    />
  </div>
  
  <div class="ncm-composer__schedule-actions">
    <button class="ncm-btn ncm-btn--secondary" data-action="clear-schedule">
      <i class="fas fa-times"></i> Clear
    </button>
    <button class="ncm-btn ncm-btn--primary" data-action="confirm-schedule">
      <i class="fas fa-check"></i> Confirm
    </button>
  </div>
</div>