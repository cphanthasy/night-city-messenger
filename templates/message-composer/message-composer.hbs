{{!--
  Message Composer v3 — Messaging-App Redesign
  @file templates/message-composer/message-composer.hbs
  @module cyberpunkred-messenger
  @description Conversation-first composer. Single compressed header,
    full message card for reply/forward context, one-row toolbar with
    overflow menu, compact options bar, send animation overlay.

  States:
    1. New Message — minimal chrome, straight to writing
    2. Reply — full original message card, cyan accent, locked TO
    3. Forward — full message card, gold accent, editable TO
    4. GM Send-As — clickable identity with caret, NPC picker
    5. Dead Zone — alert strip, queue mode
    6. Darknet — alert strip, anonymized routing
    7. Sending — transmission overlay animation
    8. Sent/Failed — result overlay
--}}

<div class="ncm-composer">

  {{!-- ═══ §1 HEADER — Identity + Net Pill + Time + Mode + Close ═══ --}}
  <header class="ncm-composer__header">

    {{!-- Identity cluster — GM: clickable with caret; Player: static --}}
    <div class="ncm-composer__identity {{#if isGM}}ncm-composer__identity--clickable{{/if}}"
         {{#if isGM}}data-action="toggleSendAs"{{/if}}>
      <div class="ncm-composer__avatar {{#if isGMSendAs}}ncm-composer__avatar--gm{{/if}}">
        {{#if fromImg}}
          <img src="{{fromImg}}" alt="{{fromName}}" />
        {{else}}
          <span class="ncm-composer__avatar-initials">{{fromInitials}}</span>
        {{/if}}
      </div>
      <div class="ncm-composer__id-info">
        <span class="ncm-composer__id-name">
          {{fromName}}
          {{#if isGMSendAs}}<span class="ncm-composer__gm-tag">GM</span>{{/if}}
        </span>
        <span class="ncm-composer__id-email">{{fromEmail}}</span>
      </div>
      {{#if isGM}}<i class="fas fa-caret-down ncm-composer__id-caret"></i>{{/if}}
    </div>

    <div class="ncm-composer__header-divider"></div>

    {{!-- Network pill --}}
    <div class="ncm-composer__net-pill ncm-composer__net-pill--{{netPillState}}">
      <span class="ncm-composer__net-dot ncm-composer__net-dot--{{netPillState}}"
            {{#if networkThemeColor}}style="background:{{networkThemeColor}};box-shadow:0 0 4px {{networkThemeColor}}80;"{{/if}}>
      </span>
      <span class="ncm-composer__net-name"
            {{#if networkThemeColor}}style="color:{{networkThemeColor}};"{{/if}}>
        {{networkName}}
      </span>
      <span class="ncm-composer__net-bars">
        {{#each netPillBars}}
          <span class="ncm-composer__net-bar {{#if this.active}}ncm-composer__net-bar--active{{/if}}"
                {{#if ../networkThemeColor}}{{#if this.active}}style="background:{{../networkThemeColor}};"{{/if}}{{/if}}>
          </span>
        {{/each}}
      </span>
      {{!-- Inline FX tags --}}
      {{#each fxTags}}
        <span class="ncm-composer__fx-tag ncm-composer__fx-tag--{{variant}}">{{label}}</span>
      {{/each}}
    </div>

    {{!-- Date/Time chip --}}
    <div class="ncm-composer__time-chip">
      <span class="ncm-composer__time-label">Date / Time</span>
      <span class="ncm-composer__time-val">{{currentGameTime}}</span>
    </div>

    {{!-- Mode badge --}}
    <span class="ncm-composer__mode ncm-composer__mode--{{modeKey}}">
      <i class="fas {{modeLabelIcon}}"></i> {{modeLabelText}}
    </span>

    {{!-- Close --}}
    <div class="ncm-composer__close" data-action="cancel"><i class="fas fa-xmark"></i></div>
  </header>

  {{!-- ═══ §2 GM SEND-AS DROPDOWN (GM only, toggled by JS) ═══ --}}
  {{#if isGM}}
  <div class="ncm-composer__sendas-dropdown ncm-hidden" data-id="sendas-dropdown">
    <div class="ncm-composer__sendas-header">
      <i class="fas fa-masks-theater"></i> Send As NPC
    </div>
    <div class="ncm-composer__sendas-search">
      <input type="text" placeholder="Search contacts..." data-id="sendas-search" />
    </div>
    <div class="ncm-composer__sendas-list" data-id="sendas-list">
      {{!-- Populated dynamically by JS --}}
    </div>
  </div>
  {{/if}}

  {{!-- ═══ §3 ALERTS — Dead Zone / Darknet ═══ --}}
  {{#if isDeadZone}}
  <div class="ncm-composer__alert ncm-composer__alert--danger">
    <i class="fas fa-triangle-exclamation"></i>
    <span class="ncm-composer__alert-text">Dead Zone — No signal. Message will be queued and sent when signal is restored.</span>
    <button class="ncm-composer__alert-action" data-action="queueMessage">Queue</button>
  </div>
  {{/if}}

  {{#if isDarknet}}
  <div class="ncm-composer__alert ncm-composer__alert--warn">
    <i class="fas fa-mask"></i>
    <span class="ncm-composer__alert-text">Darknet — Anonymized routing. Sender identity masked.
      {{#if degradedSignal}}{{reliabilityFailChance}}% chance of transmission failure.{{/if}}</span>
  </div>
  {{/if}}

  {{!-- ═══ §4 CONVERSATION CONTEXT — Original message card (reply/forward) ═══ --}}
  {{#if originalMessageCard}}
  <div class="ncm-composer__context">
    <div class="ncm-composer__msg-card ncm-composer__msg-card--{{mode}}">

      {{!-- Context label --}}
      <div class="ncm-composer__context-label ncm-composer__context-label--{{mode}}">
        {{#if isReply}}<i class="fas fa-reply"></i> Replying to this message{{/if}}
        {{#if isForward}}<i class="fas fa-share"></i> Forwarding this message{{/if}}
      </div>

      {{!-- Message header --}}
      <div class="ncm-composer__msg-header">
        <div class="ncm-composer__msg-avatar"
             {{#if originalMessageCard.avatarColor}}style="color:{{originalMessageCard.avatarColor}};"{{/if}}>
          {{#if originalMessageCard.portrait}}
            <img src="{{originalMessageCard.portrait}}" alt="" />
          {{else}}
            {{originalMessageCard.initials}}
          {{/if}}
        </div>
        <div class="ncm-composer__msg-meta">
          <div class="ncm-composer__msg-sender">{{originalMessageCard.sender}}</div>
          <div class="ncm-composer__msg-detail-row">
            <span class="ncm-composer__msg-email">{{originalMessageCard.email}}</span>
            <span class="ncm-composer__msg-time">{{originalMessageCard.formattedTime}}</span>
            <span class="ncm-composer__msg-net-tag"
                  {{#if originalMessageCard.networkColor}}style="color:{{originalMessageCard.networkColor}};border-color:{{originalMessageCard.networkColor}}30;background:{{originalMessageCard.networkColor}}08;"{{/if}}>
              {{originalMessageCard.network}}
            </span>
          </div>
        </div>
      </div>

      {{!-- Subject --}}
      {{#if originalMessageCard.subject}}
      <div class="ncm-composer__msg-subject">{{originalMessageCard.subject}}</div>
      {{/if}}

      {{!-- Body --}}
      <div class="ncm-composer__msg-body" data-id="original-msg-body">
        {{{originalMessageCard.body}}}
        <div class="ncm-composer__msg-body-fade"></div>
      </div>
      <div class="ncm-composer__msg-expand" data-action="toggleQuote">
        <i class="fas fa-chevron-down"></i> Show full message
      </div>

      {{!-- Encryption badge --}}
      {{#if originalMessageCard.encrypted}}
      <div class="ncm-composer__msg-enc-badge">
        <i class="fas fa-shield-halved"></i> ICE-PROTECTED
        {{#if originalMessageCard.encDV}}· DV {{originalMessageCard.encDV}}{{/if}}
      </div>
      {{/if}}

      {{!-- Attachments on original --}}
      {{#if originalMessageCard.hasAttachments}}
      <div class="ncm-composer__msg-attachments">
        {{#each originalMessageCard.attachments}}
        <div class="ncm-composer__msg-attach {{#if isEddies}}ncm-composer__msg-attach--eddies{{/if}}">
          <i class="fas {{icon}}"></i> {{name}}
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>
  </div>

  {{!-- Reply/Forward divider --}}
  <div class="ncm-composer__reply-divider">
    <div class="ncm-composer__reply-divider-line"></div>
    <span class="ncm-composer__reply-divider-label ncm-composer__reply-divider-label--{{mode}}">
      <i class="fas fa-pen"></i>
      {{#if isReply}}Your Reply{{else}}Your Note{{/if}}
    </span>
    <div class="ncm-composer__reply-divider-line ncm-composer__reply-divider-line--right"></div>
  </div>
  {{/if}}

  {{!-- ═══ §5 FORM FIELDS — TO / CC / SUBJECT ═══ --}}
  {{!-- TO field: hidden in reply (implicit), visible in compose/forward --}}
  {{#unless recipientLocked}}
  <div class="ncm-composer__field {{#if errors.to}}ncm-composer__field--error{{/if}}" style="position:relative;">
    <span class="ncm-composer__field-label {{#if errors.to}}ncm-composer__field-label--error{{/if}}">TO:</span>
    <div class="ncm-composer__chips" data-id="recipient-chips">
      {{#each recipients}}
      <div class="ncm-composer__chip {{#if mismatch}}ncm-composer__chip--mismatch{{/if}} {{#if unreachable}}ncm-composer__chip--unreachable{{/if}}"
           data-actor-id="{{actorId}}">
        <div class="ncm-composer__chip-avatar" {{#if avatarColor}}style="color:{{avatarColor}};"{{/if}}>{{initials}}</div>
        {{name}}
        {{#if mismatch}}
        <i class="fas fa-triangle-exclamation ncm-composer__chip-warn" title="{{mismatchTooltip}}"></i>
        {{/if}}
        {{#unless locked}}
        <i class="fas fa-xmark ncm-composer__chip-remove" data-action="removeRecipient" data-actor-id="{{actorId}}"></i>
        {{/unless}}
      </div>
      {{/each}}
      <input class="ncm-composer__field-input" data-id="recipient-input"
             placeholder="{{#if recipients.length}}Add recipient...{{else}}Search contacts...{{/if}}"
             autocomplete="off" />
    </div>
    <button class="ncm-composer__field-action" data-action="toggleCC">CC</button>
    {{#if errors.to}}
    <span class="ncm-composer__field-error"><i class="fas fa-exclamation-circle"></i> {{errors.to}}</span>
    {{/if}}
    {{!-- Autocomplete dropdown --}}
    <div class="ncm-composer__autocomplete ncm-hidden" data-id="autocomplete-dropdown"></div>
  </div>
  {{/unless}}

  {{!-- CC field (toggled by JS) --}}
  <div class="ncm-composer__field ncm-hidden" data-id="cc-field">
    <span class="ncm-composer__field-label">CC:</span>
    <div class="ncm-composer__chips" data-id="cc-chips">
      <input class="ncm-composer__field-input" data-id="cc-input"
             placeholder="Add CC recipient..." autocomplete="off" />
    </div>
  </div>

  {{!-- Subject: hidden in reply (inherited), visible in compose/forward --}}
  {{#unless isReply}}
  <div class="ncm-composer__field ncm-composer__field--subj">
    <span class="ncm-composer__field-label">SUBJ:</span>
    <input class="ncm-composer__field-input ncm-composer__field-input--full" data-id="subject-input" name="subject"
           value="{{subject}}" placeholder="Subject line..." />
  </div>
  {{/unless}}

  {{!-- ═══ §6 OPTIONS BAR — Priority + Encryption + Schedule + Self-Destruct ═══ --}}
  <div class="ncm-composer__options">
    {{!-- Priority --}}
    <span class="ncm-composer__opt-label">PRI</span>
    {{#each priorities}}
    <button class="ncm-composer__opt-pill {{#if active}}ncm-composer__opt-pill--active-{{id}}{{/if}}"
            data-action="setPriority" data-priority="{{id}}">{{label}}</button>
    {{/each}}

    <div class="ncm-composer__opt-sep"></div>

    {{!-- Encryption toggle --}}
    <span class="ncm-composer__opt-label">ENC</span>
    <div class="ncm-composer__enc-switch">
      <button class="ncm-composer__enc-opt {{#unless encryptionEnabled}}ncm-composer__enc-opt--open-active{{/unless}}"
              data-action="setEncryption" data-value="open">
        <i class="fas fa-unlock"></i> Open
      </button>
      <button class="ncm-composer__enc-opt {{#if encryptionEnabled}}ncm-composer__enc-opt--ice-active{{/if}}"
              data-action="setEncryption" data-value="ice">
        <i class="fas fa-lock"></i> ICE
      </button>
    </div>
    {{#if encryptionEnabled}}
    <span class="ncm-composer__enc-dv">
      DV:<input class="ncm-composer__enc-dv-input" data-id="encryption-dv" type="number"
                value="{{encryptionDV}}" min="1" max="30" />
    </span>
    <span class="ncm-composer__enc-type" data-action="cycleEncryptionType">{{encryptionType}} ▾</span>
    {{/if}}

    <div class="ncm-composer__opt-sep"></div>

    {{!-- Feature toggles --}}
    <button class="ncm-composer__toggle {{#if scheduleEnabled}}ncm-composer__toggle--on-gold{{/if}}"
            data-action="toggleSchedule">
      <i class="fas fa-clock"></i> Sched
    </button>
    <button class="ncm-composer__toggle {{#if selfDestructEnabled}}ncm-composer__toggle--on-red{{/if}}"
            data-action="toggleSelfDestruct">
      <i class="fas fa-bomb"></i> Destruct
    </button>
  </div>

  {{!-- Self-destruct expansion strip --}}
  {{#if selfDestructEnabled}}
  <div class="ncm-composer__strip ncm-composer__strip--destruct">
    <i class="fas fa-bomb"></i>
    <span class="ncm-composer__strip-label">Self-Destruct:</span>
    {{#each selfDestructOptions}}
    <button class="ncm-composer__destruct-pill {{#if active}}ncm-composer__destruct-pill--active{{/if}}"
            data-action="setSelfDestructMode" data-mode="{{id}}">{{label}}</button>
    {{/each}}
    <i class="fas fa-xmark ncm-composer__strip-close" data-action="toggleSelfDestruct"></i>
  </div>
  {{/if}}

  {{!-- Schedule expansion strip --}}
  {{#if scheduleEnabled}}
  <div class="ncm-composer__strip ncm-composer__strip--schedule">
    <i class="fas fa-clock"></i>
    <span class="ncm-composer__strip-label">Deliver at:</span>
    <div class="ncm-ctp-trigger ncm-composer__sched-trigger" data-action="openSchedulePicker">
      <i class="fas fa-clock ncm-ctp-trigger__icon"></i>
      <span class="ncm-ctp-trigger__value {{unless scheduledTimeFormatted}}ncm-ctp-trigger__value--empty{{/unless}}">
        {{#if scheduledTimeFormatted}}{{scheduledTimeFormatted}}{{else}}Pick a time...{{/if}}
      </span>
      <i class="fas fa-chevron-down ncm-ctp-trigger__chevron"></i>
    </div>
    <input type="hidden" name="scheduledTime" value="{{scheduledTime}}" data-id="schedule-hidden" />
    <i class="fas fa-xmark ncm-composer__strip-close" data-action="toggleSchedule"></i>
  </div>
  {{/if}}

  {{!-- ═══ §7 EDITOR — Toolbar + Content area ═══ --}}
  <div class="ncm-composer__editor-wrap {{#if encryptionEnabled}}ncm-composer__editor-wrap--encrypted{{/if}}">

    {{!-- Single-row toolbar with overflow --}}
    <div class="ncm-composer__toolbar">
      <button class="ncm-composer__tool" data-action="editorCommand" data-command="bold" title="Bold (Ctrl+B)"><i class="fas fa-bold"></i></button>
      <button class="ncm-composer__tool" data-action="editorCommand" data-command="italic" title="Italic (Ctrl+I)"><i class="fas fa-italic"></i></button>
      <button class="ncm-composer__tool" data-action="editorCommand" data-command="monospace" title="Code"><i class="fas fa-code"></i></button>
      <button class="ncm-composer__tool" data-action="editorCommand" data-command="link" title="Insert Link"><i class="fas fa-link"></i></button>
      <button class="ncm-composer__tool" data-action="editorCommand" data-command="bulletList" title="List"><i class="fas fa-list-ul"></i></button>
      <div class="ncm-composer__tool-sep"></div>
      <button class="ncm-composer__tool" data-action="attachShard" title="Attach Data Shard"><i class="fas fa-microchip"></i></button>
      <button class="ncm-composer__tool" data-action="attachFile" title="Attach File"><i class="fas fa-paperclip"></i></button>
      <button class="ncm-composer__tool ncm-composer__tool--eddies" data-action="attachEddies" title="Attach Eddies"><i class="fas fa-coins"></i></button>
      <div class="ncm-composer__tool-sep"></div>
      <button class="ncm-composer__tool" data-action="insertTimestamp" title="Insert Timestamp"><i class="fas fa-clock"></i></button>
      <button class="ncm-composer__tool ncm-composer__tool--more" data-action="toggleOverflow" title="More tools">⋯</button>
    </div>

    {{!-- Overflow menu (toggled by JS) --}}
    <div class="ncm-composer__overflow ncm-hidden" data-id="overflow-menu">
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="underline"><i class="fas fa-underline"></i> Underline</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="strikethrough"><i class="fas fa-strikethrough"></i> Strikethrough</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="blockquote"><i class="fas fa-quote-right"></i> Blockquote</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="numberList"><i class="fas fa-list-ol"></i> Numbered List</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="horizontalRule"><i class="fas fa-minus"></i> Divider</div>
      <div class="ncm-composer__overflow-sep"></div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="unlink"><i class="fas fa-link-slash"></i> Remove Link</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="clearFormat"><i class="fas fa-eraser"></i> Clear Format</div>
      <div class="ncm-composer__overflow-sep"></div>
      <div class="ncm-composer__overflow-item" data-action="insertCoords"><i class="fas fa-location-dot"></i> Insert Location</div>
      <div class="ncm-composer__overflow-item" data-action="insertSignature"><i class="fas fa-signature"></i> Insert Signature</div>
      <div class="ncm-composer__overflow-item" data-action="editorCommand" data-command="lock"><i class="fas fa-lock"></i> ICE Text Block</div>
    </div>

    {{!-- Editor content --}}
    <div class="ncm-composer__editor" data-id="editor-content" contenteditable="true"
         data-placeholder="{{#if isForward}}> Add a note (optional)...{{else}}> Type your message...{{/if}}">{{{body}}}</div>

    {{#if encryptionEnabled}}
    <span class="ncm-composer__ice-badge"><i class="fas fa-shield-halved"></i> ICE-PROTECTED</span>
    {{/if}}
    <span class="ncm-composer__char-count" data-id="editor-counter">{{charCount}} chars</span>
  </div>

  {{!-- ═══ §8 ATTACHMENTS BAR ═══ --}}
  {{#if hasAttachments}}
  <div class="ncm-composer__attachments">
    {{#each attachments}}
    <div class="ncm-composer__attach {{#if isEddies}}ncm-composer__attach--eddies{{/if}} {{#if encrypted}}ncm-composer__attach--encrypted{{/if}}">
      <i class="fas {{icon}}"></i>
      {{#if isEddies}}
        <span class="ncm-composer__attach-amount">{{eddiesFormatted}}</span>
      {{else}}
        {{name}} <span class="ncm-composer__attach-size">{{size}}</span>
      {{/if}}
      <i class="fas fa-xmark ncm-composer__attach-remove" data-action="removeAttachment" data-index="{{@index}}"></i>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{!-- ═══ §9 FOOTER ═══ --}}
  <div class="ncm-composer__footer">
    {{!-- Primary action --}}
    {{#if isDeadZone}}
      <button class="ncm-composer__btn ncm-composer__btn--send ncm-composer__btn--disabled" disabled>
        <i class="fas fa-paper-plane"></i> Send
      </button>
      <button class="ncm-composer__btn ncm-composer__btn--queue" data-action="queueMessage">
        <i class="fas fa-clock"></i> Queue
      </button>
    {{else if scheduleEnabled}}
      <button class="ncm-composer__btn ncm-composer__btn--schedule" data-action="send" {{#if sending}}disabled{{/if}}>
        {{#if sending}}<i class="fas fa-spinner fa-spin"></i> Scheduling...
        {{else}}<i class="fas fa-clock"></i> Schedule Send{{/if}}
      </button>
    {{else}}
      <button class="ncm-composer__btn ncm-composer__btn--send {{#if sending}}ncm-composer__btn--disabled{{/if}}"
              data-action="send" {{#if sending}}disabled{{/if}}>
        {{#if sending}}<i class="fas fa-spinner fa-spin"></i> Sending...
        {{else}}<i class="fas fa-paper-plane"></i>
          {{#if isReply}}Send Reply{{else if isForward}}Forward{{else}}Send{{/if}}
        {{/if}}
      </button>
    {{/if}}

    <button class="ncm-composer__btn ncm-composer__btn--draft" data-action="saveDraft">
      <i class="fas fa-floppy-disk"></i> Draft
    </button>

    <div class="ncm-composer__footer-spacer"></div>

    {{#if autoSaveTime}}
    <div class="ncm-composer__autosave">
      <i class="fas fa-check-circle"></i> Saved {{autoSaveTime}}
    </div>
    {{/if}}

    <div class="ncm-composer__shortcuts">
      <span class="ncm-composer__shortcut">
        <kbd>Ctrl</kbd>+<kbd>↵</kbd>
        {{#if scheduleEnabled}}Schedule{{else if isDeadZone}}Queue{{else}}Send{{/if}}
      </span>
      <span class="ncm-composer__shortcut"><kbd>Esc</kbd> Close</span>
    </div>
  </div>

  {{!-- ═══ §10 SEND ANIMATION OVERLAY (toggled by JS) ═══ --}}
  <div class="ncm-composer__send-overlay ncm-hidden" data-id="send-overlay">
    {{!-- Transmitting state --}}
    <div class="ncm-composer__send-transmit" data-id="send-transmit">
      <div class="ncm-composer__send-ring"><i class="fas fa-paper-plane"></i></div>
      <div class="ncm-composer__send-progress">
        <div class="ncm-composer__send-progress-bar" data-id="send-progress-bar"></div>
      </div>
      <div class="ncm-composer__send-status">Transmitting<span>...</span></div>
      <div class="ncm-composer__send-route" data-id="send-route">
        <span class="ncm-composer__send-route-label">FROM</span>
        <div class="ncm-composer__send-route-dot"></div>
        <div class="ncm-composer__send-route-line"></div>
        <span class="ncm-composer__send-route-label" data-id="send-route-net">{{networkName}}</span>
        <div class="ncm-composer__send-route-line"></div>
        <div class="ncm-composer__send-route-dot"></div>
        <span class="ncm-composer__send-route-target" data-id="send-route-to">—</span>
      </div>
      <div class="ncm-composer__send-stream" data-id="send-stream"></div>
    </div>

    {{!-- Success state --}}
    <div class="ncm-composer__send-success ncm-hidden" data-id="send-success">
      <div class="ncm-composer__send-success-icon"><i class="fas fa-check"></i></div>
      <div class="ncm-composer__send-success-text">Message Transmitted</div>
      <div class="ncm-composer__send-success-detail" data-id="send-success-detail"></div>
    </div>

    {{!-- Failure state --}}
    <div class="ncm-composer__send-failure ncm-hidden" data-id="send-failure">
      <div class="ncm-composer__send-fail-icon"><i class="fas fa-triangle-exclamation"></i></div>
      <div class="ncm-composer__send-fail-text">Transmission Failed</div>
      <div class="ncm-composer__send-fail-detail" data-id="send-fail-detail"></div>
      <div class="ncm-composer__send-fail-actions">
        <button class="ncm-composer__btn ncm-composer__btn--queue" data-action="retrySend"><i class="fas fa-redo"></i> Retry</button>
        <button class="ncm-composer__btn ncm-composer__btn--draft" data-action="queueMessage"><i class="fas fa-clock"></i> Queue</button>
        <button class="ncm-composer__btn ncm-composer__btn--draft" data-action="saveDraft"><i class="fas fa-floppy-disk"></i> Save Draft</button>
      </div>
    </div>
