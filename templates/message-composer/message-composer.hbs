{{!-- Message Composer — Compose / Reply / Forward --}}
<div class="ncm-composer">

  {{!-- Header --}}
  <div class="ncm-composer__header">
    <h2 class="ncm-composer__title">
      <i class="fas fa-{{#if (eq mode 'reply')}}reply{{else if (eq mode 'forward')}}share{{else}}pen{{/if}}"></i>
      {{modeLabel}} Message
    </h2>
  </div>

  {{!-- Form Fields --}}
  <div class="ncm-composer__fields">

    {{!-- FROM --}}
    <div class="ncm-field">
      <label class="ncm-field__label">FROM:</label>
      <div class="ncm-field__value">
        <select class="ncm-from-select ncm-input">
          {{#each ownedActors}}
          <option value="{{actorId}}" {{#if (eq actorId ../fromActorId)}}selected{{/if}}>
            {{name}} {{#if email}}&lt;{{email}}&gt;{{/if}}
          </option>
          {{/each}}
        </select>
      </div>
    </div>

    {{!-- TO --}}
    <div class="ncm-field">
      <label class="ncm-field__label">TO:</label>
      <div class="ncm-field__value ncm-recipient-field">
        {{#if toActor}}
        <div class="ncm-selected-recipient">
          <img src="{{toActor.img}}" class="ncm-selected-recipient__img" alt="">
          <span class="ncm-selected-recipient__name">{{toActor.name}}</span>
          {{#if toEmail}}<span class="ncm-selected-recipient__email">&lt;{{toEmail}}&gt;</span>{{/if}}
          <button class="ncm-btn ncm-btn--icon ncm-btn--tiny" data-action="clearRecipient">
            <i class="fas fa-times"></i>
          </button>
        </div>
        {{else}}
        <input type="text" class="ncm-recipient-search ncm-input" 
               placeholder="Search contacts..." autocomplete="off">
        <div class="ncm-recipient-dropdown"></div>
        {{/if}}
      </div>
    </div>

    {{!-- SUBJECT --}}
    <div class="ncm-field">
      <label class="ncm-field__label">SUBJ:</label>
      <div class="ncm-field__value">
        <input type="text" name="subject" class="ncm-input" value="{{subject}}" 
               placeholder="Subject line...">
      </div>
    </div>

    {{!-- PRIORITY --}}
    <div class="ncm-field">
      <label class="ncm-field__label">PRIORITY:</label>
      <div class="ncm-field__value ncm-priority-selector">
        {{#each priorities}}
        <button class="ncm-priority-pill {{#if active}}ncm-priority-pill--active{{/if}} ncm-priority-pill--{{id}}"
                data-action="setPriority" data-priority="{{id}}">
          {{label}}
        </button>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Body --}}
  <div class="ncm-composer__body">
    <textarea name="body" class="ncm-textarea" placeholder="Type your message...">{{body}}</textarea>
  </div>

  {{!-- Footer --}}
  <div class="ncm-composer__footer">
    <div class="ncm-composer__footer-left">
      {{!-- Future: Attach, Schedule buttons --}}
    </div>
    <div class="ncm-composer__footer-right">
      <button class="ncm-btn ncm-btn--ghost" data-action="cancel">Cancel</button>
      <button class="ncm-btn ncm-btn--primary ncm-btn--send" data-action="send" 
              {{#if sending}}disabled{{/if}}>
        {{#if sending}}
        <i class="fas fa-spinner fa-spin"></i> Sending...
        {{else}}
        <i class="fas fa-paper-plane"></i> Send
        {{/if}}
      </button>
    </div>
  </div>
</div>
