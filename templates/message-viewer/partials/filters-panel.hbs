{{!-- Filters Panel Partial --}}
{{!-- File: templates/message-viewer/partials/filters-panel.hbs --}}

<div class="ncm-message-viewer__filters {{#if showFilters}}ncm-message-viewer__filters--active{{/if}}">
  <div class="ncm-message-viewer__filter-group">
    <label class="ncm-message-viewer__filter-label">Status</label>
    <select class="ncm-message-viewer__filter-select" data-filter="status">
      <option value="all" {{#if (eq currentFilter 'all')}}selected{{/if}}>All Messages</option>
      <option value="unread" {{#if (eq currentFilter 'unread')}}selected{{/if}}>Unread</option>
      <option value="read" {{#if (eq currentFilter 'read')}}selected{{/if}}>Read</option>
      <option value="saved" {{#if (eq currentFilter 'saved')}}selected{{/if}}>Saved</option>
      <option value="spam" {{#if (eq currentFilter 'spam')}}selected{{/if}}>Spam</option>
    </select>
  </div>
  
  <div class="ncm-message-viewer__search">
    <i class="ncm-message-viewer__search-icon fas fa-search"></i>
    <input 
      type="text" 
      class="ncm-message-viewer__search-input" 
      placeholder="Search messages..."
      value="{{searchTerm}}"
      data-action="search"
    />
  </div>
  
  <div class="ncm-message-viewer__filter-group">
    <label class="ncm-message-viewer__filter-label">Sort By</label>
    <select class="ncm-message-viewer__filter-select" data-filter="sort">
      <option value="date-desc" {{#if (eq sortOrder 'date-desc')}}selected{{/if}}>Newest First</option>
      <option value="date-asc" {{#if (eq sortOrder 'date-asc')}}selected{{/if}}>Oldest First</option>
      <option value="sender-az" {{#if (eq sortOrder 'sender-az')}}selected{{/if}}>Sender (A-Z)</option>
      <option value="sender-za" {{#if (eq sortOrder 'sender-za')}}selected{{/if}}>Sender (Z-A)</option>
    </select>
  </div>
  
  <div class="ncm-message-viewer__filter-group">
    <button class="ncm-btn ncm-btn--primary" data-action="compose">
      <i class="fas fa-edit"></i> Compose
    </button>
    <button class="ncm-btn ncm-btn--secondary" data-action="refresh">
      <i class="fas fa-sync"></i> Refresh
    </button>
  </div>
</div>