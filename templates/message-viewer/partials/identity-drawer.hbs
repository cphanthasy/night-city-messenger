{{!--
  Identity Drawer — v3.2 New Partial
  @file templates/message-viewer/partials/identity-drawer.hbs
  @module cyberpunkred-messenger
  @description Left slide-in drawer overlay showing:
    - Profile: large portrait, name, role
    - Contact info: editable email, handle (readonly)
    - Network status: colored rows (status green, latency cyan, enc gold, queue purple)
    - Character switcher: list of owned actors with active indicator
    - Footer: Contacts, Theme, Alerts, Prefs shortcuts

  Opened by clicking the header portrait. Closed by clicking overlay or × button.
  The drawer sits inside the .ncm-viewer container as an absolute-positioned overlay.
  Toggle class: .ncm-viewer--drawer-open on the root .ncm-viewer element.

  Expected context (from _prepareContext):
    viewingAsName, viewingAsPortrait, viewingAsInitial, viewingAsEmail,
    currentNetwork, signalStrength, connectionStatus,
    encryptionCipher, latencyMs, queuedMessageCount,
    ownedCharacters — [{actorId, name, portrait, initials, email, isActive, avatarColor}]
    viewingAsRole — string like 'Solo · Street Kid' (optional)
--}}

{{!-- Overlay backdrop --}}
<div class="ncm-viewer__drawer-overlay" data-action="close-identity-drawer"></div>

{{!-- Drawer panel --}}
<div class="ncm-viewer__drawer">
  <div class="ncm-viewer__drawer-accent"></div>

  {{!-- Drawer Header --}}
  <div class="ncm-viewer__drawer-header">
    <span class="ncm-viewer__drawer-title">Identity</span>
    <button class="ncm-viewer__drawer-close" data-action="close-identity-drawer">
      <i class="fas fa-xmark"></i>
    </button>
  </div>

  {{!-- Profile Section --}}
  <div class="ncm-viewer__drawer-profile">
    <div class="ncm-viewer__drawer-avatar">
      {{#if viewingAsPortrait}}
        <img src="{{viewingAsPortrait}}" alt="{{viewingAsName}}" />
      {{else}}
        {{viewingAsInitial}}
      {{/if}}
    </div>
    <div class="ncm-viewer__drawer-name">{{viewingAsName}}</div>
    {{#if viewingAsRole}}
      <div class="ncm-viewer__drawer-role">{{viewingAsRole}}</div>
    {{/if}}
  </div>

  {{!-- Contact Info --}}
  <div class="ncm-viewer__drawer-section">
    <div class="ncm-viewer__drawer-section-title">Contact Info</div>
    <div class="ncm-viewer__drawer-field">
      <span class="ncm-viewer__drawer-field-label ncm-viewer__drawer-field-label--email">Email Address</span>
      <div class="ncm-viewer__drawer-field-value">
        <i class="fas fa-envelope ncm-viewer__drawer-field-icon ncm-viewer__drawer-field-icon--email"></i>
        <span class="ncm-viewer__drawer-field-input" style="flex:1;font-family:var(--ncm-font-mono,'Share Tech Mono',monospace);font-size:12px;color:var(--ncm-secondary,#00D4E6);">{{viewingAsEmail}}</span>
        {{#if canChangeIdentity}}
        <button class="ncm-viewer__drawer-field-btn" data-action="change-identity" title="Change NET identity">
          <i class="fas fa-pen"></i>
        </button>
        {{/if}}
      </div>
    </div>
    <div class="ncm-viewer__drawer-field">
      <span class="ncm-viewer__drawer-field-label ncm-viewer__drawer-field-label--handle">Handle</span>
      <div class="ncm-viewer__drawer-field-value">
        <i class="fas fa-at ncm-viewer__drawer-field-icon ncm-viewer__drawer-field-icon--handle"></i>
        <span class="ncm-viewer__drawer-field-input" style="flex:1;font-family:var(--ncm-font-mono,'Share Tech Mono',monospace);font-size:12px;">{{viewingAsHandle}}</span>
      </div>
    </div>
  </div>

  {{!-- Network Status --}}
  <div class="ncm-viewer__drawer-section">
    <div class="ncm-viewer__drawer-section-title">Network</div>
    <div class="ncm-viewer__drawer-net-status ncm-viewer__drawer-net-status--{{netPillState}}">
      <span class="ncm-viewer__drawer-net-dot" style="background: var(--ncm-signal-{{netPillState}});"></span>
      <span class="ncm-viewer__drawer-net-name" style="color: var(--ncm-signal-{{netPillState}});">
        {{#if isDeadZone}}NO SIGNAL{{else}}{{currentNetwork.name}}{{/if}}
      </span>
      <span class="ncm-viewer__drawer-net-pct" style="color: var(--ncm-signal-{{netPillState}});">{{signalStrength}}%</span>
    </div>
    <div class="ncm-viewer__drawer-net-row ncm-viewer__drawer-net-row--status">
      <i class="fas fa-signal"></i>
      <span>Status</span>
      <span style="margin-left: auto;">
        {{#if (eq connectionStatus "CONNECTED")}}CONNECTED{{/if}}
        {{#if (eq connectionStatus "DEGRADED")}}DEGRADED{{/if}}
        {{#if (eq connectionStatus "NO_SIGNAL")}}OFFLINE{{/if}}
      </span>
    </div>
    <div class="ncm-viewer__drawer-net-row ncm-viewer__drawer-net-row--latency">
      <i class="fas fa-gauge-high"></i>
      <span>Latency</span>
      <span style="margin-left: auto;">{{latencyMs}}ms</span>
    </div>
    <div class="ncm-viewer__drawer-net-row ncm-viewer__drawer-net-row--enc">
      <i class="fas fa-shield-halved"></i>
      <span>Encryption</span>
      <span style="margin-left: auto;">{{encryptionCipher}}</span>
    </div>
    <div class="ncm-viewer__drawer-net-row ncm-viewer__drawer-net-row--queue">
      <i class="fas fa-layer-group"></i>
      <span>Queued</span>
      <span style="margin-left: auto;">{{queuedMessageCount}}</span>
    </div>
  </div>

  {{!-- Character Switcher --}}
  {{#if ownedCharacters}}
    <div class="ncm-viewer__drawer-section">
      <div class="ncm-viewer__drawer-section-title">Characters</div>
      <div class="ncm-viewer__drawer-char-list">
        {{#each ownedCharacters}}
          <div class="ncm-viewer__drawer-char {{#if this.isActive}}ncm-viewer__drawer-char--active{{/if}}"
               data-action="switch-character" data-actor-id="{{this.actorId}}">
            <div class="ncm-viewer__drawer-char-avatar"
                 style="color: {{this.avatarColor}}; {{#if this.isActive}}border-color: rgba(0,212,230,0.4);{{/if}}">
              {{#if this.portrait}}
                <img src="{{this.portrait}}" alt="{{this.name}}" />
              {{else}}
                {{this.initials}}
              {{/if}}
            </div>
            <div class="ncm-viewer__drawer-char-info">
              <span class="ncm-viewer__drawer-char-name">{{this.name}}</span>
              <span class="ncm-viewer__drawer-char-email">{{this.email}}</span>
            </div>
            {{#if this.isActive}}
              <i class="fas fa-check ncm-viewer__drawer-char-check"></i>
            {{/if}}
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}

  {{!-- Drawer Footer --}}
  <div class="ncm-viewer__drawer-footer">
    <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="open-contacts">
      <i class="fas fa-address-book"></i> Contacts
    </button>
    <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="open-settings">
      <i class="fas fa-gear"></i> Settings
    </button>
  </div>
</div>
