{{!--
  Message List Item — v3.3 State Styling
  @file templates/message-viewer/partials/message-list-item.hbs
  @module cyberpunkred-messenger

  State priority (highest wins for conflicting treatments):
    1. Network-locked (dims everything, overrides encrypted visual)
    2. Infected/Malware (biohazard badge, red ring)
    3. Encrypted (gold ring, lock badge, cipher preview)
    4. Self-destruct (red border, timer)
    5. Traced (recording dot)
    6. Darknet (purple theme)
    7. Queued (amber badge)
    8. Priority (left border color)
    9. Unread (bright text, cyan dot)
--}}

<div class="ncm-viewer__msg
  {{~#unless status.read}} ncm-viewer__msg--unread{{/unless~}}
  {{~#if selected}} ncm-viewer__msg--selected{{/if~}}
  {{~#if status.infected}} ncm-viewer__msg--infected{{/if~}}
  {{~#if isNetworkLocked}} ncm-viewer__msg--locked{{/if~}}
  {{~#if isEncrypted}}{{~#unless isNetworkLocked}} ncm-viewer__msg--encrypted{{/unless~}}{{/if~}}
  {{~#if isDarknet}} ncm-viewer__msg--darknet{{/if~}}
  {{~#if isTraced}} ncm-viewer__msg--traced{{/if~}}
  {{~#if hasSelfDestruct}} ncm-viewer__msg--destruct{{/if~}}"
     data-message-id="{{messageId}}"
     data-priority="{{priority}}"
     data-action="select-message"
     {{~#if netStripeColor}} style="border-right: 3px solid {{netStripeColor}}"{{/if~}}>

  {{!-- Unread dot --}}
  {{#unless status.read}}
    <div class="ncm-viewer__msg-unread-dot"></div>
  {{/unless}}

  {{!-- Network-locked indicator (left edge) --}}
  {{#if isNetworkLocked}}
    <div class="ncm-viewer__msg-lock" data-ncm-tooltip="Requires {{lockedNetworkName}} access">
      <i class="fas fa-lock"></i>
    </div>
  {{/if}}

  {{!-- Avatar --}}
  <div class="ncm-viewer__msg-avatar"
    style="color: {{avatarColor}}; border-color: {{avatarColor}}">
    {{#if fromPortrait}}
      <img src="{{fromPortrait}}" alt="{{fromDisplay}}" />
    {{else}}
      {{!-- Network-locked or encrypted with no sender: show ? --}}
      {{#if isNetworkLocked}}
        <i class="fas fa-lock" style="font-size:11px;opacity:0.3;"></i>
      {{else if isEncrypted}}
        {{#if fromInitial}}
          {{fromInitial}}
        {{else}}
          <i class="fas fa-question" style="font-size:12px;opacity:0.4;"></i>
        {{/if}}
      {{else if isDarknet}}
        {{#if fromInitial}}
          {{fromInitial}}
        {{else}}
          <i class="fas fa-ghost" style="font-size:12px;opacity:0.5;"></i>
        {{/if}}
      {{else}}
        {{fromInitial}}
      {{/if}}
    {{/if}}

    {{!-- Encrypted lock badge (bottom-right) — only when NOT network-locked --}}
    {{#if isEncrypted}}
      {{#unless isNetworkLocked}}
        <span class="ncm-viewer__msg-av-badge ncm-viewer__msg-av-badge--lock">
          <i class="fas fa-lock"></i>
        </span>
      {{/unless}}
    {{/if}}

    {{!-- Infected biohazard badge (bottom-left to avoid overlap with lock badge) --}}
    {{#if status.infected}}
      <span class="ncm-viewer__msg-av-badge ncm-viewer__msg-av-badge--biohazard">
        <i class="fas fa-biohazard"></i>
      </span>
    {{/if}}
  </div>

  {{!-- Content --}}
  <div class="ncm-viewer__msg-content">

    {{!-- Row 1: Sender + Indicators + Net Pip + Stacked Time --}}
    <div class="ncm-viewer__msg-top">
      <span class="ncm-viewer__msg-sender">{{fromDisplay}}</span>

      {{!-- Encryption tag — only when NOT network-locked --}}
      {{#if isEncrypted}}
        {{#unless isNetworkLocked}}
          <span class="ncm-viewer__msg-encrypt-tag">
            <i class="fas fa-shield-halved"></i> {{encryptionTag}}
          </span>
        {{/unless}}
      {{/if}}

      {{!-- Traced indicator --}}
      {{#if isTraced}}
        <span class="ncm-viewer__msg-traced-indicator">
          <span class="ncm-viewer__msg-traced-dot"></span>
          {{#if traceAgency}}{{traceAgency}}{{else}}TRACED{{/if}}
        </span>
      {{/if}}

      {{!-- Self-destruct timer --}}
      {{#if hasSelfDestruct}}
        <span class="ncm-viewer__msg-destruct-timer {{#if selfDestructUrgent}}ncm-viewer__msg-destruct-timer--urgent{{/if}}">
          <i class="fas fa-bomb"></i> {{selfDestructListDisplay}}
        </span>
      {{/if}}

      {{!-- Darknet anonymous tag --}}
      {{#if isDarknet}}
        <span class="ncm-viewer__msg-anon-tag">// ANON</span>
      {{/if}}

      {{!-- Saved icon --}}
      {{#if status.saved}}
        <i class="fas fa-bookmark ncm-viewer__msg-icon ncm-viewer__msg-icon--saved"
           data-ncm-tooltip="Saved"></i>
      {{/if}}

      {{!-- Network pip --}}
      {{#if netPipLabel}}
        <span class="ncm-viewer__msg-net-pip"
              style="color: {{netPipColor}}; border-color: {{netPipColor}}40; background: {{netPipColor}}0A">
          <i class="fas {{netPipIcon}}"></i> {{netPipLabel}}
        </span>
      {{/if}}

      {{!-- Queued badge --}}
      {{#if isQueued}}
        <span class="ncm-viewer__msg-queue-badge"><i class="fas fa-clock"></i> Queued</span>
      {{/if}}

      {{!-- Stacked timestamp --}}
      <span class="ncm-viewer__msg-time">
        {{#if formattedDate}}
          <span class="ncm-viewer__msg-time-date">{{formattedDate}}</span>
          <span class="ncm-viewer__msg-time-rel {{#if isRecentMessage}}ncm-viewer__msg-time-rel--recent{{/if}}">{{relativeTime}}</span>
        {{else}}
          <span class="ncm-viewer__msg-time-date">{{formattedTime}}</span>
        {{/if}}
      </span>
    </div>

    {{!-- Row 2: Subject + Badge --}}
    <div class="ncm-viewer__msg-subject">
      <span class="ncm-viewer__msg-subject-text">
        {{~#if isNetworkLocked~}}
          [ACCESS RESTRICTED]
        {{~else if isEncrypted~}}
          [ENCRYPTED MESSAGE]
        {{~else~}}
          {{subject}}
        {{~/if~}}
      </span>

      {{!-- Badge slot --}}
      {{#if threatBadge}}
        <span class="ncm-viewer__msg-badge ncm-viewer__msg-badge--{{threatBadge.variant}}"
              data-ncm-tooltip="{{threatBadge.label}}">
          <i class="{{threatBadge.icon}}"></i> {{threatBadge.label}}
        </span>
      {{else if (eq priority "critical")}}
        <span class="ncm-viewer__msg-badge ncm-viewer__msg-badge--crit">
          <i class="fas fa-triangle-exclamation"></i> CRIT
        </span>
      {{else if (eq priority "urgent")}}
        <span class="ncm-viewer__msg-badge ncm-viewer__msg-badge--urgent">
          <i class="fas fa-bolt"></i> URG
        </span>
      {{/if}}
    </div>

    {{!-- Row 3: Preview --}}
    {{#if isNetworkLocked}}
      <div class="ncm-viewer__msg-preview ncm-viewer__msg-preview--locked">
        <i class="fas fa-lock"></i> REQUIRES {{lockedNetworkName}} ACCESS
      </div>
    {{else if isEncrypted}}
      <div class="ncm-viewer__msg-preview ncm-viewer__msg-preview--encrypted">
        █▓░ 4F 7A C3 █▓░ B2 1D ░▓█ 9E ░█▓ A7 ░▓
      </div>
    {{else if bodyPreview}}
      <div class="ncm-viewer__msg-preview">{{bodyPreview}}</div>
    {{/if}}

  </div>
</div>
