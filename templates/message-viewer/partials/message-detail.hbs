{{!--
  Message Detail Panel — Partial
  @file templates/message-viewer/partials/message-detail.hbs
  @module cyberpunkred-messenger
  @description Displays a selected message with full metadata, body, actions,
    and quick-reply bar. Uses Sprint 0 design system components.

  Expected context:
    message — enriched message object from _getEnrichedMessage()
      { messageId, from, to, subject, body, bodyRendered, timestamp, network,
        priority, priorityVariant, fromDisplay, fromInitial, fromPortrait,
        toDisplay, formattedTime, status, threadInfo, attachments }
    quickReplies — array of quick-reply strings
    isGM — boolean
--}}

<div class="ncm-message-detail" data-message-id="{{message.messageId}}">

  {{!-- ═══ Bracket Header ═══ --}}
  {{> "modules/cyberpunkred-messenger/templates/partials/section-header.hbs"
      title="MESSAGE DETAIL" size="small" align="left" }}

  {{!-- ═══ Encryption Overlay (if encrypted & not decrypted) ═══ --}}
  {{#if message.status.encrypted}}
    <div class="ncm-message-encrypted-overlay">
      <div class="ncm-encrypted-icon">
        <i class="fas fa-lock"></i>
      </div>
      <div class="ncm-encrypted-title">MESSAGE ENCRYPTED</div>
      <div class="ncm-encrypted-subtitle">
        ICE-protected transmission. Requires decryption to access content.
      </div>
      <div class="ncm-encrypted-actions">
        <button class="ncm-btn ncm-btn--secondary" data-action="decrypt-message"
                data-message-id="{{message.messageId}}">
          <i class="fas fa-unlock-keyhole"></i>
          <span>Attempt Decrypt</span>
        </button>
        {{#if isGM}}
          <button class="ncm-btn ncm-btn--ghost" data-action="force-decrypt-message"
                  data-message-id="{{message.messageId}}">
            <i class="fas fa-shield-halved"></i>
            <span>GM Force Decrypt</span>
          </button>
        {{/if}}
      </div>
    </div>
  {{else}}

    {{!-- ═══ Message Metadata ═══ --}}
    <div class="ncm-detail-meta">

      {{!-- FROM --}}
      <div class="ncm-detail-meta__row">
        <span class="ncm-detail-meta__label">FROM</span>
        <div class="ncm-detail-meta__value ncm-detail-meta__from">
          {{#if message.fromPortrait}}
            <img class="ncm-detail-meta__avatar" src="{{message.fromPortrait}}" alt="{{message.fromDisplay}}" />
          {{else}}
            <div class="ncm-detail-meta__avatar-initials">{{message.fromInitial}}</div>
          {{/if}}
          <span class="ncm-detail-meta__from-name">{{message.fromDisplay}}</span>
          <span class="ncm-detail-meta__from-email">{{message.from}}</span>
        </div>
      </div>

      {{!-- TO --}}
      <div class="ncm-detail-meta__row">
        <span class="ncm-detail-meta__label">TO</span>
        <span class="ncm-detail-meta__value">
          {{#if message.toDisplay}}{{message.toDisplay}}{{else}}{{message.to}}{{/if}}
        </span>
      </div>

      {{!-- DATE --}}
      <div class="ncm-detail-meta__row">
        <span class="ncm-detail-meta__label">DATE</span>
        <span class="ncm-detail-meta__value ncm-detail-meta__value--mono">{{message.formattedTime}}</span>
      </div>

      {{!-- NETWORK --}}
      <div class="ncm-detail-meta__row">
        <span class="ncm-detail-meta__label">NETWORK</span>
        <span class="ncm-detail-meta__value">
          {{> "modules/cyberpunkred-messenger/templates/partials/tag-badge.hbs"
              label=message.network variant="network" icon="fas fa-tower-broadcast" }}
        </span>
      </div>

      {{!-- PRIORITY (if not normal) --}}
      {{#if (neq message.priority "normal")}}
        <div class="ncm-detail-meta__row">
          <span class="ncm-detail-meta__label">PRIORITY</span>
          <span class="ncm-detail-meta__value">
            {{> "modules/cyberpunkred-messenger/templates/partials/tag-badge.hbs"
                label=message.priority variant=message.priorityVariant }}
          </span>
        </div>
      {{/if}}

      {{!-- Subject --}}
      <div class="ncm-detail-meta__row ncm-detail-meta__row--subject">
        <span class="ncm-detail-meta__label">SUBJECT</span>
        <span class="ncm-detail-meta__value ncm-detail-meta__value--subject">
          {{#if message.subject}}{{message.subject}}{{else}}<em>(No Subject)</em>{{/if}}
        </span>
      </div>
    </div>

    {{!-- ═══ Thread Indicator ═══ --}}
    {{#if message.threadInfo.count}}
      <div class="ncm-thread-indicator" data-action="toggle-thread">
        <i class="fas fa-code-branch"></i>
        <span>{{message.threadInfo.count}} message{{#if (gt message.threadInfo.count 1)}}s{{/if}} in thread</span>
        <i class="fas fa-chevron-right ncm-thread-chevron"></i>
      </div>
    {{/if}}

    {{!-- ═══ Message Body ═══ --}}
    <div class="ncm-detail-body ncm-scrollbar">
      {{#if message.bodyRendered}}
        {{{message.bodyRendered}}}
      {{else}}
        <p class="ncm-detail-body__empty">
          <em>// No message body //</em>
        </p>
      {{/if}}
    </div>

    {{!-- ═══ Attachments ═══ --}}
    {{#if message.attachments.length}}
      <div class="ncm-detail-attachments">
        {{> "modules/cyberpunkred-messenger/templates/partials/section-header.hbs"
            title="ATTACHMENTS" count=message.attachments.length size="small" align="left" }}
        <div class="ncm-attachment-list">
          {{#each message.attachments}}
          <div class="ncm-attachment-item" data-action="open-attachment" data-index="{{@index}}">
            <i class="fas fa-file-alt"></i>
            <span>{{this.name}}</span>
          </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{!-- ═══ Malware Warning ═══ --}}
    {{#if message.status.infected}}
      {{> "modules/cyberpunkred-messenger/templates/partials/alert-panel.hbs"
          variant="danger"
          icon="fas fa-biohazard"
          title="MALWARE DETECTED"
          message="This message contains a hostile daemon. Proceed with caution." }}
    {{/if}}

    {{!-- ═══ Quick Reply Bar ═══ --}}
    <div class="ncm-quick-reply-bar">
      {{#each quickReplies}}
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="quick-reply"
                data-reply="{{this}}">
          <i class="fas fa-bolt"></i>
          <span>{{this}}</span>
        </button>
      {{/each}}
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="quick-reply-custom"
              data-ncm-tooltip="Custom quick reply">
        <i class="fas fa-plus"></i>
      </button>
    </div>

    {{!-- ═══ Action Bar ═══ --}}
    <div class="ncm-detail-action-bar">
      <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="reply"
              data-ncm-tooltip="Reply (R)">
        <i class="fas fa-reply"></i>
        <span>Reply</span>
      </button>
      <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="forward"
              data-ncm-tooltip="Forward">
        <i class="fas fa-share"></i>
        <span>Forward</span>
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="toggle-saved"
              data-ncm-tooltip="{{#if message.status.saved}}Unsave{{else}}Save{{/if}}">
        <i class="fas {{#if message.status.saved}}fa-bookmark{{else}}fa-bookmark{{/if}}"></i>
        <span>{{#if message.status.saved}}Unsave{{else}}Save{{/if}}</span>
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="share-to-chat"
              data-ncm-tooltip="Share to chat">
        <i class="fas fa-comment-dots"></i>
        <span>Share</span>
      </button>

      <div class="ncm-detail-action-bar__spacer"></div>

      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="mark-spam"
              data-ncm-tooltip="Mark as spam">
        <i class="fas fa-shield-halved"></i>
      </button>
      <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="delete-message"
              data-ncm-tooltip="Delete (Del)">
        <i class="fas fa-trash"></i>
      </button>
    </div>

  {{/if}}
</div>
