{{!--
  Message Detail Panel — Partial
  @file templates/message-viewer/partials/message-detail.hbs
  @module cyberpunkred-messenger
  @description Displays a selected message with full metadata, body, actions,
    and quick-reply bar. Uses Sprint 0 design system components.

  Sprint 2B additions:
    - Security verification strip below metadata (§2.4)
    - Thread badge pill in subject row (§2.5)
    - Interactive encrypted attachments via partial (§2.6)
    - Attachment chips via partial (§2.8)

  Visual Audit Fixes:
    - Metadata restructured: Subject as heading, FROM/TO/DATE/NET in horizontal
      flex row matching mockup (Fix 2A)
    - Alert partial param fixed: message= → text= (Fix 3A)
    - Quick reply pills remain as <span> with .ncm-quick-pill class (Fix 1B — CSS)

  Expected context:
    message — enriched message object from _getEnrichedMessage()
      { messageId, from, to, subject, body, bodyRendered, timestamp, network,
        priority, priorityVariant, fromDisplay, fromInitial, fromPortrait,
        toDisplay, formattedTime, status, threadInfo, attachments,
        security (Sprint 2B):
          { verifiedSender, verifiedVariant, encrypted, encryptedVariant,
            attachmentScan, attachmentScanVariant, attachmentScanLabel,
            routeHops, securityLevel } }
    quickReplies — array of quick-reply strings
    isGM — boolean
--}}

<div class="ncm-message-detail" data-message-id="{{message.messageId}}">

  {{!-- ═══ Bracket Header ═══ --}}
  {{> "modules/cyberpunkred-messenger/templates/partials/section-header.hbs"
      title="MESSAGE DETAIL" size="small" align="left" }}

  {{!-- ═══ Encryption Overlay (if encrypted & not decrypted) ═══ --}}
  {{#if message.status.encrypted}}
    <div class="ncm-message-encrypted-overlay">
      <div class="ncm-encrypted-icon">
        <i class="fas fa-lock"></i>
      </div>
      <div class="ncm-encrypted-title">MESSAGE ENCRYPTED</div>
      <div class="ncm-encrypted-subtitle">
        ICE-protected transmission. Requires decryption to access content.
      </div>
      <div class="ncm-encrypted-actions">
        <button class="ncm-btn ncm-btn--secondary" data-action="decrypt-message"
                data-message-id="{{message.messageId}}">
          <i class="fas fa-unlock-keyhole"></i>
          <span>Attempt Decrypt</span>
        </button>
        {{#if isGM}}
          <button class="ncm-btn ncm-btn--ghost" data-action="force-decrypt-message"
                  data-message-id="{{message.messageId}}">
            <i class="fas fa-shield-halved"></i>
            <span>GM Force Decrypt</span>
          </button>
        {{/if}}
      </div>
    </div>
  {{else}}

    {{!-- ═══ Message Metadata — Restructured (Fix 2A) ═══
         Subject as large heading row (with thread badge).
         Then FROM / TO / DATE / NET as a compact horizontal flex row.
    --}}
    <div class="ncm-detail-meta">

      {{!-- Subject Heading Row --}}
      <div class="ncm-detail-subject">
        <span class="ncm-detail-subject__text">
          {{#if message.subject}}{{message.subject}}{{else}}<em>(No Subject)</em>{{/if}}
        </span>

        {{!-- Priority badge (inline with subject) --}}
        {{#if (neq message.priority "normal")}}
          {{> "modules/cyberpunkred-messenger/templates/partials/tag-badge.hbs"
              label=message.priority variant=message.priorityVariant }}
        {{/if}}

        {{!-- §2.5 Thread Badge Pill --}}
        {{#if message.threadInfo.count}}
          <div class="ncm-thread-badge" data-action="toggle-thread">
            <i class="fas fa-code-branch"></i>
            <span class="ncm-thread-badge__label">THREAD</span>
            <span class="ncm-thread-badge__count">{{message.threadInfo.count}}</span>
          </div>
        {{/if}}
      </div>

      {{!-- Compact Horizontal Meta Row --}}
      <div class="ncm-detail-meta__row-inline">
        <div class="ncm-detail-meta-item">
          <span class="ncm-detail-meta-label">FROM</span>
          <span class="ncm-detail-meta-value">{{message.fromDisplay}}</span>
        </div>
        <div class="ncm-detail-meta-item">
          <span class="ncm-detail-meta-label">TO</span>
          <span class="ncm-detail-meta-value">
            {{#if message.toDisplay}}{{message.toDisplay}}{{else}}{{message.to}}{{/if}}
          </span>
        </div>
        <div class="ncm-detail-meta-item">
          <span class="ncm-detail-meta-label">DATE</span>
          <span class="ncm-detail-meta-value ncm-detail-meta-value--mono">{{message.formattedTime}}</span>
        </div>
        <div class="ncm-detail-meta-item">
          <span class="ncm-detail-meta-label">NET</span>
          <span class="ncm-detail-meta-value ncm-detail-meta-value--highlight">{{message.network}}</span>
        </div>
      </div>
    </div>

    {{!-- ═══ §2.4 Security Verification Strip ═══ --}}
    {{#if message.security}}
      <div class="ncm-security-strip ncm-security-strip--{{message.security.securityLevel}}">

        {{!-- Verified Sender --}}
        <div class="ncm-security-item ncm-security-item--{{message.security.verifiedVariant}}">
          <i class="fas fa-shield-check"></i>
          <span>{{#if message.security.verifiedSender}}VERIFIED SENDER{{else}}UNKNOWN SENDER{{/if}}</span>
        </div>

        {{!-- E2E Encryption --}}
        <div class="ncm-security-item ncm-security-item--{{message.security.encryptedVariant}}">
          <i class="fas fa-lock"></i>
          <span>{{#if message.security.encrypted}}E2E ENCRYPTED{{else}}CLEARTEXT{{/if}}</span>
        </div>

        {{!-- Attachment Scan --}}
        <div class="ncm-security-item ncm-security-item--{{message.security.attachmentScanVariant}}">
          <i class="fas fa-paperclip"></i>
          <span>{{message.security.attachmentScanLabel}}</span>
        </div>

        {{!-- Route Hops (pushed right) --}}
        <div class="ncm-security-item ncm-security-item--route">
          <i class="fas fa-route"></i>
          <span>ROUTE: {{message.security.routeHops}} HOP{{#if (gt message.security.routeHops 1)}}S{{/if}}</span>
        </div>

      </div>
    {{/if}}

    {{!-- ═══ Thread Indicator (expanded bar below strip) ═══ --}}
    {{#if message.threadInfo.count}}
      <div class="ncm-thread-indicator" data-action="toggle-thread">
        <i class="fas fa-code-branch"></i>
        <span>{{message.threadInfo.count}} message{{#if (gt message.threadInfo.count 1)}}s{{/if}} in thread</span>
        <i class="fas fa-chevron-right ncm-thread-chevron"></i>
      </div>
    {{/if}}

    {{!-- ═══ Message Body ═══ --}}
    <div class="ncm-detail-body ncm-scrollbar">
      {{#if message.bodyRendered}}
        {{{message.bodyRendered}}}
      {{else}}
        <p class="ncm-detail-body__empty">
          <em>// No message body //</em>
        </p>
      {{/if}}

      {{!-- ═══ §2.6 Encrypted Attachments (inline in body) ═══ --}}
      {{#each message.encryptedAttachments}}
        {{> "modules/cyberpunkred-messenger/templates/partials/encrypted-attachment.hbs"
            attachment=this
            messageId=../message.messageId
            isGM=../isGM }}
      {{/each}}

      {{!-- ═══ §2.8 Attachment Chips (inline in body) ═══ --}}
      {{#if message.regularAttachments.length}}
        <div class="ncm-attachments">
          {{#each message.regularAttachments}}
            {{> "modules/cyberpunkred-messenger/templates/partials/attachment-chip.hbs"
                attachment=this
                messageId=../message.messageId
                index=@index }}
          {{/each}}
        </div>
      {{/if}}
    </div>

    {{!-- ═══ Malware Warning (Fix 3A — param: text= not message=) ═══ --}}
    {{#if message.status.infected}}
      {{> "modules/cyberpunkred-messenger/templates/partials/alert-panel.hbs"
          variant="danger"
          icon="fas fa-biohazard"
          title="MALWARE DETECTED"
          text="This message contains a hostile daemon. Proceed with caution."
      }}
    {{/if}}

    {{!-- ═══ Action Bar ═══ --}}
    <div class="ncm-detail-actions">
      <button class="ncm-btn ncm-btn--primary" data-action="reply-message">
        <i class="fas fa-reply"></i> Reply
      </button>
      <button class="ncm-btn ncm-btn--ghost" data-action="forward-message">
        <i class="fas fa-share"></i> Forward
      </button>
      <button class="ncm-btn ncm-btn--ghost" data-action="save-message">
        <i class="fas fa-bookmark"></i> Save
      </button>
      <button class="ncm-btn ncm-btn--ghost" data-action="share-to-chat">
        <i class="fas fa-share-from-square"></i> Chat
      </button>
      {{#if isGM}}
        <button class="ncm-btn ncm-btn--ghost" data-action="gm-edit-message"
                data-ncm-tooltip="GM: Edit message flags">
          <i class="fas fa-pen-to-square"></i>
        </button>
      {{/if}}
    </div>

  {{/if}}{{!-- /else encrypted --}}

</div>
