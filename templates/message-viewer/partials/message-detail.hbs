{{!--
  Message Detail Panel — v4 Network States Redesign
  @file templates/message-viewer/partials/message-detail.hbs
  @module cyberpunkred-messenger
  @description Displays selected message with redesigned network state screens:
    - Network Restricted: network identity card + "Connect to [Network]" CTA
    - Lockout: red takeover with static, glitch, vignette, countdown
    - Encrypted: gold ICE overlay with type + DV chips, breach CTA
    - Self-destruct: depleting fill bar + countdown timer
    - Trace: scanning sweep bar (active + complete states)
    - Signal degradation: severity badge + reconstruct button
    - Malware: alert card with Quarantine/Analyze actions
    - Network body effects (darknet, corpnet, govnet)

  Expected context:
    message — enriched from _getEnrichedMessage()
    quickReplies — array of quick-reply strings
    isGM — boolean
    currentFilter — active filter name
--}}

<div class="ncm-viewer__detail" data-message-id="{{message.messageId}}">

  {{!-- ═══ NETWORK RESTRICTED ═══ --}}
  {{#if message.isNetworkLocked}}
    {{#if message.accessState.lockedOut}}

      {{!-- ═══ LOCKOUT — Red takeover ═══ --}}
      <div class="ncm-viewer__lockout">
        <div class="ncm-viewer__lockout-vignette"></div>
        <div class="ncm-viewer__lockout-icon-ring">
          <i class="fas fa-lock ncm-viewer__lockout-icon"></i>
        </div>
        <div class="ncm-viewer__lockout-title">Access Denied</div>
        <div class="ncm-viewer__lockout-subtitle">
          Too many failed authentication attempts on <strong>{{message.lockedNetworkName}}</strong>.
          Your connection has been flagged and temporarily blocked.
        </div>
        <div class="ncm-viewer__lockout-logged">
          <i class="fas fa-exclamation-triangle"></i> This incident has been logged
        </div>

        <div class="ncm-viewer__lockout-timer-block">
          <div class="ncm-viewer__lockout-timer-label">Lockout Remaining</div>
          <div class="ncm-viewer__lockout-timer"
               data-lockout-until="{{message.accessState.lockoutUntil}}">--:--</div>
          <div class="ncm-viewer__lockout-timer-hint">Retry available after lockout expires</div>
        </div>

        <div class="ncm-viewer__lockout-pips">
          <span class="ncm-viewer__lockout-pips-label">All attempts exhausted</span>
          <div class="ncm-viewer__lockout-pip-dots">
            {{#each message.restrictedNetworkData.attemptPips}}
              <div class="ncm-viewer__lockout-pip"></div>
            {{else}}
              <div class="ncm-viewer__lockout-pip"></div>
              <div class="ncm-viewer__lockout-pip"></div>
              <div class="ncm-viewer__lockout-pip"></div>
            {{/each}}
          </div>
        </div>

        {{#if message.restrictedNetworkData}}
          <div class="ncm-viewer__lockout-net-badge">
            <i class="fas {{message.restrictedNetworkData.icon}}"></i>
            {{message.restrictedNetworkData.name}} — Connection Flagged
          </div>
        {{/if}}

        {{#if isGM}}
          <div class="ncm-viewer__lockout-gm">
            <span class="ncm-viewer__lockout-gm-label">GM Only</span>
            <button class="ncm-btn ncm-btn--gm ncm-btn--sm"
                    data-action="gm-force-reveal" data-message-id="{{message.messageId}}">
              <i class="fas fa-shield-halved"></i> Force Reveal
            </button>
            <button class="ncm-btn ncm-btn--gm ncm-btn--sm"
                    data-action="gm-reset-lockout" data-message-id="{{message.messageId}}">
              <i class="fas fa-clock-rotate-left"></i> Reset Lockout
            </button>
          </div>
        {{/if}}
      </div>

    {{else}}

      {{!-- ═══ RESTRICTED — Network card + Connect CTA ═══ --}}
      <div class="ncm-viewer__restricted"
        {{#if message.restrictedNetworkData}}
           style="--net-color: {{message.restrictedNetworkData.color}};
                  --net-glow: {{message.restrictedNetworkData.glow}};
                  --net-rgb: {{message.restrictedNetworkData.rgb}};"
        {{/if}}>

        <div class="ncm-viewer__restricted-icon-ring">
          <i class="fas fa-tower-broadcast ncm-viewer__restricted-icon"></i>
        </div>
        <div class="ncm-viewer__restricted-title">Network Restricted</div>
        <div class="ncm-viewer__restricted-subtitle">
          This message was transmitted on a secured network.
          Connect and authenticate to access content.
        </div>

        {{#if message.restrictedNetworkData}}
          {{!-- Network Identity Card --}}
          <div class="ncm-viewer__restricted-net-card">
            <div class="ncm-viewer__restricted-net-icon"
                 style="background: {{message.restrictedNetworkData.color}}18;
                        color: {{message.restrictedNetworkData.color}};
                        border: 1px solid {{message.restrictedNetworkData.color}}33;">
              <i class="fas {{message.restrictedNetworkData.icon}}"></i>
            </div>
            <div class="ncm-viewer__restricted-net-info">
              <div class="ncm-viewer__restricted-net-name">{{message.restrictedNetworkData.name}}</div>
              <div class="ncm-viewer__restricted-net-meta">
                <span>{{message.restrictedNetworkData.typeLabel}}</span>
                <span class="ncm-viewer__restricted-security-tag ncm-viewer__restricted-security-tag--{{message.restrictedNetworkData.securityTagClass}}">
                  <i class="fas fa-shield-halved"></i> {{message.restrictedNetworkData.securityLevel}}
                </span>
              </div>
            </div>
          </div>

          {{!-- Auth Requirement Chips --}}
          {{#if message.restrictedNetworkData.reqChips.length}}
            <div class="ncm-viewer__restricted-requires">
              <i class="fas fa-info-circle"></i>
              <span>Requires:</span>
              {{#each message.restrictedNetworkData.reqChips}}
                {{#unless @first}}
                  <span class="ncm-viewer__restricted-req-and">
                    {{#if (eq ../message.restrictedNetworkData.authLogic "AND")}}+{{else}}or{{/if}}
                  </span>
                {{/unless}}
                <span class="ncm-viewer__restricted-req-chip ncm-viewer__restricted-req-chip--{{this.type}}">
                  <i class="fas {{this.icon}}"></i> {{this.label}}
                </span>
              {{/each}}
            </div>
          {{/if}}

          {{!-- Connect CTA --}}
          <button class="ncm-viewer__restricted-connect"
                  data-action="connect-network"
                  data-network-id="{{message.restrictedNetworkData.networkId}}"
                  style="border-color: {{message.restrictedNetworkData.color}}66;
                         background: {{message.restrictedNetworkData.color}}14;">
            <i class="fas fa-plug-circle-bolt"></i> Connect to {{message.restrictedNetworkData.name}}
          </button>
          <span class="ncm-viewer__restricted-hint">Opens network authentication dialog</span>

          {{!-- Attempt Pips --}}
          {{#if message.restrictedNetworkData.maxAttempts}}
            <div class="ncm-viewer__restricted-pips">
              <span class="ncm-viewer__restricted-pips-label">Attempts</span>
              <div class="ncm-viewer__restricted-pip-dots">
                {{#each message.restrictedNetworkData.attemptPips}}
                  <div class="ncm-viewer__restricted-pip ncm-viewer__restricted-pip--{{this.state}}"></div>
                {{/each}}
              </div>
            </div>
          {{/if}}
        {{else}}
          <div class="ncm-viewer__restricted-subtitle" style="margin-top: 0;">
            Connect to <strong>{{message.lockedNetworkName}}</strong> to access this message.
          </div>
        {{/if}}

        {{#if isGM}}
          <div class="ncm-viewer__restricted-gm">
            <span class="ncm-viewer__restricted-gm-label">GM Only</span>
            <button class="ncm-btn ncm-btn--gm ncm-btn--sm"
                    data-action="gm-force-reveal" data-message-id="{{message.messageId}}">
              <i class="fas fa-shield-halved"></i> Force Reveal
            </button>
          </div>
        {{/if}}
      </div>
    {{/if}}

  {{!-- ═══ ENCRYPTED ═══ --}}
  {{else if message.status.encrypted}}
    <div class="ncm-viewer__encrypted">
      <div class="ncm-viewer__encrypted-icon-ring">
        <i class="fas fa-lock ncm-viewer__encrypted-icon"></i>
      </div>
      <div class="ncm-viewer__encrypted-title">Message Encrypted</div>
      <div class="ncm-viewer__encrypted-subtitle">
        ICE-protected transmission. Requires decryption to access content.
      </div>
      {{#if message.encryption}}
        <div class="ncm-viewer__encrypted-ice-meta">
          {{#if message.encryption.type}}
            <span class="ncm-viewer__encrypted-ice-chip">
              <i class="fas fa-shield-halved"></i> {{message.encryption.type}}
            </span>
          {{/if}}
          {{#if message.encryption.dc}}
            <span class="ncm-viewer__encrypted-ice-chip">
              <i class="fas fa-dice-d20"></i> DV {{message.encryption.dc}}
            </span>
          {{/if}}
        </div>
      {{/if}}
      <button class="ncm-viewer__encrypted-breach"
              data-action="attempt-decrypt" data-message-id="{{message.messageId}}">
        <i class="fas fa-terminal"></i> Attempt Decryption
      </button>
      {{#if isGM}}
        <div class="ncm-viewer__encrypted-gm">
          <span class="ncm-viewer__encrypted-gm-label">GM Only</span>
          <button class="ncm-btn ncm-btn--gm ncm-btn--sm"
                  data-action="gm-force-reveal" data-message-id="{{message.messageId}}">
            <i class="fas fa-shield-halved"></i> Force Reveal
          </button>
        </div>
      {{/if}}
    </div>

  {{else}}
    {{!-- ═══ NORMAL MESSAGE CONTENT ═══ --}}

    {{!-- GM restriction indicator — shows when message IS restricted but GM can bypass --}}
    {{#if message.hasNetworkRestriction}}
      {{#unless message.isNetworkLocked}}
        <div class="ncm-viewer__gm-restricted-banner"
          {{#if message.restrictedNetworkData}}
            style="--net-color: {{message.restrictedNetworkData.color}};
                   --net-rgb: {{message.restrictedNetworkData.rgb}};"
          {{/if}}>
          <div class="ncm-viewer__gm-restricted-accent"></div>
          <i class="fas fa-tower-broadcast ncm-viewer__gm-restricted-icon"></i>
          <span class="ncm-viewer__gm-restricted-label">Network Restricted</span>
          {{#if message.restrictedNetworkData}}
            <span class="ncm-viewer__gm-restricted-net">
              <i class="fas {{message.restrictedNetworkData.icon}}"></i>
              {{message.restrictedNetworkData.name}}
            </span>
            <span class="ncm-viewer__gm-restricted-security">
              {{message.restrictedNetworkData.securityLevel}}
            </span>
          {{/if}}
          <span class="ncm-viewer__gm-restricted-bypass">
            <i class="fas fa-shield-halved"></i> GM BYPASS
          </span>
        </div>
      {{/unless}}
    {{/if}}

    {{!-- Detail Header --}}
    <div class="ncm-viewer__detail-head">
      <div class="ncm-viewer__detail-head-top">
        <div class="ncm-viewer__detail-avatar"
             style="color: {{message.avatarColor}}; border-color: {{message.avatarColor}}">
          {{#if message.fromPortrait}}
            <img src="{{message.fromPortrait}}" alt="{{message.fromDisplay}}" />
          {{else}}
            {{message.fromInitial}}
          {{/if}}
        </div>
        <div class="ncm-viewer__detail-info">
          <div class="ncm-viewer__detail-sender-row">
            <span class="ncm-viewer__detail-sender-name">{{message.fromDisplay}}</span>
            {{#unless message.senderIsContact}}
              <button class="ncm-viewer__detail-add-contact" data-action="add-sender-contact"
                      data-email="{{message.from}}" data-name="{{message.fromDisplay}}">
                <i class="fas fa-user-plus"></i> Add
              </button>
            {{/unless}}
            <span class="ncm-viewer__detail-time">{{message.formattedTime}}</span>
          </div>
          <div class="ncm-viewer__detail-to-summary">
            <span class="ncm-viewer__detail-to-label">to</span>
            <span class="ncm-viewer__detail-to-val">{{message.toDisplay}}</span>
            <button class="ncm-viewer__detail-expand" data-action="toggle-detail-grid">
              <i class="fas fa-chevron-down"></i>
            </button>
          </div>
        </div>
      </div>
      <div class="ncm-viewer__detail-grid ncm-viewer__detail-grid--collapsed">
        <span class="ncm-viewer__detail-grid-label">From</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--from">{{message.from}}</span>
        <span class="ncm-viewer__detail-grid-label">To</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--to">{{message.to}}</span>
        <span class="ncm-viewer__detail-grid-label">Time</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--time">{{message.formattedTime}}</span>
        <span class="ncm-viewer__detail-grid-label">Net</span>
        <span class="ncm-viewer__detail-grid-val"
              {{#if message.networkBadgeTheme.color}}style="color: {{message.networkBadgeTheme.color}}"{{/if}}>
          <i class="fas {{#if message.networkBadgeTheme.icon}}{{message.networkBadgeTheme.icon}}{{else}}fa-wifi{{/if}}"
             style="font-size: 9px; margin-right: 3px; opacity: 0.6;"></i>{{message.networkLabel}}
        </span>
      </div>
      <div class="ncm-viewer__subject-strip
        {{~#if (eq message.priority 'critical')}} ncm-viewer__subject-strip--critical
        {{~else if (eq message.priority 'urgent')}} ncm-viewer__subject-strip--urgent
        {{~else}} ncm-viewer__subject-strip--default{{/if}}"
        {{~#unless (or (eq message.priority 'critical') (eq message.priority 'urgent'))}}
          {{~#if message.networkBadgeTheme.color}}
            style="--ncm-strip-accent: {{message.networkBadgeTheme.color}}"
          {{/if}}
        {{/unless}}>
        <span class="ncm-viewer__subject-micro">Subject</span>
        <div class="ncm-viewer__subject-row">
          <span class="ncm-viewer__subject-text">{{message.subject}}</span>
          {{#if message.priorityIcon}}
            <span class="ncm-viewer__priority-pill ncm-viewer__priority-pill--{{message.priority}}">
              <i class="{{message.priorityIcon}}"></i> {{message.priority}}
            </span>
          {{/if}}
          {{#if message.threatBadge}}
            <span class="ncm-viewer__priority-pill ncm-viewer__priority-pill--threat">
              <i class="{{message.threatBadge.icon}}"></i> {{message.threatBadge.label}}
            </span>
          {{/if}}
          {{#if message.threadInfo}}
            <span class="ncm-viewer__detail-thread">
              <i class="fas fa-code-branch"></i> Thread · {{message.threadInfo.count}}
            </span>
          {{/if}}
        </div>
        <div class="ncm-viewer__subject-rule"></div>
      </div>
    </div>

    {{!-- Self-Destruct Bar --}}
    {{#if message.selfDestructActive}}
      <div class="ncm-viewer__destruct-bar">
        <div class="ncm-viewer__destruct-bar-fill" style="width: 100%;"></div>
        <i class="fas fa-bomb ncm-viewer__destruct-bar-icon"></i>
        <span class="ncm-viewer__destruct-bar-label">Self-Destruct</span>
        <span class="ncm-viewer__destruct-bar-spacer"></span>
        <span class="ncm-viewer__destruct-bar-timer"
              data-expires-at="{{message.selfDestruct.expiresAt}}"
              data-duration="{{message.selfDestruct.duration}}">
          {{message.selfDestructDisplay}}
        </span>
        <span class="ncm-viewer__destruct-bar-mode">
          {{#if (eq message.selfDestruct.mode 'after_read')}}READ{{else}}TIMED{{/if}}
        </span>
      </div>
    {{/if}}

    {{!-- Trace Bar --}}
    {{#if message.traceActive}}
      <div class="ncm-viewer__trace-bar ncm-viewer__trace-bar--active">
        <i class="fas fa-satellite-dish ncm-viewer__trace-bar-icon"></i>
        <span class="ncm-viewer__trace-bar-label">Trace in Progress</span>
        <span class="ncm-viewer__trace-bar-spacer"></span>
        <span class="ncm-viewer__trace-bar-timer" data-trace-expires="{{message.traceExpiresAt}}">--:--</span>
      </div>
    {{else if message.traceCompleted}}
      <div class="ncm-viewer__trace-bar ncm-viewer__trace-bar--complete">
        <i class="fas fa-satellite-dish ncm-viewer__trace-bar-icon"></i>
        <span class="ncm-viewer__trace-bar-label">Trace Complete</span>
        <span class="ncm-viewer__trace-bar-spacer"></span>
        <span class="ncm-viewer__trace-bar-detail">Your location was logged by network security</span>
      </div>
    {{/if}}

    {{!-- Message Body --}}
    <div class="ncm-viewer__detail-body ncm-scrollbar
      {{~#if message.networkBodyEffect}} ncm-viewer__detail-body--{{message.networkBodyEffect}}{{/if~}}">
      {{#if message.bodyRendered}}
        {{{message.bodyRendered}}}
      {{else}}
        <p class="ncm-viewer__detail-body-empty"><em>// No message body //</em></p>
      {{/if}}

      {{!-- Signal Degradation --}}
      {{#if message.signalDegradation}}
        {{#unless message.signalDegradation.reconstructed}}
          <div class="ncm-viewer__signal-reconstruct">
            <div class="ncm-viewer__signal-reconstruct-header">
              <i class="fas fa-signal ncm-viewer__signal-reconstruct-icon"></i>
              <span class="ncm-viewer__signal-reconstruct-label">Signal Degraded</span>
              <span class="ncm-viewer__signal-reconstruct-level ncm-viewer__signal-reconstruct-level--{{#if (gt message.signalDegradation.corruptionPercent 30)}}severe{{else}}moderate{{/if}}">
                {{message.signalDegradation.corruptionLevel}}
              </span>
            </div>
            <div class="ncm-viewer__signal-status">
              Received at {{message.signalDegradation.originalSignal}}% signal —
              {{message.signalDegradation.corruptionLevel}} corruption detected
            </div>
            <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                    data-action="reconstruct-signal" data-message-id="{{message.messageId}}">
              <i class="fas fa-wrench"></i> Reconstruct
              <span class="ncm-viewer__signal-dv">{{message.signalDegradation.reconstructSkill}} DV {{message.signalDegradation.reconstructDC}}</span>
            </button>
          </div>
        {{/unless}}
      {{/if}}

      {{!-- Eddies --}}
      {{#if message.eddiesData}}
        <div class="ncm-viewer__eddies {{#if message.eddiesData.claimed}}ncm-viewer__eddies--claimed{{/if}}"
             data-message-id="{{message.messageId}}">
          <i class="fas {{#if message.eddiesData.isSentCopy}}fa-paper-plane{{else if message.eddiesData.claimed}}fa-check-circle{{else}}fa-coins{{/if}} ncm-viewer__eddies-icon"></i>
          <div class="ncm-viewer__eddies-info">
            <div class="ncm-viewer__eddies-amount">{{message.eddiesData.formatted}}</div>
            <div class="ncm-viewer__eddies-label">{{#if message.eddiesData.isSentCopy}}Eddies Sent{{else}}Eddies Transfer{{/if}}</div>
          </div>
          {{#if message.eddiesData.claimed}}
            <span class="ncm-viewer__eddies-status">
              <i class="fas {{#if message.eddiesData.isSentCopy}}fa-arrow-up{{else}}fa-check{{/if}}"></i>
              {{message.eddiesData.claimedAt}}
            </span>
          {{else}}
            <button class="ncm-viewer__eddies-btn" data-action="claim-eddies"
                    data-message-id="{{message.messageId}}" data-amount="{{message.eddiesData.amount}}">
              <i class="fas fa-download"></i> Claim
            </button>
          {{/if}}
          <div class="ncm-viewer__eddies-progress" data-id="eddies-progress"></div>
        </div>
      {{/if}}

      {{!-- Encrypted Attachments --}}
      {{#each message.encryptedAttachments}}
        {{> "modules/cyberpunkred-messenger/templates/partials/encrypted-attachment.hbs"
            attachment=this messageId=../message.messageId isGM=../isGM }}
      {{/each}}

      {{!-- Attachments --}}
      {{#if message.hasAttachmentCards}}
        <div class="ncm-viewer__attach-grid">
          {{#each message.attachmentCards}}
            <div class="ncm-viewer__attach-card" data-action="{{this.action}}"
                 data-attachment-index="{{@index}}" data-message-id="{{../message.messageId}}"
                 data-item-id="{{this.itemId}}">
              <div class="ncm-viewer__attach-thumb {{this.thumbClass}}">
                {{#if this.thumbSrc}}<img src="{{this.thumbSrc}}" alt="">
                {{else}}<i class="{{this.thumbIcon}}"></i>{{/if}}
              </div>
              <div class="ncm-viewer__attach-info">
                <div class="ncm-viewer__attach-name" {{#if this.nameStyle}}style="{{this.nameStyle}}"{{/if}}>{{this.name}}</div>
                <div class="ncm-viewer__attach-meta {{this.metaClass}}">{{this.meta}}</div>
              </div>
            </div>
          {{/each}}
        </div>
      {{/if}}
    </div>

    {{!-- Malware Alert --}}
    {{#if message.status.infected}}
      <div class="ncm-viewer__malware-alert">
        <div class="ncm-viewer__malware-alert-icon-wrap">
          <i class="fas fa-biohazard ncm-viewer__malware-alert-icon"></i>
        </div>
        <div class="ncm-viewer__malware-alert-body">
          <div class="ncm-viewer__malware-alert-title">Malware Detected</div>
          <div class="ncm-viewer__malware-alert-text">
            This message contains a <strong>hostile daemon</strong>. Your cyberdeck may be compromised.
          </div>
          <div class="ncm-viewer__malware-alert-actions">
            <button class="ncm-btn ncm-btn--danger ncm-btn--sm"
                    data-action="quarantine-malware" data-message-id="{{message.messageId}}">
              <i class="fas fa-shield-virus"></i> Quarantine
            </button>
            <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                    data-action="analyze-malware" data-message-id="{{message.messageId}}">
              <i class="fas fa-magnifying-glass"></i> Analyze
            </button>
          </div>
        </div>
      </div>
    {{/if}}

    {{!-- Action Bar --}}
    <div class="ncm-viewer__detail-actions">
      {{#if (eq currentFilter 'trash')}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="restore-message"><i class="fas fa-undo"></i> Restore</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="permanent-delete"><i class="fas fa-fire"></i> Delete</button>
      {{else if (eq currentFilter 'spam')}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="reply-message"><i class="fas fa-reply"></i> Reply</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="restore-message"><i class="fas fa-undo"></i> Not Spam</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="permanent-delete"><i class="fas fa-fire"></i> Delete</button>
      {{else if message.isSent}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="forward-message"><i class="fas fa-share"></i> Forward</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="share-to-chat"><i class="fas fa-share-from-square"></i> Chat</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="delete-message"><i class="fas fa-trash"></i> Delete</button>
      {{else}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="reply-message"><i class="fas fa-reply"></i> Reply</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="forward-message"><i class="fas fa-share"></i> Forward</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="save-message"><i class="fas fa-bookmark"></i> Save</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="share-to-chat"><i class="fas fa-share-from-square"></i> Chat</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="mark-spam"><i class="fas fa-ban"></i> Spam</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="delete-message"><i class="fas fa-trash"></i> Delete</button>
      {{/if}}
    </div>

    {{!-- Quick Reply --}}
    {{#unless message.isSent}}
      {{#unless (eq currentFilter 'trash')}}
        {{#unless (eq currentFilter 'spam')}}
          <div class="ncm-viewer__quick-reply">
            <div class="ncm-viewer__quick-reply-row">
