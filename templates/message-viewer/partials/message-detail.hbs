{{!--
  Message Detail Panel — v3.2 Redesign
  @file templates/message-viewer/partials/message-detail.hbs
  @module cyberpunkred-messenger
  @description Displays selected message with:
    - Clickable sender avatar with color-coded border
    - Sender name + "Add Contact" button for unknown senders
    - Color-coded meta fields (from=cyan, to=gold, time=muted, network=green)
    - Security verification strip
    - Thread indicator badge
    - Message body with eddies claim, attachments, encrypted blocks
    - Network-locked and encryption overlays
    - Quick reply bar

  Expected context:
    message — enriched from _getEnrichedMessage()
    quickReplies — array of quick-reply strings
    isGM — boolean
    currentFilter — active filter name
--}}

<div class="ncm-viewer__detail" data-message-id="{{message.messageId}}">

  {{!-- ═══ Network-Locked Overlay ═══ --}}
  {{#if message.isNetworkLocked}}
    <div class="ncm-viewer__locked-overlay ncm-viewer__locked-overlay--network">
      <div class="ncm-viewer__locked-icon"><i class="fas fa-tower-broadcast"></i></div>
      <div class="ncm-viewer__locked-title">NETWORK RESTRICTED</div>
      <div class="ncm-viewer__locked-subtitle">
        This message was transmitted on <strong>{{message.lockedNetworkName}}</strong>.
        {{#if message.accessState.lockedOut}}
          Access locked — too many failed attempts.
        {{else}}
          Connect to this network or bypass access controls.
        {{/if}}
      </div>
      <div class="ncm-viewer__locked-badge">
        <i class="fas fa-lock"></i> REQUIRES {{message.lockedNetworkName}} ACCESS
      </div>

      {{#if message.accessState.lockedOut}}
        <div class="ncm-viewer__locked-lockout">
          <i class="fas fa-clock"></i>
          <span>SYSTEM LOCKED</span>
          <span class="ncm-viewer__locked-timer" data-lockout-until="{{message.accessState.lockoutUntil}}">--:--</span>
        </div>
      {{else}}
        {{!-- Attempt counter --}}
        {{#if message.accessState.maxAttempts}}
          {{#if message.accessState.hackAttempts}}
            <div class="ncm-viewer__locked-attempts">
              <span>Bypass attempts:</span>
              <span>{{sub message.accessState.maxAttempts message.accessState.hackAttempts}} of {{message.accessState.maxAttempts}} remaining</span>
            </div>
          {{/if}}
        {{/if}}

        <div class="ncm-viewer__locked-bypass">
          {{!-- Password --}}
          {{#if message.accessState.bypassOptions.password}}
            <div class="ncm-viewer__locked-bypass-row">
              <div class="ncm-viewer__locked-bypass-field">
                <span class="ncm-viewer__locked-bypass-prefix">pass&gt;</span>
                <input class="ncm-viewer__locked-bypass-input" type="password"
                       name="bypassPassword" placeholder="enter access code..."
                       data-message-id="{{message.messageId}}" />
              </div>
              <button class="ncm-btn ncm-btn--secondary ncm-btn--sm"
                      data-action="bypass-password" data-message-id="{{message.messageId}}">
                <i class="fas fa-key"></i> AUTH
              </button>
            </div>
          {{/if}}

          {{!-- Skill check --}}
          {{#if message.accessState.bypassOptions.skillCheck}}
            <div class="ncm-viewer__locked-bypass-row ncm-viewer__locked-bypass-row--skill">
              {{#each message.accessState.bypassSkills}}
                <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                        data-action="bypass-skill"
                        data-message-id="{{../message.messageId}}"
                        data-skill="{{this}}">
                  <i class="fas fa-dice-d20"></i> {{this}} Check
                  <span class="ncm-viewer__locked-dv">DV {{../message.accessState.bypassDC}}</span>
                </button>
              {{/each}}
            </div>
          {{/if}}

          {{!-- Key item --}}
          {{#if message.accessState.bypassOptions.keyItem}}
            <div class="ncm-viewer__locked-bypass-row">
              <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                      data-action="bypass-keyitem" data-message-id="{{message.messageId}}">
                <i class="fas fa-id-badge"></i> Present {{message.accessState.keyItemName}}
              </button>
            </div>
          {{/if}}

          {{!-- No bypass hint --}}
          {{#unless message.accessState.bypassOptions.password}}
            {{#unless message.accessState.bypassOptions.skillCheck}}
              {{#unless message.accessState.bypassOptions.keyItem}}
                <div class="ncm-viewer__locked-no-bypass">
                  No bypass methods available. Connect to <strong>{{message.lockedNetworkName}}</strong> directly.
                </div>
              {{/unless}}
            {{/unless}}
          {{/unless}}
        </div>
      {{/if}}

      {{!-- GM Controls --}}
      {{#if isGM}}
        <div class="ncm-viewer__locked-gm">
          <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                  data-action="gm-force-reveal" data-message-id="{{message.messageId}}">
            <i class="fas fa-shield-halved"></i> GM Force Reveal
          </button>
        </div>
      {{/if}}
    </div>

  {{!-- ═══ Encryption Overlay ═══ --}}
  {{else if message.status.encrypted}}
    <div class="ncm-viewer__locked-overlay ncm-viewer__locked-overlay--encrypted">
      <div class="ncm-viewer__locked-icon"><i class="fas fa-lock"></i></div>
      <div class="ncm-viewer__locked-title">MESSAGE ENCRYPTED</div>
      <div class="ncm-viewer__locked-subtitle">ICE-protected transmission. Requires decryption to access content.</div>
      {{#if message.encryption}}
        <div class="ncm-viewer__locked-meta">
          {{#if message.encryption.type}}
            <span><i class="fas fa-shield-halved"></i> {{message.encryption.type}}</span>
          {{/if}}
          {{#if message.encryption.dc}}
            <span><i class="fas fa-dice-d20"></i> DV {{message.encryption.dc}}</span>
          {{/if}}
        </div>
      {{/if}}
      <button class="ncm-btn ncm-btn--secondary ncm-btn--sm"
              data-action="attempt-decrypt" data-message-id="{{message.messageId}}">
        <i class="fas fa-terminal"></i> Attempt Decryption
      </button>
      {{#if isGM}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                data-action="gm-force-reveal" data-message-id="{{message.messageId}}">
          <i class="fas fa-shield-halved"></i> GM Force Reveal
        </button>
      {{/if}}
    </div>

  {{else}}
    {{!-- ═══ Normal Message Content ═══ --}}

    {{!-- Detail Header — Collapsible Grid Readout --}}
    <div class="ncm-viewer__detail-head">
      {{!-- Always-visible: Avatar + Sender + Time + expand toggle --}}
      <div class="ncm-viewer__detail-head-top">
        <div class="ncm-viewer__detail-avatar"
             style="color: {{message.avatarColor}}; border-color: {{message.avatarColor}}">
          {{#if message.fromPortrait}}
            <img src="{{message.fromPortrait}}" alt="{{message.fromDisplay}}" />
          {{else}}
            {{message.fromInitial}}
          {{/if}}
        </div>

        <div class="ncm-viewer__detail-info">
          <div class="ncm-viewer__detail-sender-row">
            <span class="ncm-viewer__detail-sender-name">{{message.fromDisplay}}</span>
            {{#unless message.senderIsContact}}
              <button class="ncm-viewer__detail-add-contact" data-action="add-sender-contact"
                      data-email="{{message.from}}" data-name="{{message.fromDisplay}}">
                <i class="fas fa-user-plus"></i> Add
              </button>
            {{/unless}}
            <span class="ncm-viewer__detail-time">{{message.formattedTime}}</span>
          </div>
          <div class="ncm-viewer__detail-to-summary">
            <span class="ncm-viewer__detail-to-label">to</span>
            <span class="ncm-viewer__detail-to-val">{{message.toDisplay}}</span>
            <button class="ncm-viewer__detail-expand" data-action="toggle-detail-grid">
              <i class="fas fa-chevron-down"></i>
            </button>
          </div>
        </div>
      </div>

      {{!-- Expandable grid (hidden by default, toggled by arrow) --}}
      <div class="ncm-viewer__detail-grid ncm-viewer__detail-grid--collapsed">
        <span class="ncm-viewer__detail-grid-label">From</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--from">{{message.from}}</span>
        <span class="ncm-viewer__detail-grid-label">To</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--to">{{message.to}}</span>
        <span class="ncm-viewer__detail-grid-label">Time</span>
        <span class="ncm-viewer__detail-grid-val ncm-viewer__detail-grid-val--time">{{message.formattedTime}}</span>
        <span class="ncm-viewer__detail-grid-label">Net</span>
        <span class="ncm-viewer__detail-grid-val"
              {{#if message.networkBadgeTheme.color}}style="color: {{message.networkBadgeTheme.color}}"{{/if}}>
          <i class="fas {{#if message.networkBadgeTheme.icon}}{{message.networkBadgeTheme.icon}}{{else}}fa-wifi{{/if}}"
             style="font-size: 9px; margin-right: 3px; opacity: 0.6;"></i>{{message.networkLabel}}
        </span>
      </div>

      {{!-- Subject Strip — Two-tier: micro label + large title + fading rule --}}
      <div class="ncm-viewer__subject-strip
        {{~#if (eq message.priority 'critical')}} ncm-viewer__subject-strip--critical
        {{~else if (eq message.priority 'urgent')}} ncm-viewer__subject-strip--urgent
        {{~else}} ncm-viewer__subject-strip--default{{/if}}"
        {{~#unless (or (eq message.priority 'critical') (eq message.priority 'urgent'))}}
          {{~#if message.networkBadgeTheme.color}}
            style="--ncm-strip-accent: {{message.networkBadgeTheme.color}}"
          {{/if}}
        {{/unless}}>
        <span class="ncm-viewer__subject-micro">Subject</span>
        <div class="ncm-viewer__subject-row">
          <span class="ncm-viewer__subject-text">{{message.subject}}</span>
          {{#if message.priorityIcon}}
            <span class="ncm-viewer__priority-pill ncm-viewer__priority-pill--{{message.priority}}">
              <i class="{{message.priorityIcon}}"></i> {{message.priority}}
            </span>
          {{/if}}
          {{#if message.threatBadge}}
            <span class="ncm-viewer__priority-pill ncm-viewer__priority-pill--threat">
              <i class="{{message.threatBadge.icon}}"></i> {{message.threatBadge.label}}
            </span>
          {{/if}}
          {{#if message.threadInfo}}
            <span class="ncm-viewer__detail-thread">
              <i class="fas fa-code-branch"></i> Thread · {{message.threadInfo.count}}
            </span>
          {{/if}}
        </div>
        <div class="ncm-viewer__subject-rule"></div>
      </div>
    </div>

    {{!-- Self-destruct bar --}}
    {{#if message.selfDestructActive}}
      <div class="ncm-viewer__destruct-bar">
        <i class="fas fa-bomb"></i>
        <span>SELF-DESTRUCT ACTIVE</span>
        <span class="ncm-viewer__destruct-timer"
              data-self-destruct-display="{{message.selfDestructDisplay}}"
              data-expires-at="{{message.selfDestruct.expiresAt}}">
          {{message.selfDestructDisplay}}
        </span>
      </div>
    {{/if}}

    {{!-- Trace bar --}}
    {{#if message.traceActive}}
      <div class="ncm-viewer__trace-bar">
        <i class="fas fa-satellite-dish"></i>
        <span class="ncm-viewer__trace-label">TRACE IN PROGRESS</span>
        <span class="ncm-viewer__trace-timer" data-trace-expires="{{message.traceExpiresAt}}">--:--</span>
      </div>
    {{else if message.traceCompleted}}
      <div class="ncm-viewer__trace-bar ncm-viewer__trace-bar--complete">
        <i class="fas fa-satellite-dish"></i>
        <span class="ncm-viewer__trace-label">TRACE COMPLETE</span>
        <span>Your location was logged by network security</span>
      </div>
    {{/if}}

    {{!-- ═══ Message Body ═══ --}}
    <div class="ncm-viewer__detail-body ncm-scrollbar
      {{~#if message.networkBodyEffect}} ncm-viewer__detail-body--{{message.networkBodyEffect}}{{/if~}}">
      {{#if message.bodyRendered}}
        {{{message.bodyRendered}}}
      {{else}}
        <p class="ncm-viewer__detail-body-empty"><em>// No message body //</em></p>
      {{/if}}

      {{!-- Signal reconstruction --}}
      {{#if message.signalDegradation}}
        {{#unless message.signalDegradation.reconstructed}}
          <div class="ncm-viewer__signal-reconstruct">
            <div class="ncm-viewer__signal-status">
              <i class="fas fa-signal"></i>
              SIGNAL DEGRADED — {{message.signalDegradation.corruptionLevel}} corruption
              (received at {{message.signalDegradation.originalSignal}}% signal)
            </div>
            <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                    data-action="reconstruct-signal" data-message-id="{{message.messageId}}">
              <i class="fas fa-wrench"></i>
              Reconstruct ({{message.signalDegradation.reconstructSkill}} DV {{message.signalDegradation.reconstructDC}})
            </button>
          </div>
        {{/unless}}
      {{/if}}

      {{!-- Eddies claim --}}
      {{#if message.eddiesData}}
        <div class="ncm-viewer__eddies {{#if message.eddiesData.claimed}}ncm-viewer__eddies--claimed{{/if}}"
             data-message-id="{{message.messageId}}">
          <i class="fas {{#if message.eddiesData.isSentCopy}}fa-paper-plane{{else if message.eddiesData.claimed}}fa-check-circle{{else}}fa-coins{{/if}} ncm-viewer__eddies-icon"></i>
          <div class="ncm-viewer__eddies-info">
            <div class="ncm-viewer__eddies-amount">{{message.eddiesData.formatted}}</div>
            <div class="ncm-viewer__eddies-label">{{#if message.eddiesData.isSentCopy}}Eddies Sent{{else}}Eddies Transfer{{/if}}</div>
          </div>
          {{#if message.eddiesData.claimed}}
            <span class="ncm-viewer__eddies-status">
              <i class="fas {{#if message.eddiesData.isSentCopy}}fa-arrow-up{{else}}fa-check{{/if}}"></i>
              {{message.eddiesData.claimedAt}}
            </span>
          {{else}}
            <button class="ncm-viewer__eddies-btn" data-action="claim-eddies"
                    data-message-id="{{message.messageId}}" data-amount="{{message.eddiesData.amount}}">
              <i class="fas fa-download"></i> Claim
            </button>
          {{/if}}
          <div class="ncm-viewer__eddies-progress" data-id="eddies-progress"></div>
        </div>
      {{/if}}

      {{!-- Encrypted attachments --}}
      {{#each message.encryptedAttachments}}
        {{> "modules/cyberpunkred-messenger/templates/partials/encrypted-attachment.hbs"
            attachment=this messageId=../message.messageId isGM=../isGM }}
      {{/each}}

      {{!-- Regular attachment cards --}}
      {{#if message.hasAttachmentCards}}
        <div class="ncm-viewer__attach-grid">
          {{#each message.attachmentCards}}
            <div class="ncm-viewer__attach-card" data-action="{{this.action}}"
                 data-attachment-index="{{@index}}" data-message-id="{{../message.messageId}}"
                 data-item-id="{{this.itemId}}">
              <div class="ncm-viewer__attach-thumb {{this.thumbClass}}">
                {{#if this.thumbSrc}}
                  <img src="{{this.thumbSrc}}" alt="">
                {{else}}
                  <i class="{{this.thumbIcon}}"></i>
                {{/if}}
              </div>
              <div class="ncm-viewer__attach-info">
                <div class="ncm-viewer__attach-name" {{#if this.nameStyle}}style="{{this.nameStyle}}"{{/if}}>{{this.name}}</div>
                <div class="ncm-viewer__attach-meta {{this.metaClass}}">{{this.meta}}</div>
              </div>
            </div>
          {{/each}}
        </div>
      {{/if}}
    </div>

    {{!-- Malware warning --}}
    {{#if message.status.infected}}
      {{> "modules/cyberpunkred-messenger/templates/partials/alert-panel.hbs"
          variant="danger" icon="fas fa-biohazard"
          title="MALWARE DETECTED"
          text="This message contains a hostile daemon. Proceed with caution." }}
    {{/if}}

    {{!-- ═══ Action Bar (inside detail panel) ═══ --}}
    <div class="ncm-viewer__detail-actions">
      {{#if (eq currentFilter 'trash')}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="restore-message"><i class="fas fa-undo"></i> Restore</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="permanent-delete"><i class="fas fa-fire"></i> Delete</button>
      {{else if (eq currentFilter 'spam')}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="reply-message"><i class="fas fa-reply"></i> Reply</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="restore-message"><i class="fas fa-undo"></i> Not Spam</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="permanent-delete"><i class="fas fa-fire"></i> Delete</button>
      {{else if message.isSent}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="forward-message"><i class="fas fa-share"></i> Forward</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="share-to-chat"><i class="fas fa-share-from-square"></i> Chat</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="delete-message"><i class="fas fa-trash"></i> Delete</button>
      {{else}}
        <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="reply-message"><i class="fas fa-reply"></i> Reply</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="forward-message"><i class="fas fa-share"></i> Forward</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="save-message"><i class="fas fa-bookmark"></i> Save</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="share-to-chat"><i class="fas fa-share-from-square"></i> Chat</button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="mark-spam"><i class="fas fa-ban"></i> Spam</button>
        <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="delete-message"><i class="fas fa-trash"></i> Delete</button>
      {{/if}}
    </div>

    {{!-- Quick Reply Bar --}}
    {{#unless message.isSent}}
      {{#unless (eq currentFilter 'trash')}}
        {{#unless (eq currentFilter 'spam')}}
          <div class="ncm-viewer__quick-reply">
            <div class="ncm-viewer__quick-reply-row">
              <input type="text" class="ncm-viewer__quick-reply-input" placeholder="Quick reply..." />
              <button class="ncm-viewer__quick-reply-send" data-action="send-reply">
                <i class="fas fa-paper-plane"></i>
              </button>
            </div>
          </div>
        {{/unless}}
      {{/unless}}
    {{/unless}}

  {{/if}}{{!-- /else encrypted --}}

</div>
