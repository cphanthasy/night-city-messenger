{{!--
  Message Viewer (Inbox) — Sprint 2A: Inbox Layout Redesign
  @file templates/message-viewer/message-viewer.hbs
  @module cyberpunkred-messenger
  @description Main inbox template with condensed cyberdeck terminal layout.
    Layout: Condensed Header (identity + network + stats + actions) →
    Tightened HUD strip → Tabs with counts + controls →
    Split panel (list | detail) → Smart Footer with keyboard hints.

  Sprint 2A changes:
    - Condensed header merges identity, network badge, stat counters, and actions
      into a single ~52px row
    - HUD strip tightened to ~20px
    - Tabs absorb count badges from old stat cards
    - Smart footer with persistent info + context-aware shortcuts
    - Old stat cards row REMOVED
    - Old separate search/unread badge REMOVED from header (moved to tab controls)

  CRITICAL CSS RULE:
    NEVER set properties on .ncm-app root — it IS Foundry's window frame.
    All styling targets .ncm-app > .window-content and descendants.
--}}

<div class="ncm-message-viewer" data-density="{{density}}">

  {{!-- ═══════ CONDENSED HEADER BAR — Sprint 2A ═══════
       Single ~52px row: [Avatar Name/Email] | [● NET ▼ ████] | [12 TOTAL 3 UNREAD 2 SAVED] | [Compose] [⚙] [×]
  --}}
  <header class="ncm-inbox-header">

    {{!-- Identity Cluster --}}
    <div class="ncm-inbox-identity">
      {{#if viewingAsPortrait}}
        <img class="ncm-inbox-identity__portrait" src="{{viewingAsPortrait}}" alt="{{viewingAsName}}" />
      {{else}}
        <div class="ncm-inbox-identity__initials">{{viewingAsInitial}}</div>
      {{/if}}
      <div class="ncm-inbox-identity__info">
        <span class="ncm-inbox-identity__name">{{viewingAsName}}</span>
        {{#if viewingAsEmail}}
          <span class="ncm-inbox-identity__email">{{viewingAsEmail}}</span>
        {{/if}}
      </div>
    </div>

    {{!-- Divider --}}
    <div class="ncm-header-divider"></div>

    {{!-- Network Badge — compact clickable pill with full selector dropdown --}}
    <div class="ncm-inbox-network" data-action="toggleNetworkSelector">
      <span class="ncm-inbox-network__dot ncm-inbox-network__dot--{{connectionStatus}}"></span>
      <span class="ncm-inbox-network__name">{{currentNetwork.name}}</span>

      {{!-- Signal Bars (inline, 4 bars) --}}
      <div class="ncm-inbox-network__signal" title="Signal: {{signalStrength}}%">
        <div class="ncm-signal-bar-mini ncm-signal-bar-mini--1 {{#if (gte signalStrength 20)}}ncm-signal-bar-mini--active{{/if}}"></div>
        <div class="ncm-signal-bar-mini ncm-signal-bar-mini--2 {{#if (gte signalStrength 40)}}ncm-signal-bar-mini--active{{/if}}"></div>
        <div class="ncm-signal-bar-mini ncm-signal-bar-mini--3 {{#if (gte signalStrength 60)}}ncm-signal-bar-mini--active{{/if}}"></div>
        <div class="ncm-signal-bar-mini ncm-signal-bar-mini--4 {{#if (gte signalStrength 80)}}ncm-signal-bar-mini--active{{/if}}"></div>
      </div>

      <i class="fas fa-caret-down ncm-inbox-network__caret"></i>

      {{!-- WP-5: Full Network Selector Dropdown --}}
      <div class="ncm-net-selector-wrap ncm-hidden">
        {{> "modules/cyberpunkred-messenger/templates/message-viewer/partials/network-selector.hbs"}}
      </div>
    </div>

    {{!-- Divider --}}
    <div class="ncm-header-divider"></div>

    {{!-- Inline Stat Counters --}}
    <div class="ncm-header-stats">
      <div class="ncm-header-stat" data-action="set-filter" data-filter="inbox"
           data-ncm-tooltip="Show all messages">
        <span class="ncm-header-stat__value ncm-header-stat__value--total">{{counts.total}}</span>
        <span class="ncm-header-stat__label">TOTAL</span>
      </div>
      <div class="ncm-header-stat" data-action="set-filter" data-filter="unread"
           data-ncm-tooltip="Show unread messages">
        <span class="ncm-header-stat__value ncm-header-stat__value--unread">{{counts.unread}}</span>
        <span class="ncm-header-stat__label">UNREAD</span>
      </div>
      <div class="ncm-header-stat" data-action="set-filter" data-filter="saved"
           data-ncm-tooltip="Show saved messages">
        <span class="ncm-header-stat__value ncm-header-stat__value--saved">{{counts.saved}}</span>
        <span class="ncm-header-stat__label">SAVED</span>
      </div>
    </div>

    {{!-- Spacer --}}
    <div class="ncm-header-spacer"></div>

    {{!-- Header Actions --}}
    <div class="ncm-header-actions">
      <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="compose-new"
              data-ncm-tooltip="Compose new message">
        <i class="fas fa-pen-to-square"></i>
        <span>Compose</span>
      </button>
      {{#if isGM}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="open-settings"
                data-ncm-tooltip="Settings">
          <i class="fas fa-gear"></i>
        </button>
      {{/if}}
    </div>
  </header>

  {{!-- ═══════ HUD STRIP — Tightened Sprint 2A ═══════
       3px padding, 9px mono font. NET // SIG // LAT // QUEUE // ENC // ONLINE
  --}}
  <div class="ncm-hud-strip ncm-hud-strip--tight">
    <span class="ncm-hud-strip__item">
      <span class="ncm-hud-strip__label">NET</span>
      <span class="ncm-hud-strip__value ncm-hud-strip__value--network">{{currentNetwork.name}}</span>
    </span>
    <span class="ncm-hud-strip__sep">//</span>
    <span class="ncm-hud-strip__item">
      <span class="ncm-hud-strip__label">SIG</span>
      <span class="ncm-hud-strip__value">{{signalStrength}}%</span>
    </span>
    <span class="ncm-hud-strip__sep">//</span>
    <span class="ncm-hud-strip__item">
      <span class="ncm-hud-strip__label">LAT</span>
      <span class="ncm-hud-strip__value">{{latencyMs}}ms</span>
    </span>
    <span class="ncm-hud-strip__sep">//</span>
    <span class="ncm-hud-strip__item">
      <span class="ncm-hud-strip__label">QUEUE</span>
      <span class="ncm-hud-strip__value {{#if (gt queuedMessageCount 0)}}ncm-hud-strip__value--alert{{/if}}">{{queuedMessageCount}}</span>
    </span>
    <span class="ncm-hud-strip__sep">//</span>
    <span class="ncm-hud-strip__item ncm-hud-strip__item--accent">
      <span class="ncm-hud-strip__label">ENC</span>
      <span class="ncm-hud-strip__value">{{encryptionCipher}}</span>
    </span>

    {{!-- Right-aligned connection status --}}
    <span class="ncm-hud-strip__spacer"></span>
    <span class="ncm-hud-strip__status ncm-hud-strip__status--{{connectionStatus}}">
      <span class="ncm-hud-strip__status-dot"></span>
      <span class="ncm-hud-strip__status-text">
        {{#if (eq connectionStatus "CONNECTED")}}ONLINE{{/if}}
        {{#if (eq connectionStatus "DEGRADED")}}DEGRADED{{/if}}
        {{#if (eq connectionStatus "NO_SIGNAL")}}OFFLINE{{/if}}
      </span>
    </span>
  </div>

  {{!-- ═══════ TABS — Sprint 2A: Embedded Counts + Tab Controls ═══════ --}}
  <nav class="ncm-inbox-tabs">
    <div class="ncm-tabs">
      <button class="ncm-tab {{#if (eq currentFilter 'inbox')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="inbox">
        <i class="fas fa-inbox"></i>
        <span>Inbox</span>
        {{#if counts.inbox}}<span class="ncm-tab__count">{{counts.inbox}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'unread')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="unread">
        <i class="fas fa-envelope"></i>
        <span>Unread</span>
        {{#if counts.unread}}<span class="ncm-tab__count ncm-tab__count--alert">{{counts.unread}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'sent')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="sent">
        <i class="fas fa-paper-plane"></i>
        <span>Sent</span>
        {{#if counts.sent}}<span class="ncm-tab__count">{{counts.sent}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'saved')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="saved">
        <i class="fas fa-bookmark"></i>
        <span>Saved</span>
        {{#if counts.saved}}<span class="ncm-tab__count">{{counts.saved}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'spam')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="spam">
        <i class="fas fa-shield-halved"></i>
        <span>Spam</span>
        {{#if counts.spam}}<span class="ncm-tab__count ncm-tab__count--alert">{{counts.spam}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'trash')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="trash">
        <i class="fas fa-trash"></i>
        <span>Trash</span>
        {{#if counts.trash}}<span class="ncm-tab__count">{{counts.trash}}</span>{{/if}}
      </button>
    </div>

    {{!-- Tab Controls: Sort + Search (right-aligned) --}}
    <div class="ncm-tab-controls">
      {{!-- Sort --}}
      <div class="ncm-sort-control" data-action="toggle-sort-dropdown">
        <i class="fas fa-arrow-down-short-wide"></i>
        <span>{{sortLabel}}</span>
        <i class="fas fa-caret-down"></i>
        <div class="ncm-sort-dropdown ncm-hidden">
          {{#each sortOptions}}
          <div class="ncm-sort-option {{#if this.active}}ncm-sort-option--active{{/if}}"
               data-action="set-sort" data-sort="{{this.id}}">
            {{this.label}}
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Search Toggle --}}
      {{#if searchActive}}
        <div class="ncm-tab-search ncm-tab-search--expanded">
          <input type="text"
                 class="ncm-search-input"
                 placeholder="Search messages..."
                 value="{{searchTerm}}"
                 autofocus />
          <button class="ncm-tab-control" data-action="toggle-search"
                  data-ncm-tooltip="Close search (Esc)">
            <i class="fas fa-times"></i>
          </button>
        </div>
      {{else}}
        <button class="ncm-tab-control" data-action="toggle-search"
                data-ncm-tooltip="Search (/)">
          <i class="fas fa-search"></i>
        </button>
      {{/if}}
    </div>
  </nav>

  {{!-- ═══════ BULK ACTIONS (visible when items selected) ═══════ --}}
  {{#if showBulkActions}}
    <div class="ncm-bulk-bar">
      <span class="ncm-bulk-bar__count">{{bulkCount}} selected</span>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-mark-read">
        <i class="fas fa-check-double"></i> Mark Read
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-mark-spam">
        <i class="fas fa-shield-halved"></i> Spam
      </button>
      <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="bulk-delete">
        <i class="fas fa-trash"></i> Delete
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-clear">
        <i class="fas fa-times"></i> Clear
      </button>
    </div>
  {{/if}}

  {{!-- ═══════ SPLIT PANEL: List + Detail ═══════ --}}
  <div class="ncm-inbox-split-panel">

    {{!-- Left: Message List --}}
    <div class="ncm-message-list-panel ncm-scrollbar" style="width: {{sidebarWidth}}px;">
      <div class="ncm-message-list">
        {{#if messages.length}}
          {{#each messages}}
            {{> "modules/cyberpunkred-messenger/templates/message-viewer/partials/message-list-item.hbs" }}
          {{/each}}
        {{else}}
          {{> "modules/cyberpunkred-messenger/templates/partials/empty-state.hbs"
              icon="fas fa-inbox" title="NO MESSAGES"
              message="Awaiting transmissions..." }}
        {{/if}}
      </div>

      {{!-- Pagination Footer --}}
      {{#if (gt totalPages 1)}}
      <div class="ncm-inbox-pagination">
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="prev-page"
                {{#if (eq currentPage 1)}}disabled{{/if}}>
          <i class="fas fa-chevron-left"></i>
        </button>
        <span class="ncm-pagination-info">
          Page {{currentPage}} of {{totalPages}}
        </span>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="next-page"
                {{#if (eq currentPage totalPages)}}disabled{{/if}}>
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
      {{/if}}
    </div>

    {{!-- Divider --}}
    <div class="ncm-panel-divider">
      <div class="ncm-divider-grip">
        <span></span><span></span><span></span>
      </div>
    </div>

    {{!-- Right: Message Detail --}}
    <div class="ncm-message-detail-panel ncm-scrollbar">
      {{#if selectedMessage}}
        {{> "modules/cyberpunkred-messenger/templates/message-viewer/partials/message-detail.hbs"
            message=selectedMessage quickReplies=quickReplies isGM=isGM }}
      {{else}}
        {{!-- Empty Detail State --}}
        <div class="ncm-detail-empty">
          {{> "modules/cyberpunkred-messenger/templates/partials/empty-state.hbs"
              icon="fas fa-terminal"
              title="AWAITING INPUT"
              message="> SELECT MESSAGE TO READ_" }}
        </div>
      {{/if}}
    </div>
  </div>

  {{!-- ═══════ SMART FOOTER — Sprint 2A ═══════
       Left: message count + actor + network
       Right: context-aware keyboard shortcuts
  --}}
  <footer class="ncm-inbox-footer">
    <div class="ncm-footer-info">
      <span class="ncm-footer-item">
        <i class="fas fa-database"></i>
        {{totalMessages}} MESSAGE{{#if (neq totalMessages 1)}}S{{/if}}
      </span>
      <span class="ncm-footer-item">
        <i class="fas fa-user"></i>
        {{viewingAsName}}
      </span>
      <span class="ncm-footer-item">
        <i class="fas fa-network-wired"></i>
        {{currentNetwork.name}}
      </span>
    </div>
    <div class="ncm-footer-shortcuts">
      <span class="ncm-footer-item">
        <i class="fas fa-keyboard"></i>
        {{!-- Default to list-focused shortcuts. JS will swap based on focus context --}}
        <span class="ncm-shortcut-hint" data-context="list">
          / SEARCH &nbsp; ↑↓ NAV &nbsp; ENTER SELECT
        </span>
        <span class="ncm-shortcut-hint ncm-hidden" data-context="detail">
          R REPLY &nbsp; F FORWARD &nbsp; S SAVE &nbsp; DEL TRASH
        </span>
        <span class="ncm-shortcut-hint ncm-hidden" data-context="composer">
          CTRL+ENTER SEND &nbsp; ESC CANCEL
        </span>
      </span>
    </div>
  </footer>

</div>
