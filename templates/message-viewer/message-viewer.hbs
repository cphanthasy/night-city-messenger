{{!--
  Message Viewer (Inbox) — Sprint 1 + Sprint 1.5.4
  @file templates/message-viewer/message-viewer.hbs
  @module cyberpunkred-messenger
  @description Main inbox template with cyberdeck terminal aesthetic.
    Layout: HUD strip → header bar → stat cards → category tabs →
    message list | detail panel → status footer.

  Sprint 1.5.4 additions:
    - HUD strip at top (monospace system readout)
    - Stat cards row (TOTAL / UNREAD / SAVED / SPAM)
    - Network indicator badge with connection dot
    - Uses Sprint 0 design system components throughout.
--}}

<div class="ncm-message-viewer" data-density="{{density}}">

  {{!-- ═══════ HUD STRIP — Sprint 1.5.4 ═══════ --}}
  {{> "modules/cyberpunkred-messenger/templates/partials/hud-strip.hbs"
      networkName=currentNetwork.name
      signalPercent=signalStrength
      queuedCount=queuedMessageCount
      encryptionCipher=encryptionCipher
      latencyMs=latencyMs
      connectionStatus=connectionStatus }}

  {{!-- ═══════ HEADER BAR ═══════ --}}
  <header class="ncm-inbox-header">

    {{!-- Character Identity --}}
    <div class="ncm-inbox-identity">
      {{#if viewingAsPortrait}}
        <img class="ncm-inbox-identity__portrait" src="{{viewingAsPortrait}}" alt="{{viewingAsName}}" />
      {{else}}
        <div class="ncm-inbox-identity__initials">{{viewingAsInitial}}</div>
      {{/if}}
      <div class="ncm-inbox-identity__info">
        <span class="ncm-inbox-identity__name">{{viewingAsName}}</span>
        {{#if viewingAsEmail}}
          <span class="ncm-inbox-identity__email">{{viewingAsEmail}}</span>
        {{/if}}
      </div>
    </div>

    {{!-- Network Indicator Badge — Sprint 1.5.4: connection dot --}}
    <div class="ncm-inbox-network" data-action="toggle-network-dropdown">
      <span class="ncm-inbox-network__indicator ncm-inbox-network__indicator--{{connectionStatus}}"></span>
      <i class="fas fa-satellite-dish ncm-inbox-network__icon"></i>
      <span class="ncm-inbox-network__name">{{currentNetwork.name}}</span>
      {{#if currentNetwork.requiresAuth}}
        <i class="fas fa-lock ncm-inbox-network__lock" data-ncm-tooltip="Authenticated"></i>
      {{/if}}
      <i class="fas fa-caret-down ncm-inbox-network__caret"></i>

      {{!-- Signal Bar (Sprint 0 partial) --}}
      {{> "modules/cyberpunkred-messenger/templates/partials/signal-bar.hbs"
          strength=signalStrength quality=signalQuality segments=signalSegments }}

      {{!-- Network Dropdown --}}
      <div class="ncm-network-dropdown ncm-hidden">
        {{#each availableNetworks}}
        <div class="ncm-network-option {{#if this.active}}ncm-network-option--active{{/if}}"
             data-action="switch-network"
             data-network-id="{{this.id}}">
          <i class="{{this.icon}} ncm-network-option__icon"></i>
          <span class="ncm-network-option__name">{{this.name}}</span>
          {{#if this.requiresAuth}}
            <i class="fas fa-lock ncm-network-option__lock"></i>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Unread Badge --}}
    <div class="ncm-inbox-unread {{#if (gt unreadCount 0)}}ncm-inbox-unread--active{{/if}}"
         data-action="jump-to-unread"
         data-ncm-tooltip="{{unreadCount}} unread messages">
      <span class="ncm-inbox-unread__label">UNREAD</span>
      <span class="ncm-inbox-unread__count">{{unreadCount}}</span>
    </div>

    {{!-- Spacer --}}
    <div class="ncm-inbox-header__spacer"></div>

    {{!-- Search --}}
    <div class="ncm-inbox-search {{#if searchActive}}ncm-inbox-search--expanded{{/if}}">
      {{#if searchActive}}
        <input type="text"
               class="ncm-input ncm-search-input"
               placeholder="Search messages..."
               value="{{searchTerm}}"
               autofocus />
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="toggle-search"
                data-ncm-tooltip="Close search (Esc)">
          <i class="fas fa-times"></i>
        </button>
      {{else}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="toggle-search"
                data-ncm-tooltip="Search (/)">
          <i class="fas fa-search"></i>
        </button>
      {{/if}}
    </div>

    {{!-- Header Actions --}}
    <div class="ncm-inbox-header__actions">
      <button class="ncm-btn ncm-btn--primary ncm-btn--sm" data-action="compose-new"
              data-ncm-tooltip="Compose new message">
        <i class="fas fa-pen-to-square"></i>
        <span>Compose</span>
      </button>
      {{#if isGM}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="open-settings"
                data-ncm-tooltip="Settings">
          <i class="fas fa-gear"></i>
        </button>
      {{/if}}
    </div>
  </header>

  {{!-- ═══════ STAT CARDS ROW — Sprint 1.5.4 ═══════ --}}
  <div class="ncm-inbox-stats">
    <div class="ncm-stat-grid ncm-stat-grid--4">
      <div class="ncm-stat-card ncm-stat-card--clickable"
           data-action="set-filter" data-filter="inbox"
           data-ncm-tooltip="Show all messages">
        <span class="ncm-stat-card__label">TOTAL</span>
        <span class="ncm-stat-card__value">{{counts.total}}</span>
      </div>
      <div class="ncm-stat-card ncm-stat-card--primary ncm-stat-card--clickable
        {{~#if (gt counts.unread 0)}} ncm-stat-card--pulse{{/if}}"
           data-action="set-filter" data-filter="unread"
           data-ncm-tooltip="Show unread messages">
        <span class="ncm-stat-card__label">UNREAD</span>
        <span class="ncm-stat-card__value">{{counts.unread}}</span>
      </div>
      <div class="ncm-stat-card ncm-stat-card--secondary ncm-stat-card--clickable"
           data-action="set-filter" data-filter="saved"
           data-ncm-tooltip="Show saved messages">
        <span class="ncm-stat-card__label">SAVED</span>
        <span class="ncm-stat-card__value">{{counts.saved}}</span>
      </div>
      <div class="ncm-stat-card ncm-stat-card--warning ncm-stat-card--clickable"
           data-action="set-filter" data-filter="spam"
           data-ncm-tooltip="Show spam messages">
        <span class="ncm-stat-card__label">SPAM</span>
        <span class="ncm-stat-card__value">{{counts.spam}}</span>
      </div>
    </div>
  </div>

  {{!-- ═══════ CATEGORY TABS ═══════ --}}
  <nav class="ncm-inbox-tabs">
    <div class="ncm-tabs">
      <button class="ncm-tab {{#if (eq currentFilter 'inbox')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="inbox">
        <i class="fas fa-inbox"></i>
        <span>Inbox</span>
        {{#if counts.inbox}}<span class="ncm-tab__count">{{counts.inbox}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'unread')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="unread">
        <i class="fas fa-circle"></i>
        <span>Unread</span>
        {{#if counts.unread}}<span class="ncm-tab__count">{{counts.unread}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'sent')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="sent">
        <i class="fas fa-paper-plane"></i>
        <span>Sent</span>
        {{#if counts.sent}}<span class="ncm-tab__count">{{counts.sent}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'saved')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="saved">
        <i class="fas fa-bookmark"></i>
        <span>Saved</span>
        {{#if counts.saved}}<span class="ncm-tab__count">{{counts.saved}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'spam')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="spam">
        <i class="fas fa-shield-halved"></i>
        <span>Spam</span>
        {{#if counts.spam}}<span class="ncm-tab__count">{{counts.spam}}</span>{{/if}}
      </button>
      <button class="ncm-tab {{#if (eq currentFilter 'trash')}}ncm-tab--active{{/if}}"
              data-action="set-filter" data-filter="trash">
        <i class="fas fa-trash"></i>
        <span>Trash</span>
        {{#if counts.trash}}<span class="ncm-tab__count">{{counts.trash}}</span>{{/if}}
      </button>
    </div>

    {{!-- Tab Controls: Sort + Network Filter --}}
    <div class="ncm-inbox-tab-controls">
      {{!-- Network Filter --}}
      {{#if showNetworkFilter}}
        <div class="ncm-network-filter-control" data-action="toggle-network-filter">
          <i class="fas fa-tower-broadcast"></i>
          <span>{{#if networkFilter}}{{networkFilter}}{{else}}All Networks{{/if}}</span>
          <i class="fas fa-caret-down"></i>
          <div class="ncm-network-filter-dropdown ncm-hidden">
            <div class="ncm-network-filter-option {{#unless networkFilter}}ncm-network-filter-option--active{{/unless}}"
                 data-action="set-network-filter" data-network="">
              All Networks
            </div>
            {{#each messageNetworks}}
            <div class="ncm-network-filter-option {{#if (eq this ../networkFilter)}}ncm-network-filter-option--active{{/if}}"
                 data-action="set-network-filter" data-network="{{this}}">
              {{this}}
            </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{!-- Sort Control --}}
      <div class="ncm-sort-control" data-action="toggle-sort-dropdown">
        <i class="fas fa-arrow-down-short-wide"></i>
        <span>{{sortLabel}}</span>
        <i class="fas fa-caret-down"></i>
        <div class="ncm-sort-dropdown ncm-hidden">
          {{#each sortOptions}}
          <div class="ncm-sort-option {{#if this.active}}ncm-sort-option--active{{/if}}"
               data-action="set-sort" data-sort="{{this.key}}">
            {{this.label}}
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </nav>

  {{!-- ═══════ BULK ACTIONS (visible when items selected) ═══════ --}}
  {{#if showBulkActions}}
    <div class="ncm-bulk-bar">
      <span class="ncm-bulk-bar__count">{{bulkCount}} selected</span>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-mark-read">
        <i class="fas fa-check-double"></i> Mark Read
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-mark-spam">
        <i class="fas fa-shield-halved"></i> Spam
      </button>
      <button class="ncm-btn ncm-btn--danger ncm-btn--sm" data-action="bulk-delete">
        <i class="fas fa-trash"></i> Delete
      </button>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="bulk-clear">
        <i class="fas fa-times"></i> Clear
      </button>
    </div>
  {{/if}}

  {{!-- ═══════ SPLIT PANEL: List + Detail ═══════ --}}
  <div class="ncm-inbox-split-panel">

    {{!-- Left: Message List --}}
    <div class="ncm-message-list-panel ncm-scrollbar" style="width: {{sidebarWidth}}px;">
      <div class="ncm-message-list">
        {{#if messages.length}}
          {{#each messages}}
            {{> "modules/cyberpunkred-messenger/templates/message-viewer/partials/message-list-item.hbs" }}
          {{/each}}
        {{else}}
          {{> "modules/cyberpunkred-messenger/templates/partials/empty-state.hbs"
              icon="fas fa-inbox" title="NO MESSAGES"
              message="Awaiting transmissions..." }}
        {{/if}}
      </div>

      {{!-- Pagination Footer --}}
      {{#if (gt totalPages 1)}}
      <div class="ncm-inbox-pagination">
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="prev-page"
                {{#if (eq currentPage 1)}}disabled{{/if}}>
          <i class="fas fa-chevron-left"></i>
        </button>
        <span class="ncm-pagination-info">
          Page {{currentPage}} of {{totalPages}}
        </span>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="next-page"
                {{#if (eq currentPage totalPages)}}disabled{{/if}}>
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
      {{/if}}
    </div>

    {{!-- Divider --}}
    <div class="ncm-panel-divider">
      <div class="ncm-divider-grip">
        <span></span><span></span><span></span>
      </div>
    </div>

    {{!-- Right: Message Detail --}}
    <div class="ncm-message-detail-panel ncm-scrollbar">
      {{#if selectedMessage}}
        {{> "modules/cyberpunkred-messenger/templates/message-viewer/partials/message-detail.hbs"
            message=selectedMessage quickReplies=quickReplies isGM=isGM }}
      {{else}}
        {{!-- Empty Detail State --}}
        <div class="ncm-detail-empty">
          {{> "modules/cyberpunkred-messenger/templates/partials/empty-state.hbs"
              icon="fas fa-terminal"
              title="AWAITING INPUT"
              message="> SELECT MESSAGE TO READ_" }}
        </div>
      {{/if}}
    </div>
  </div>

  {{!-- ═══════ STATUS FOOTER ═══════ --}}
  <footer class="ncm-inbox-footer">
    <span class="ncm-footer-count">
      <i class="fas fa-database"></i>
      {{totalMessages}} message{{#if (neq totalMessages 1)}}s{{/if}}
    </span>
    <span class="ncm-footer-identity">
      <i class="fas fa-user"></i>
      {{viewingAsName}}
    </span>
    <span class="ncm-footer-network">
      <i class="fas fa-satellite-dish"></i>
      {{currentNetwork.name}}
    </span>
  </footer>

</div>
