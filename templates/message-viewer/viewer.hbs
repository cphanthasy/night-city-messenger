{{!-- Message Viewer Template (FIXED) --}}
{{!-- Uses canonical header structure from reset.css --}}

<div class="ncm-message-viewer__container">
  
  {{!-- CANONICAL HEADER - Used across ALL components --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-wifi"></i> {{networkName}}
      </div>
      <div class="ncm-header__title">NIGHT CITY MESSAGES</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">Welcome, {{userName}}</span>
      <span class="ncm-header__badge">{{#if encrypted}}ENCRYPTED{{else}}STANDARD{{/if}}</span>
    </div>
  </div>
  
  {{!-- Filters Bar --}}
  <div class="ncm-message-viewer__filters {{#if showFilters}}ncm-message-viewer__filters--active{{/if}}">
    <div class="ncm-message-viewer__filter-group">
      <label class="ncm-message-viewer__filter-label">Status</label>
      <select class="ncm-message-viewer__filter-select" data-filter="status">
        <option value="all">All Messages</option>
        <option value="unread">Unread</option>
        <option value="read">Read</option>
        <option value="saved">Saved</option>
        <option value="spam">Spam</option>
      </select>
    </div>
    
    <div class="ncm-message-viewer__search">
      <i class="ncm-message-viewer__search-icon fas fa-search"></i>
      <input 
        type="text" 
        class="ncm-message-viewer__search-input" 
        placeholder="Search messages..."
        value="{{searchTerm}}"
        data-action="search"
      />
    </div>
    
    <div class="ncm-message-viewer__filter-group">
      <button class="ncm-btn ncm-btn--primary" data-action="compose">
        <i class="fas fa-edit"></i> Compose
      </button>
      <button class="ncm-btn ncm-btn--secondary" data-action="refresh">
        <i class="fas fa-sync"></i> Refresh
      </button>
    </div>
  </div>
  
  {{!-- Main Content Area --}}
  <div class="ncm-message-viewer__content">
    
    {{!-- Message List Sidebar --}}
    <div class="ncm-message-viewer__sidebar">
      {{#if messages.length}}
      <div class="ncm-message-viewer__message-list">
        {{#each messages}}
        <div class="ncm-message-item {{#if this.unread}}ncm-message-item--unread{{/if}} {{#if this.selected}}ncm-message-item--selected{{/if}}" 
             data-message-id="{{this.id}}"
             data-action="select-message">
          
          <div class="ncm-message-item__header">
            <span class="ncm-message-item__sender">{{this.from}}</span>
            <span class="ncm-message-item__time">{{this.timestamp}}</span>
          </div>
          
          <div class="ncm-message-item__subject">{{this.subject}}</div>
          
          <div class="ncm-message-item__preview">{{this.preview}}</div>
          
          {{#if this.indicators}}
          <div class="ncm-message-item__indicators">
            {{#if this.encrypted}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--encrypted">
              <i class="fas fa-lock"></i> Encrypted
            </span>
            {{/if}}
            {{#if this.malware}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--malware">
              <i class="fas fa-virus"></i> Malware
            </span>
            {{/if}}
            {{#if this.saved}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--saved">
              <i class="fas fa-star"></i>
            </span>
            {{/if}}
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      
      {{!-- Pagination --}}
      {{#if totalPages}}
      <div class="ncm-message-viewer__pagination">
        <button class="ncm-pagination__btn" data-action="prev-page" {{#if (eq currentPage 1)}}disabled{{/if}}>
          <i class="fas fa-chevron-left"></i>
        </button>
        <span class="ncm-pagination__indicator">{{currentPage}} / {{totalPages}}</span>
        <button class="ncm-pagination__btn" data-action="next-page" {{#if (eq currentPage totalPages)}}disabled{{/if}}>
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
      {{/if}}
      
      {{else}}
      <div class="ncm-message-viewer__empty">
        <i class="ncm-message-viewer__empty-icon fas fa-inbox"></i>
        <p class="ncm-message-viewer__empty-text">No Messages</p>
        <p class="ncm-message-viewer__empty-subtext">Your inbox is empty</p>
      </div>
      {{/if}}
    </div>
    
    {{!-- Message Detail View --}}
    <div class="ncm-message-viewer__detail">
      {{#if selectedMessage}}
      
      {{!-- Message Header --}}
      <div class="ncm-detail__header">
        <h2 class="ncm-detail__subject">{{selectedMessage.subject}}</h2>
        
        <div class="ncm-detail__meta">
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">From:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.from}}</span>
          </div>
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">To:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.to}}</span>
          </div>
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">Date:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.timestamp}}</span>
          </div>
        </div>
      </div>
      
      {{!-- Message Body --}}
      <div class="ncm-detail__body">
        {{{selectedMessage.body}}}
      </div>
      
      {{!-- Message Footer Actions --}}
      <div class="ncm-detail__footer">
        <button class="ncm-btn ncm-btn--primary" data-action="reply">
          <i class="fas fa-reply"></i> Reply
        </button>
        <button class="ncm-btn" data-action="forward">
          <i class="fas fa-share"></i> Forward
        </button>
        <button class="ncm-btn" data-action="share-chat">
          <i class="fas fa-comment"></i> Share
        </button>
        <button class="ncm-btn" data-action="save">
          <i class="fas fa-star"></i> {{#if selectedMessage.saved}}Unsave{{else}}Save{{/if}}
        </button>
        <button class="ncm-btn ncm-btn--danger" data-action="delete">
          <i class="fas fa-trash"></i> Delete
        </button>
      </div>
      
      {{else}}
      
      {{!-- No Message Selected --}}
      <div class="ncm-message-viewer__empty">
        <i class="ncm-message-viewer__empty-icon fas fa-envelope-open"></i>
        <p class="ncm-message-viewer__empty-text">No Message Selected</p>
        <p class="ncm-message-viewer__empty-subtext">Select a message from the list</p>
      </div>
      
      {{/if}}
    </div>
  </div>
</div>