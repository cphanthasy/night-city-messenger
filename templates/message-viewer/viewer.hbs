{{!-- 
  Message Viewer Template
  File: templates/message-viewer/viewer.hbs
  Module: cyberpunkred-messenger
  Description: Main inbox viewer with message list and detail
--}}

<div class="ncm-message-viewer__container">
  
  {{!-- ============================================
       HEADER
       ============================================ --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-wifi"></i> CONNECTED to {{networkName}}
      </div>
      <div class="ncm-header__title">NIGHT CITY MESSAGES</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    
    <div class="ncm-header__bottom">
      {{!-- Character Selector (GM or multi-character players) --}}
      {{#if showCharacterSelector}}
        <div class="ncm-header__character-selector">
          <label for="character-select">Viewing:</label>
          <select id="character-select" class="ncm-header__select" data-action="select-character">
            <option value="">-- Select Character --</option>
            {{#each availableActors}}
            <option value="{{this.id}}" {{#if (eq this.id ../selectedActorId)}}selected{{/if}}>
              {{this.name}}
            </option>
            {{/each}}
          </select>
          
          {{#if selectedActor}}
          <span class="ncm-header__email">
            {{#if selectedActor.flags.cyberpunkred-messenger.emailAddress}}
              {{selectedActor.flags.cyberpunkred-messenger.emailAddress}}
            {{else}}
              <span class="ncm-header__email--warning">No email set</span>
            {{/if}}
          </span>
          {{/if}}
        </div>
      {{else}}
        {{!-- Simple welcome for single-character players --}}
        <span class="ncm-header__welcome">Welcome, {{userName}}</span>
        
        {{#if selectedActor}}
        <span class="ncm-header__email">
          {{#if selectedActor.flags.cyberpunkred-messenger.emailAddress}}
            {{selectedActor.flags.cyberpunkred-messenger.emailAddress}}
          {{else}}
            <button class="ncm-btn ncm-btn--small ncm-btn--warning" data-action="setup-email">
              <i class="fas fa-exclamation-triangle"></i> Set Email
            </button>
          {{/if}}
        </span>
        {{/if}}
      {{/if}}
      
      {{!-- GM Tools --}}
      {{#if isGM}}
      <button class="ncm-btn ncm-btn--small ncm-btn--gm" data-action="open-admin" title="GM Tools">
        <i class="fas fa-toolbox"></i> GM Tools
      </button>
      {{/if}}
    </div>
  </div>
  
  {{!-- ============================================
       TOOLBAR
       ============================================ --}}
  <div class="ncm-message-viewer__toolbar">
    {{!-- Category Filter Buttons --}}
    <div class="ncm-toolbar__categories">
      {{!-- Inbox --}}
      <button class="ncm-toolbar__category {{#if (eq currentFilter 'inbox')}}ncm-toolbar__category--active{{/if}}" 
              data-action="filter" data-filter="inbox">
        <i class="fas fa-inbox"></i> Inbox
        {{#if filters.unread}}<span class="ncm-toolbar__badge">{{filters.unread}}</span>{{/if}}
      </button>
      
      {{!-- Saved --}}
      <button class="ncm-toolbar__category {{#if (eq currentFilter 'saved')}}ncm-toolbar__category--active{{/if}}" 
              data-action="filter" data-filter="saved">
        <i class="fas fa-star"></i> Saved
        {{#if filters.saved}}<span class="ncm-toolbar__badge">{{filters.saved}}</span>{{/if}}
      </button>
      
      {{!-- Spam --}}
      <button class="ncm-toolbar__category {{#if (eq currentFilter 'spam')}}ncm-toolbar__category--active{{/if}}" 
              data-action="filter" data-filter="spam">
        <i class="fas fa-exclamation-triangle"></i> Spam
        {{#if filters.spam}}<span class="ncm-toolbar__badge">{{filters.spam}}</span>{{/if}}
      </button>
      
      {{!-- Sent --}}
      <button class="ncm-toolbar__category {{#if (eq currentFilter 'sent')}}ncm-toolbar__category--active{{/if}}" 
              data-action="filter" data-filter="sent">
        <i class="fas fa-paper-plane"></i> Sent
      </button>
      
      {{!-- Scheduled --}}
      <button class="ncm-toolbar__category {{#if (eq currentFilter 'scheduled')}}ncm-toolbar__category--active{{/if}}" 
              data-action="filter" data-filter="scheduled">
        <i class="fas fa-calendar-alt"></i> Scheduled
        {{#if filters.scheduled}}<span class="ncm-toolbar__badge">{{filters.scheduled}}</span>{{/if}}
      </button>
    </div>
    
    {{!-- Search and Action Buttons --}}
    <div class="ncm-toolbar__actions">
      <div class="ncm-toolbar__search">
        <i class="ncm-toolbar__search-icon fas fa-search"></i>
        <input type="text" 
               class="ncm-toolbar__search-input" 
               placeholder="Search messages..."
               value="{{searchTerm}}"
               data-action="search"
               autocomplete="off" />
      </div>
      
      <button class="ncm-btn ncm-btn--icon" 
              data-action="toggle-filters" 
              title="Advanced Filters"
              {{#if showAdvancedFilters}}aria-pressed="true"{{/if}}>
        <i class="fas fa-filter"></i>
        {{#if hasActiveFilters}}<span class="ncm-btn__indicator"></span>{{/if}}
      </button>
      
      <button class="ncm-btn ncm-btn--icon" data-action="refresh" title="Refresh">
        <i class="fas fa-sync"></i>
      </button>
      
      <button class="ncm-btn ncm-btn--icon" data-action="open-contacts" title="Contacts">
        <i class="fas fa-address-book"></i>
      </button>
      
      <button class="ncm-btn ncm-btn--icon" data-action="open-settings" title="Settings">
        <i class="fas fa-cog"></i>
      </button>
      
      <button class="ncm-btn ncm-btn--primary" data-action="compose">
        <i class="fas fa-pen"></i> Compose
      </button>
    </div>
  </div>
  
  {{!-- ============================================
       ADVANCED FILTERS PANEL (toggleable)
       ============================================ --}}
  {{#if showAdvancedFilters}}
  <div class="ncm-filters-panel">
    <div class="ncm-filters-panel__section">
      <h4 class="ncm-filters-panel__title">
        <i class="fas fa-user"></i> Filter by Sender
      </h4>
      <select class="ncm-filters-panel__select" data-filter-field="sender">
        <option value="">-- All Senders --</option>
        {{#each uniqueSenders}}
        <option value="{{this}}" {{#if (eq ../advancedFilters.sender this)}}selected{{/if}}>
          {{this}}
        </option>
        {{/each}}
      </select>
    </div>
    
    <div class="ncm-filters-panel__section">
      <h4 class="ncm-filters-panel__title">
        <i class="fas fa-calendar-alt"></i> Filter by Date
      </h4>
      <div class="ncm-filters-panel__date-range">
        <label>
          From:
          <input type="date" 
                 class="ncm-filters-panel__input" 
                 data-filter-field="dateFrom"
                 value="{{advancedFilters.dateFrom}}" />
        </label>
        <label>
          To:
          <input type="date" 
                 class="ncm-filters-panel__input" 
                 data-filter-field="dateTo"
                 value="{{advancedFilters.dateTo}}" />
        </label>
      </div>
    </div>
    
    <div class="ncm-filters-panel__section">
      <h4 class="ncm-filters-panel__title">
        <i class="fas fa-envelope"></i> Message Status
      </h4>
      <label class="ncm-filters-panel__checkbox">
        <input type="checkbox" 
               data-filter-field="unreadOnly"
               {{#if advancedFilters.unreadOnly}}checked{{/if}} />
        Unread Only
      </label>
    </div>
    
    <div class="ncm-filters-panel__actions">
      <button class="ncm-btn ncm-btn--primary" data-action="apply-filters">
        <i class="fas fa-check"></i> Apply Filters
      </button>
      <button class="ncm-btn" data-action="reset-filters">
        <i class="fas fa-undo"></i> Reset
      </button>
    </div>
  </div>
  {{/if}}
  
  {{!-- ============================================
       MAIN CONTENT (Sidebar + Detail)
       ============================================ --}}
  <div class="ncm-message-viewer__content">
    
    {{!-- ============================================
         SIDEBAR - Message List
         ============================================ --}}
    <div class="ncm-message-viewer__sidebar">
      {{#if messages.length}}
      <div class="ncm-message-viewer__message-list">
        {{#each messages}}
        <div class="ncm-message-item 
                    {{#if this.status.read}}ncm-message-item--read{{else}}ncm-message-item--unread{{/if}} 
                    {{#if this.selected}}ncm-message-item--selected{{/if}}" 
             data-message-id="{{this.id}}"
             data-action="select-message">
          
          {{!-- Header: Sender + Timestamp --}}
          <div class="ncm-message-item__header">
            <div class="ncm-message-item__sender-with-icon">
              {{!-- Status Icons --}}
              {{#if this.status.sent}}
                <i class="fas fa-paper-plane ncm-message-item__type-icon ncm-message-item__type-icon--sent" 
                   title="Sent by you"></i>
              {{/if}}
              
              {{#if this.metadata.messageType}}
                {{#if (eq this.metadata.messageType "reply")}}
                  <i class="fas fa-reply ncm-message-item__type-icon ncm-message-item__type-icon--reply" 
                     title="Reply"></i>
                {{else if (eq this.metadata.messageType "forward")}}
                  <i class="fas fa-share ncm-message-item__type-icon ncm-message-item__type-icon--forward" 
                     title="Forwarded"></i>
                {{else if (eq this.metadata.messageType "scheduled")}}
                  <i class="fas fa-clock ncm-message-item__type-icon ncm-message-item__type-icon--scheduled" 
                     title="Scheduled delivery"></i>
                {{/if}}
              {{/if}}
              
              {{#if this.status.scheduled}}
                <i class="fas fa-hourglass-half ncm-message-item__type-icon ncm-message-item__type-icon--pending" 
                   title="Pending delivery"></i>
              {{/if}}
              
              <span class="ncm-message-item__sender">{{this.from}}</span>
            </div>
            
            <div class="ncm-message-item__timestamp">
              <span class="ncm-message-item__datetime" title="{{this.fullTimestamp}}">
                {{this.formattedTimestamp}}
              </span>
              
              {{!-- Badges --}}
              {{#if this.scDisplay}}
              <span class="ncm-message-item__badge ncm-message-item__badge--sc" 
                    title="In-game time: {{this.scDisplay}}">
                <i class="fas fa-calendar-alt"></i>
              </span>
              {{/if}}
              
              {{#if this.wasScheduled}}
              <span class="ncm-message-item__badge ncm-message-item__badge--scheduled" 
                    title="This message was scheduled">
                <i class="fas fa-clock"></i>
              </span>
              {{/if}}
            </div>
          </div>
          
          {{!-- Subject --}}
          <div class="ncm-message-item__subject">
            {{#unless this.status.read}}
            <span class="ncm-message-item__unread-dot"></span>
            {{/unless}}
            {{this.subject}}
          </div>
          
          {{!-- Preview --}}
          <div class="ncm-message-item__preview">{{this.preview}}</div>
          
          {{!-- Footer: Relative Time --}}
          <div class="ncm-message-item__footer">
            <div class="ncm-message-item__spacer"></div>
            <span class="ncm-message-item__relative">{{this.relativeTime}}</span>
          </div>
          
          {{!-- Indicators (encryption, malware, etc.) --}}
          {{#if this.status}}
          <div class="ncm-message-item__indicators">
            {{#if this.status.encrypted}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--encrypted" title="Encrypted">
              <i class="fas fa-lock"></i>
            </span>
            {{/if}}
            {{#if this.status.infected}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--malware" title="Malware">
              <i class="fas fa-virus"></i>
            </span>
            {{/if}}
            {{#if this.status.saved}}
            <span class="ncm-message-item__indicator ncm-message-item__indicator--saved" title="Saved">
              <i class="fas fa-star"></i>
            </span>
            {{/if}}
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      
      {{!-- Pagination --}}
      {{#if totalPages}}
      <div class="ncm-message-viewer__pagination">
        <button class="ncm-pagination__btn" 
                data-action="prev-page" 
                {{#if (eq currentPage 1)}}disabled{{/if}}>
          <i class="fas fa-chevron-left"></i>
        </button>
        <span class="ncm-pagination__indicator">Page {{currentPage}} of {{totalPages}}</span>
        <button class="ncm-pagination__btn" 
                data-action="next-page" 
                {{#if (eq currentPage totalPages)}}disabled{{/if}}>
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
      {{/if}}
      
      {{else}}
      {{!-- Empty Sidebar --}}
      <div class="ncm-message-viewer__empty">
        <i class="ncm-message-viewer__empty-icon fas fa-inbox"></i>
        <p class="ncm-message-viewer__empty-text">
          {{#if (eq currentFilter "inbox")}}Your inbox is empty{{/if}}
          {{#if (eq currentFilter "saved")}}No saved messages{{/if}}
          {{#if (eq currentFilter "spam")}}No spam messages{{/if}}
          {{#if (eq currentFilter "sent")}}No sent messages{{/if}}
          {{#if (eq currentFilter "scheduled")}}No scheduled messages{{/if}}
        </p>
        {{#if searchTerm}}
        <p class="ncm-message-viewer__empty-subtext">
          No messages match: "{{searchTerm}}"
        </p>
        {{/if}}
      </div>
      {{/if}}
    </div>
    
    {{!-- ============================================
         DETAIL VIEW - Message Content
         ============================================ --}}
    <div class="ncm-message-viewer__detail">
      {{#if selectedMessage}}
      
      {{!-- Message Header --}}
      <div class="ncm-detail__header">
        <h2 class="ncm-detail__subject">{{selectedMessage.subject}}</h2>
        
        <div class="ncm-detail__meta">
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">From:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.from}}</span>
            <button class="ncm-btn ncm-btn--small ncm-btn--ghost" 
                    data-action="add-sender-to-contacts"
                    title="Add to Contacts">
              <i class="fas fa-user-plus"></i>
            </button>
          </div>
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">To:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.to}}</span>
          </div>
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">Date:</span>
            <span class="ncm-detail__meta-value">{{formatDateTime selectedMessage.timestamp}}</span>
          </div>
          {{#if selectedMessage.network}}
          <div class="ncm-detail__meta-row">
            <span class="ncm-detail__meta-label">Network:</span>
            <span class="ncm-detail__meta-value">{{selectedMessage.network}}</span>
          </div>
          {{/if}}
        </div>
      </div>
      
      {{!-- Message Body --}}
      <div class="ncm-detail__body">
        {{{selectedMessage.body}}}
      </div>
      
      {{!-- Message Footer / Actions --}}
      <div class="ncm-detail__footer">
        {{#if selectedMessage.metadata.scheduleId}}
          {{!-- SCHEDULED MESSAGE ACTIONS --}}
          <div class="ncm-message-detail__scheduled-section">
            <hr style="margin: 15px 0; border-color: var(--ncm-primary); opacity: 0.3;">
            <div class="ncm-message-detail__scheduled-info">
              <span class="ncm-message-detail__scheduled-label">
                <i class="fas fa-clock"></i>
                <strong>Scheduled for:</strong> {{selectedMessage.formattedTimestamp}}
              </span>
              <div class="ncm-message-detail__scheduled-actions">
                <button class="ncm-btn ncm-btn--secondary" 
                        data-action="reschedule-message"
                        title="Change scheduled time">
                  <i class="fas fa-calendar-alt"></i> Reschedule
                </button>
                <button class="ncm-btn ncm-btn--danger" 
                        data-action="cancel-schedule"
                        title="Cancel this scheduled message">
                  <i class="fas fa-ban"></i> Cancel Schedule
                </button>
              </div>
            </div>
          </div>
        {{else}}
          {{!-- NORMAL MESSAGE ACTIONS --}}
          <button class="ncm-btn ncm-btn--primary" data-action="reply">
            <i class="fas fa-reply"></i> Reply
          </button>
          <button class="ncm-btn" data-action="forward">
            <i class="fas fa-share"></i> Forward
          </button>
          <button class="ncm-btn" data-action="share-to-chat">
            <i class="fas fa-comment"></i> Share to Chat
          </button>
          <button class="ncm-btn" data-action="save-message">
            <i class="fas fa-star"></i> {{#if selectedMessage.status.saved}}Unsave{{else}}Save{{/if}}
          </button>
          <button class="ncm-btn" data-action="mark-spam">
            <i class="fas fa-exclamation-triangle"></i> {{#if selectedMessage.status.spam}}Not Spam{{else}}Spam{{/if}}
          </button>
          <button class="ncm-btn ncm-btn--danger" data-action="delete-message">
            <i class="fas fa-trash"></i> Delete
          </button>
        {{/if}}
      </div>
      
      {{else}}
      
      {{!-- No Message Selected --}}
      <div class="ncm-message-viewer__empty ncm-message-viewer__empty--large">
        <i class="ncm-message-viewer__empty-icon fas fa-envelope-open fa-4x"></i>
        <p class="ncm-message-viewer__empty-text">No Message Selected</p>
        <p class="ncm-message-viewer__empty-subtext">
          Select a message from the list to view its contents
        </p>
        <div class="ncm-message-viewer__empty-action">
          <p>or</p>
          <button class="ncm-btn ncm-btn--primary ncm-btn--large" data-action="compose">
            <i class="fas fa-pen"></i> Compose New Message
          </button>
        </div>
      </div>
      
      {{/if}}
    </div>
  </div>
</div>