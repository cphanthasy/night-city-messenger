{{!-- User Settings Panel Template --}}
{{!-- File: templates/settings/user-settings.hbs --}}

<div class="ncm-settings__container">
  
  {{!-- CANONICAL HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-cog"></i> Settings
      </div>
      <div class="ncm-header__title">MESSENGER SETTINGS</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">{{characterName}}</span>
    </div>
  </div>
  
  {{!-- Tabs Navigation --}}
  <nav class="ncm-settings__tabs tabs" data-group="primary">
    {{#each tabs}}
    <a class="ncm-settings__tab item" data-tab="{{this.id}}">
      <i class="fas {{this.icon}}"></i>
      <span>{{this.label}}</span>
    </a>
    {{/each}}
  </nav>
  
  {{!-- Form --}}
  <form class="ncm-settings__form">
    
    {{!-- General Tab --}}
    <div class="ncm-settings__content tab" data-tab="general" data-group="primary">
      
      {{!-- Email Section --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-envelope"></i> Email Address
        </h3>
        
        {{#if hasCharacter}}
        <div class="ncm-settings__email-display">
          <div class="ncm-settings__email-value">
            {{#if email}}
              <i class="fas fa-check-circle" style="color: #4ade80;"></i>
              {{email}}
            {{else}}
              <i class="fas fa-exclamation-circle" style="color: #f59e0b;"></i>
              Not set
            {{/if}}
          </div>
          <button type="button" class="ncm-btn ncm-btn--primary" data-action="change-email">
            <i class="fas fa-edit"></i> Change Email
          </button>
        </div>
        {{else}}
        <div class="ncm-settings__warning">
          <i class="fas fa-exclamation-triangle"></i>
          You must have a character assigned to use messaging.
        </div>
        {{/if}}
      </section>
      
      {{!-- Display Preferences --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-desktop"></i> Display
        </h3>
        
        <div class="ncm-settings__field">
          <label>Messages Per Page</label>
          <input type="number" name="messagesPerPage" value="{{settings.messagesPerPage}}" min="10" max="100" step="5" />
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="autoRefresh" {{#if settings.autoRefresh}}checked{{/if}} />
            Auto-refresh inbox
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>Refresh Interval (seconds)</label>
          <input type="number" name="refreshInterval" value="{{settings.refreshInterval}}" min="10" max="300" step="10" />
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="autoMarkRead" {{#if settings.autoMarkRead}}checked{{/if}} />
            Auto-mark messages as read when opened
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="confirmDelete" {{#if settings.confirmDelete}}checked{{/if}} />
            Confirm before deleting messages
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="showNetworkStatus" {{#if settings.showNetworkStatus}}checked{{/if}} />
            Show network status indicator
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="showTimestamps" {{#if settings.showTimestamps}}checked{{/if}} />
            Show message timestamps
          </label>
        </div>
      </section>
    </div>
    
    {{!-- Appearance Tab --}}
    <div class="ncm-settings__content tab" data-tab="appearance" data-group="primary">
      
      {{!-- Theme Presets --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-palette"></i> Theme Presets
        </h3>
        
        <div class="ncm-settings__theme-grid">
          <button type="button" class="ncm-settings__theme-card" data-action="apply-theme" data-theme="cyberpunk-red">
            <div class="ncm-settings__theme-preview" style="background: linear-gradient(135deg, #F65261, #19f3f7);"></div>
            <span>Cyberpunk Red</span>
          </button>
          
          <button type="button" class="ncm-settings__theme-card" data-action="apply-theme" data-theme="neon-blue">
            <div class="ncm-settings__theme-preview" style="background: linear-gradient(135deg, #00d4ff, #ff006e);"></div>
            <span>Neon Blue</span>
          </button>
          
          <button type="button" class="ncm-settings__theme-card" data-action="apply-theme" data-theme="corpo-gold">
            <div class="ncm-settings__theme-preview" style="background: linear-gradient(135deg, #ffd700, #4a90e2);"></div>
            <span>Corpo Gold</span>
          </button>
          
          <button type="button" class="ncm-settings__theme-card" data-action="apply-theme" data-theme="dark-minimal">
            <div class="ncm-settings__theme-preview" style="background: linear-gradient(135deg, #ffffff, #888888);"></div>
            <span>Dark Minimal</span>
          </button>
          
          <button type="button" class="ncm-settings__theme-card" data-action="apply-theme" data-theme="nomad-green">
            <div class="ncm-settings__theme-preview" style="background: linear-gradient(135deg, #00ff41, #ff9800);"></div>
            <span>Nomad Green</span>
          </button>
        </div>
      </section>
      
      {{!-- Custom Colors --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-eyedropper"></i> Custom Colors
        </h3>
        
        <div class="ncm-settings__color-grid">
          <div class="ncm-settings__color-field">
            <label>Primary Color</label>
            <input type="color" name="primaryColor" value="{{settings.primaryColor}}" />
          </div>
          
          <div class="ncm-settings__color-field">
            <label>Secondary Color</label>
            <input type="color" name="secondaryColor" value="{{settings.secondaryColor}}" />
          </div>
          
          <div class="ncm-settings__color-field">
            <label>Background Color</label>
            <input type="color" name="backgroundColor" value="{{settings.backgroundColor}}" />
          </div>
        </div>
      </section>
      
      {{!-- Typography --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-font"></i> Typography
        </h3>
        
        <div class="ncm-settings__field">
          <label>Font Family</label>
          <select name="fontFamily">
            <option value="Rajdhani" {{#if (eq settings.fontFamily "Rajdhani")}}selected{{/if}}>Rajdhani</option>
            <option value="Orbitron" {{#if (eq settings.fontFamily "Orbitron")}}selected{{/if}}>Orbitron</option>
            <option value="Courier New" {{#if (eq settings.fontFamily "Courier New")}}selected{{/if}}>Courier New</option>
            <option value="system-ui" {{#if (eq settings.fontFamily "system-ui")}}selected{{/if}}>System</option>
          </select>
        </div>
        
        <div class="ncm-settings__field">
          <label>Font Size</label>
          <select name="fontSize">
            <option value="small" {{#if (eq settings.fontSize "small")}}selected{{/if}}>Small</option>
            <option value="medium" {{#if (eq settings.fontSize "medium")}}selected{{/if}}>Medium</option>
            <option value="large" {{#if (eq settings.fontSize "large")}}selected{{/if}}>Large</option>
          </select>
        </div>
      </section>
      
      {{!-- Visual Effects --}}
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-sparkles"></i> Visual Effects
        </h3>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="showAnimations" {{#if settings.showAnimations}}checked{{/if}} />
            Enable animations
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="compactMode" {{#if settings.compactMode}}checked{{/if}} />
            Compact mode
          </label>
        </div>
      </section>
      
      {{!-- Theme Actions --}}
      <div class="ncm-settings__actions">
        <button type="button" class="ncm-btn" data-action="preview-theme">
          <i class="fas fa-eye"></i> Preview
        </button>
        <button type="button" class="ncm-btn" data-action="reset-theme">
          <i class="fas fa-undo"></i> Reset to Defaults
        </button>
      </div>
    </div>
    
    {{!-- Notifications Tab --}}
    <div class="ncm-settings__content tab" data-tab="notifications" data-group="primary">
      
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-bell"></i> Notifications
        </h3>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="notifyOnNewMessage" {{#if settings.notifyOnNewMessage}}checked{{/if}} />
            Notify on new messages
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="notifyOnScheduledSend" {{#if settings.notifyOnScheduledSend}}checked{{/if}} />
            Notify when scheduled messages send
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="desktopNotifications" {{#if settings.desktopNotifications}}checked{{/if}} />
            Enable desktop notifications
          </label>
          <small>Requires browser permission</small>
        </div>
      </section>
      
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-volume-up"></i> Sounds
        </h3>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="soundEnabled" {{#if settings.soundEnabled}}checked{{/if}} />
            Enable sound effects
          </label>
        </div>
        
        <div class="ncm-settings__field">
          <label>Sound Volume</label>
          <input type="range" name="soundVolume" value="{{settings.soundVolume}}" min="0" max="100" step="5" />
          <span class="ncm-settings__value">{{settings.soundVolume}}%</span>
        </div>
        
        <button type="button" class="ncm-btn" data-action="test-sound">
          <i class="fas fa-play"></i> Test Sound
        </button>
        <button type="button" class="ncm-btn" data-action="test-notification">
          <i class="fas fa-bell"></i> Test Notification
        </button>
      </section>
    </div>
    
    {{!-- Advanced Tab --}}
    <div class="ncm-settings__content tab" data-tab="advanced" data-group="primary">
      
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-database"></i> Data Management
        </h3>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="cacheMessages" {{#if settings.cacheMessages}}checked{{/if}} />
            Cache messages for faster loading
          </label>
        </div>
        
        <button type="button" class="ncm-btn ncm-btn--danger" data-action="clear-cache">
          <i class="fas fa-trash"></i> Clear Cache
        </button>
      </section>
      
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-bug"></i> Debug
        </h3>
        
        <div class="ncm-settings__field">
          <label>
            <input type="checkbox" name="debugMode" {{#if settings.debugMode}}checked{{/if}} />
            Enable debug mode
          </label>
          <small>Shows additional console logging</small>
        </div>
      </section>
      
      <section class="ncm-settings__section">
        <h3 class="ncm-settings__section-title">
          <i class="fas fa-info-circle"></i> Module Info
        </h3>
        
        <div class="ncm-settings__info">
          <p><strong>Version:</strong> 1.0.0</p>
          <p><strong>System:</strong> Cyberpunk RED</p>
          <p><strong>Foundry:</strong> v11+</p>
        </div>
      </section>
    </div>
    
  </form>
  
  {{!-- Footer Actions --}}
  <div class="ncm-settings__footer">
    <button type="button" class="ncm-btn ncm-btn--primary" data-action="save-settings">
      <i class="fas fa-save"></i> Save Settings
    </button>
  </div>
  
</div>