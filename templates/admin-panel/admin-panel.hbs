{{!-- Admin Panel — GM Dashboard (Sprint 4: 6-Tab Rewrite) --}}
{{!-- @file templates/admin-panel/admin-panel.hbs --}}
{{!-- @module cyberpunkred-messenger --}}
{{!-- Tabs: Overview | Messages | Contacts | Networks | Data Shards | Tools --}}

{{#if isGM}}
<div class="ncm-admin-panel">

  {{!-- ═══ CONDENSED HEADER ═══ --}}
  <div class="ncm-admin-header">
    <div class="ncm-admin-header__identity">
      <div class="ncm-admin-header__icon-ring"><i class="fas fa-shield-halved"></i></div>
      <div class="ncm-admin-header__label">
        <span class="ncm-admin-header__title">GM Dashboard</span>
        <span class="ncm-admin-header__subtitle">ADMIN CLEARANCE // FULL ACCESS</span>
      </div>
    </div>
    <div class="ncm-admin-header__sep"></div>
    <div class="ncm-admin-header__stats">
      <div class="ncm-admin-header__stat">
        <span class="ncm-admin-header__stat-value ncm-admin-header__stat-value--cyan">{{stats.totalMessages}}</span>
        <span class="ncm-admin-header__stat-label">Messages</span>
      </div>
      <div class="ncm-admin-header__stat">
        <span class="ncm-admin-header__stat-value ncm-admin-header__stat-value--red">{{stats.unreadMessages}}</span>
        <span class="ncm-admin-header__stat-label">Unread</span>
      </div>
      <div class="ncm-admin-header__stat">
        <span class="ncm-admin-header__stat-value ncm-admin-header__stat-value--gold">{{scheduledCount}}</span>
        <span class="ncm-admin-header__stat-label">Scheduled</span>
      </div>
      <div class="ncm-admin-header__stat">
        <span class="ncm-admin-header__stat-value ncm-admin-header__stat-value--green">{{onlineCount}}</span>
        <span class="ncm-admin-header__stat-label">Online</span>
      </div>
    </div>
    <div class="ncm-admin-header__network">
      <div class="ncm-admin-header__network-dot"></div>
      <span class="ncm-admin-header__network-name">{{currentNetwork}}</span>
    </div>
  </div>

  {{!-- ═══ HUD STRIP ═══ --}}
  <div class="ncm-hud-strip">
    <div class="ncm-hud-strip__item">ACTORS <span>{{hudCounts.actors}}</span></div>
    <div class="ncm-hud-strip__item">CONTACTS <span>{{hudCounts.contacts}}</span></div>
    <div class="ncm-hud-strip__item">NETWORKS <span>{{hudCounts.networks}}</span></div>
    <div class="ncm-hud-strip__item ncm-hud-strip__item--gold">SHARDS <span>{{hudCounts.shards}}</span></div>
    <div class="ncm-hud-strip__online">
      <div class="ncm-hud-strip__online-dot"></div> SYSTEM NOMINAL
    </div>
  </div>

  {{!-- ═══ TAB NAVIGATION — 6 Tabs ═══ --}}
  <nav class="ncm-admin-tabs">
    <button class="ncm-admin-tab {{#if (eq activeTab 'overview')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="overview">
      <i class="fas fa-chart-bar"></i> Overview
    </button>
    <button class="ncm-admin-tab {{#if (eq activeTab 'messages')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="messages">
      <i class="fas fa-envelope"></i> Messages
      {{#if stats.unreadMessages}}<span class="ncm-admin-tab__count">{{stats.unreadMessages}}</span>{{/if}}
    </button>
    <button class="ncm-admin-tab {{#if (eq activeTab 'contacts')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="contacts">
      <i class="fas fa-address-book"></i> Contacts
    </button>
    <button class="ncm-admin-tab {{#if (eq activeTab 'networks')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="networks">
      <i class="fas fa-network-wired"></i> Networks
    </button>
    <button class="ncm-admin-tab {{#if (eq activeTab 'shards')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="shards">
      <i class="fas fa-database"></i> Shards
    </button>
    <button class="ncm-admin-tab {{#if (eq activeTab 'tools')}}ncm-admin-tab--active{{/if}}"
            data-action="switchTab" data-tab="tools">
      <i class="fas fa-wrench"></i> Tools
    </button>
  </nav>

  {{!-- ═══ TAB CONTENT ═══ --}}
  <div class="ncm-admin-content">

    {{!-- ──────────────────────────────────────────
         TAB 1: OVERVIEW
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'overview')}}

    {{!-- Actor Inbox Cards --}}
    <div class="ncm-section-title">
      <i class="fas fa-inbox"></i> Actor Inboxes
      <button class="ncm-section-title__action" data-action="openAllInboxes">Open All →</button>
    </div>
    {{#if stats.actorStats.length}}
    <div class="ncm-actor-grid">
      {{#each stats.actorStats}}
      <div class="ncm-actor-card {{#if this.hasPlayerOwner}}ncm-actor-card--player{{else}}ncm-actor-card--npc{{/if}} {{#if this.unreadMessages}}ncm-actor-card--alert{{/if}}"
           data-actor-id="{{this.actorId}}">
        <div class="ncm-actor-card__avatar" style="color: {{this.avatarColor}}; border-color: {{this.avatarBorderColor}};">
          {{#if this.actorImg}}
          <img src="{{this.actorImg}}" alt="{{this.actorName}}">
          {{else}}
          {{this.initial}}
          {{/if}}
        </div>
        <div class="ncm-actor-card__info">
          <div class="ncm-actor-card__name">{{this.actorName}}</div>
          <div class="ncm-actor-card__meta">
            {{#if this.ownerName}}<span><i class="fas fa-user"></i> {{this.ownerName}}</span>{{/if}}
            <span><i class="fas fa-wifi"></i> {{../currentNetwork}}</span>
          </div>
        </div>
        <div class="ncm-actor-card__stats">
          <div class="ncm-actor-card__msg-count">{{this.totalMessages}}</div>
          {{#if this.unreadMessages}}
          <div class="ncm-actor-card__unread">{{this.unreadMessages}} unread</div>
          {{else}}
          <div class="ncm-actor-card__last-active">{{this.lastActive}}</div>
          {{/if}}
        </div>
        <div class="ncm-actor-card__actions">
          <button class="ncm-actor-card__action" data-action="openInbox" data-actor-id="{{this.actorId}}" title="Open Inbox">
            <i class="fas fa-envelope"></i>
          </button>
          <button class="ncm-actor-card__action ncm-actor-card__action--contacts" data-action="viewPlayerContacts" data-actor-id="{{this.actorId}}" title="View Contacts">
            <i class="fas fa-address-book"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-inbox"></i> No actors with messages yet.</div>
    {{/if}}

    {{!-- Active Connections --}}
    <div class="ncm-section-title"><i class="fas fa-signal"></i> Active Connections</div>
    <div class="ncm-connection-list">
      {{#each connections}}
      <div class="ncm-connection-row">
        <div class="ncm-connection-row__dot {{#if this.isGM}}ncm-connection-row__dot--gm{{else}}ncm-connection-row__dot--online{{/if}}"></div>
        <span class="ncm-connection-row__name">{{this.userName}}</span>
        <span class="ncm-connection-row__role {{#if this.isGM}}ncm-connection-row__role--gm{{else}}ncm-connection-row__role--player{{/if}}">{{#if this.isGM}}GM{{else}}Player{{/if}}</span>
        <span class="ncm-connection-row__actor">{{this.actorNames}}</span>
        {{#unless this.isGM}}<span class="ncm-connection-row__network">{{../currentNetwork}}</span>{{/unless}}
        <span class="ncm-connection-row__session">{{this.sessionTime}}</span>
      </div>
      {{/each}}
    </div>

    {{/if}}

    {{!-- ──────────────────────────────────────────
         TAB 2: MESSAGES
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'messages')}}

    {{!-- NPC Quick-Send --}}
    <div class="ncm-section-title">
      <i class="fas fa-paper-plane"></i> Send As NPC
      <button class="ncm-section-title__action" data-action="openComposer"><i class="fas fa-plus"></i> Compose →</button>
    </div>
    {{#if npcActors.length}}
    <div class="ncm-quicksend-grid">
      {{#each npcActors}}
      <div class="ncm-quicksend-card" data-action="quickSend" data-actor-id="{{this.id}}">
        <div class="ncm-quicksend-card__avatar" style="color: {{this.color}};">{{this.initial}}</div>
        <div class="ncm-quicksend-card__info">
          <div class="ncm-quicksend-card__name">{{this.name}}</div>
          <div class="ncm-quicksend-card__last">{{#if this.lastMessage}}{{this.lastMessage}}{{else}}No messages sent{{/if}}</div>
        </div>
        <div class="ncm-quicksend-card__send"><i class="fas fa-paper-plane"></i></div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-user-slash"></i> No NPC actors configured.</div>
    {{/if}}

    {{!-- Scheduled Deliveries --}}
    <div class="ncm-section-title">
      <i class="fas fa-clock"></i> Scheduled Deliveries
      {{#if scheduledCount}}<span class="ncm-admin-tab__count" style="margin-left: 4px;">{{scheduledCount}}</span>{{/if}}
    </div>
    {{#if scheduledEntries.length}}
    <div class="ncm-scheduled-list">
      {{#each scheduledEntries}}
      <div class="ncm-scheduled-item">
        <div class="ncm-scheduled-item__time">
          <div class="ncm-scheduled-item__countdown {{#if this.isSoon}}ncm-scheduled-item__countdown--soon{{/if}}">{{this.countdown}}</div>
          <div class="ncm-scheduled-item__date">{{this.deliveryDate}}</div>
        </div>
        <div class="ncm-scheduled-item__route">
          <div class="ncm-scheduled-item__from-to">
            <span style="color: {{this.fromColor}};">{{this.fromName}}</span>
            <span class="arrow">→</span>
            <span>{{this.toName}}</span>
          </div>
          <div class="ncm-scheduled-item__subject">"{{this.subject}}"</div>
        </div>
        <div class="ncm-scheduled-item__priority ncm-scheduled-item__priority--{{this.priority}}">{{this.priority}}</div>
        <div class="ncm-scheduled-item__actions">
          <button class="ncm-admin-action-btn" data-action="editScheduled" data-schedule-id="{{this.scheduleId}}" title="Edit"><i class="fas fa-pen"></i></button>
          <button class="ncm-admin-action-btn ncm-admin-action-btn--danger" data-action="cancelScheduled" data-schedule-id="{{this.scheduleId}}" title="Cancel"><i class="fas fa-xmark"></i></button>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-clock"></i> No scheduled messages pending.</div>
    {{/if}}

    {{/if}}

    {{!-- ──────────────────────────────────────────
         TAB 3: CONTACTS
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'contacts')}}

    {{!-- Combined Header + Toolbar --}}
    <div class="ncm-contacts-header">
      <div class="ncm-contacts-header__top">
        <span class="ncm-contacts-header__title">
          <i class="fas fa-address-book"></i> MASTER CONTACTS
          <span class="ncm-contacts-header__count">({{contactSummary.total}})</span>
        </span>
        <button class="ncm-contacts-header__editor-btn" data-action="openGMContacts">
          <i class="fas fa-expand"></i> FULL EDITOR
        </button>
      </div>
      <div class="ncm-contacts-header__toolbar">
        <div class="ncm-contacts-toolbar__group">
          <button class="ncm-admin-action-btn" data-action="importActorsAsContacts" data-ncm-tooltip="Import Contacts JSON">
            <i class="fas fa-download"></i>
          </button>
          <button class="ncm-admin-action-btn" data-action="exportContacts" data-ncm-tooltip="Export JSON">
            <i class="fas fa-file-export"></i>
          </button>
          <button class="ncm-admin-action-btn ncm-admin-action-btn--accent" data-action="createNewContact" data-ncm-tooltip="New Contact">
            <i class="fas fa-plus"></i>
          </button>
        </div>
        <div class="ncm-contacts-toolbar__sep"></div>
        <button class="ncm-section-title__action" data-action="pushAllContacts" style="margin-left: 0;">
          <i class="fas fa-arrow-up-from-bracket"></i> Share All
        </button>
        <span class="ncm-contacts-toolbar__count">
          <b>{{contactSummary.total}}</b> total
          {{#if contactSummary.linked}} · <span class="ncm-contacts-toolbar__linked">{{contactSummary.linked}} linked</span>{{/if}}
          {{#if contactSummary.burned}} · <span class="ncm-contacts-toolbar__burned">{{contactSummary.burned}} burned</span>{{/if}}
        </span>
      </div>
    </div>

    {{!-- Search + Sort Row --}}
    <div class="ncm-contacts-search">
      <i class="fas fa-search ncm-contacts-search__icon"></i>
      <input type="text" class="ncm-contacts-search__input"
             placeholder="Search name, email, org, tag..."
             value="{{contactSummary.contactSearch}}" />
      {{#if contactSummary.contactSearch}}
        <button class="ncm-contacts-search__clear" data-action="contactClearSearch">
          <i class="fas fa-times"></i>
        </button>
      {{/if}}
      <select class="ncm-contacts-sort__select">
        <option value="name" {{#if (eq contactSummary.contactSort 'name')}}selected{{/if}}>A–Z Name</option>
        <option value="trust" {{#if (eq contactSummary.contactSort 'trust')}}selected{{/if}}>Trust ↓</option>
        <option value="role" {{#if (eq contactSummary.contactSort 'role')}}selected{{/if}}>Role</option>
        <option value="recent" {{#if (eq contactSummary.contactSort 'recent')}}selected{{/if}}>Recent</option>
      </select>
      <span class="ncm-contacts-search__count">{{contactSummary.filteredCount}} of {{contactSummary.total}}</span>
    </div>

    {{!-- Filter Pills --}}
    <div class="ncm-contacts-filters">
      <button class="ncm-contacts-filter {{#if (eq contactSummary.contactFilter 'all')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="all">ALL</button>
      <button class="ncm-contacts-filter {{#if (eq contactSummary.contactFilter 'linked')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="linked">
        <i class="fas fa-link"></i> LINKED
      </button>
      <button class="ncm-contacts-filter {{#if (eq contactSummary.contactFilter 'unlinked')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="unlinked">
        <i class="fas fa-link-slash"></i> UNLINKED
      </button>
      <button class="ncm-contacts-filter {{#if (eq contactSummary.contactFilter 'player')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="player">
        <i class="fas fa-user"></i> PLAYER
      </button>
      <button class="ncm-contacts-filter ncm-contacts-filter--burned {{#if (eq contactSummary.contactFilter 'burned')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="burned">
        <i class="fas fa-fire"></i> BURNED
      </button>
      <button class="ncm-contacts-filter ncm-contacts-filter--ice {{#if (eq contactSummary.contactFilter 'ice')}}ncm-contacts-filter--active{{/if}}"
              data-action="contactFilter" data-filter="ice">
        <i class="fas fa-lock"></i> ICE
      </button>
      {{!-- Dynamic role pills --}}
      {{#each contactSummary.roles}}
        <button class="ncm-contacts-filter ncm-contacts-filter--role {{#if (eq this ../contactSummary.contactFilter)}}ncm-contacts-filter--active{{/if}}"
                data-action="contactFilter" data-filter="{{this}}">{{this}}</button>
      {{/each}}
    </div>
    {{#if contactSummary.contacts.length}}
    <div class="ncm-contact-list">
      {{#each contactSummary.contacts}}
      <div class="ncm-contact-row {{#if this.burned}}ncm-contact-row--burned{{/if}}"
           data-contact-id="{{this.id}}" data-action="editContactInEditor">

        {{!-- Avatar --}}
        <div class="ncm-contact-row__avatar" style="color: {{this.avatarColor}}; border-color: {{this.avatarBorderColor}};">
          {{#if this.hasPortrait}}
            <img src="{{this.portrait}}" alt="{{this.initial}}" class="ncm-contact-row__portrait">
          {{else}}
            {{this.initial}}
          {{/if}}
        </div>

        {{!-- Name + Email --}}
        <div class="ncm-contact-row__info">
          <div class="ncm-contact-row__name">{{this.name}}</div>
          <div class="ncm-contact-row__email">{{this.email}}</div>
        </div>

        {{!-- Meta: Role + Linked Info --}}
        <div class="ncm-contact-row__meta">
          {{#if this.roleBadge}}
            <span class="ncm-contact-row__role ncm-contact-row__role--{{this.roleBadgeClass}}">{{this.roleBadge}}</span>
          {{/if}}
          {{#if this.actorName}}
            <div class="ncm-contact-row__linked">
              <i class="fas fa-link"></i> {{this.actorName}}
              {{#if this.playerOwnerName}}
                <span class="ncm-contact-row__player"><i class="fas fa-user"></i> {{this.playerOwnerName}}</span>
              {{/if}}
            </div>
          {{/if}}
        </div>

        {{!-- Trust Bar (clickable to set trust) --}}
        {{#unless this.burned}}
          {{#unless this.encrypted}}
            <div class="ncm-contact-row__trust ncm-contact-row__trust--interactive">
              {{#each this.trustSegments}}
                <div class="ncm-contact-row__trust-seg {{#if this.active}}ncm-contact-row__trust-seg--active ncm-contact-row__trust-seg--{{../trustLevel}}{{/if}}"
                     data-action="setContactTrust"
                     data-trust-value="{{this.value}}"
                     data-contact-id="{{../id}}"
                     data-ncm-tooltip="Trust {{this.value}}"></div>
              {{/each}}
            </div>
          {{/unless}}
        {{/unless}}

        {{!-- Status Badge --}}
        <div class="ncm-contact-row__status">
          {{#if this.burned}}
            <span class="ncm-contact-row__badge ncm-contact-row__badge--burned"><i class="fas fa-fire"></i> BURNED</span>
          {{else if this.encrypted}}
            <span class="ncm-contact-row__badge ncm-contact-row__badge--ice"><i class="fas fa-lock"></i> ICE DV{{this.encryptionDV}}</span>
          {{/if}}
        </div>

        {{!-- Hover Actions --}}
        <div class="ncm-contact-row__actions">
          <button class="ncm-contact-row__action ncm-contact-row__action--send" data-action="sendAsContact" data-contact-id="{{this.id}}" data-ncm-tooltip="Send As">
            <i class="fas fa-paper-plane"></i>
          </button>
          <button class="ncm-contact-row__action ncm-contact-row__action--inbox" data-action="openContactInbox" data-contact-id="{{this.id}}" data-ncm-tooltip="Inbox">
            <i class="fas fa-inbox"></i>
          </button>
          <button class="ncm-contact-row__action" data-action="composeToContact" data-contact-id="{{this.id}}" data-ncm-tooltip="Message">
            <i class="fas fa-envelope"></i>
          </button>
          <button class="ncm-contact-row__action ncm-contact-row__action--edit" data-action="editContactInEditor" data-contact-id="{{this.id}}" data-ncm-tooltip="Edit">
            <i class="fas fa-pen"></i>
          </button>
        </div>

      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-address-book"></i> No contacts in master directory.</div>
    {{/if}}

    {{!-- Recent Pushes --}}
    {{#if pushLog.length}}
    <div class="ncm-section-title"><i class="fas fa-arrow-up-from-bracket"></i> Recent Pushes</div>
    <div class="ncm-push-log">
      {{#each pushLog}}
      <div class="ncm-push-log__entry">
        <i class="fas fa-check"></i>
        {{{this.text}}}
        <span class="ncm-push-log__entry__time">{{this.time}}</span>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{/if}}

    {{!-- ──────────────────────────────────────────
         TAB 4: NETWORKS (Enhanced — Sprint 6)
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'networks')}}

    {{#if (eq networkSubView 'logs')}}
    {{!-- ═══ FULL ACTIVITY LOG PANEL ═══ --}}
    <div class="ncm-section-title">
      <i class="fas fa-scroll"></i> Network Activity Log ({{logEntryCount}})
      <button class="ncm-section-title__action" data-action="openNetworkManagerLogs"><i class="fas fa-up-right-from-square"></i> Open in Manager</button>
      <button class="ncm-section-title__action" data-action="switchNetworkSubView" data-subview="cards">← Back</button>
    </div>

    <div class="ncm-netlog-panel">
      <div class="ncm-netlog-toolbar">
        <div class="ncm-netlog-filter-group">
          {{#each logTypeFilters}}
          <button class="ncm-netlog-filter-btn {{#if this.active}}ncm-netlog-filter-btn--active{{/if}}"
                  data-action="filterLogType" data-filter="{{this.value}}">{{this.label}}</button>
          {{/each}}
        </div>
        <select class="ncm-netlog-network-filter" data-action="filterLogNetwork">
          <option value="">All Networks</option>
          {{#each networks}}
          <option value="{{this.id}}" {{#if (eq this.id ../logNetworkFilter)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
        <div class="ncm-netlog-spacer"></div>
        <button class="ncm-netlog-btn ncm-netlog-btn--accent" data-action="toggleAddLogForm">
          <i class="fas fa-plus"></i> Add Entry
        </button>
        <button class="ncm-netlog-btn" data-action="exportNetworkLogs">
          <i class="fas fa-file-export"></i> Export
        </button>
        <button class="ncm-netlog-btn ncm-netlog-btn--danger" data-action="clearNetworkLogs">
          <i class="fas fa-trash"></i> Clear
        </button>
      </div>

      <div class="ncm-netlog-list">
        {{#if fullLogEntries.length}}
        {{#each fullLogEntries}}
        <div class="ncm-netlog-entry {{#if this.manual}}ncm-netlog-entry--manual{{/if}}" data-entry-id="{{this.id}}">
          <div class="ncm-netlog-entry__row1">
            <span class="ncm-netlog-entry__icon" style="color:var(--ncm-{{this.colorVar}});">
              <i class="fas {{this.typeIcon}}"></i>
            </span>
            <span class="ncm-netlog-entry__type-label">{{this.typeLabel}}</span>
            <span class="ncm-netlog-entry__network">{{this.networkName}}</span>
            <span class="ncm-netlog-entry__time">{{this.displayDate}} {{this.displayTime}}</span>
            <div class="ncm-netlog-entry__actions">
              <button class="ncm-log-entry__action-btn" data-action="editLogEntry" data-entry-id="{{this.id}}" title="Edit"><i class="fas fa-pen"></i></button>
              <button class="ncm-log-entry__action-btn ncm-log-entry__action-btn--danger" data-action="deleteLogEntry" data-entry-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          <div class="ncm-netlog-entry__row2">
            <span class="ncm-netlog-entry__actor">{{this.actorName}}</span>
            <span class="ncm-netlog-entry__message">{{this.message}}</span>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="ncm-netlog-empty">
          <i class="fas fa-clipboard-list"></i> No log entries
        </div>
        {{/if}}
      </div>

      {{#if showAddLogForm}}
      <div class="ncm-add-log-form">
        <div class="ncm-add-log-field">
          <label>Network</label>
          <select name="logNetwork">
            {{#each networks}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
        </div>
        <div class="ncm-add-log-field">
          <label>Actor</label>
          <input type="text" name="logActor" placeholder="Unknown" style="width:80px;">
        </div>
        <div class="ncm-add-log-field">
          <label>Type</label>
          <select name="logType">
            <option value="connect">Connect</option>
            <option value="disconnect">Disconnect</option>
            <option value="auth_success">Auth Success</option>
            <option value="auth_failure">Auth Failure</option>
            <option value="hack">Hack Attempt</option>
            <option value="lockout">Lockout</option>
            <option value="manual">Trace / Manual</option>
            <option value="malware">Malware</option>
            <option value="system">System</option>
          </select>
        </div>
        <div class="ncm-add-log-field ncm-add-log-field--message">
          <label>Message</label>
          <input type="text" name="logMessage" placeholder="[TRACE] Unauthorized access from...">
        </div>
        <button class="ncm-add-log-submit" data-action="addManualLogEntry"><i class="fas fa-plus"></i> Add</button>
      </div>
      {{/if}}
    </div>

    {{else}}
    {{!-- ═══ NETWORK CARDS VIEW (Default) ═══ --}}

    <div class="ncm-section-title">
      <i class="fas fa-network-wired"></i> Network Operations
      <button class="ncm-section-title__action ncm-section-title__action--accent" data-action="switchNetworkSubView" data-subview="logs"><i class="fas fa-scroll"></i> Activity Log ({{logEntryCount}}) →</button>
      <button class="ncm-section-title__action" data-action="openNetworkManagerLogs"><i class="fas fa-external-link-alt"></i> Full Manager →</button>
    </div>

    {{!-- Health Strip --}}
    <div class="ncm-net-health-strip">
      <div class="ncm-net-health-card">
        <div class="ncm-net-health-card__value ncm-net-health-card__value--cyan">{{netStats.total}}</div>
        <div class="ncm-net-health-card__label">Subnets</div>
      </div>
      <div class="ncm-net-health-card">
        <div class="ncm-net-health-card__value ncm-net-health-card__value--green">{{netStats.active}}</div>
        <div class="ncm-net-health-card__label">Active</div>
      </div>
      <div class="ncm-net-health-card">
        <div class="ncm-net-health-card__value ncm-net-health-card__value--red">{{netStats.deadZones}}</div>
        <div class="ncm-net-health-card__label">Dead Zones</div>
      </div>
      <div class="ncm-net-health-card">
        <div class="ncm-net-health-card__value ncm-net-health-card__value--gold">{{netStats.secured}}</div>
        <div class="ncm-net-health-card__label">Secured</div>
      </div>
      <div class="ncm-net-health-card">
        <div class="ncm-net-health-card__value ncm-net-health-card__value--cyan">{{netStats.connected}}</div>
        <div class="ncm-net-health-card__label">Connected</div>
      </div>
    </div>

    {{!-- Scene Quick Strip --}}
    {{#if sceneStrip.length}}
    <div class="ncm-scene-strip">
      <div class="ncm-scene-strip__label"><i class="fas fa-map"></i> Scene Dead Zones</div>
      {{#each sceneStrip}}
      <div class="ncm-scene-chip {{#if this.deadZone}}ncm-scene-chip--dead{{/if}} {{#if this.isCurrent}}ncm-scene-chip--current{{/if}}"
           data-scene-id="{{this.id}}">
        <div class="ncm-scene-chip__dot"></div>
        <div class="ncm-scene-chip__info">
          <div class="ncm-scene-chip__name">{{this.name}}</div>
          <div class="ncm-scene-chip__network">{{this.defaultNetworkName}}</div>
        </div>
        <button class="ncm-scene-chip__toggle-btn {{#if this.deadZone}}ncm-scene-chip__toggle-btn--dead{{/if}}"
             data-action="toggleSceneDeadZone"
             title="{{#if this.deadZone}}Restore signal{{else}}Jam all signals{{/if}}">
          <i class="fas {{#if this.deadZone}}fa-signal{{else}}fa-signal-slash{{/if}}"></i>
          {{#if this.deadZone}}Restore{{else}}Jam{{/if}}
        </button>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{!-- Broadcast Bar --}}
    <div class="ncm-broadcast-bar">
      <div class="ncm-broadcast-bar__icon"><i class="fas fa-tower-broadcast"></i></div>
      <div><div class="ncm-broadcast-bar__label">Broadcast</div></div>
      <select class="ncm-broadcast-bar__select" name="broadcastNetwork">
        <option value="all">All Networks</option>
        {{#each networks}}
        <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
      <input class="ncm-broadcast-bar__input" name="broadcastMessage"
             placeholder="System message to all connected users...">
      <button class="ncm-broadcast-bar__send" data-action="sendBroadcast">
        <i class="fas fa-paper-plane"></i> Send
      </button>
    </div>

    {{!-- Network Search / Filter --}}
    {{#if (gt networks.length 4)}}
    <div class="ncm-network-search-bar">
      <i class="fas fa-search ncm-network-search-bar__icon"></i>
      <input class="ncm-network-search-bar__input" type="text"
             placeholder="Filter networks..." value="{{networkSearchQuery}}">
    </div>
    {{/if}}

    {{!-- Network Cards — Grouped --}}
    {{#if networkGroups.length}}
    {{#each networkGroups}}
    <div class="ncm-network-group">
      <div class="ncm-network-group__header" data-action="toggleNetworkGroup" data-group-key="{{this.key}}">
        <i class="fas {{this.icon}} ncm-network-group__icon ncm-network-group__icon{{this.iconClass}}"></i>
        <span class="ncm-network-group__title">{{this.name}}</span>
        <span class="ncm-network-group__count">{{this.count}}</span>
        <span class="ncm-network-group__arrow">{{#if this.collapsed}}▶{{else}}▼{{/if}}</span>
      </div>
      {{#unless this.collapsed}}
      <div class="ncm-network-grid">
        {{#each this.networks}}
        <div class="ncm-network-card {{#if this.enabled}}ncm-network-card--active{{else}}ncm-network-card--disabled{{/if}}"
             data-network-id="{{this.id}}">
          <div class="ncm-network-card__header">
            <div class="ncm-network-card__icon ncm-network-card__icon--{{this.iconClass}}">
              <i class="fas fa-{{this.icon}}"></i>
            </div>
            <div class="ncm-network-card__title-area">
              <div class="ncm-network-card__name">{{this.name}}</div>
              <div class="ncm-network-card__type">{{this.type}}</div>
              {{#if this.tags.length}}
              <div class="ncm-network-card__tags">
                {{#each this.tags}}<span class="ncm-tag ncm-tag--{{this.class}}">{{this.label}}</span>{{/each}}
              </div>
              {{/if}}
            </div>
            {{#if this.isGlobal}}
            <span class="ncm-network-card__global-badge"><i class="fas fa-globe"></i> GLOBAL</span>
            {{else}}
            <div class="ncm-network-card__toggle {{#if this.enabled}}ncm-network-card__toggle--on{{/if}}"
                 data-action="toggleNetwork" data-network-id="{{this.id}}"></div>
            {{/if}}
          </div>
          <div class="ncm-network-card__stats">
            <span>Signal <span class="val {{this.signalClass}}">{{this.signal}}%</span></span>
            <span>Users <span class="val">{{this.userCount}}</span></span>
            {{#if this.reliability}}<span>Rel <span class="val">{{this.reliability}}%</span></span>{{/if}}
          </div>
          <div class="ncm-network-card__quick">
            <span class="ncm-network-card__quick-label">Signal</span>
            <input type="range" class="ncm-network-card__quick-slider"
                   min="0" max="100" value="{{this.signal}}"
                   data-network-id="{{this.id}}">
            <span class="ncm-network-card__quick-value">{{this.signal}}%</span>
          </div>
          {{#if this.connectedUsers.length}}
          <div class="ncm-network-card__users">
            {{#each this.connectedUsers}}
            <div class="ncm-network-card__user-chip"><div class="ncm-network-card__user-dot"></div> {{this.name}}</div>
            {{/each}}
          </div>
          {{/if}}
          <div class="ncm-network-card__auth ncm-network-card__auth--{{this.authClass}}">
            <i class="fas fa-{{this.authIcon}}"></i> {{this.authLabel}}
          </div>
          <div class="ncm-network-card__actions">
            <button class="ncm-network-card__action-btn" data-action="openNetworkManager"><i class="fas fa-pen"></i> Edit</button>
            {{#if this.authClass}}{{#if (eq this.authClass 'password')}}
            <button class="ncm-network-card__action-btn" data-action="resetNetworkAuth" data-network-id="{{this.id}}"><i class="fas fa-key"></i> Reset Auth</button>
            {{/if}}{{/if}}
          </div>
          <button class="ncm-network-card__log-toggle" data-action="toggleCardLog" data-network-id="{{this.id}}">
            <i class="fas fa-scroll"></i> Activity Log
            {{#if this.logCount}}<span class="ncm-network-card__log-count">{{this.logCount}}</span>{{/if}}
            <span class="ncm-network-card__log-arrow">{{#if this.logExpanded}}▼{{else}}▶{{/if}}</span>
          </button>
          {{#if this.logExpanded}}
          <div class="ncm-network-card__log">
            {{#each this.logEntries}}
            <div class="ncm-log-entry {{#if this.manual}}ncm-log-entry--manual{{/if}}" data-entry-id="{{this.id}}">
              <div class="ncm-log-entry__row1">
                <span class="ncm-log-entry__icon ncm-log-entry__icon--{{this.typeClass}}"><i class="fas {{this.typeIcon}}"></i></span>
                <span class="ncm-log-entry__type-label">{{this.typeLabel}}</span>
                <span class="ncm-log-entry__time">{{this.displayDate}} {{this.displayTime}}</span>
                <div class="ncm-log-entry__actions">
                  <button class="ncm-log-entry__action-btn" data-action="editLogEntry" data-entry-id="{{this.id}}"><i class="fas fa-pen"></i></button>
                  <button class="ncm-log-entry__action-btn ncm-log-entry__action-btn--danger" data-action="deleteLogEntry" data-entry-id="{{this.id}}"><i class="fas fa-trash"></i></button>
                </div>
              </div>
              <div class="ncm-log-entry__row2">
                <span class="ncm-log-entry__actor">{{this.actorName}}</span>
                <span class="ncm-log-entry__message">{{this.message}}</span>
              </div>
            </div>
            {{/each}}
            {{#unless this.logEntries.length}}
            <div class="ncm-log-entry" style="justify-content:center; color:var(--ncm-text-muted); padding: 12px;">No activity</div>
            {{/unless}}
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/unless}}
    </div>
    {{/each}}
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-network-wired"></i> No networks found.</div>
    {{/if}}

    {{/if}}{{!-- /networkSubView --}}

    {{/if}}

    {{!-- ──────────────────────────────────────────
         TAB 5: DATA SHARDS
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'shards')}}

    <div class="ncm-section-title">
      <i class="fas fa-database"></i> All Data Shards ({{shards.length}})
      <button class="ncm-section-title__action" data-action="convertItemToShard"><i class="fas fa-plus"></i> Convert Item →</button>
    </div>
    {{#if shards.length}}
    <div class="ncm-shard-grid">
      {{#each shards}}
      <div class="ncm-shard-card ncm-shard-card--{{this.status}}"
           data-action="openShardItem" data-item-id="{{this.itemId}}">
        <div class="ncm-shard-card__header">
          <div class="ncm-shard-card__icon {{this.iconClass}}"><i class="fas fa-{{this.icon}}"></i></div>
          <div class="ncm-shard-card__title-area">
            <div class="ncm-shard-card__name">{{this.name}}</div>
            <div class="ncm-shard-card__owner">Owner: {{this.owner}}</div>
          </div>
        </div>
        <div class="ncm-shard-card__security">
          {{#each this.securityLayers}}
          <span class="ncm-shard-card__layer ncm-shard-card__layer--{{this.type}}">{{this.label}}</span>
          {{/each}}
        </div>
        <div class="ncm-shard-card__meta">
          <span><i class="fas fa-envelope"></i> {{this.messageCount}} message{{#unless (eq this.messageCount 1)}}s{{/unless}}</span>
          {{#if this.breachedBy}}
          <span><i class="fas fa-check" style="color: var(--ncm-success);"></i> Breached by {{this.breachedBy}}</span>
          {{else}}
          <span><i class="fas fa-clock"></i> {{this.attemptCount}} attempt{{#unless (eq this.attemptCount 1)}}s{{/unless}}</span>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-database"></i> No data shards in the world.</div>
    {{/if}}

    {{!-- Access Log --}}
    {{#if accessLog.length}}
    <div class="ncm-section-title"><i class="fas fa-clipboard-list"></i> Recent Access Log</div>
    <div class="ncm-access-log">
      {{#each accessLog}}
      <div class="ncm-access-log__entry ncm-access-log__entry--{{this.type}}">
        <i class="fas fa-{{this.icon}}"></i>
        <span class="ncm-access-log__entry__text">{{{this.text}}}</span>
        <span class="ncm-access-log__entry__time">{{this.time}}</span>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{/if}}

    {{!-- ──────────────────────────────────────────
         TAB 6: TOOLS
         ────────────────────────────────────────── --}}
    {{#if (eq activeTab 'tools')}}

    <div class="ncm-section-title"><i class="fas fa-cog"></i> System Tools</div>
    <div class="ncm-tools-grid">
      <div class="ncm-tool-card" data-action="openThemeCustomizer">
        <i class="fas fa-palette ncm-tool-card__icon ncm-tool-card__icon--gold"></i>
        <span class="ncm-tool-card__name">Themes</span>
        <span class="ncm-tool-card__desc">Colors, fonts &amp; effects</span>
      </div>
      <div class="ncm-tool-card" data-action="forceRefreshAll">
        <i class="fas fa-broadcast-tower ncm-tool-card__icon ncm-tool-card__icon--green"></i>
        <span class="ncm-tool-card__name">Force Refresh</span>
        <span class="ncm-tool-card__desc">Sync all clients</span>
      </div>
      <div class="ncm-tool-card" data-action="exportLogs">
        <i class="fas fa-file-export ncm-tool-card__icon"></i>
        <span class="ncm-tool-card__name">Export Logs</span>
        <span class="ncm-tool-card__desc">Download message JSON</span>
      </div>
      <div class="ncm-tool-card" data-action="healthCheck">
        <i class="fas fa-heartbeat ncm-tool-card__icon ncm-tool-card__icon--green"></i>
        <span class="ncm-tool-card__name">Health Check</span>
        <span class="ncm-tool-card__desc">Run diagnostics</span>
      </div>
      <div class="ncm-tool-card" data-action="openTimeSettings">
        <i class="fas fa-clock-rotate-left ncm-tool-card__icon ncm-tool-card__icon--gold"></i>
        <span class="ncm-tool-card__name">Time Settings</span>
        <span class="ncm-tool-card__desc">SimpleCalendar config</span>
      </div>
      <div class="ncm-tool-card" data-action="openSoundSettings">
        <i class="fas fa-volume-high ncm-tool-card__icon"></i>
        <span class="ncm-tool-card__name">Sound Settings</span>
        <span class="ncm-tool-card__desc">Notification audio</span>
      </div>
    </div>

    <div class="ncm-danger-zone">
      <div class="ncm-section-title"><i class="fas fa-triangle-exclamation"></i> Danger Zone</div>
      <div class="ncm-tools-grid">
        <div class="ncm-tool-card" data-action="purgeMessages">
          <i class="fas fa-trash ncm-tool-card__icon"></i>
          <span class="ncm-tool-card__name">Purge Messages</span>
          <span class="ncm-tool-card__desc">Delete all for an actor</span>
        </div>
        <div class="ncm-tool-card" data-action="resetModule">
          <i class="fas fa-rotate-left ncm-tool-card__icon"></i>
          <span class="ncm-tool-card__name">Reset Module</span>
          <span class="ncm-tool-card__desc">Clear all data (irreversible)</span>
        </div>
        <div class="ncm-tool-card" data-action="rebuildIndex">
          <i class="fas fa-hammer ncm-tool-card__icon"></i>
          <span class="ncm-tool-card__name">Rebuild Index</span>
          <span class="ncm-tool-card__desc">Reindex journals &amp; contacts</span>
        </div>
      </div>
    </div>

    {{/if}}

  </div>{{!-- /ncm-admin-content --}}

  {{!-- ═══ FOOTER ═══ --}}
  <div class="ncm-admin-footer">
    <div class="ncm-admin-footer__info">
      <span><i class="fas fa-shield-halved"></i> GM ADMIN</span>
      {{#if (eq activeTab 'overview')}}<span><i class="fas fa-inbox"></i> {{stats.totalMessages}} MESSAGES</span><span><i class="fas fa-wifi"></i> {{currentNetwork}}</span>{{/if}}
      {{#if (eq activeTab 'messages')}}<span><i class="fas fa-clock"></i> {{scheduledCount}} SCHEDULED</span>{{/if}}
      {{#if (eq activeTab 'contacts')}}<span><i class="fas fa-address-book"></i> {{contactSummary.total}} CONTACTS</span>{{#if contactSummary.burned}}<span style="color: var(--ncm-danger);"><i class="fas fa-fire"></i> {{contactSummary.burned}} BURNED</span>{{/if}}{{/if}}
      {{#if (eq activeTab 'networks')}}<span><i class="fas fa-network-wired"></i> {{netStats.active}}/{{netStats.total}} ACTIVE</span><span><i class="fas fa-ban"></i> {{netStats.deadZones}} DEAD ZONES</span><span><i class="fas fa-users"></i> {{netStats.connected}} CONNECTED</span>{{/if}}
      {{#if (eq activeTab 'shards')}}<span><i class="fas fa-database"></i> {{shards.length}} SHARDS</span>{{#if shardSummary.locked}}<span style="color: var(--ncm-accent);"><i class="fas fa-lock"></i> {{shardSummary.locked}} LOCKED</span>{{/if}}{{#if shardSummary.blackice}}<span style="color: var(--ncm-danger);"><i class="fas fa-skull-crossbones"></i> {{shardSummary.blackice}} BLACK ICE</span>{{/if}}{{/if}}
      {{#if (eq activeTab 'tools')}}<span><i class="fas fa-code-branch"></i> NCM v4.1</span>{{/if}}
    </div>
    <div class="ncm-admin-footer__shortcuts">
      {{#if (eq activeTab 'overview')}}<kbd>TAB</kbd> SWITCH &nbsp; <kbd>R</kbd> REFRESH{{/if}}
      {{#if (eq activeTab 'messages')}}<kbd>N</kbd> NEW MESSAGE &nbsp; <kbd>S</kbd> SCHEDULE{{/if}}
      {{#if (eq activeTab 'contacts')}}<kbd>CLICK</kbd> EDIT &nbsp; <kbd>P</kbd> PUSH &nbsp; <kbd>N</kbd> NEW{{/if}}
      {{#if (eq activeTab 'networks')}}<kbd>CLICK</kbd> TOGGLE &nbsp; <kbd>E</kbd> EDIT &nbsp; <kbd>N</kbd> NEW &nbsp; <kbd>L</kbd> LOGS{{/if}}
      {{#if (eq activeTab 'shards')}}<kbd>CLICK</kbd> OPEN SHARD &nbsp; <kbd>F</kbd> FORCE DECRYPT &nbsp; <kbd>R</kbd> RELOCK{{/if}}
      {{#if (eq activeTab 'tools')}}<kbd>CLICK</kbd> TOOL → OPEN &nbsp; <kbd>ESC</kbd> CLOSE{{/if}}
    </div>
  </div>

</div>{{!-- /ncm-admin-panel --}}

{{else}}
<div class="ncm-admin-panel">
  <div class="ncm-admin-empty">
    <i class="fas fa-lock"></i>
    Access denied — GM clearance required.
  </div>
</div>
{{/if}}
