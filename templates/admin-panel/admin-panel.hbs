{{!-- Admin Panel Template - UPDATED to match CSS --}}
{{!-- File: templates/admin-panel/admin-panel.hbs --}}

<div class="ncm-admin-panel__container">
  
  {{!-- CANONICAL HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-shield-alt"></i> NETWATCH ADMIN
      </div>
      <div class="ncm-header__title">ADMIN CONSOLE</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">Administrator: {{userName}}</span>
      <span class="ncm-header__badge">CLEARANCE: MAXIMUM</span>
    </div>
  </div>
  
  {{!-- SIDEBAR NAVIGATION --}}
  <div class="ncm-admin-panel__sidebar">
    <nav class="ncm-admin-panel__nav">
      <button class="ncm-admin-panel__nav-item ncm-admin-panel__nav-item--active" data-tab="dashboard">
        <i class="ncm-admin-panel__nav-icon fas fa-tachometer-alt"></i>
        <span>Dashboard</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="inboxes">
        <i class="ncm-admin-panel__nav-icon fas fa-inbox"></i>
        <span>Inboxes</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="contacts">
        <i class="ncm-admin-panel__nav-icon fas fa-address-book"></i>
        <span>Contacts</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="networks">
        <i class="ncm-admin-panel__nav-icon fas fa-network-wired"></i>
        <span>Networks</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="security">
        <i class="ncm-admin-panel__nav-icon fas fa-lock"></i>
        <span>Security</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="malware">
        <i class="ncm-admin-panel__nav-icon fas fa-virus"></i>
        <span>Malware</span>
      </button>
      <button class="ncm-admin-panel__nav-item" data-tab="settings">
        <i class="ncm-admin-panel__nav-icon fas fa-cog"></i>
        <span>Settings</span>
      </button>
    </nav>
    
    {{!-- System Status --}}
    <div class="ncm-admin-panel__system-status">
      <div class="ncm-admin-panel__status-item">
        <span class="ncm-admin-panel__status-label">Messages</span>
        <span class="ncm-admin-panel__status-value">{{stats.totalMessages}}</span>
      </div>
      <div class="ncm-admin-panel__status-item">
        <span class="ncm-admin-panel__status-label">Unread</span>
        <span class="ncm-admin-panel__status-value">{{stats.unreadMessages}}</span>
      </div>
      <div class="ncm-admin-panel__status-item">
        <span class="ncm-admin-panel__status-label">Networks</span>
        <span class="ncm-admin-panel__status-value">{{stats.networksOnline}}</span>
      </div>
      <div class="ncm-admin-panel__status-item">
        <span class="ncm-admin-panel__status-label">Users</span>
        <span class="ncm-admin-panel__status-value">{{stats.activeUsers}}</span>
      </div>
    </div>
  </div>
  
  {{!-- MAIN CONTENT --}}
  <div class="ncm-admin-panel__content">
    
    {{!-- Dashboard Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="dashboard" style="display: block;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">System Dashboard</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--secondary" data-action="refresh">
            <i class="fas fa-sync"></i> Refresh
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        {{> "modules/cyberpunkred-messenger/templates/admin-panel/partials/statistics.hbs"}}
      </div>
    </div>
    
    {{!-- Inboxes Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="inboxes" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">Character Inboxes</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--primary" data-action="compose-message">
            <i class="fas fa-pen"></i> Compose
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        <div class="ncm-admin-panel__inbox-grid">
          <div class="ncm-admin-panel__inbox-list">
            {{#each messageJournals}}
            <div class="ncm-admin-panel__inbox-item {{#if (eq ../selectedJournal.id this.id)}}ncm-admin-panel__inbox-item--selected{{/if}}" 
                 data-journal-id="{{this.id}}">
              <div class="ncm-admin-panel__inbox-header">
                <span class="ncm-admin-panel__inbox-owner">{{this.name}}</span>
                <span class="ncm-admin-panel__inbox-count">{{this.pages.size}}</span>
              </div>
              <div class="ncm-admin-panel__inbox-email">{{this.email}}</div>
            </div>
            {{else}}
            <div class="ncm-admin-panel__empty">
              <i class="ncm-admin-panel__empty-icon fas fa-inbox"></i>
              <p>No message journals found</p>
            </div>
            {{/each}}
          </div>
          
          <div class="ncm-admin-panel__inbox-details">
            {{#if selectedJournal}}
            <div class="ncm-admin-panel__inbox-detail-header">
              <h3>{{selectedJournal.name}}</h3>
              <div class="ncm-admin-panel__inbox-actions">
                <button class="ncm-btn ncm-btn--small" data-action="view-as" data-actor-id="{{selectedCharacter.id}}">
                  <i class="fas fa-eye"></i> View As
                </button>
                <button class="ncm-btn ncm-btn--small" data-action="mark-all-read">
                  <i class="fas fa-check"></i> Mark Read
                </button>
              </div>
            </div>
            
            {{#if selectedCharacter}}
            <div class="ncm-admin-panel__character-info">
              <img class="ncm-admin-panel__character-avatar" src="{{selectedCharacter.img}}" alt="{{selectedCharacter.name}}" />
              <div class="ncm-admin-panel__character-details">
                <div class="ncm-admin-panel__character-name">{{selectedCharacter.name}}</div>
                <div class="ncm-admin-panel__character-email">{{selectedCharacter.email}}</div>
              </div>
            </div>
            {{/if}}
            {{else}}
            <div class="ncm-admin-panel__empty">
              <i class="ncm-admin-panel__empty-icon fas fa-mouse-pointer"></i>
              <p>Select an inbox to view details</p>
            </div>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
    
    {{!-- Contacts Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="contacts" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">Contact Management</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--primary" data-action="add-contact">
            <i class="fas fa-plus"></i> Add Contact
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        <div class="ncm-admin-panel__contacts-container">
          <div class="ncm-admin-panel__contacts-search">
            <input type="text" class="ncm-input" placeholder="Search contacts..." data-search="contacts" />
          </div>
          <div class="ncm-admin-panel__contacts-table">
            <table class="ncm-admin-panel__table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Type</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each contacts}}
                <tr>
                  <td>{{this.name}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.type}}</td>
                  <td>
                    <div class="ncm-admin-panel__table-actions">
                      <button class="ncm-btn ncm-btn--small" data-action="edit-contact" data-contact-id="{{this.id}}">
                        <i class="fas fa-edit"></i>
                      </button>
                      <button class="ncm-btn ncm-btn--small ncm-btn--danger" data-action="delete-contact" data-contact-id="{{this.id}}">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    
    {{!-- Networks Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="networks" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">Network Management</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--primary" data-action="create-network">
            <i class="fas fa-plus"></i> Create Network
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        <div class="ncm-admin-panel__tools">
          {{#each networks}}
          <div class="ncm-admin-panel__tool-card">
            <h3 class="ncm-admin-panel__tool-title">{{this.name}}</h3>
            <p class="ncm-admin-panel__tool-description">{{this.description}}</p>
            <div class="ncm-admin-panel__inbox-actions">
              <button class="ncm-btn ncm-btn--small" data-action="edit-network" data-network-id="{{this.id}}">
                <i class="fas fa-edit"></i> Edit
              </button>
              <button class="ncm-btn ncm-btn--small ncm-btn--danger" data-action="delete-network" data-network-id="{{this.id}}">
                <i class="fas fa-trash"></i> Delete
              </button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
    
    {{!-- Security Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="security" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">Security Settings</h2>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        {{> "modules/cyberpunkred-messenger/templates/admin-panel/partials/system-tools.hbs"}}
      </div>
    </div>
    
    {{!-- Malware Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="malware" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">Malware Control</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--danger" data-action="purge-all-malware">
            <i class="fas fa-broom"></i> Purge All
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        <p>Malware management tools will appear here</p>
      </div>
    </div>
    
    {{!-- Settings Tab --}}
    <div class="ncm-admin-tab-content" data-tab-content="settings" style="display: none;">
      <div class="ncm-admin-panel__content-header">
        <h2 class="ncm-admin-panel__content-title">System Configuration</h2>
        <div class="ncm-admin-panel__content-actions">
          <button class="ncm-btn ncm-btn--secondary" data-action="reset-defaults">
            <i class="fas fa-undo"></i> Reset
          </button>
          <button class="ncm-btn ncm-btn--primary" data-action="save-settings">
            <i class="fas fa-save"></i> Save
          </button>
        </div>
      </div>
      
      <div class="ncm-admin-panel__content-body">
        {{> "modules/cyberpunkred-messenger/templates/admin-panel/partials/user-management.hbs"}}
      </div>
    </div>
    
  </div>
</div>