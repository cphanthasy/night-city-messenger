{{!-- System Tools Partial --}}
{{!-- File: templates/admin-panel/partials/system-tools.hbs --}}

<div class="ncm-admin-panel__tools">
  {{!-- Encryption Settings --}}
  <div class="ncm-admin-panel__tool-card">
    <h3 class="ncm-admin-panel__tool-title">Encryption Control</h3>
    <p class="ncm-admin-panel__tool-description">Manage encryption levels and policies</p>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__label">Default Encryption Level</label>
      <select class="ncm-dialog__select" data-setting="defaultEncryption">
        <option value="none">None</option>
        <option value="basic">Basic (DV 10)</option>
        <option value="standard">Standard (DV 15)</option>
        <option value="military">Military (DV 20)</option>
        <option value="corporate">Corporate (DV 25)</option>
      </select>
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__checkbox-label">
        <input type="checkbox" data-setting="gmBypassEncryption" checked>
        <span>GM Can Bypass All Encryption</span>
      </label>
    </div>
  </div>
  
  {{!-- Hacking Settings --}}
  <div class="ncm-admin-panel__tool-card">
    <h3 class="ncm-admin-panel__tool-title">Hacking Parameters</h3>
    <p class="ncm-admin-panel__tool-description">Configure hacking difficulty and consequences</p>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__label">Base Hacking DV</label>
      <input type="number" class="ncm-dialog__input" value="15" data-setting="baseHackingDV">
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__label">Failed Hack Penalty</label>
      <select class="ncm-dialog__select" data-setting="failedHackPenalty">
        <option value="none">None</option>
        <option value="alert">Alert Owner</option>
        <option value="trace">Initiate Trace</option>
        <option value="ice">Activate ICE</option>
        <option value="blackice">Deploy BLACK ICE</option>
      </select>
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__checkbox-label">
        <input type="checkbox" data-setting="logHackAttempts" checked>
        <span>Log All Hack Attempts</span>
      </label>
    </div>
  </div>
  
  {{!-- BLACK ICE Configuration --}}
  <div class="ncm-admin-panel__tool-card">
    <h3 class="ncm-admin-panel__tool-title">BLACK ICE Configuration</h3>
    <p class="ncm-admin-panel__tool-description">Lethal security countermeasures</p>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__label">BLACK ICE Damage</label>
      <input type="text" class="ncm-dialog__input" value="5d6" data-setting="blackIceDamage">
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__label">Activation Threshold</label>
      <input type="number" class="ncm-dialog__input" value="2" data-setting="blackIceThreshold">
      <p class="ncm-dialog__hint">Failed attempts before BLACK ICE activates</p>
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__checkbox-label">
        <input type="checkbox" data-setting="blackIceEnabled" checked>
        <span>Enable BLACK ICE</span>
      </label>
    </div>
    
    <div class="ncm-dialog__form-group">
      <label class="ncm-dialog__checkbox-label">
        <input type="checkbox" data-setting="blackIceWarning" checked>
        <span>Warn Players Before Activation</span>
      </label>
    </div>
  </div>
  
  {{!-- Data Management --}}
  <div class="ncm-admin-panel__tool-card">
    <h3 class="ncm-admin-panel__tool-title">Data Management</h3>
    <p class="ncm-admin-panel__tool-description">Export, import, and cleanup tools</p>
    
    <div class="ncm-admin-panel__inbox-actions">
      <button class="ncm-btn ncm-btn--secondary" data-action="export-all-data">
        <i class="fas fa-download"></i> Export All
      </button>
      <button class="ncm-btn ncm-btn--secondary" data-action="import-data">
        <i class="fas fa-upload"></i> Import
      </button>
      <button class="ncm-btn ncm-btn--danger" data-action="purge-all-data">
        <i class="fas fa-trash-alt"></i> Purge All
      </button>
    </div>
  </div>
</div>