    {{#if (eq activeTab 'networks')}}

    {{#if (eq networkSubView 'logs')}}
    {{!-- ═══ FULL ACTIVITY LOG PANEL ═══ --}}
    <div class="ncm-netlog-header">
      <button class="ncm-netlog-header__back" data-action="switchNetworkSubView" data-subview="cards">
        <i class="fas fa-arrow-left"></i> Back
      </button>
      <div class="ncm-netlog-header__title"><i class="fas fa-scroll"></i> Network Activity Log</div>
      <span class="ncm-netlog-header__count">{{logEntryCount}} entries</span>
      <div class="ncm-netlog-header__spacer"></div>
      <button class="ncm-netlog-header__action" data-action="openNetworkManagerLogs">
        <i class="fas fa-up-right-from-square"></i> Full Manager
      </button>
    </div>

    <div class="ncm-netlog-panel">
      <div class="ncm-netlog-toolbar">
        <div class="ncm-netlog-toolbar-row">
          <div class="ncm-netlog-filter-group">
            {{#each logTypeFilters}}
            <button class="ncm-netlog-filter-btn {{#if this.active}}ncm-netlog-filter-btn--active{{/if}}"
                    data-action="filterLogType" data-filter="{{this.value}}">{{this.label}}</button>
            {{/each}}
          </div>
          <select class="ncm-netlog-network-filter" data-action="filterLogNetwork">
            <option value="">All Networks</option>
            {{#each networks}}
            <option value="{{this.id}}" {{#if (eq this.id ../logNetworkFilter)}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
          </select>
          <div class="ncm-netlog-spacer"></div>
          <button class="ncm-netlog-btn ncm-netlog-btn--accent" data-action="toggleAddLogForm">
            <i class="fas fa-plus"></i> Add
          </button>
          <button class="ncm-netlog-btn" data-action="importNetworkLogs" title="Import log entries">
            <i class="fas fa-file-import"></i>
          </button>
          <button class="ncm-netlog-btn" data-action="exportNetworkLogs" title="Export as JSON">
            <i class="fas fa-file-export"></i>
          </button>
          <button class="ncm-netlog-btn ncm-netlog-btn--danger" data-action="clearNetworkLogs" title="Clear all entries">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>

      <div class="ncm-netlog-list">
        {{#if fullLogEntries.length}}
        {{#each fullLogEntries}}
        <div class="ncm-netlog-entry {{#if this.isTrace}}ncm-netlog-entry--trace{{/if}} {{#if this.manual}}ncm-netlog-entry--manual{{/if}}" data-entry-id="{{this.id}}">
          <div class="ncm-netlog-entry__badge ncm-netlog-entry__badge--{{this.badgeClass}}">
            {{#if this.actorImg}}
            <img class="ncm-netlog-entry__badge-img" src="{{this.actorImg}}" alt="">
            <span class="ncm-netlog-entry__badge-overlay ncm-netlog-entry__badge-overlay--{{this.badgeClass}}"><i class="fas {{this.badgeIcon}}"></i></span>
            {{else}}
            <i class="fas {{this.badgeIcon}}"></i>
            {{/if}}
          </div>
          <div class="ncm-netlog-entry__body">
            <div class="ncm-netlog-entry__line1">
              <span class="ncm-netlog-entry__actor">{{this.actorName}}</span>
              <span class="ncm-netlog-entry__verb">{{this.actionVerb}}</span>
              <span class="ncm-netlog-entry__network ncm-netlog-entry__network--{{this.networkColor}}">{{this.networkName}}</span>
            </div>
            <div class="ncm-netlog-entry__line2">
              <span class="ncm-netlog-entry__type-tag ncm-netlog-entry__type-tag--{{this.typeTagClass}}">{{this.typeTag}}</span>
              {{#if this.message}}
              <span class="ncm-netlog-entry__message">{{this.message}}</span>
              {{/if}}
              {{#if this.hasLink}}
              <span class="ncm-netlog-entry__link {{#if (eq this.linkType 'shard')}}ncm-netlog-entry__link--shard{{/if}}"
                    data-action="openLogReference"
                    data-link-type="{{this.linkType}}"
                    data-message-id="{{this.linkMessageId}}"
                    data-actor-id="{{this.linkActorId}}"
                    data-item-id="{{this.linkItemId}}">
                <i class="fas {{this.linkIcon}}"></i> {{this.linkLabel}}
              </span>
              {{/if}}
              <span class="ncm-netlog-entry__time">
                <span class="ncm-netlog-entry__time-date">{{this.displayDate}} //</span> {{this.displayTime}}
              </span>
            </div>
          </div>
          <div class="ncm-netlog-entry__actions">
            <button class="ncm-netlog-entry__act" data-action="editLogEntry" data-entry-id="{{this.id}}" title="Edit"><i class="fas fa-pen"></i></button>
            <button class="ncm-netlog-entry__act ncm-netlog-entry__act--danger" data-action="deleteLogEntry" data-entry-id="{{this.id}}" title="Delete"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="ncm-netlog-empty">
          <i class="fas fa-clipboard-list"></i> No log entries
        </div>
        {{/if}}
      </div>

      {{#if showAddLogForm}}
      <div class="ncm-add-log-form">
        <div class="ncm-add-log-field">
          <label>Network</label>
          <select name="logNetwork">
            {{#each networks}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
        </div>
        <div class="ncm-add-log-field">
          <label>Actor</label>
          <input type="text" name="logActor" placeholder="Unknown" style="width:80px;">
        </div>
        <div class="ncm-add-log-field">
          <label>Type</label>
          <select name="logType">
            <option value="connect">Connect</option>
            <option value="disconnect">Disconnect</option>
            <option value="auth_success">Auth Success</option>
            <option value="auth_failure">Auth Failure</option>
            <option value="hack">Hack Attempt</option>
            <option value="lockout">Lockout</option>
            <option value="trace">Trace</option>
            <option value="manual">Manual</option>
            <option value="malware">Malware</option>
            <option value="system">System</option>
          </select>
        </div>
        <div class="ncm-add-log-field ncm-add-log-field--message">
          <label>Message</label>
          <input type="text" name="logMessage" placeholder="[TRACE] Unauthorized access from...">
        </div>
        <button class="ncm-add-log-submit" data-action="addManualLogEntry"><i class="fas fa-plus"></i> Add</button>
      </div>
      {{/if}}
    </div>

    {{else}}
    {{!-- ═══ WAR ROOM DASHBOARD ═══ --}}

    {{!-- STATUS BAR --}}
    <div class="ncm-net-status-bar">
      <div class="ncm-net-stat"><div class="ncm-net-stat__val ncm-net-stat__val--cyan">{{netStats.total}}</div><div class="ncm-net-stat__label">Subnets</div></div>
      <div class="ncm-net-stat__sep"></div>
      <div class="ncm-net-stat"><div class="ncm-net-stat__val ncm-net-stat__val--green">{{netStats.active}}</div><div class="ncm-net-stat__label">Active</div></div>
      <div class="ncm-net-stat__sep"></div>
      <div class="ncm-net-stat"><div class="ncm-net-stat__val ncm-net-stat__val--red">{{netStats.deadZones}}</div><div class="ncm-net-stat__label">Dead Zones</div></div>
      <div class="ncm-net-stat__sep"></div>
      <div class="ncm-net-stat"><div class="ncm-net-stat__val ncm-net-stat__val--gold">{{netStats.secured}}</div><div class="ncm-net-stat__label">Secured</div></div>
      <div class="ncm-net-stat__sep"></div>
      <div class="ncm-net-stat"><div class="ncm-net-stat__val">{{netStats.connected}}</div><div class="ncm-net-stat__label">Players Online</div></div>
    </div>

    {{!-- CONNECTED PLAYERS --}}
    <div class="ncm-war-section">
      <i class="fas fa-users ncm-war-section__icon"></i>
      <div class="ncm-war-section__title">Connected Players</div>
      <div class="ncm-war-section__hint">— who's on what network right now</div>
      <div class="ncm-war-section__line"></div>
    </div>

    <div class="ncm-net-players">
      {{#if connectedPlayers.length}}
      {{#each connectedPlayers}}
      <div class="ncm-player-card ncm-player-card--{{this.signalTier}}">
        <div class="ncm-player-card__top">
          {{#if this.img}}
          <div class="ncm-player-card__avatar"><img src="{{this.img}}" /></div>
          {{else}}
          <div class="ncm-player-card__avatar"><i class="fas fa-user"></i></div>
          {{/if}}
          <div class="ncm-player-card__name-area">
            <div class="ncm-player-card__name">{{this.name}}</div>
            <div class="ncm-player-card__status ncm-player-card__status--{{this.signalTier}}">{{this.statusText}}</div>
          </div>
          <button class="ncm-player-card__move" data-action="switchPlayerNetwork" data-user-id="{{this.userId}}"><i class="fas fa-arrow-right-arrow-left"></i> Switch Net</button>
        </div>
        <div class="ncm-player-card__bottom">
          <div class="ncm-player-card__net ncm-player-card__net--{{this.netClass}}"><i class="fas {{this.netIcon}}"></i> {{this.networkName}}</div>
          <div class="ncm-player-card__signal ncm-player-card__signal--{{this.signalTier}}"><i class="fas {{this.signalIcon}}"></i> {{this.signal}}%</div>
        </div>
      </div>
      {{/each}}
      {{else}}
      <div class="ncm-net-players-empty"><i class="fas fa-users-slash"></i> No players online</div>
      {{/if}}
    </div>

    {{!-- SIGNAL MIXER --}}
    <div class="ncm-war-section">
      <i class="fas fa-sliders ncm-war-section__icon"></i>
      <div class="ncm-war-section__title">Signal Control</div>
      <div class="ncm-war-section__hint">— drag sliders to adjust signal strength mid-session</div>
      <div class="ncm-war-section__line"></div>
    </div>

    <div class="ncm-mixer-wrap">
      <div class="ncm-mixer-arrow ncm-mixer-arrow--left" data-action="scrollMixerLeft"><i class="fas fa-chevron-left"></i></div>
      <div class="ncm-mixer-strip">
        {{#each networks}}
        <div class="ncm-mixer-ch {{#if this.enabled}}ncm-mixer-ch--on{{else}}ncm-mixer-ch--off{{/if}} {{#if this.isCurrent}}ncm-mixer-ch--current{{/if}}" data-network-id="{{this.id}}">
          <div class="ncm-mixer-ch__icon ncm-mixer-ch__icon--{{this.iconClass}}">
            {{{ncm-net-icon this.theme}}}
          </div>
          <div class="ncm-mixer-ch__name">{{this.name}}</div>
          <div class="ncm-mixer-ch__slider-wrap">
            <div class="ncm-mixer-ch__slider-label">Signal</div>
            <div class="ncm-mixer-ch__slider-track" data-network-id="{{this.id}}">
              <div class="ncm-mixer-ch__slider-fill ncm-mixer-ch__slider-fill--{{this.signalTier}}" style="height:{{this.signal}}%;"></div>
              {{#if this.enabled}}
              <div class="ncm-mixer-ch__slider-thumb" style="bottom:calc({{this.signal}}% - 3px);"></div>
              {{/if}}
            </div>
          </div>
          <input type="number" class="ncm-mixer-ch__pct-input" min="0" max="100" value="{{this.signal}}" data-network-id="{{this.id}}" {{#unless this.enabled}}disabled{{/unless}}>
          <div class="ncm-mixer-ch__info">
            <div class="ncm-mixer-ch__auth ncm-mixer-ch__auth--{{this.authClass}}"><i class="fas fa-{{this.authIcon}}"></i> {{this.authLabel}}</div>
            <div class="ncm-mixer-ch__users"><i class="fas fa-user"></i> <span class="ct">{{this.userCount}}</span> {{#if (eq this.authClass 'blocked')}}trapped{{else}}connected{{/if}}</div>
            {{#if this.isGlobal}}
            <div class="ncm-mixer-ch__toggle ncm-mixer-ch__toggle--on ncm-mixer-ch__toggle--global" title="Global — always on"></div>
            {{else}}
            <div class="ncm-mixer-ch__toggle {{#if this.enabled}}ncm-mixer-ch__toggle--on{{/if}}" data-action="toggleNetwork" data-network-id="{{this.id}}" title="{{#if this.enabled}}Network is ON — click to disable{{else}}Network is OFF — click to enable{{/if}}"></div>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      <div class="ncm-mixer-arrow ncm-mixer-arrow--right" data-action="scrollMixerRight"><i class="fas fa-chevron-right"></i></div>
    </div>

    {{!-- SCENES — Full Row Layout --}}
    <div class="ncm-war-section">
      <i class="fas fa-map ncm-war-section__icon ncm-war-section__icon--gold"></i>
      <div class="ncm-war-section__title">Scene Signal</div>
      <div class="ncm-war-section__hint">— jam or restore per-scene signal</div>
      <div class="ncm-war-section__line"></div>
    </div>

    <div class="ncm-scene-list">
      {{#each sceneStrip}}
      <div class="ncm-scene-row {{#if this.isCurrent}}ncm-scene-row--active{{/if}} {{#if this.deadZone}}ncm-scene-row--jammed{{/if}}"
           data-scene-id="{{this.id}}">
        <div class="ncm-scene-row__dot"></div>
        <div class="ncm-scene-row__info">
          <div class="ncm-scene-row__name">{{this.name}}</div>
          <div class="ncm-scene-row__sub">{{this.defaultNetworkName}}{{#if this.isCurrent}} · Current scene{{/if}}</div>
        </div>
        {{#if this.isCurrent}}
        <span class="ncm-scene-row__current-tag">Current</span>
        {{/if}}
        {{#if this.deadZone}}
        <span class="ncm-scene-row__jammed-tag"><i class="fas fa-ban"></i> Jammed</span>
        <button class="ncm-scene-row__btn ncm-scene-row__btn--restore" data-action="toggleSceneDeadZone" data-scene-id="{{this.id}}">
          <i class="fas fa-wifi"></i> Restore
        </button>
        {{else}}
        <div class="ncm-scene-row__signal">
          <div class="ncm-scene-row__signal-bar">
            <div class="ncm-scene-row__signal-fill ncm-scene-row__signal-fill--{{this.signalTier}}" style="width:{{this.signalPct}}%;"></div>
          </div>
          <span class="ncm-scene-row__signal-pct ncm-scene-row__signal-pct--{{this.signalTier}}">{{this.signalPct}}%</span>
        </div>
        <button class="ncm-scene-row__btn ncm-scene-row__btn--jam" data-action="toggleSceneDeadZone" data-scene-id="{{this.id}}">
          <i class="fas fa-ban"></i> Jam
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>

    {{!-- BROADCAST --}}
    <div class="ncm-war-section">
      <i class="fas fa-tower-broadcast ncm-war-section__icon ncm-war-section__icon--red"></i>
      <div class="ncm-war-section__title">Broadcast</div>
      <div class="ncm-war-section__hint">— send an in-character system message to players</div>
      <div class="ncm-war-section__line"></div>
    </div>

    <div class="ncm-broadcast">
      <div class="ncm-broadcast__top">
        <i class="fas fa-tower-broadcast ncm-broadcast__icon"></i>
        <span class="ncm-broadcast__title">Network Broadcast</span>
        <span class="ncm-broadcast__desc">All connected players will receive this message</span>
      </div>
      <div class="ncm-broadcast__form">
        <select class="ncm-broadcast__select" name="broadcastNetwork">
          <option value="all">All Networks</option>
          {{#each networks}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
        <input class="ncm-broadcast__input" name="broadcastMessage" placeholder="Type a message all connected players will see...">
        <button class="ncm-broadcast__send" data-action="sendBroadcast"><i class="fas fa-paper-plane"></i> Send</button>
      </div>
    </div>

    {{!-- ZONE DIVIDER --}}
    <div class="ncm-net-zone-div">
      <i class="fas fa-cog ncm-net-zone-div__icon"></i>
      <div class="ncm-net-zone-div__title">Network Configuration</div>
      <div class="ncm-net-zone-div__hint">— create, edit, and manage network settings</div>
      <div class="ncm-net-zone-div__line"></div>
    </div>

    {{!-- CONFIG TOOLBAR — all actions on one line --}}
    <div class="ncm-net-config-toolbar">
      <div class="ncm-net-config-search">
        <i class="fas fa-search"></i>
        <input type="text" class="ncm-net-config-search__input" placeholder="Search networks..." value="{{networkSearchQuery}}">
      </div>
      <div class="ncm-net-filter-pill" data-action="cycleNetAuthFilter">Auth <span class="ncm-net-filter-val">{{netAuthFilter}}</span> <i class="fas fa-chevron-down"></i></div>
      <div class="ncm-net-filter-pill" data-action="cycleNetStatusFilter">Status <span class="ncm-net-filter-val">{{netStatusFilter}}</span> <i class="fas fa-chevron-down"></i></div>
      <div class="ncm-net-filter-pill" data-action="cycleNetGroupFilter">Group <span class="ncm-net-filter-val">{{netGroupFilter}}</span> <i class="fas fa-chevron-down"></i></div>
      <div class="ncm-net-config-toolbar__spacer"></div>
      <button class="ncm-net-config-btn" data-action="switchNetworkSubView" data-subview="logs"><i class="fas fa-scroll"></i> Activity Logs</button>
      <button class="ncm-net-config-btn" data-action="openNetworkManagerLogs"><i class="fas fa-external-link-alt"></i> Full Manager</button>
      <button class="ncm-net-config-btn ncm-net-config-btn--cyan" data-action="createNetwork"><i class="fas fa-plus"></i> Create Network</button>
    </div>

    {{!-- CONFIG LIST — GROUPED --}}
    {{#if networkGroups.length}}
    {{#each networkGroups}}
    <div class="ncm-net-config-group {{#if this.collapsed}}ncm-net-config-group--collapsed{{/if}}">
      <div class="ncm-net-config-group__header" data-action="toggleNetworkGroup" data-group-key="{{this.key}}">
        <i class="fas fa-chevron-down ncm-net-config-group__chevron"></i>
        <div class="ncm-net-config-group__icon ncm-net-config-group__icon{{this.iconClass}}"><i class="fas {{this.icon}}"></i></div>
        <div class="ncm-net-config-group__title">{{this.name}}</div>
        <div class="ncm-net-config-group__summary">
          <div class="ncm-net-config-group__pips">
            {{#each this.networks}}
            <div class="ncm-net-cg-pip {{#if this.enabled}}ncm-net-cg-pip--active{{else}}ncm-net-cg-pip--disabled{{/if}}"></div>
            {{/each}}
          </div>
          <div class="ncm-net-config-group__count">{{this.count}} subnet{{#unless (eq this.count 1)}}s{{/unless}}</div>
        </div>
      </div>
      {{#unless this.collapsed}}
      <div class="ncm-net-config-group__body">
        {{#each this.networks}}
        <div class="ncm-net-config-row {{#unless this.enabled}}ncm-net-config-row--disabled{{/unless}}" data-network-id="{{this.id}}">
          <div class="ncm-net-config-row__pip {{#if this.enabled}}ncm-net-config-row__pip--active{{else}}ncm-net-config-row__pip--disabled{{/if}}"></div>
          <div class="ncm-net-config-row__icon ncm-net-config-row__icon--{{this.iconClass}}">
            {{{ncm-net-icon this.theme}}}
          </div>
          <div class="ncm-net-config-row__info">
            <div class="ncm-net-config-row__name">{{this.name}}</div>
            <div class="ncm-net-config-row__desc">{{this.type}}{{#if this.isGlobal}} · Available everywhere{{/if}}{{#if this.authLabel}} · {{this.authLabel}}{{/if}}</div>
          </div>
          <div class="ncm-net-config-row__badges">
            {{#each this.tags}}
            <span class="ncm-net-cbadge ncm-net-cbadge--{{this.class}}">{{this.label}}</span>
            {{/each}}
          </div>
          <div class="ncm-net-config-row__actions">
            <div class="ncm-action-btn" data-action="editNetworkInManager" data-network-id="{{this.id}}" title="Edit network settings"><i class="fas fa-pen"></i></div>
            {{#if this.authClass}}{{#if (eq this.authClass 'password')}}
            <div class="ncm-action-btn ncm-action-btn--gold" data-action="resetNetworkAuth" data-network-id="{{this.id}}" title="Reset all player authentications"><i class="fas fa-key"></i></div>
            {{/if}}{{/if}}
            {{#unless this.isCore}}
            <div class="ncm-action-btn ncm-action-btn--danger" data-action="deleteNetwork" data-network-id="{{this.id}}" title="Delete this network"><i class="fas fa-trash"></i></div>
            {{/unless}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/unless}}
    </div>
    {{/each}}
    {{else}}
    <div class="ncm-admin-empty"><i class="fas fa-network-wired"></i> No networks found.</div>
    {{/if}}

    {{/if}}{{!-- /networkSubView --}}

    {{/if}}
