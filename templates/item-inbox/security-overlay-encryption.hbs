{{!-- Security Overlay: Encryption Layer (Sprint 4.6 Themed Redesign) --}}
<div class="ncm-security-overlay ncm-security-overlay-encryption">
  <div class="ncm-sec-backdrop ncm-sec-backdrop--matrix"></div>
  <div class="ncm-sec-card">
    <div class="ncm-sec-icon"><i class="fas fa-shield-halved"></i></div>
    <div class="ncm-sec-title">ICE Protected</div>
    <div class="ncm-sec-info">
      Encryption: <strong>{{encryptionType}}</strong>
      {{#if isBlackICE}}<span class="ncm-sec-text-muted">// Lethal countermeasures active</span>{{/if}}
    </div>

    {{#if isLockedOut}}
      <div class="ncm-sec-lockout">
        <div class="ncm-sec-lockout-icon"><i class="fas fa-ban"></i></div>
        <div class="ncm-sec-lockout-text">System Locked</div>
        {{#if isPermanentlyLocked}}
          <div class="ncm-sec-lockout-timer">PERMANENT</div>
        {{else}}
          <div class="ncm-sec-lockout-timer" data-lockout-countdown>{{lockoutRemaining}}s</div>
        {{/if}}
        <div class="ncm-sec-muted">Maximum attempts exceeded. Cooldown active.</div>
      </div>
      <div class="ncm-sec-attempts">
        {{#each attemptDots}}
          <div class="ncm-sec-attempt-dot ncm-sec-attempt-dot--used"></div>
        {{/each}}
      </div>

    {{else if hasActor}}
      {{!-- Skill Selection --}}
      <div class="ncm-sec-skill-instruction">
        {{#if hackingSkillName}}
          <i class="fas fa-check-circle" style="color:#00ff41;margin-right:4px;"></i>
          <strong>{{hackingSkillName}}</strong> selected — ready to breach
        {{else}}
          <i class="fas fa-hand-pointer" style="color:var(--sp-accent);margin-right:4px;"></i>
          Select a skill to breach the ICE:
        {{/if}}
      </div>

      <div class="ncm-sec-skill-list">
        {{#each availableSkills}}
          <button type="button" data-action="selectSkill" data-skill="{{name}}"
                  class="ncm-sec-skill-btn {{#if selected}}ncm-sec-skill-btn--selected{{/if}}"
                  title="{{stat}}({{statValue}}) + {{name}}({{level}}) = {{total}} + 1d10 vs DV {{dc}}">
            <span class="ncm-sec-skill-name">{{name}}</span>
            <span class="ncm-sec-skill-stats">{{stat}} {{total}} + 1d10</span>
            <span class="ncm-sec-skill-dv">DV {{dc}}</span>
          </button>
        {{/each}}
      </div>

      <div class="ncm-sec-attempts">
        {{#each attemptDots}}
          <div class="ncm-sec-attempt-dot {{#if used}}ncm-sec-attempt-dot--used{{else if current}}ncm-sec-attempt-dot--current{{/if}}"></div>
        {{/each}}
      </div>
      <div class="ncm-sec-muted">Attempt {{hackAttemptCurrent}} of {{maxHackAttempts}}</div>

      {{#if hackingSkillName}}
        <button type="button" data-action="attemptBreach" class="ncm-sec-btn ncm-sec-btn--breach">
          <i class="fas fa-bolt"></i> Attempt Breach
        </button>
      {{else}}
        <button type="button" class="ncm-sec-btn ncm-sec-btn--breach ncm-sec-btn--disabled" disabled>
          <i class="fas fa-bolt"></i> Select a Skill First
        </button>
      {{/if}}

    {{else}}
      <div class="ncm-sec-muted" style="margin-top:12px;">No character assigned. Set your character in User Configuration.</div>
    {{/if}}

    {{#if isGM}}
      <div class="ncm-sec-gm">
        <div class="ncm-sec-gm-label">GM Controls</div>
        <button type="button" data-action="forceDecrypt" class="ncm-sec-btn ncm-sec-btn--gm">
          <i class="fas fa-unlock-keyhole"></i> Force Decrypt
        </button>
      </div>
    {{/if}}
  </div>
</div>
