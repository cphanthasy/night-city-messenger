{{!-- Data Shard Message Composer - Updated to match main composer --}}
{{!-- File: templates/item-inbox/message-composer.hbs --}}

<div class="ncm-composer__container">
  
  {{!-- HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-database"></i> DATA SHARD
      </div>
      <div class="ncm-header__title">ADD MESSAGE TO SHARD</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      {{#if isGM}}
        <span class="ncm-header__welcome">
          <i class="fas fa-shield-alt" style="color: #fbbf24;"></i>
          <span style="color: #fbbf24;">GM Mode</span> - Full control
        </span>
      {{else}}
        <span class="ncm-header__welcome">Adding to: {{shardName}}</span>
      {{/if}}
    </div>
  </div>
  
  {{!-- HEADER FIELDS --}}
  <div class="ncm-composer__header-section">
    
    {{!-- FROM FIELD --}}
    {{#if isGM}}
    <div class="ncm-composer__field ncm-composer__field--from">
      <label class="ncm-composer__label">
        <i class="fas fa-user-secret"></i> From:
      </label>
      <div class="ncm-composer__field-content">
        <div class="ncm-composer__from-wrapper">
          <input 
            type="text" 
            name="from" 
            class="ncm-composer__from-input"
            value="{{messageData.from}}" 
            placeholder="Select or enter sender identity..."
            autocomplete="off"
          />
          <div class="ncm-composer__from-suggestions" style="display: none;"></div>
        </div>
        
        <button type="button" class="ncm-btn ncm-btn--small ncm-btn--gm" data-action="select-from-master">
          <i class="fas fa-address-book"></i> Master List
        </button>
      </div>
      <p class="ncm-composer__field-hint">
        <i class="fas fa-info-circle"></i>
        Send AS any NPC identity from your master contact list
      </p>
    </div>
    {{else}}
    <div class="ncm-composer__field ncm-composer__field--from-readonly">
      <label class="ncm-composer__label">From:</label>
      <div class="ncm-composer__from-display">
        <i class="fas fa-user-circle"></i>
        <span>{{currentUserEmail}}</span>
      </div>
    </div>
    {{/if}}
    
    {{!-- TO FIELD --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">To:</label>
      <div class="ncm-composer__field-content">
        <div class="ncm-composer__recipient-wrapper">
          <input 
            type="text" 
            name="to" 
            class="ncm-composer__recipient-input"
            value="{{messageData.to}}" 
            placeholder="recipient@example.net"
            autocomplete="off"
          />
          <div class="ncm-composer__to-suggestions" style="display: none;"></div>
        </div>
        
        <button type="button" class="ncm-btn ncm-btn--small" data-action="select-contact">
          <i class="fas fa-address-book"></i> Contacts
        </button>
      </div>
    </div>
    
    {{!-- SUBJECT FIELD --}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">Subject:</label>
      <div class="ncm-composer__field-content">
        <input 
          type="text" 
          name="subject" 
          class="ncm-composer__subject-input"
          value="{{messageData.subject}}" 
          placeholder="Message subject..."
        />
      </div>
    </div>
    
    {{!-- DATE FIELD (GM only) --}}
    {{#if isGM}}
    <div class="ncm-composer__field">
      <label class="ncm-composer__label">
        <i class="fas fa-calendar"></i> Date/Time:
      </label>
      <div class="ncm-composer__field-content">
        <input 
          type="datetime-local" 
          name="date" 
          class="ncm-composer__date-input"
          value="{{messageData.date}}" 
        />
      </div>
      <p class="ncm-composer__field-hint">
        <i class="fas fa-info-circle"></i>
        Set custom timestamp (leave blank for current time)
      </p>
    </div>
    {{/if}}
  </div>
  
  {{!-- EDITOR SECTION --}}
  <div class="ncm-composer__editor-section">
    
    {{!-- Simple Toolbar --}}
    <div class="ncm-composer__toolbar">
      <div class="ncm-composer__toolbar-row">
        <button class="ncm-composer__toolbar-btn" data-format="bold" title="Bold" type="button">
          <i class="fas fa-bold"></i>
        </button>
        <button class="ncm-composer__toolbar-btn" data-format="italic" title="Italic" type="button">
          <i class="fas fa-italic"></i>
        </button>
        <button class="ncm-composer__toolbar-btn" data-format="underline" title="Underline" type="button">
          <i class="fas fa-underline"></i>
        </button>
        
        <div class="ncm-composer__toolbar-separator"></div>
        
        <button class="ncm-composer__toolbar-btn" data-format="insertUnorderedList" title="Bullet List" type="button">
          <i class="fas fa-list-ul"></i>
        </button>
        <button class="ncm-composer__toolbar-btn" data-format="insertOrderedList" title="Numbered List" type="button">
          <i class="fas fa-list-ol"></i>
        </button>
        
        <div class="ncm-composer__toolbar-separator"></div>
        
        <button class="ncm-composer__toolbar-btn" data-action="insert-link" title="Insert Link" type="button">
          <i class="fas fa-link"></i>
        </button>
      </div>
    </div>
    
    {{!-- Content Editor --}}
    <div class="ncm-composer__editor" 
         contenteditable="true" 
         spellcheck="true"
         placeholder="Type your message here...">
      {{{messageData.content}}}
    </div>
  </div>
  
  {{!-- ENCRYPTION SECTION (if enabled) --}}
  {{#if allowMessageEncryption}}
  <div class="ncm-composer__encryption-section">
    <h3 class="ncm-composer__section-title">
      <i class="fas fa-lock"></i> Message Encryption
    </h3>
    
    <label class="ncm-composer__checkbox">
      <input type="checkbox" name="messageEncrypted" {{#if messageEncrypted}}checked{{/if}} />
      <span>Encrypt This Message</span>
    </label>
    
    <div class="ncm-composer__encryption-options" {{#unless messageEncrypted}}style="display: none;"{{/unless}}>
      <div class="ncm-composer__field">
        <label class="ncm-composer__label">Encryption Type</label>
        <select name="encryptionType" class="ncm-composer__select">
          {{#each encryptionTypes}}
          <option value="{{this.value}}" {{#if (eq ../encryptionType this.value)}}selected{{/if}}>
            {{this.label}}
          </option>
          {{/each}}
        </select>
      </div>
      
      <div class="ncm-composer__field">
        <label class="ncm-composer__label">Difficulty (DV)</label>
        <input type="number" name="encryptionDC" value="{{encryptionDC}}" min="9" max="29" class="ncm-composer__input" />
      </div>
    </div>
  </div>
  {{/if}}
  
  {{!-- FOOTER ACTIONS --}}
  <div class="ncm-composer__footer">
    <div class="ncm-composer__footer-left">
      <button type="button" class="ncm-btn" data-action="preview-message">
        <i class="fas fa-eye"></i> Preview
      </button>
    </div>
    
    <div class="ncm-composer__footer-right">
      <button type="button" class="ncm-btn ncm-btn--primary" data-action="add-message">
        <i class="fas fa-plus"></i> Add to Shard
      </button>
      
      <button type="button" class="ncm-btn" data-action="cancel">
        <i class="fas fa-times"></i> Cancel
      </button>
    </div>
  </div>
  
</div>