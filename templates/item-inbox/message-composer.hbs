{{!-- Data Shard Message Composer Template --}}
{{!-- File: templates/item-inbox/message-composer.hbs --}}

<form class="ncm-datashard-composer-form">
  
  {{!-- Template Selector --}}
  <div class="ncm-composer-section ncm-composer-templates">
    <label>Message Template (Optional)</label>
    <select class="ncm-template-select">
      <option value="">-- Blank Message --</option>
      {{#each templates}}
      <option value="{{id}}" {{#if (eq ../selectedTemplate.id id)}}selected{{/if}}>
        {{name}}
      </option>
      {{/each}}
    </select>
    <p class="ncm-help-text">Choose a pre-made template or start from scratch</p>
  </div>
  
  {{!-- From Field --}}
  <div class="ncm-composer-section">
    <label>From:</label>
    <div class="ncm-input-with-button">
      <input type="text" name="from" value="{{messageData.from}}" 
             placeholder="sender@nightcity.net" 
             {{#unless canEditAll}}disabled{{/unless}} />
      {{#if isGM}}
      <button type="button" class="ncm-quick-fill-from" title="Quick Fill">
        <i class="fas fa-user"></i>
      </button>
      {{/if}}
    </div>
    {{#unless isGM}}
    <p class="ncm-help-text">Your address: {{currentUserEmail}}</p>
    {{/unless}}
  </div>
  
  {{!-- To Field --}}
  <div class="ncm-composer-section">
    <label>To:</label>
    <div class="ncm-input-with-button">
      <input type="text" name="to" value="{{messageData.to}}" 
             placeholder="recipient@nightcity.net" />
      <button type="button" class="ncm-quick-fill-to" title="Quick Fill">
        <i class="fas fa-users"></i>
      </button>
    </div>
    <p class="ncm-help-text">Enter email address or select from list</p>
  </div>
  
  {{!-- Subject Field --}}
  <div class="ncm-composer-section">
    <label>Subject:</label>
    <input type="text" name="subject" value="{{messageData.subject}}" 
           placeholder="Enter subject..." />
  </div>
  
  {{!-- Date Field (GM only) --}}
  {{#if isGM}}
  <div class="ncm-composer-section">
    <label>Date/Time:</label>
    <input type="datetime-local" name="date" 
           value="{{messageData.date}}" />
    <p class="ncm-help-text">Set custom timestamp (leave blank for current time)</p>
  </div>
  {{/if}}
  
  {{!-- Content Editor --}}
  <div class="ncm-composer-section ncm-composer-content">
    <div class="ncm-editor-toolbar">
      <button type="button" class="ncm-format-bold" title="Bold">
        <i class="fas fa-bold"></i>
      </button>
      <button type="button" class="ncm-format-italic" title="Italic">
        <i class="fas fa-italic"></i>
      </button>
      <button type="button" class="ncm-format-code" title="Code">
        <i class="fas fa-code"></i>
      </button>
      <button type="button" class="ncm-format-header" title="Header">
        <i class="fas fa-heading"></i>
      </button>
      <div class="ncm-toolbar-separator"></div>
      <label>Insert Variable:</label>
      <button type="button" class="ncm-insert-variable" data-variable="playerName" title="Player Name">
        Player
      </button>
      <button type="button" class="ncm-insert-variable" data-variable="date" title="Date">
        Date
      </button>
      <button type="button" class="ncm-insert-variable" data-variable="randomEddies" title="Random Eddies">
        Eddies
      </button>
      <button type="button" class="ncm-insert-variable" data-variable="randomLocation" title="Random Location">
        Location
      </button>
    </div>
    
    <label>Message Content:</label>
    <textarea name="content" rows="12" placeholder="Enter message content...">{{messageData.content}}</textarea>
    
    <div class="ncm-editor-hints">
      <p><strong>Formatting:</strong> Use HTML tags or select text and click formatting buttons</p>
      <p><strong>Variables:</strong> Click variable buttons to insert (e.g., {{playerName}} → actual player name)</p>
    </div>
  </div>

  {{!-- Add this section BEFORE the buttons in your message-composer.hbs --}}

  {{#if allowMessageEncryption}}
  <div class="ncm-form-section ncm-encryption-section">
    <h3 class="ncm-section-title">
      <i class="fas fa-lock"></i>
      Message Encryption
    </h3>
    
    <div class="ncm-form-group">
      <label class="ncm-checkbox">
        <input type="checkbox" id="message-encrypted" name="messageEncrypted" {{checked messageEncrypted}} />
        <span class="ncm-checkbox-label">Encrypt This Message</span>
      </label>
      <p class="ncm-help-text">
        This message will require hacking to read its content
      </p>
    </div>
    
    <div class="ncm-encryption-options" style="{{#unless messageEncrypted}}display: none;{{/unless}}">
      
      <div class="ncm-form-group">
        <label class="ncm-label">Encryption Type</label>
        <select name="encryptionType" class="ncm-select">
          {{#each encryptionTypes}}
            <option value="{{this.value}}" {{selected (eq ../encryptionType this.value)}}>
              {{this.label}}
            </option>
          {{/each}}
        </select>
        <p class="ncm-help-text">
          <span class="ncm-text-warning">
            <i class="fas fa-skull"></i>
            BLACK/RED ICE can kill characters on failed hacks!
          </span>
        </p>
      </div>
      
      <div class="ncm-form-group">
        <label class="ncm-label">Encryption Difficulty (DV)</label>
        <div class="ncm-input-group">
          <input type="number" name="encryptionDC" value="{{encryptionDC}}" min="9" max="29" class="ncm-input" />
          <span class="ncm-input-suffix">DV</span>
        </div>
        <p class="ncm-help-text">
          Target number for skill checks (9=Easy, 15=Difficult, 21=Nearly Impossible)
        </p>
      </div>
      
      <div class="ncm-form-group">
        <label class="ncm-label">Allowed Skills (check multiple)</label>
        <div class="ncm-skill-checkboxes">
          <label class="ncm-checkbox ncm-skill-option">
            <input type="checkbox" name="allowedSkills" value="Interface" 
                   {{#if (includes allowedSkills "Interface")}}checked{{/if}} />
            <span class="ncm-checkbox-label">Interface</span>
          </label>
          <label class="ncm-checkbox ncm-skill-option">
            <input type="checkbox" name="allowedSkills" value="Electronics/Security Tech" 
                   {{#if (includes allowedSkills "Electronics/Security Tech")}}checked{{/if}} />
            <span class="ncm-checkbox-label">Electronics/Security Tech</span>
          </label>
          <label class="ncm-checkbox ncm-skill-option">
            <input type="checkbox" name="allowedSkills" value="Basic Tech" 
                   {{#if (includes allowedSkills "Basic Tech")}}checked{{/if}} />
            <span class="ncm-checkbox-label">Basic Tech</span>
          </label>
          <label class="ncm-checkbox ncm-skill-option">
            <input type="checkbox" name="allowedSkills" value="Cryptography" 
                   {{#if (includes allowedSkills "Cryptography")}}checked{{/if}} />
            <span class="ncm-checkbox-label">Cryptography</span>
          </label>
        </div>
      </div>
      
    </div>
  </div>
  {{else}}
    {{#if shardEncrypted}}
      <div class="ncm-info-box">
        <i class="fas fa-lock"></i>
        <p>This data shard uses shard-level encryption. All messages inherit the shard's encryption settings.</p>
      </div>
    {{/if}}
  {{/if}}
  
  {{!-- Actions --}}
  <div class="ncm-composer-actions">
    <button type="button" class="ncm-preview-message ncm-button-secondary">
      <i class="fas fa-eye"></i>
      Preview
    </button>
    <button type="button" class="ncm-save-draft ncm-button-secondary">
      <i class="fas fa-save"></i>
      Save Draft
    </button>
    <button type="button" class="ncm-send-message ncm-button-primary">
      <i class="fas fa-paper-plane"></i>
      Add to Data Shard
    </button>
  </div>
  
</form>