{{!-- Security Overlay: Network Layer (Sprint 4.6 Themed Redesign) --}}
<div class="ncm-security-overlay ncm-security-overlay-network">
  <div class="ncm-sec-backdrop ncm-sec-backdrop--static"></div>
  <div class="ncm-sec-card ncm-sec-animate-in">
    <div class="ncm-sec-icon ncm-sec-icon--network"><i class="fas fa-network-wired"></i></div>
    <div class="ncm-sec-title">Network Required</div>
    <div class="ncm-sec-info">This shard requires connection to:</div>
    <div class="ncm-sec-highlight">{{#if requiredNetworkName}}{{requiredNetworkName}}{{else}}Authorized Network{{/if}}</div>
    <div class="ncm-sec-info" style="margin-top:8px;">
      Current: <strong class="ncm-sec-text-danger">{{#if currentNetworkName}}{{currentNetworkName}}{{else}}None{{/if}}</strong>
      <span class="ncm-sec-text-muted">// Not authorized</span>
    </div>

    {{!-- Network Selector — switch network directly from overlay --}}
    {{#if availableNetworks.length}}
      <div class="ncm-sec-divider"></div>
      <div class="ncm-sec-section-label"><i class="fas fa-satellite-dish"></i> SWITCH NETWORK</div>
      <select data-field="networkSelector" class="ncm-sec-network-select">
        <option value="" disabled selected>Select a network...</option>
        {{#each availableNetworks}}
          <option value="{{id}}" {{#if isCurrent}}disabled{{/if}}>
            {{name}}{{#if isCurrent}} (current){{/if}}
          </option>
        {{/each}}
      </select>
      <div class="ncm-sec-muted">Switching network will apply globally.</div>
    {{/if}}

    {{#if hasSkills}}
      <div class="ncm-sec-divider"></div>
      <button type="button" data-action="hackLayer" data-layer="network" class="ncm-sec-btn ncm-sec-btn--primary" style="margin-top:4px;">
        <i class="fas fa-wifi"></i> Attempt Network Spoof
      </button>
      <div class="ncm-sec-muted">Use a skill check to bypass the network requirement.</div>
    {{/if}}
    {{#if isGM}}
      <div class="ncm-sec-gm">
        <div class="ncm-sec-gm-label">GM Controls</div>
        <button type="button" data-action="forceDecrypt" class="ncm-sec-btn ncm-sec-btn--gm">
          <i class="fas fa-unlock-keyhole"></i> Bypass All Security
        </button>
      </div>
    {{/if}}
  </div>
</div>
