{{!--
  Item Inbox Config — Sprint 4.6 Redesign (Tabbed)
  File: templates/item-inbox/item-inbox-config.hbs
  Module: cyberpunkred-messenger
  Tabs: Identity · Security · Network · Systems · Boot
--}}

{{#if hasItem}}
<div class="ncm-cfg" data-active-tab="identity">

  {{!-- TAB BAR --}}
  <div class="ncm-cfg-tabs">
    <button type="button" class="ncm-cfg-tab ncm-cfg-tab--active" data-action="switchTab" data-tab="identity"><i class="fas fa-id-badge"></i> Identity</button>
    <button type="button" class="ncm-cfg-tab" data-action="switchTab" data-tab="security"><i class="fas fa-shield-halved"></i> Security <span class="ncm-cfg-badge {{#if securityLayerCount}}ncm-cfg-badge--on{{/if}}">{{securityLayerCount}}</span></button>
    <button type="button" class="ncm-cfg-tab" data-action="switchTab" data-tab="network"><i class="fas fa-network-wired"></i> Network {{#if networkRequired}}<span class="ncm-cfg-badge ncm-cfg-badge--on">ON</span>{{/if}}</button>
    <button type="button" class="ncm-cfg-tab" data-action="switchTab" data-tab="systems"><i class="fas fa-gears"></i> Systems</button>
    <button type="button" class="ncm-cfg-tab" data-action="switchTab" data-tab="boot"><i class="fas fa-power-off"></i> Boot</button>
  </div>

  <div class="ncm-cfg-content">

    {{!-- ═══ TAB 1: IDENTITY ═══ --}}
    <div class="ncm-cfg-panel ncm-cfg-panel--active" data-panel="identity">

      <div class="ncm-cfg-item-box">
        <div class="ncm-cfg-item-img">{{#if itemImg}}<img src="{{itemImg}}" alt="">{{else}}<i class="fas fa-microchip"></i>{{/if}}</div>
        <div class="ncm-cfg-item-meta"><div class="ncm-cfg-item-name">{{itemName}}</div><div class="ncm-cfg-item-type">{{itemType}}</div></div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-palette ncm-cfg-section-icon" style="color:#a855f7"></i><div class="ncm-cfg-section-title">Preset & Theme</div></div>
        <div class="ncm-cfg-desc">Choose a visual theme. Applying loads default colors, boot, and icon. Customize after.</div>
        <div class="ncm-cfg-row">
          <span class="ncm-cfg-label">Preset</span>
          <select name="preset" class="ncm-cfg-select ncm-cfg-flex">{{#each presetOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
          <button type="button" data-action="applyPreset" class="ncm-cfg-btn-icon" title="Apply preset"><i class="fas fa-download"></i></button>
        </div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-fingerprint ncm-cfg-section-icon" style="color:#19f3f7"></i><div class="ncm-cfg-section-title">Shard Identity</div></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Display Name</span><input type="text" name="shardName" class="ncm-cfg-input ncm-cfg-flex" value="{{shardName}}" placeholder="Leave empty to use item name" /></div>
        <div class="ncm-cfg-row ncm-cfg-row--col"><span class="ncm-cfg-label">Description</span><textarea name="shardDescription" class="ncm-cfg-input ncm-cfg-textarea" placeholder="GM-only notes about this shard.">{{shardDescription}}</textarea></div>
        <div class="ncm-cfg-hint">GM-only. Use entries for player-visible content.</div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-tags ncm-cfg-section-icon" style="color:#f7c948"></i><div class="ncm-cfg-section-title">Metadata</div></div>
        <div class="ncm-cfg-desc">These fields appear in the shard header as provenance information — who made it, where it came from, when. All fields are <strong>optional</strong>. Players see these when viewing the shard.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Creator</span><input type="text" name="metaCreator" class="ncm-cfg-input ncm-cfg-flex" value="{{metaCreator}}" placeholder="Who created this" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Network Origin</span><input type="text" name="metaNetwork" class="ncm-cfg-input ncm-cfg-flex" value="{{metaNetwork}}" placeholder="Origin network" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Location</span><input type="text" name="metaLocation" class="ncm-cfg-input ncm-cfg-flex" value="{{metaLocation}}" placeholder="Origin location" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Timestamp</span><input type="datetime-local" name="metaTimestamp" class="ncm-cfg-input ncm-cfg-flex" value="{{metaTimestampLocal}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Classification</span><input type="text" name="metaClassification" class="ncm-cfg-input ncm-cfg-flex" value="{{metaClassification}}" placeholder="e.g. TOP SECRET" /></div>
        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Type Line</span><select name="typeLineMode" class="ncm-cfg-select ncm-cfg-flex"><option value="preset-status" {{#if typeLineModePresetStatus}}selected{{/if}}>Preset + Status</option><option value="status-only" {{#if typeLineModeStatusOnly}}selected{{/if}}>Status Only</option><option value="custom" {{#if typeLineModeCustom}}selected{{/if}}>Custom Text</option></select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Custom Text</span><input type="text" name="typeLineCustom" class="ncm-cfg-input ncm-cfg-flex" value="{{typeLineCustom}}" placeholder="Custom subtitle" /></div>
      </div>
    </div>

    {{!-- ═══ TAB 2: SECURITY ═══ --}}
    <div class="ncm-cfg-panel" data-panel="security">
      <div class="ncm-cfg-desc">Security layers are checked <strong>in order</strong> from left to right. A player must pass each enabled layer before reaching the shard data. Any layer can be <strong>hacked</strong> using the skills configured below, and each layer has its own failure consequences.</div>

      {{!-- Pipeline --}}
      <div class="ncm-cfg-pipeline">
        <div class="ncm-cfg-pipe-node"><div class="ncm-cfg-pipe-icon {{#if networkRequired}}ncm-cfg-pipe-icon--on{{/if}}"><i class="fas fa-network-wired"></i></div><div class="ncm-cfg-pipe-label {{#if networkRequired}}ncm-cfg-pipe-label--on{{/if}}">Network</div></div>
        <div class="ncm-cfg-pipe-arrow {{#if networkRequired}}ncm-cfg-pipe-arrow--on{{/if}}"><i class="fas fa-chevron-right"></i></div>
        <div class="ncm-cfg-pipe-node"><div class="ncm-cfg-pipe-icon {{#if requiresKeyItem}}ncm-cfg-pipe-icon--on{{/if}}"><i class="fas fa-id-card"></i></div><div class="ncm-cfg-pipe-label {{#if requiresKeyItem}}ncm-cfg-pipe-label--on{{/if}}">Key Item</div></div>
        <div class="ncm-cfg-pipe-arrow {{#if requiresKeyItem}}ncm-cfg-pipe-arrow--on{{/if}}"><i class="fas fa-chevron-right"></i></div>
        <div class="ncm-cfg-pipe-node"><div class="ncm-cfg-pipe-icon {{#if requiresLogin}}ncm-cfg-pipe-icon--on{{/if}}"><i class="fas fa-terminal"></i></div><div class="ncm-cfg-pipe-label {{#if requiresLogin}}ncm-cfg-pipe-label--on{{/if}}">Login</div></div>
        <div class="ncm-cfg-pipe-arrow {{#if requiresLogin}}ncm-cfg-pipe-arrow--on{{/if}}"><i class="fas fa-chevron-right"></i></div>
        <div class="ncm-cfg-pipe-node"><div class="ncm-cfg-pipe-icon {{#if isEncrypted}}ncm-cfg-pipe-icon--on{{/if}}"><i class="fas fa-shield-halved"></i></div><div class="ncm-cfg-pipe-label {{#if isEncrypted}}ncm-cfg-pipe-label--on{{/if}}">ICE</div></div>
        <div class="ncm-cfg-pipe-arrow"><i class="fas fa-chevron-right"></i></div>
        <div class="ncm-cfg-pipe-node"><div class="ncm-cfg-pipe-icon"><i class="fas fa-unlock"></i></div><div class="ncm-cfg-pipe-label">Data</div></div>
      </div>

      {{!-- Skills --}}
      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-dice-d20 ncm-cfg-section-icon" style="color:#a855f7"></i><div class="ncm-cfg-section-title">Hacking Skills</div></div>
        <div class="ncm-cfg-desc">These skills are available when a player attempts to hack <strong>any</strong> security layer. Each skill can have its own DV (difficulty value). When hacking, the player chooses which skill to roll, then rolls <strong>Stat + Skill + 1d10 vs DV</strong>.</div>
        <div class="ncm-cfg-skill-list">
          {{#each skillEntries}}
          <div class="ncm-cfg-skill-row" data-skill="{{name}}">
            <span class="ncm-cfg-skill-name">{{name}} <small>({{stat}})</small></span>
            <span class="ncm-cfg-skill-dv-label">DV</span>
            <input type="number" name="skillDC-{{name}}" value="{{dc}}" min="1" max="30" class="ncm-cfg-skill-dv" />
            <button type="button" class="ncm-cfg-btn-icon ncm-cfg-btn-icon--danger" data-action="removeSkill" data-skill="{{name}}"><i class="fas fa-times"></i></button>
          </div>
          {{/each}}
        </div>
        <div class="ncm-cfg-row" style="margin-top:6px"><select name="newSkill" class="ncm-cfg-select ncm-cfg-flex"><option value="">— Add Skill —</option>{{#each allSkills}}<option value="{{this}}">{{this}}</option>{{/each}}</select><button type="button" data-action="addSkill" class="ncm-cfg-btn-sm"><i class="fas fa-plus"></i> Add</button></div>
      </div>

      {{!-- Layer 1: Network --}}
      <div class="ncm-cfg-layer {{#if networkRequired}}ncm-cfg-layer--enabled{{/if}}" style="border-left-color:#19f3f7">
        <div class="ncm-cfg-layer-header"><i class="fas fa-network-wired ncm-cfg-layer-icon" style="color:#19f3f7"></i><div class="ncm-cfg-layer-title">① Network</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="networkRequired" {{#if networkRequired}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">Full config on <strong>Network</strong> tab.</div>
        <div class="ncm-cfg-consequence"><div class="ncm-cfg-consequence-label"><i class="fas fa-skull"></i> Hack Failure</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Max</span><input type="number" name="networkHackMaxAttempts" class="ncm-cfg-input ncm-cfg-input--short" value="{{networkHackMaxAttempts}}" min="1" max="10" /><span class="ncm-cfg-label" style="min-width:auto">then</span><select name="networkHackFailureMode" class="ncm-cfg-select ncm-cfg-flex">{{#each layerFailureModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></div>
        </div>
      </div>

      {{!-- Layer 2: Key Item --}}
      <div class="ncm-cfg-layer {{#if requiresKeyItem}}ncm-cfg-layer--enabled{{/if}}" style="border-left-color:#f7c948">
        <div class="ncm-cfg-layer-header"><i class="fas fa-id-card ncm-cfg-layer-icon" style="color:#f7c948"></i><div class="ncm-cfg-layer-title">② Key Item</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="requiresKeyItem" {{#if requiresKeyItem}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">Requires the player to have a specific item in their character's inventory. Choose the item below, configure what the player sees on the security overlay, and set behavior options for what happens when the item is presented.</div>

        {{!-- Item Picker --}}
        {{#if keyItemName}}
        <div class="ncm-cfg-item-picker" data-key-item-filled>
          <div class="ncm-cfg-ip-img">{{#if keyItemImg}}<img src="{{keyItemImg}}" alt="">{{else}}<i class="fas fa-cube"></i>{{/if}}</div>
          <div class="ncm-cfg-ip-meta">
            <div class="ncm-cfg-ip-name">{{keyItemName}}</div>
            {{#if keyItemId}}<div class="ncm-cfg-ip-id">ID: {{keyItemId}}</div>{{/if}}
            <div class="ncm-cfg-ip-actions"><button type="button" data-action="searchKeyItem" class="ncm-cfg-ip-btn ncm-cfg-ip-btn--search"><i class="fas fa-magnifying-glass"></i> Change</button><button type="button" data-action="clearKeyItem" class="ncm-cfg-ip-btn ncm-cfg-ip-btn--clear"><i class="fas fa-times"></i> Clear</button></div>
          </div>
        </div>
        {{else}}
        <div class="ncm-cfg-item-picker-empty" data-action="searchKeyItem"><div class="ncm-cfg-ipe-icon"><i class="fas fa-magnifying-glass"></i></div><div class="ncm-cfg-ipe-text">Click to search items</div></div>
        {{/if}}
        <input type="hidden" name="keyItemName" value="{{keyItemName}}" /><input type="hidden" name="keyItemId" value="{{keyItemId}}" /><input type="hidden" name="keyItemImg" value="{{keyItemImg}}" />
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Match Tag</span><input type="text" name="keyItemTag" class="ncm-cfg-input ncm-cfg-flex" value="{{keyItemTag}}" placeholder="Optional tag" /></div>

        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Overlay Title</span><input type="text" name="keyItemDisplayName" class="ncm-cfg-input ncm-cfg-flex" value="{{keyItemDisplayName}}" placeholder="What player sees" /></div>
        <div class="ncm-cfg-row ncm-cfg-row--col" style="margin:6px 0">
          <span class="ncm-cfg-label" style="margin-bottom:4px">Overlay Icon <span class="ncm-cfg-hint" style="display:inline;margin:0">(security screen icon)</span></span>
          <div class="ncm-cfg-icon-grid" data-target="keyItemIcon">
            {{#each keyItemIconOptions}}<div class="ncm-cfg-ig-item {{#if selected}}ncm-cfg-ig-item--active{{/if}}" data-action="selectIcon" data-icon="{{value}}" data-target="keyItemIcon"><i class="{{value}}"></i></div>{{/each}}
          </div>
          <input type="hidden" name="keyItemIcon" value="{{keyItemIcon}}" />
        </div>

        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-step-label"><i class="fas fa-sliders" style="color:#f7c948"></i> Token Behavior</div>
        <div class="ncm-cfg-desc">Controls what happens when the player presents the correct item. <strong>Bypass</strong> options skip subsequent security layers entirely. <strong>Consume</strong> deletes the item from inventory after use.</div>
        <div class="ncm-cfg-row ncm-cfg-row--col" style="gap:8px">
          <label class="ncm-cfg-check"><input type="checkbox" name="keyItemBypassLogin" {{#if keyItemBypassLogin}}checked{{/if}} /> Skip login layer when item is presented</label>
          <label class="ncm-cfg-check"><input type="checkbox" name="keyItemBypassEncryption" {{#if keyItemBypassEncryption}}checked{{/if}} /> Skip encryption (ICE) layer too</label>
          <label class="ncm-cfg-check"><input type="checkbox" name="keyItemConsumeOnUse" {{#if keyItemConsumeOnUse}}checked{{/if}} /> Delete item from inventory after use</label>
        </div>
        <div class="ncm-cfg-consequence"><div class="ncm-cfg-consequence-label"><i class="fas fa-skull"></i> Hack Failure</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Max</span><input type="number" name="keyitemHackMaxAttempts" class="ncm-cfg-input ncm-cfg-input--short" value="{{keyitemHackMaxAttempts}}" min="1" max="10" /><span class="ncm-cfg-label" style="min-width:auto">then</span><select name="keyitemHackFailureMode" class="ncm-cfg-select ncm-cfg-flex">{{#each layerFailureModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></div>
        </div>
      </div>

      {{!-- Layer 3: Login --}}
      <div class="ncm-cfg-layer {{#if requiresLogin}}ncm-cfg-layer--enabled{{/if}}" style="border-left-color:#00ff41">
        <div class="ncm-cfg-layer-header"><i class="fas fa-terminal ncm-cfg-layer-icon" style="color:#00ff41"></i><div class="ncm-cfg-layer-title">③ Login</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="requiresLogin" {{#if requiresLogin}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">Presents a login terminal where players type a username and password. They can enter credentials directly (if they found them in-game) or attempt to <strong>brute force</strong> using a skill check. Failed login attempts count separately from hack attempts.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Display Name</span><input type="text" name="loginDisplayName" class="ncm-cfg-input ncm-cfg-flex" value="{{loginDisplayName}}" placeholder="Login screen title" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Username</span><input type="text" name="loginUsername" class="ncm-cfg-input ncm-cfg-flex" value="{{loginUsername}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Password</span><input type="text" name="loginPassword" class="ncm-cfg-input ncm-cfg-flex" value="{{loginPassword}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Login Attempts</span><input type="number" name="maxLoginAttempts" class="ncm-cfg-input ncm-cfg-input--short" value="{{maxLoginAttempts}}" min="1" max="10" /></div>
        <div class="ncm-cfg-consequence"><div class="ncm-cfg-consequence-label"><i class="fas fa-skull"></i> Hack Failure</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Max</span><input type="number" name="loginHackMaxAttempts" class="ncm-cfg-input ncm-cfg-input--short" value="{{loginHackMaxAttempts}}" min="1" max="10" /><span class="ncm-cfg-label" style="min-width:auto">then</span><select name="loginHackFailureMode" class="ncm-cfg-select ncm-cfg-flex">{{#each layerFailureModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></div>
        </div>
      </div>

      {{!-- Layer 4: Encryption --}}
      <div class="ncm-cfg-layer {{#if isEncrypted}}ncm-cfg-layer--enabled{{/if}}" style="border-left-color:#ff0033">
        <div class="ncm-cfg-layer-header"><i class="fas fa-shield-halved ncm-cfg-layer-icon" style="color:#ff0033"></i><div class="ncm-cfg-layer-title">④ Encryption (ICE)</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="encrypted" {{#if isEncrypted}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">The final security layer. Players see an animated hacking terminal where they select a skill and roll to breach the encryption. <strong>Standard ICE</strong> has no damage penalty. <strong>BLACK ICE</strong> deals 3d6 damage on failure. <strong>RED ICE</strong> deals 5d6 lethal damage — and can kill.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">ICE Type</span><select name="encryptionType" class="ncm-cfg-select ncm-cfg-flex">{{#each encryptionTypes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></div>

        {{!-- BLACK ICE Source --}}
        <div class="ncm-cfg-ice-source" data-ice-source>
          <div class="ncm-cfg-ice-modes">
            <div class="ncm-cfg-ice-card {{#if iceSourceDefault}}ncm-cfg-ice-card--sel{{/if}}" data-action="selectIceMode" data-mode="default"><i class="fas fa-dice"></i><span>Default</span></div>
            <div class="ncm-cfg-ice-card {{#if iceSourceCustom}}ncm-cfg-ice-card--sel{{/if}}" data-action="selectIceMode" data-mode="custom"><i class="fas fa-pen-fancy"></i><span>Custom</span></div>
            <div class="ncm-cfg-ice-card {{#if iceSourceActor}}ncm-cfg-ice-card--sel{{/if}}" data-action="selectIceMode" data-mode="actor"><i class="fas fa-robot"></i><span>Actor</span></div>
          </div>
          <input type="hidden" name="iceSource" value="{{iceSource}}" />

          <div class="ncm-cfg-ice-panel {{#if iceSourceDefault}}ncm-cfg-ice-panel--on{{/if}}" data-ice-panel="default">
            <div class="ncm-cfg-dmg-preview"><span class="ncm-cfg-dmg-dice" data-dmg-dice>{{iceDamageDice}}</span><span class="ncm-cfg-dmg-label">damage on failure</span></div>
          </div>
          <div class="ncm-cfg-ice-panel {{#if iceSourceCustom}}ncm-cfg-ice-panel--on{{/if}}" data-ice-panel="custom">
            <div class="ncm-cfg-row"><span class="ncm-cfg-label">ICE Name</span><input type="text" name="iceCustomName" class="ncm-cfg-input ncm-cfg-flex" value="{{iceCustomName}}" placeholder="e.g. HELLHOUND" /></div>
            <div class="ncm-cfg-row"><span class="ncm-cfg-label">Portrait</span><input type="text" name="iceCustomPortrait" class="ncm-cfg-input ncm-cfg-flex" value="{{iceCustomPortrait}}" /><button type="button" data-action="browseImage" data-target="iceCustomPortrait" class="ncm-cfg-btn-icon"><i class="fas fa-folder-open"></i></button></div>
            <div class="ncm-cfg-row"><span class="ncm-cfg-label">Damage</span><input type="text" name="iceCustomDamage" class="ncm-cfg-input ncm-cfg-input--short" value="{{iceCustomDamage}}" placeholder="3d6" style="width:80px" /></div>
          </div>
          <div class="ncm-cfg-ice-panel {{#if iceSourceActor}}ncm-cfg-ice-panel--on{{/if}}" data-ice-panel="actor">
            <div class="ncm-cfg-actor-grid">
              {{#each blackIceActors}}<div class="ncm-cfg-actor-card {{#if selected}}ncm-cfg-actor-card--sel{{/if}}" data-action="selectIceActor" data-actor-id="{{id}}"><div class="ncm-cfg-actor-img">{{#if img}}<img src="{{img}}" alt="">{{else}}<i class="fas fa-robot"></i>{{/if}}</div><div class="ncm-cfg-actor-name">{{name}}</div></div>{{else}}<div class="ncm-cfg-hint" style="padding:8px;text-align:center;width:100%">No Black ICE actors found.</div>{{/each}}
            </div>
            <input type="hidden" name="iceActorId" value="{{iceActorId}}" />
          </div>
        </div>

        <div class="ncm-cfg-row" style="margin-top:8px"><span class="ncm-cfg-label">Default DV</span><input type="number" name="encryptionDC" class="ncm-cfg-input ncm-cfg-input--short" value="{{encryptionDC}}" min="1" max="30" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Decrypt Mode</span><select name="encryptionMode" class="ncm-cfg-select ncm-cfg-flex"><option value="shard" {{#if encryptionModeShard}}selected{{/if}}>Shard-level</option><option value="message" {{#if encryptionModeMessage}}selected{{/if}}>Per-entry</option></select></div>
        <div class="ncm-cfg-consequence"><div class="ncm-cfg-consequence-label"><i class="fas fa-skull"></i> Breach Failure</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Max</span><input type="number" name="maxHackAttempts" class="ncm-cfg-input ncm-cfg-input--short" value="{{maxHackAttempts}}" min="1" max="10" /><span class="ncm-cfg-label" style="min-width:auto">then</span><select name="failureMode" class="ncm-cfg-select ncm-cfg-flex">{{#each failureModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Lockout</span><input type="number" name="lockoutMinutes" class="ncm-cfg-input ncm-cfg-input--short" value="{{lockoutMinutes}}" min="1" max="1440" /><span class="ncm-cfg-hint" style="margin:0">min</span></div>
        </div>
      </div>
    </div>

    {{!-- ═══ TAB 3: NETWORK ═══ --}}
    <div class="ncm-cfg-panel" data-panel="network">
      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-wifi ncm-cfg-section-icon" style="color:#19f3f7"></i><div class="ncm-cfg-section-title">Network Access</div></div>
        <div class="ncm-cfg-desc">When enabled, the shard checks what network the player is currently connected to. If they're on the wrong network, they see a locked overlay and can either <strong>switch to a valid network</strong> or <strong>hack past</strong> the restriction using a skill check.</div>

        <div class="ncm-cfg-step-label"><i class="fas fa-key" style="color:#19f3f7"></i> Who can access?</div>
        <div class="ncm-cfg-access-modes">
          <div class="ncm-cfg-am-card {{#if accessModeAny}}ncm-cfg-am-card--sel{{/if}}" data-action="selectAccessMode" data-mode="any"><div class="ncm-cfg-am-icon"><i class="fas fa-globe"></i></div><div class="ncm-cfg-am-title">Open</div><div class="ncm-cfg-am-desc">Any network</div></div>
          <div class="ncm-cfg-am-card {{#if accessModeWhitelist}}ncm-cfg-am-card--sel{{/if}}" data-action="selectAccessMode" data-mode="whitelist"><div class="ncm-cfg-am-icon"><i class="fas fa-list-check"></i></div><div class="ncm-cfg-am-title">Specific</div><div class="ncm-cfg-am-desc">Whitelisted only</div></div>
          <div class="ncm-cfg-am-card {{#if accessModeType}}ncm-cfg-am-card--sel{{/if}}" data-action="selectAccessMode" data-mode="type"><div class="ncm-cfg-am-icon"><i class="fas fa-layer-group"></i></div><div class="ncm-cfg-am-title">By Type</div><div class="ncm-cfg-am-desc">e.g. CORPORATE</div></div>
        </div>
        <input type="hidden" name="accessMode" value="{{accessModeValue}}" />

        <div data-net-section="whitelist" {{#if accessModeAny}}style="display:none"{{/if}}>
          <div class="ncm-cfg-step-label"><i class="fas fa-network-wired" style="color:#19f3f7"></i> Allowed networks</div>
          <div class="ncm-cfg-hint" style="margin-bottom:6px">Click to toggle. Highlighted = access granted.</div>
          <div class="ncm-cfg-net-grid">
            {{#each networkOptions}}<div class="ncm-cfg-net-card {{#if selected}}ncm-cfg-net-card--on{{/if}}" data-action="toggleNetwork" data-net-id="{{value}}"><div class="ncm-cfg-net-icon" style="color:{{color}}"><i class="fas {{icon}}"></i></div><div class="ncm-cfg-net-name">{{label}}</div><div class="ncm-cfg-net-type">{{type}}</div></div>{{/each}}
          </div>
          <div id="ncm-network-hidden-inputs">{{#each networkOptions}}{{#if selected}}<input type="hidden" name="allowedNetwork" value="{{value}}" data-net-hidden="{{value}}" />{{/if}}{{/each}}</div>
        </div>

        <div data-net-section="type" {{#unless accessModeType}}style="display:none"{{/unless}}>
          <div class="ncm-cfg-step-label"><i class="fas fa-layer-group" style="color:#19f3f7"></i> Allowed network types</div>
          <div class="ncm-cfg-type-cards">
            {{#each networkTypeChecks}}
              <div class="ncm-cfg-type-card {{#if checked}}ncm-cfg-type-card--on{{/if}}" data-action="toggleNetworkType" data-type-value="{{value}}">
                <i class="fas fa-tag" style="font-size:9px"></i> {{label}}
              </div>
            {{/each}}
          </div>
          {{!-- Hidden checkboxes for form collection --}}
          <div style="display:none">{{#each networkTypeChecks}}<input type="checkbox" name="allowedType" value="{{value}}" {{#if checked}}checked{{/if}} />{{/each}}</div>
        </div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-plug ncm-cfg-section-icon" style="color:#f7c948"></i><div class="ncm-cfg-section-title">Connection</div></div>
        <div class="ncm-cfg-step-label"><i class="fas fa-plug" style="color:#f7c948"></i> After connecting?</div>
        <div class="ncm-cfg-conn-modes">
          <div class="ncm-cfg-cm-card {{#if connectionModeOffline}}ncm-cfg-cm-card--sel{{/if}}" data-action="selectConnMode" data-mode="offline">
            <div class="ncm-cfg-cm-title"><i class="fas fa-plug-circle-check"></i> Check Once</div>
            <div class="ncm-cfg-cm-desc">Verified on open. Can switch after.</div>
          </div>
          <div class="ncm-cfg-cm-card {{#if connectionModeTethered}}ncm-cfg-cm-card--sel{{/if}}" data-action="selectConnMode" data-mode="tethered">
            <div class="ncm-cfg-cm-title"><i class="fas fa-link"></i> Live Tether</div>
            <div class="ncm-cfg-cm-desc">Disconnect = "Connection Lost".</div>
          </div>
        </div>
        <input type="hidden" name="connectionMode" value="{{connectionModeValue}}" />
        <div class="ncm-cfg-desc"><strong>Min Signal</strong> sets the minimum signal strength needed to maintain access. Below this threshold, tethered connections drop. <strong>Signal → DV</strong> makes weak signals increase the difficulty of hack rolls. <strong>Degradation</strong> means signal weakens the longer the player stays connected.</div>
        <div class="ncm-cfg-row" style="margin-top:4px"><span class="ncm-cfg-label">Min Signal</span><input type="number" name="signalThreshold" class="ncm-cfg-input ncm-cfg-input--short" value="{{signalThreshold}}" min="0" max="100" /><span class="ncm-cfg-hint" style="margin:0">% — tethered connections drop below this</span></div>
        <div class="ncm-cfg-row ncm-cfg-row--col" style="gap:8px;margin-top:6px">
          <label class="ncm-cfg-check"><input type="checkbox" name="signalDVModifier" {{#if signalDVModifier}}checked{{/if}} /> Weak signal increases hack difficulty (DV modifier)</label>
          <label class="ncm-cfg-check"><input type="checkbox" name="signalDegradation" {{#if signalDegradation}}checked{{/if}} /> Signal weakens over time while connected</label>
        </div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-satellite-dish ncm-cfg-section-icon" style="color:#ff6600"></i><div class="ncm-cfg-section-title">Tracing</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="tracingEnabled" {{#if tracingEnabled}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">When enabled, accessing this shard creates a digital footprint. The GM receives a whisper with details about who accessed the shard and when. Depending on <strong>Visibility</strong>, the player may not know they've been traced, may get a vague warning, or see the full trace alert. <strong>Trigger</strong> controls whether the trace fires on any access, only hack attempts, or only failed hacks.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Visibility</span><select name="tracingMode" class="ncm-cfg-select ncm-cfg-flex"><option value="silent" {{#if tracingModeSilent}}selected{{/if}}>Silent — GM sees, player doesn't</option><option value="warned" {{#if tracingModeWarned}}selected{{/if}}>Warned — player gets ambiguous alert</option><option value="visible" {{#if tracingModeVisible}}selected{{/if}}>Visible — player sees full trace</option></select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Trigger</span><select name="tracingTriggerOn" class="ncm-cfg-select ncm-cfg-flex"><option value="access" {{#if (eq tracingTriggerOn 'access')}}selected{{/if}}>Any access to shard</option><option value="hack-attempt" {{#if (eq tracingTriggerOn 'hack-attempt')}}selected{{/if}}>Hack attempt only</option><option value="hack-fail" {{#if (eq tracingTriggerOn 'hack-fail')}}selected{{/if}}>Failed hack only</option></select></div>
        <div class="ncm-cfg-row ncm-cfg-row--col" style="gap:8px;margin-top:4px"><label class="ncm-cfg-check"><input type="checkbox" name="tracingRevealIdentity" {{#if tracingRevealIdentity}}checked{{/if}} /> Trace reveals the player's character name</label><label class="ncm-cfg-check"><input type="checkbox" name="tracingRevealLocation" {{#if tracingRevealLocation}}checked{{/if}} /> Trace reveals the player's current location</label></div>
      </div>
    </div>

    {{!-- ═══ TAB 4: SYSTEMS ═══ --}}
    <div class="ncm-cfg-panel" data-panel="systems">
      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-heart-crack ncm-cfg-section-icon" style="color:#ff4444"></i><div class="ncm-cfg-section-title">Integrity</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="integrityEnabled" {{#if integrityEnabled}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">Tracks how damaged the shard data is. Failed hack attempts degrade integrity. When integrity drops below the <strong>Corrupt Below</strong> threshold, individual entries have a chance to become corrupted. <strong>Cosmetic</strong> mode shows visual glitches (scanlines, garbled text) but data remains readable. <strong>Mechanical</strong> mode can make entries actually unreadable or hide them entirely.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Mode</span><select name="integrityMode" class="ncm-cfg-select ncm-cfg-flex"><option value="cosmetic" {{#if integrityModeCosmetic}}selected{{/if}}>Cosmetic</option><option value="mechanical" {{#if integrityModeMechanical}}selected{{/if}}>Mechanical</option></select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Max</span><input type="number" name="integrityMax" class="ncm-cfg-input ncm-cfg-input--short" value="{{integrityMax}}" min="10" max="100" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Degrade/Fail</span><input type="number" name="integrityDegradePerFailure" class="ncm-cfg-input ncm-cfg-input--short" value="{{integrityDegradePerFailure}}" min="1" max="50" /><span class="ncm-cfg-hint" style="margin:0">pts</span></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Corrupt Below</span><input type="number" name="integrityCorruptionThreshold" class="ncm-cfg-input ncm-cfg-input--short" value="{{integrityCorruptionThreshold}}" min="0" max="100" /><span class="ncm-cfg-hint" style="margin:0">%</span></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Corrupt %</span><input type="number" name="integrityCorruptionChance" class="ncm-cfg-input ncm-cfg-input--short" value="{{integrityCorruptionChance}}" min="0" max="100" step="5" /></div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-clock ncm-cfg-section-icon" style="color:#f7c948"></i><div class="ncm-cfg-section-title">Expiration</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="expirationEnabled" {{#if expirationEnabled}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">Makes the shard self-destruct after a condition is met. <strong>Timer</strong> starts a real-world countdown from the first time any player opens the shard. <strong>Calendar</strong> expires at a specific in-game date (requires SimpleCalendar). <strong>On-Access</strong> expires after the shard has been opened a set number of times across all players.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Mode</span><select name="expirationMode" class="ncm-cfg-select ncm-cfg-flex"><option value="timer" {{#if expirationModeTimer}}selected{{/if}}>Timer</option><option value="calendar" {{#if expirationModeCalendar}}selected{{/if}}>Calendar</option><option value="on-access" {{#if expirationModeAccess}}selected{{/if}}>On-Access</option></select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Duration (hrs)</span><input type="number" name="expirationHours" class="ncm-cfg-input ncm-cfg-input--short" value="{{expirationHours}}" min="1" max="720" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Access Count</span><input type="number" name="expirationAccessCount" class="ncm-cfg-input ncm-cfg-input--short" value="{{expirationAccessCount}}" min="1" max="100" /></div>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-bell ncm-cfg-section-icon" style="color:#a855f7"></i><div class="ncm-cfg-section-title">Notifications & Display</div></div>
        <div class="ncm-cfg-desc">Controls what happens when a player accesses this shard. <strong>GM whisper</strong> sends a chat notification only the GM sees. <strong>NPC notify</strong> triggers an in-character contact notification as if an NPC detected the access.</div>
        <div class="ncm-cfg-row ncm-cfg-row--col" style="gap:8px">
          <label class="ncm-cfg-check"><input type="checkbox" name="notifyGM" {{#if notifyGM}}checked{{/if}} /> Whisper GM when any player opens this shard</label>
          <label class="ncm-cfg-check"><input type="checkbox" name="notifyContact" {{#if notifyContact}}checked{{/if}} /> Send an NPC contact notification on access</label>
        </div>
        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-desc"><strong>Single entry mode</strong> hides the entry list and shows just one content block. Useful for shards that contain a single document, image, or message.</div>
        <label class="ncm-cfg-check"><input type="checkbox" name="singleMessage" {{#if singleMessage}}checked{{/if}} /> Single entry mode (skip the entry list)</label>
      </div>

      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-link ncm-cfg-section-icon" style="color:#19f3f7"></i><div class="ncm-cfg-section-title">Linked Shards</div></div>
        <div class="ncm-cfg-desc">Creates a breadcrumb trail between shards. When a player finishes reading this shard, a link appears pointing them to the next one in the chain. Useful for multi-part intel drops or quest progressions.</div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Links To</span><input type="text" name="linkedShardId" class="ncm-cfg-input ncm-cfg-flex" placeholder="Item ID or name of next shard" /></div>
      </div>
    </div>

    {{!-- ═══ TAB 5: BOOT ═══ --}}
    <div class="ncm-cfg-panel" data-panel="boot">
      <div class="ncm-cfg-section">
        <div class="ncm-cfg-section-header"><i class="fas fa-power-off ncm-cfg-section-icon" style="color:#00ff41"></i><div class="ncm-cfg-section-title">Boot Sequence</div><label class="ncm-cfg-toggle-label"><input type="checkbox" name="bootEnabled" {{#if bootEnabled}}checked{{/if}} /></label></div>
        <div class="ncm-cfg-desc">The boot animation plays once when a player first opens this shard. It shows the shard's icon, title, a progress bar, and optional terminal-style log lines. The animation style and timing are determined by the selected <strong>preset</strong> — switch presets to get different animations. Use <strong>Preview</strong> at the bottom to test.</div>

        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Icon Source</span><select name="bootIconMode" class="ncm-cfg-select ncm-cfg-flex" data-action="changeIconMode" data-group="bootIcon"><option value="fa" {{#if bootIconModeFa}}selected{{/if}}>FontAwesome</option><option value="image" {{#if bootIconModeImage}}selected{{/if}}>Image</option><option value="item" {{#if bootIconModeItem}}selected{{/if}}>Item Default</option></select></div>

        <div class="ncm-cfg-icon-mode-section" data-icon-mode="fa" {{#unless bootIconModeFa}}style="display:none"{{/unless}}>
          <div class="ncm-cfg-row ncm-cfg-row--col" style="margin:6px 0"><span class="ncm-cfg-label" style="margin-bottom:4px">Icon</span>
          <div class="ncm-cfg-icon-grid" data-target="bootFaIcon">{{#each bootIconOptions}}<div class="ncm-cfg-ig-item {{#if selected}}ncm-cfg-ig-item--active{{/if}}" data-action="selectIcon" data-icon="{{value}}" data-target="bootFaIcon"><i class="{{value}}"></i></div>{{/each}}</div>
          <input type="hidden" name="bootFaIcon" value="{{bootFaIconCustom}}" /></div>
          <div class="ncm-cfg-row"><span class="ncm-cfg-label">Custom FA</span><input type="text" name="bootFaIconManual" class="ncm-cfg-input ncm-cfg-flex" placeholder="fas fa-custom" /></div>
          <div class="ncm-cfg-row"><span class="ncm-cfg-label">Color</span><div class="ncm-cfg-color-dots">{{#each iconColorOptions}}<div class="ncm-cfg-color-dot {{#if isActive}}ncm-cfg-color-dot--active{{/if}}" style="background:{{hex}}" data-action="selectIconColor" data-color="{{hex}}" data-target="bootIconColor"></div>{{/each}}</div><input type="hidden" name="bootIconColor" value="{{bootIconColor}}" /></div>
        </div>
        <div class="ncm-cfg-icon-mode-section" data-icon-mode="image" {{#unless bootIconModeImage}}style="display:none"{{/unless}}>
          <div class="ncm-cfg-row"><span class="ncm-cfg-label">Image</span><input type="text" name="bootImageUrl" class="ncm-cfg-input ncm-cfg-flex" value="{{bootImageUrl}}" /><button type="button" data-action="browseImage" data-target="bootImageUrl" class="ncm-cfg-btn-icon"><i class="fas fa-folder-open"></i></button></div>
          <div class="ncm-cfg-row"><span class="ncm-cfg-label">Size</span><input type="number" name="bootImageSize" class="ncm-cfg-input ncm-cfg-input--short" value="{{bootImageSize}}" min="32" max="128" /></div>
        </div>
        <div class="ncm-cfg-icon-mode-section" data-icon-mode="item" {{#unless bootIconModeItem}}style="display:none"{{/unless}}><div class="ncm-cfg-hint">Uses item's default image.</div></div>

        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Title</span><input type="text" name="bootTitle" class="ncm-cfg-input ncm-cfg-flex" value="{{bootTitle}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Subtitle</span><input type="text" name="bootSubtitle" class="ncm-cfg-input ncm-cfg-flex" value="{{bootSubtitle}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Progress</span><input type="text" name="bootProgressLabel" class="ncm-cfg-input ncm-cfg-flex" value="{{bootProgressLabel}}" /></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Speed</span><select name="bootSpeed" class="ncm-cfg-select ncm-cfg-flex"><option value="fast" {{#if bootSpeedFast}}selected{{/if}}>Fast</option><option value="normal" {{#if bootSpeedNormal}}selected{{/if}}>Normal</option><option value="dramatic" {{#if bootSpeedDramatic}}selected{{/if}}>Dramatic</option><option value="custom" {{#if bootSpeedCustom}}selected{{/if}}>Custom</option></select></div>
        <div class="ncm-cfg-row"><span class="ncm-cfg-label">Custom sec</span><input type="number" name="bootCustomSeconds" class="ncm-cfg-input ncm-cfg-input--short" value="{{bootCustomSeconds}}" min="0.5" max="30" step="0.5" /></div>

        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-row ncm-cfg-row--col"><span class="ncm-cfg-label" style="margin-bottom:4px">Boot Log Lines</span>
        <div class="ncm-cfg-boot-log-list">{{#each bootLogLines}}<div class="ncm-cfg-boot-log-entry"><input type="text" name="bootLogLine" class="ncm-cfg-input" value="{{this}}" /><button type="button" class="ncm-cfg-btn-icon ncm-cfg-btn-icon--danger" data-action="removeBootLogLine"><i class="fas fa-times"></i></button></div>{{/each}}</div>
        <button type="button" data-action="addBootLogLine" class="ncm-cfg-btn-sm" style="margin-top:4px"><i class="fas fa-plus"></i> Add</button></div>

        <div class="ncm-cfg-divider"></div>
        <div class="ncm-cfg-preview-section">
          <div class="ncm-cfg-preview-bar"><span class="ncm-cfg-preview-label"><i class="fas fa-eye"></i> Preview</span><button type="button" data-action="previewBoot" class="ncm-cfg-preview-btn"><i class="fas fa-play"></i> Preview Boot</button></div>
          <div class="ncm-cfg-preview-frame" data-boot-preview><div class="ncm-cfg-pf-idle">Click Preview to test</div></div>
        </div>
      </div>
    </div>

  </div>

  {{!-- Footer --}}
  <div class="ncm-cfg-footer">
    <button type="button" data-action="relockShard" class="ncm-cfg-footer-btn ncm-cfg-footer-btn--danger"><i class="fas fa-lock"></i> Relock</button>
    <button type="button" data-action="resetDefaults" class="ncm-cfg-footer-btn ncm-cfg-footer-btn--secondary"><i class="fas fa-undo"></i> Reset</button>
    <button type="button" data-action="saveConfig" class="ncm-cfg-footer-btn ncm-cfg-footer-btn--primary"><i class="fas fa-save"></i> Save</button>
  </div>
</div>
{{else}}
<p style="padding:20px;text-align:center;color:var(--ncm-text-muted);">No item selected or not GM.</p>
{{/if}}