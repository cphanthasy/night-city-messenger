{{!-- Item Inbox Config — GM Shard Configuration --}}
{{#if hasItem}}
<form class="ncm-shard-config" autocomplete="off">
  <h3 class="ncm-config-title"><i class="fas fa-microchip"></i> {{itemName}}</h3>

  {{!-- Encryption Section --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-shield-halved"></i> Encryption</legend>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="encrypted" {{#if isEncrypted}}checked{{/if}} /> Enable Encryption</label>
    </div>
    <div class="ncm-form-row">
      <label>Type:
        <select name="encryptionType">
          {{#each encryptionTypes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
    <div class="ncm-form-row">
      <label>Default DV: <input type="number" name="encryptionDC" value="{{encryptionDC}}" min="1" max="30" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Mode:
        <select name="encryptionMode">
          <option value="shard" {{#if encryptionModeShard}}selected{{/if}}>Shard-level (decrypt once)</option>
          <option value="message" {{#if encryptionModeMessage}}selected{{/if}}>Per-message</option>
        </select>
      </label>
    </div>
  </fieldset>

  {{!-- Skills Section --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-dice-d20"></i> Allowed Skills</legend>
    <div class="ncm-skill-list">
      {{#each skillEntries}}
        <div class="ncm-skill-entry" data-skill="{{name}}">
          <span class="ncm-skill-name">{{name}} <small>({{stat}})</small></span>
          <label>DV: <input type="number" name="skillDC-{{name}}" value="{{dc}}" min="1" max="30" class="ncm-skill-dc" /></label>
          <button type="button" class="ncm-btn-icon" data-action="removeSkill" data-skill="{{name}}" title="Remove"><i class="fas fa-times"></i></button>
        </div>
      {{/each}}
    </div>
    <div class="ncm-form-row ncm-add-skill">
      <select name="newSkill">
        <option value="">— Add Skill —</option>
        {{#each allSkills}}<option value="{{this}}">{{this}}</option>{{/each}}
      </select>
      <button type="button" data-action="addSkill" class="ncm-btn ncm-btn-small"><i class="fas fa-plus"></i></button>
    </div>
  </fieldset>

  {{!-- Failure Handling --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-skull"></i> Failure Handling</legend>
    <div class="ncm-form-row">
      <label>Mode:
        <select name="failureMode">
          {{#each failureModes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
    <div class="ncm-form-row">
      <label>Max Attempts: <input type="number" name="maxHackAttempts" value="{{maxHackAttempts}}" min="1" max="10" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Lockout (min): <input type="number" name="lockoutMinutes" value="{{lockoutMinutes}}" min="1" max="1440" /></label>
    </div>
  </fieldset>

  {{!-- Login Auth --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-terminal"></i> Login Authentication</legend>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="requiresLogin" {{#if requiresLogin}}checked{{/if}} /> Require Login</label>
    </div>
    <div class="ncm-form-row">
      <label>Display Name: <input type="text" name="loginDisplayName" value="{{loginDisplayName}}" placeholder="System Login" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Username: <input type="text" name="loginUsername" value="{{loginUsername}}" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Password: <input type="text" name="loginPassword" value="{{loginPassword}}" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Max Attempts: <input type="number" name="maxLoginAttempts" value="{{maxLoginAttempts}}" min="1" max="10" /></label>
    </div>
  </fieldset>

  {{!-- Key Item --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-id-card"></i> Key Item</legend>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="requiresKeyItem" {{#if requiresKeyItem}}checked{{/if}} /> Require Key Item</label>
    </div>
    <div class="ncm-form-row">
      <label>Item Name: <input type="text" name="keyItemName" value="{{keyItemName}}" placeholder="e.g. Arasaka Credchip" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Item ID: <input type="text" name="keyItemId" value="{{keyItemId}}" placeholder="Foundry Item ID (optional)" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Tag: <input type="text" name="keyItemTag" value="{{keyItemTag}}" placeholder="Custom tag (optional)" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Display Name: <input type="text" name="keyItemDisplayName" value="{{keyItemDisplayName}}" placeholder="Access Token" /></label>
    </div>
    <div class="ncm-form-row">
      <label>Icon: <input type="text" name="keyItemIcon" value="{{keyItemIcon}}" placeholder="fa-id-card" /></label>
    </div>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="keyItemBypassLogin" {{#if keyItemBypassLogin}}checked{{/if}} /> Key bypasses login</label>
    </div>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="keyItemBypassEncryption" {{#if keyItemBypassEncryption}}checked{{/if}} /> Key bypasses encryption</label>
    </div>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="keyItemConsumeOnUse" {{#if keyItemConsumeOnUse}}checked{{/if}} /> Consume on use</label>
    </div>
  </fieldset>

  {{!-- Network Requirement --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-network-wired"></i> Network Requirement</legend>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="requiresNetwork" {{#if requiresNetwork}}checked{{/if}} /> Require Specific Network</label>
    </div>
    <div class="ncm-form-row">
      <label>Network:
        <select name="requiredNetwork">
          <option value="">— None —</option>
          {{#each networkOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </fieldset>

  {{!-- Display --}}
  <fieldset class="ncm-fieldset">
    <legend><i class="fas fa-palette"></i> Display</legend>
    <div class="ncm-form-row">
      <label>Theme:
        <select name="theme">
          {{#each themeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
    <div class="ncm-form-row">
      <label><input type="checkbox" name="singleMessage" {{#if singleMessage}}checked{{/if}} /> Single message mode (no list)</label>
    </div>
  </fieldset>

  {{!-- Actions --}}
  <div class="ncm-config-actions">
    <button type="button" data-action="saveConfig" class="ncm-btn ncm-btn-primary"><i class="fas fa-save"></i> Save</button>
    <button type="button" data-action="resetDefaults" class="ncm-btn ncm-btn-secondary"><i class="fas fa-undo"></i> Reset</button>
  </div>
</form>
{{else}}
  <p>No item selected or not GM.</p>
{{/if}}
