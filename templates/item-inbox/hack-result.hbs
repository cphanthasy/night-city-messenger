{{!-- Hack Result Chat Card --}}
{{!-- File: templates/item-inbox/hack-result.hbs --}}

<div class="ncm-chat-card {{#if success}}ncm-chat-card--success{{else}}ncm-chat-card--danger{{/if}}">
  <div class="ncm-chat-card__header">
    <i class="ncm-chat-card__icon fas fa-user-secret"></i>
    <div>
      <div class="ncm-chat-card__title">HACK ATTEMPT</div>
      <div class="ncm-chat-card__subtitle">{{#if success}}SUCCESS{{else}}FAILED{{/if}}</div>
    </div>
  </div>
  
  <div class="ncm-chat-card__body">
    <div class="ncm-chat-card__metadata">
      <div class="ncm-chat-card__meta-item">
        <div class="ncm-chat-card__meta-label">Target</div>
        <div class="ncm-chat-card__meta-value">{{targetName}}</div>
      </div>
      
      <div class="ncm-chat-card__meta-item">
        <div class="ncm-chat-card__meta-label">Difficulty</div>
        <div class="ncm-chat-card__meta-value">DV {{difficulty}}</div>
      </div>
      
      <div class="ncm-chat-card__meta-item">
        <div class="ncm-chat-card__meta-label">Roll</div>
        <div class="ncm-chat-card__meta-value">{{roll}}</div>
      </div>
      
      <div class="ncm-chat-card__meta-item">
        <div class="ncm-chat-card__meta-label">Result</div>
        <div class="ncm-chat-card__meta-value">
          {{#if success}}
            <span style="color: var(--ncm-text-success);">ACCESS GRANTED</span>
          {{else}}
            <span style="color: var(--ncm-text-error);">ACCESS DENIED</span>
          {{/if}}
        </div>
      </div>
    </div>
    
    <div class="ncm-chat-card__content">
      {{#if success}}
        <p>{{actor.name}} successfully hacked the data shard and gained access to the encrypted contents.</p>
      {{else}}
        <p>{{actor.name}} failed to hack the data shard. The security system detected the intrusion attempt.</p>
        
        {{#if triggeredICE}}
          <p style="color: var(--ncm-text-error);">
            <strong>WARNING:</strong> Security countermeasures activated!
            {{#if blackICE}}BLACK ICE deployed - {{damage}} damage dealt!{{/if}}
          </p>
        {{/if}}
      {{/if}}
    </div>
    
    {{#if showActions}}
    <div class="ncm-chat-card__actions">
      {{#if success}}
      <button class="ncm-btn ncm-btn--small ncm-btn--primary" data-action="view-shard" data-item-id="{{itemId}}">
        <i class="fas fa-eye"></i> View Contents
      </button>
      {{else}}
      <button class="ncm-btn ncm-btn--small ncm-btn--secondary" data-action="retry-hack" data-item-id="{{itemId}}">
        <i class="fas fa-redo"></i> Try Again
      </button>
      {{/if}}
    </div>
    {{/if}}
  </div>
</div>