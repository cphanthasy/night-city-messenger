{{!-- Item Inbox Template (Complete with Per-Message Encryption) --}}
{{!-- File: templates/item-inbox/item-inbox.hbs --}}

<div class="ncm-item-inbox ncm-theme-{{theme}}">
  
  {{!-- Header --}}
  <div class="ncm-item-inbox__header">
    <div class="ncm-item-inbox__title">
      <i class="fas fa-microchip"></i>
      {{itemName}}
    </div>
    <div class="ncm-item-inbox__actions">
      {{#if isOwner}}
        <button class="ncm-configure" title="Configure" data-action="configure">
          <i class="fas fa-cog"></i>
        </button>
      {{/if}}
    </div>
  </div>
  
  {{!-- Security Status --}}
  <div class="ncm-item-inbox__security {{#if encrypted}}ncm-item-inbox__security--encrypted{{/if}}">
    <div class="ncm-item-inbox__security-icon">
      {{#if encrypted}}
        {{#if isShardDecrypted}}
          <i class="fas fa-unlock"></i>
        {{else}}
          <i class="fas fa-lock"></i>
        {{/if}}
      {{else}}
        <i class="fas fa-hdd"></i>
      {{/if}}
    </div>
    <div class="ncm-item-inbox__security-info">
      <div class="ncm-item-inbox__security-status">
        {{#if encrypted}}
          {{#if isShardDecrypted}}
            SHARD DECRYPTED
          {{else}}
            SHARD ENCRYPTED
          {{/if}}
        {{else}}
          UNENCRYPTED
        {{/if}}
        {{#if allowsPerMessageEncryption}}
          <span class="ncm-encryption-badge">+ Per-Message Security</span>
        {{/if}}
      </div>
      <div class="ncm-item-inbox__security-level">
        {{#if encrypted}}
          {{#if isShardDecrypted}}
            Shard Access Granted
          {{else}}
            DV {{encryptionDC}} | {{encryptionType}}
          {{/if}}
        {{else}}
          No Shard Security
        {{/if}}
      </div>
    </div>
  </div>
  
  {{!-- ========================================================================
       SHARD-LEVEL ENCRYPTION OVERLAY
       Shows when entire shard is encrypted
       ======================================================================== --}}
  {{#if showShardEncryptedOverlay}}
  <div class="ncm-item-inbox__encryption-overlay">
    <div class="ncm-encryption-container">
      <div class="ncm-encryption-icon">
        <i class="fas fa-lock"></i>
      </div>
      
      <h2 class="ncm-encryption-title">DATA SHARD ENCRYPTED</h2>
      
      <div class="ncm-encryption-info">
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Security:</span>
          <span class="ncm-encryption-value">{{encryptionType}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Difficulty:</span>
          <span class="ncm-encryption-value">DV {{encryptionDC}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Failure:</span>
          <span class="ncm-encryption-value">{{failureMode}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Mode:</span>
          <span class="ncm-encryption-value">
            {{#if (eq encryptionMode "shard")}}Shard Level{{/if}}
            {{#if (eq encryptionMode "both")}}Both Layers{{/if}}
          </span>
        </div>
      </div>
      
      {{#if (or (eq encryptionType "BLACK_ICE") (eq encryptionType "RED_ICE"))}}
      <div class="ncm-encryption-warning">
        <i class="fas fa-skull"></i>
        <span>WARNING: LETHAL ICE - FAILURE WILL CAUSE DAMAGE</span>
      </div>
      {{/if}}
      
      {{#if isLockedOut}}
      <div class="ncm-lockout-warning">
        <i class="fas fa-ban"></i>
        <p>SYSTEM LOCKED OUT</p>
        <p>Retry in {{lockoutMinutes}} minutes</p>
      </div>
      {{else}}
      <div class="ncm-encryption-actions">
        {{#if selectedActor}}
          <button class="ncm-hack-button" data-action="attempt-hack">
            <i class="fas fa-user-secret"></i>
            Attempt Hack ({{selectedActor.name}})
          </button>
        {{else}}
          <div class="ncm-no-actor-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <p>Select a character to hack this data shard</p>
          </div>
        {{/if}}
        
        {{#if isGM}}
          <button class="ncm-button ncm-button-warning" data-action="gm-force-decrypt">
            <i class="fas fa-crown"></i> GM Force Decrypt
          </button>
        {{/if}}
      </div>
      {{/if}}
      
      {{#if previousAttempts.length}}
      <div class="ncm-hack-history">
        <h4>Previous Hack Attempts:</h4>
        <div class="ncm-hack-attempts">
          {{#each previousAttempts}}
          <div class="ncm-hack-attempt {{#if (eq result 'Success')}}ncm-hack-attempt--success{{else}}ncm-hack-attempt--failure{{/if}}">
            <span class="ncm-hack-actor">{{actorName}}</span>
            <span class="ncm-hack-result">{{result}}</span>
            <span class="ncm-hack-roll">Roll: {{roll}}</span>
            <span class="ncm-hack-time">{{timestamp}}</span>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>
  </div>
  {{else}}
  
  {{!-- ========================================================================
       MAIN CONTENT (Shown when shard is decrypted or not encrypted)
       ======================================================================== --}}
  <div class="ncm-item-inbox__content">
    
    {{!-- ====================================================================
         MESSAGE LIST (LEFT SIDE)
         ==================================================================== --}}
    <div class="ncm-item-inbox__messages">
      <div class="ncm-item-inbox__messages-header">
        <span class="ncm-message-count">Messages ({{messageCount}})</span>
        {{#if canAddMessage}}
        <button class="ncm-add-message" title="Add Message" data-action="add-message">
          <i class="fas fa-plus"></i>
        </button>
        {{/if}}
      </div>
      
      {{#if hasMessages}}
      <div class="ncm-item-inbox__messages-list">
        {{#each messages}}
        <div class="ncm-message-item {{#if isSelected}}ncm-message-item--selected{{/if}} {{#if showLockIcon}}ncm-message-item--encrypted{{/if}}" 
             data-message-id="{{id}}"
             data-action="select-message">
          
          {{!-- Lock icon for encrypted messages --}}
          {{#if showLockIcon}}
          <div class="ncm-message-lock-icon">
            <i class="fas fa-lock"></i>
          </div>
          {{/if}}
          
          <div class="ncm-message-item__header">
            <div class="ncm-message-item__subject">
              {{#if messageData.infected}}
                <i class="fas fa-virus ncm-text-danger"></i>
              {{/if}}
              {{messageData.subject}}
            </div>
            <div class="ncm-message-item__date">{{messageData.date}}</div>
          </div>
          <div class="ncm-message-item__meta">
            <span class="ncm-message-item__from">FROM: {{messageData.from}}</span>
            {{#if messageData.to}}
            <span class="ncm-message-item__to">TO: {{messageData.to}}</span>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="ncm-item-inbox__empty">
        <i class="fas fa-inbox"></i>
        <p class="ncm-empty-title">No Messages</p>
        <p class="ncm-empty-subtitle">This data shard is empty</p>
        {{#if canAddMessage}}
        <button class="ncm-button ncm-button-primary" data-action="add-message">
          <i class="fas fa-plus"></i> Add Message
        </button>
        {{/if}}
      </div>
      {{/if}}
    </div>
    
    {{!-- ====================================================================
         MESSAGE DETAIL (RIGHT SIDE)
         ==================================================================== --}}
    {{#if selectedMessage}}
    <div class="ncm-item-inbox__detail">
      
      {{!-- ================================================================
           PER-MESSAGE ENCRYPTION OVERLAY
           Shows when individual message is encrypted
           ================================================================ --}}
      {{#if selectedMessage.showEncryptedOverlay}}
      <div class="ncm-message-encryption-overlay">
        <div class="ncm-encryption-container">
          <div class="ncm-encryption-icon">
            <i class="fas fa-lock"></i>
          </div>
          
          <h3 class="ncm-encryption-title">MESSAGE ENCRYPTED</h3>
          
          <div class="ncm-message-info">
            <div class="ncm-message-subject-display">{{selectedMessage.messageData.subject}}</div>
            <div class="ncm-message-meta-display">
              <span>From: {{selectedMessage.messageData.from}}</span>
              <span>Date: {{selectedMessage.messageData.date}}</span>
            </div>
          </div>
          
          {{#if selectedMessage.encryption}}
          <div class="ncm-encryption-info">
            <div class="ncm-encryption-detail">
              <span class="ncm-encryption-label">Security:</span>
              <span class="ncm-encryption-value">{{selectedMessage.encryption.type}}</span>
            </div>
            <div class="ncm-encryption-detail">
              <span class="ncm-encryption-label">Difficulty:</span>
              <span class="ncm-encryption-value">DV {{selectedMessage.encryption.dc}}</span>
            </div>
            <div class="ncm-encryption-detail">
              <span class="ncm-encryption-label">Allowed Skills:</span>
              <span class="ncm-encryption-value">{{join selectedMessage.encryption.allowedSkills ", "}}</span>
            </div>
            {{#if selectedMessage.encryption.hackAttempts}}
            <div class="ncm-encryption-detail">
              <span class="ncm-encryption-label">Failed Attempts:</span>
              <span class="ncm-encryption-value">{{selectedMessage.encryption.hackAttempts}}</span>
            </div>
            {{/if}}
          </div>
          
          {{#if (or (eq selectedMessage.encryption.type "BLACK_ICE") (eq selectedMessage.encryption.type "RED_ICE"))}}
          <div class="ncm-encryption-warning">
            <i class="fas fa-skull"></i>
            <span>WARNING: BLACK ICE - FAILURE CAUSES DAMAGE</span>
          </div>
          {{/if}}
          {{/if}}
          
          <div class="ncm-encryption-actions">
            {{#if selectedMessage.canDecrypt}}
              <button class="ncm-hack-button" 
                      data-action="decrypt-message" 
                      data-message-id="{{selectedMessage.id}}">
                <i class="fas fa-user-secret"></i>
                Attempt Decrypt ({{selectedActor.name}})
              </button>
            {{else}}
              <div class="ncm-no-actor-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <p>Select a character to decrypt this message</p>
              </div>
            {{/if}}
            
            {{#if isGM}}
              <button class="ncm-button ncm-button-warning" 
                      data-action="gm-force-decrypt-message"
                      data-message-id="{{selectedMessage.id}}">
                <i class="fas fa-crown"></i> GM Force Decrypt
              </button>
            {{/if}}
          </div>
        </div>
      </div>
      
      {{!-- ================================================================
           MESSAGE CONTENT (Shown when message is decrypted)
           ================================================================ --}}
      {{else}}
      
      <!-- Message Header with subject and actions -->
      <div class="ncm-item-inbox__detail-header">
        <div class="ncm-detail-subject">
          {{#if selectedMessage.messageData.encrypted}}
            <i class="fas fa-unlock ncm-text-success" title="Decrypted"></i>
          {{/if}}
          {{#if selectedMessage.messageData.infected}}
            <i class="fas fa-virus ncm-text-danger" title="Contains Malware"></i>
          {{/if}}
          {{selectedMessage.messageData.subject}}
        </div>
        <div class="ncm-item-inbox__detail-actions">
          <button class="ncm-share-message" title="Share to Chat" data-action="share-message">
            <i class="fas fa-share"></i>
          </button>
          {{#if canAddMessage}}
          <button class="ncm-delete-message" title="Delete" data-action="delete-message">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </div>
      
      <!-- Metadata -->
      <div class="ncm-item-inbox__detail-meta">
        <div class="ncm-meta-row">
          <span class="ncm-meta-from">
            <strong>From:</strong> {{selectedMessage.messageData.from}}
          </span>
          <span class="ncm-meta-date">{{selectedMessage.messageData.date}}</span>
        </div>
        {{#if selectedMessage.messageData.to}}
        <div class="ncm-meta-row">
          <span class="ncm-meta-to">
            <strong>To:</strong> {{selectedMessage.messageData.to}}
          </span>
        </div>
        {{/if}}
      </div>
      
      <!-- Malware Warning (if infected) -->
      {{#if selectedMessage.messageData.infected}}
      <div class="ncm-malware-warning">
        <div class="ncm-malware-icon">
          <i class="fas fa-virus"></i>
        </div>
        <div class="ncm-malware-info">
          <div class="ncm-malware-title">MALWARE DETECTED</div>
          <div class="ncm-malware-detail">
            Type: {{selectedMessage.malwareType}} • Threat: {{selectedMessage.threatLevel}}
          </div>
        </div>
        <div class="ncm-malware-actions">
          <button class="ncm-button-small ncm-button-danger" data-action="quarantine-message">
            <i class="fas fa-shield-virus"></i> Quarantine
          </button>
        </div>
      </div>
      {{/if}}
      
      <!-- Message Body -->
      <div class="ncm-item-inbox__detail-content">
        {{#if selectedMessage.showContent}}
          <div class="ncm-message-body">
            {{{selectedMessage.content}}}
          </div>
        {{else}}
          <div class="ncm-encrypted-content">
            <i class="fas fa-lock"></i>
            <p>Content encrypted - decrypt to view</p>
          </div>
        {{/if}}
      </div>
      
      {{/if}}
      
    </div>
    {{else}}
    
    {{!-- Empty state when no message selected --}}
    <div class="ncm-item-inbox__detail-empty">
      <i class="fas fa-mouse-pointer"></i>
      <p>Select a message to view</p>
      {{#if allowsPerMessageEncryption}}
        <p class="ncm-help-text">
          <i class="fas fa-lock"></i> 
          Messages with lock icons require decryption
        </p>
      {{/if}}
    </div>
    {{/if}}
    
  </div>
  {{/if}}
  
</div>

{{!-- Helper CSS for lock icon positioning --}}
<style>
.ncm-message-lock-icon {
  position: absolute;
  top: 8px;
  right: 8px;
  color: var(--ncm-primary, #F65261);
  font-size: 0.9rem;
  opacity: 0.8;
}

.ncm-message-item {
  position: relative;
}

.ncm-message-item--encrypted {
  border-left: 3px solid var(--ncm-primary, #F65261);
}

.ncm-encryption-badge {
  display: inline-block;
  font-size: 0.75rem;
  padding: 2px 8px;
  background: rgba(246, 82, 97, 0.2);
  border-radius: 3px;
  margin-left: 8px;
}

.ncm-message-encryption-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: var(--ncm-spacing-xl, 20px);
}

.ncm-message-subject-display {
  font-size: 1.2rem;
  font-weight: bold;
  color: var(--ncm-primary, #F65261);
  margin-bottom: 8px;
}

.ncm-message-meta-display {
  display: flex;
  gap: 20px;
  font-size: 0.9rem;
  color: var(--ncm-text-secondary, #999);
  margin-bottom: 20px;
}
</style>