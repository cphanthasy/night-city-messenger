{{!-- Item Inbox Template - Complete with Fixed GM Controls --}}
{{!-- File: templates/item-inbox/item-inbox.hbs --}}
{{!-- Uses: styles/components/data-shard.css --}}

<div class="ncm-item-inbox ncm-theme-{{theme}}">
  
  {{!-- ==========================================================================
       HEADER
       ========================================================================== --}}
  <div class="ncm-item-inbox__header">
    <div class="ncm-item-inbox__title">
      <i class="fas fa-microchip"></i>
      {{itemName}}
    </div>
    <div class="ncm-item-inbox__actions">
      {{#if isGM}}
        <button class="ncm-configure" title="Configure" data-action="configure">
          <i class="fas fa-cog"></i>
          Configure
        </button>
      {{/if}}
    </div>
  </div>
  
  {{!-- ==========================================================================
       GM CONTROL PANEL - Shows for GMs only
       ========================================================================== --}}
  {{#if isGM}}
  <div class="ncm-gm-controls">
    <div class="ncm-gm-controls-header">
      <i class="fas fa-crown"></i>
      <span>Game Master Controls</span>
    </div>
    <div class="ncm-gm-controls-buttons">
      {{#if encrypted}}
        {{#if isActuallyDecrypted}}
          <button class="ncm-gm-btn ncm-gm-btn-warning" data-action="gm-reset-encryption" title="Re-lock this data shard">
            <i class="fas fa-lock"></i>
            Re-Lock Shard
          </button>
        {{else}}
          <button class="ncm-gm-btn ncm-gm-btn-success" data-action="gm-force-decrypt" title="Bypass encryption">
            <i class="fas fa-unlock"></i>
            Force Decrypt
          </button>
        {{/if}}
        <button class="ncm-gm-btn ncm-gm-btn-danger" data-action="gm-reset-attempts" title="Reset all failed hack attempts">
          <i class="fas fa-redo"></i>
          Reset Attempts
        </button>
      {{/if}}
      <button class="ncm-gm-btn" data-action="gm-view-all" title="Toggle GM view mode">
        <i class="fas fa-eye{{#if gmViewMode}}-slash{{/if}}"></i>
        {{#if gmViewMode}}Hide Encryption{{else}}View All{{/if}}
      </button>
    </div>
  </div>
  {{/if}}
  
  {{!-- ==========================================================================
       SECURITY STATUS BAR
       ========================================================================== --}}
  <div class="ncm-item-inbox__security {{#if encrypted}}ncm-item-inbox__security--encrypted{{/if}}">
    <div class="ncm-item-inbox__security-icon">
      {{#if encrypted}}
        {{#if isActuallyDecrypted}}
          <i class="fas fa-unlock"></i>
        {{else}}
          <i class="fas fa-lock"></i>
        {{/if}}
      {{else}}
        <i class="fas fa-hdd"></i>
      {{/if}}
    </div>
    <div class="ncm-item-inbox__security-info">
      <div class="ncm-item-inbox__security-status">
        {{#if encrypted}}
          {{#if isActuallyDecrypted}}
            <span style="color: var(--ncm-success);">● SHARD DECRYPTED</span>
          {{else}}
            <span style="color: var(--ncm-primary);">● SHARD ENCRYPTED</span>
          {{/if}}
        {{else}}
          <span style="color: var(--ncm-secondary);">● UNENCRYPTED</span>
        {{/if}}
        {{#if allowsPerMessageEncryption}}
          <span class="ncm-encryption-badge">+ Per-Message Security</span>
        {{/if}}
      </div>
      <div class="ncm-item-inbox__security-level">
        {{#if encrypted}}
          {{#if isActuallyDecrypted}}
            Access Granted • Decrypted
          {{else}}
            Protection: {{encryptionType}} • Difficulty: DV {{encryptionDC}} • Mode: {{failureMode}}
          {{/if}}
        {{else}}
          No Active Security • Open Access
        {{/if}}
      </div>
    </div>
  </div>
  
  {{!-- ==========================================================================
       MAIN CONTENT AREA
       Shows ENCRYPTION OVERLAY if locked, or MESSAGES if unlocked
       ========================================================================== --}}
  
  {{!-- CASE 1: Shard is encrypted and locked (show overlay) --}}
  {{#if showShardEncryptedOverlay}}
  <div class="ncm-item-inbox__encryption-overlay">
    <div class="ncm-encryption-container">
      
      <div class="ncm-encryption-icon">
        <i class="fas fa-lock"></i>
      </div>
      
      <h2 class="ncm-encryption-title">ENCRYPTED DATA SHARD</h2>
      
      <div class="ncm-encryption-info">
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Security Type:</span>
          <span class="ncm-encryption-value">{{encryptionType}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Difficulty Class:</span>
          <span class="ncm-encryption-value">DV {{encryptionDC}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Failure Mode:</span>
          <span class="ncm-encryption-value">{{failureMode}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Encryption Mode:</span>
          <span class="ncm-encryption-value">{{#if (eq encryptionMode "shard")}}Shard Level{{else if (eq encryptionMode "message")}}Per-Message{{else if (eq encryptionMode "both")}}Both Layers{{else}}Unknown{{/if}}</span>
        </div>
        {{#if isLockedOut}}
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Status:</span>
          <span class="ncm-encryption-value" style="color: var(--ncm-error);">
            LOCKED OUT ({{lockoutMinutes}}m)
          </span>
        </div>
        {{/if}}
      </div>
      
      {{#if (or (eq encryptionType "BLACK_ICE") (eq encryptionType "RED_ICE"))}}
      <div class="ncm-encryption-warning">
        <i class="fas fa-skull-crossbones"></i>
        <span>WARNING: LETHAL COUNTERMEASURES ACTIVE</span>
      </div>
      {{/if}}
      
      <div class="ncm-encryption-actions">
        {{#if canHackShard}}
          {{#unless isLockedOut}}
            <button class="ncm-button ncm-button-primary" data-action="attempt-hack">
              <i class="fas fa-terminal"></i>
              Attempt Decryption
            </button>
          {{/unless}}
        {{else}}
          <p class="ncm-encryption-message">
            {{#if isLockedOut}}
              <i class="fas fa-exclamation-triangle"></i>
              System locked. Access denied for {{lockoutMinutes}} minutes.
            {{else}}
              <i class="fas fa-user-slash"></i>
              Select a character with hacking skills to attempt decryption.
            {{/if}}
          </p>
        {{/if}}
      </div>
      
      {{#if previousAttempts.length}}
      <div class="ncm-encryption-history">
        <h4><i class="fas fa-history"></i> Previous Decryption Attempts:</h4>
        <ul>
          {{#each previousAttempts}}
          <li>
            <strong>{{actorName}}</strong>: {{result}} (Roll: {{roll}})
          </li>
          {{/each}}
        </ul>
      </div>
      {{/if}}
      
    </div>
  </div>
  
  {{!-- CASE 2: Shard is unlocked (show messages) --}}
  {{else}}
  <div class="ncm-item-inbox__content {{#if isSingleMode}}single-mode{{/if}}">
    
    {{!-- =======================================================================
         MESSAGE LIST (Left Panel)
         ======================================================================= --}}
    <div class="ncm-item-inbox__message-list">
      {{#if hasMessages}}
        {{#each messages}}
        <div class="ncm-item-inbox__message-item {{#if isSelected}}ncm-item-inbox__message-item--selected{{/if}}"
             data-action="select-message"
             data-message-id="{{id}}">
          <div class="ncm-item-inbox__message-header">
            <div class="ncm-item-inbox__message-from">
              <i class="fas fa-user-circle"></i>
              {{messageData.from}}
            </div>
            {{#if showLockIcon}}
              <i class="fas fa-lock" style="color: var(--ncm-primary);" title="Encrypted Message"></i>
            {{/if}}
          </div>
          <div class="ncm-item-inbox__message-subject">
            {{messageData.subject}}
          </div>
          <div class="ncm-item-inbox__message-date">
            <i class="far fa-clock"></i>
            {{messageData.date}}
          </div>
        </div>
        {{/each}}
      {{else}}
        <div class="ncm-item-inbox__empty">
          <i class="fas fa-inbox"></i>
          <p>No Messages</p>
        </div>
      {{/if}}
    </div>
    
    {{!-- =======================================================================
         MESSAGE DETAIL (Right Panel)
         ======================================================================= --}}
    <div class="ncm-item-inbox__message-detail">
      {{#if selectedMessage}}
        
        {{!-- CASE 2A: Selected message is encrypted (show per-message overlay) --}}
        {{#if selectedMessage.showEncryptedOverlay}}
        <div class="ncm-message-encrypted-overlay">
          <div class="ncm-encryption-container" style="max-width: 450px;">
            
            <div class="ncm-encryption-icon" style="font-size: 3em;">
              <i class="fas fa-envelope-open-text"></i>
            </div>
            
            <h3 class="ncm-encryption-title" style="font-size: 1.4em;">MESSAGE ENCRYPTED</h3>
            
            <div class="ncm-encryption-info">
              <div class="ncm-encryption-detail">
                <span class="ncm-encryption-label">From:</span>
                <span class="ncm-encryption-value">{{selectedMessage.messageData.from}}</span>
              </div>
              <div class="ncm-encryption-detail">
                <span class="ncm-encryption-label">Subject:</span>
                <span class="ncm-encryption-value">{{selectedMessage.messageData.subject}}</span>
              </div>
              {{#if selectedMessage.encryption}}
              <div class="ncm-encryption-detail">
                <span class="ncm-encryption-label">Difficulty:</span>
                <span class="ncm-encryption-value">DV {{selectedMessage.encryption.dc}}</span>
              </div>
              <div class="ncm-encryption-detail">
                <span class="ncm-encryption-label">Type:</span>
                <span class="ncm-encryption-value">{{selectedMessage.encryption.type}}</span>
              </div>
              {{/if}}
            </div>
            
            {{#if selectedMessage.canDecrypt}}
            <div class="ncm-encryption-actions">
              <button class="ncm-button ncm-button-primary ncm-button-small" 
                      data-action="decrypt-message"
                      data-message-id="{{selectedMessage.id}}">
                <i class="fas fa-key"></i>
                Decrypt This Message
              </button>
            </div>
            {{else}}
            <p class="ncm-encryption-message">
              <i class="fas fa-info-circle"></i>
              Select a character with hacking skills to decrypt this message.
            </p>
            {{/if}}
            
          </div>
        </div>
        
        {{!-- CASE 2B: Selected message is decrypted (show content) --}}
        {{else}}
        
        <div class="ncm-item-inbox__message-header-detail">
          <div class="ncm-item-inbox__message-meta">
            <div class="ncm-item-inbox__message-from-detail">
              <strong>From:</strong> <span style="color: var(--ncm-secondary);">{{selectedMessage.messageData.from}}</span>
            </div>
            <div class="ncm-item-inbox__message-to-detail">
              <strong>To:</strong> <span style="color: var(--ncm-secondary);">{{selectedMessage.messageData.to}}</span>
            </div>
            <div class="ncm-item-inbox__message-date-detail">
              <strong>Date:</strong> {{selectedMessage.messageData.date}}
            </div>
          </div>
          <div class="ncm-item-inbox__message-subject-detail">
            {{selectedMessage.messageData.subject}}
          </div>
        </div>
        
        <div class="ncm-item-inbox__message-body">
          {{{selectedMessage.content}}}
        </div>
        
        {{#if selectedMessage.attachments.length}}
        <div class="ncm-item-inbox__message-attachments">
          <h4><i class="fas fa-paperclip"></i> Attachments:</h4>
          <ul>
            {{#each selectedMessage.attachments}}
            <li>
              <i class="fas fa-file"></i>
              {{name}} <span style="color: var(--ncm-text-dim);">({{size}})</span>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
        
        <div class="ncm-item-inbox__message-actions">
          {{#if ../canAddMessage}}
          <button class="ncm-button" data-action="share-message">
            <i class="fas fa-share"></i>
            Share to Chat
          </button>
          <button class="ncm-button ncm-button-danger" data-action="delete-message">
            <i class="fas fa-trash"></i>
            Delete
          </button>
          {{/if}}
        </div>
        
        {{/if}}
        
      {{else}}
        {{!-- No message selected --}}
        <div class="ncm-item-inbox__message-detail-empty">
          <i class="fas fa-envelope-open"></i>
          <p>Select a Message</p>
        </div>
      {{/if}}
    </div>
    
  </div>
  
  {{!-- ==========================================================================
       FOOTER (Add Message Button)
       ========================================================================== --}}
  <div class="ncm-item-inbox__footer">
    {{#if canAddMessage}}
    <button class="ncm-button ncm-button-primary" data-action="add-message">
      <i class="fas fa-plus"></i>
      Add New Message
    </button>
    {{/if}}
  </div>
  
  {{/if}}
  
</div>