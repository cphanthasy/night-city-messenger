{{!-- Item Inbox Template (Simplified) --}}
{{!-- File: templates/item-inbox/item-inbox.hbs --}}

<div class="ncm-item-inbox ncm-theme-{{theme}}">
  
  {{!-- Header --}}
  <div class="ncm-item-inbox__header">
    <div class="ncm-item-inbox__title">
      <i class="fas fa-microchip"></i>
      {{itemName}}
    </div>
    <div class="ncm-item-inbox__actions">
      {{#if isOwner}}
        <button class="ncm-configure" title="Configure" data-action="configure">
          <i class="fas fa-cog"></i>
        </button>
      {{/if}}
    </div>
  </div>
  
  {{!-- Security Status --}}
  <div class="ncm-item-inbox__security {{#if encrypted}}ncm-item-inbox__security--encrypted{{/if}}">
    <div class="ncm-item-inbox__security-icon">
      {{#if encrypted}}
        {{#if isDecrypted}}
          <i class="fas fa-unlock"></i>
        {{else}}
          <i class="fas fa-lock"></i>
        {{/if}}
      {{else}}
        <i class="fas fa-hdd"></i>
      {{/if}}
    </div>
    <div class="ncm-item-inbox__security-info">
      <div class="ncm-item-inbox__security-status">
        {{#if encrypted}}
          {{#if isDecrypted}}
            DECRYPTED
          {{else}}
            ENCRYPTED
          {{/if}}
        {{else}}
          UNENCRYPTED
        {{/if}}
      </div>
      <div class="ncm-item-inbox__security-level">
        {{#if encrypted}}
          {{#if isDecrypted}}
            Access Granted
          {{else}}
            DV {{encryptionDC}} | {{encryptionType}}
          {{/if}}
        {{else}}
          No Security
        {{/if}}
      </div>
    </div>
  </div>
  
  {{!-- Encryption Overlay --}}
  {{#if showEncryptedOverlay}}
  <div class="ncm-item-inbox__encryption-overlay">
    <div class="ncm-encryption-container">
      <div class="ncm-encryption-icon">
        <i class="fas fa-lock"></i>
      </div>
      
      <h2 class="ncm-encryption-title">DATA ENCRYPTED</h2>
      
      <div class="ncm-encryption-info">
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Security:</span>
          <span class="ncm-encryption-value">{{encryptionType}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Difficulty:</span>
          <span class="ncm-encryption-value">DV {{encryptionDC}}</span>
        </div>
        <div class="ncm-encryption-detail">
          <span class="ncm-encryption-label">Failure:</span>
          <span class="ncm-encryption-value">{{failureMode}}</span>
        </div>
      </div>
      
      {{#if (isLethalICE encryptionType)}}
      <div class="ncm-encryption-warning">
        <i class="fas fa-skull"></i>
        <span>WARNING: LETHAL ICE</span>
      </div>
      {{/if}}
      
      {{#if isLockedOut}}
      <div class="ncm-lockout-warning">
        <i class="fas fa-ban"></i>
        <p>SYSTEM LOCKED</p>
        <p>Retry in {{lockoutMinutes}} minutes</p>
      </div>
      {{else}}
      <div class="ncm-encryption-actions">
        {{#if selectedActor}}
          <button class="ncm-hack-button" data-action="attempt-hack">
            <i class="fas fa-user-secret"></i>
            Attempt Hack ({{selectedActor.name}})
          </button>
        {{else}}
          <div class="ncm-no-actor-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <p>Select a character to hack</p>
          </div>
        {{/if}}
        
        {{#if isGM}}
          <button class="ncm-button ncm-button-warning" data-action="gm-force-decrypt">
            <i class="fas fa-crown"></i> GM Force Decrypt
          </button>
        {{/if}}
      </div>
      {{/if}}
      
      {{#if previousAttempts}}
      <div class="ncm-hack-history">
        <h4>Previous Attempts:</h4>
        <div class="ncm-hack-attempts">
          {{#each previousAttempts}}
          <div class="ncm-hack-attempt {{#if (eq result 'Success')}}ncm-hack-attempt--success{{else}}ncm-hack-attempt--failure{{/if}}">
            <span class="ncm-hack-actor">{{actorName}}</span>
            <span class="ncm-hack-result">{{result}}</span>
            <span class="ncm-hack-time">{{timestamp}}</span>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>
  </div>
  {{else}}
  
  {{!-- Main Content --}}
  <div class="ncm-item-inbox__content">
    
    {{!-- Message List --}}
    <div class="ncm-item-inbox__messages">
      <div class="ncm-item-inbox__messages-header">
        <span class="ncm-message-count">Messages ({{messageCount}})</span>
        {{#if canAddMessage}}
        <button class="ncm-add-message" title="Add Message" data-action="add-message">
          <i class="fas fa-plus"></i>
        </button>
        {{/if}}
      </div>
      
      {{#if hasMessages}}
      <div class="ncm-item-inbox__messages-list">
        {{#each messages}}
        <div class="ncm-message-item {{#if isSelected}}ncm-message-item--selected{{/if}}" 
             data-message-id="{{id}}"
             data-action="select-message">
          <div class="ncm-message-item__header">
            <div class="ncm-message-item__subject">
              {{#if infected}}
                <i class="fas fa-virus ncm-text-danger"></i>
              {{/if}}
              {{messageData.subject}}
            </div>
            <div class="ncm-message-item__date">{{messageData.date}}</div>
          </div>
          <div class="ncm-message-item__meta">
            <span class="ncm-message-item__from">FROM: {{messageData.from}}</span>
            {{#if messageData.to}}
            <span class="ncm-message-item__to">TO: {{messageData.to}}</span>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="ncm-item-inbox__empty">
        <i class="fas fa-inbox"></i>
        <p class="ncm-empty-title">No Messages</p>
        <p class="ncm-empty-subtitle">This data shard is empty</p>
        {{#if canAddMessage}}
        <button class="ncm-button ncm-button-primary" data-action="add-message">
          <i class="fas fa-plus"></i> Add Message
        </button>
        {{/if}}
      </div>
      {{/if}}
    </div>
    
    {{!-- Message Detail --}}
    {{#if selectedMessage}}
    <div class="ncm-item-inbox__detail">
      
      <!-- Clean Header with subject and actions -->
      <div class="ncm-item-inbox__detail-header">
        <div class="ncm-detail-subject">
          {{#if selectedMessage.infected}}
            <i class="fas fa-virus" style="color: var(--ncm-error);"></i>
          {{/if}}
          {{selectedMessage.messageData.subject}}
        </div>
        <div class="ncm-item-inbox__detail-actions">
          <button class="ncm-share-message" title="Share to Chat" data-action="share-message">
            <i class="fas fa-share"></i>
          </button>
          {{#if canAddMessage}}
          <button class="ncm-delete-message" title="Delete" data-action="delete-message">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </div>
      
      <!-- Compact Metadata Row -->
      <div class="ncm-item-inbox__detail-meta">
        <div class="ncm-meta-row">
          <span class="ncm-meta-from">
            <strong>From:</strong> {{selectedMessage.messageData.from}}
          </span>
          <span class="ncm-meta-date">{{selectedMessage.messageData.date}}</span>
        </div>
        {{#if selectedMessage.messageData.to}}
        <div class="ncm-meta-row">
          <span class="ncm-meta-to">
            <strong>To:</strong> {{selectedMessage.messageData.to}}
          </span>
        </div>
        {{/if}}
      </div>
      
      <!-- Malware Warning (if infected) -->
      {{#if selectedMessage.infected}}
      <div class="ncm-malware-warning">
        <div class="ncm-malware-icon">
          <i class="fas fa-virus"></i>
        </div>
        <div class="ncm-malware-info">
          <div class="ncm-malware-title">MALWARE DETECTED</div>
          <div class="ncm-malware-detail">
            Type: {{selectedMessage.malwareType}} • Threat: {{selectedMessage.threatLevel}}
          </div>
        </div>
        <div class="ncm-malware-actions">
          <button class="ncm-button-small ncm-button-danger" data-action="quarantine-message">
            <i class="fas fa-shield-virus"></i> Quarantine
          </button>
        </div>
      </div>
      {{/if}}
      
      <!-- Message Body -->
      <div class="ncm-item-inbox__detail-content">
        {{#if selectedMessage.canView}}
          <div class="ncm-message-body">
            {{{selectedMessage.content}}}
          </div>
        {{else}}
          <div class="ncm-encrypted-content">
            <i class="fas fa-lock"></i>
            <p>Content encrypted - decrypt to view</p>
          </div>
        {{/if}}
      </div>
      
    </div>
    {{else}}
    <div class="ncm-item-inbox__detail-empty">
      <i class="fas fa-mouse-pointer"></i>
      <p>Select a message to view</p>
    </div>
    {{/if}}
    
  </div>
  {{/if}}
  
</div>