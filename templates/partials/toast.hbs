{{!--
  Toast Notification v2 — Cyberpunk-styled notification popup
  @file templates/partials/toast.hbs
  @module cyberpunkred-messenger
  @description Renders a single toast notification with clip-path corner, accent glow bar,
    icon with filled background, title/separator/detail, optional action button,
    dismiss button, and progress bar. Hex strips and signal bars injected by JS post-render.

  Toast type families:
    Core:    info, success, warning, error, danger
    Message: message, msg-sent, msg-scheduled, msg-decrypted
    Contact: contact-acquired, contact-burned
    Network: net-switch, net-connect, net-disconnect, net-auth, net-auth-fail, net-lockout, net-queue
    Shard:   shard-decrypt, shard-ice, shard-login, shard-login-fail, shard-key, shard-key-fail,
             shard-eddies, shard-trace, shard-bricked, shard-expired

  @param {string} id            — Unique toast ID
  @param {string} type          — Toast type key
  @param {string} title         — Header text
  @param {string} [detail]      — Body text
  @param {string} [titleIcon]   — Optional icon class before title text
  @param {string} icon          — Icon class for the left circle
  @param {string} [accentColor] — CSS override for accent bar + icon
  @param {string} [actionLabel] — Optional action button label
  @param {string} [actionId]    — Data attribute for action routing
  @param {number} [duration]    — Auto-dismiss ms (0 = no auto-dismiss)
--}}

<div class="ncm-toast ncm-toast--{{type}}" data-toast-id="{{id}}">

  {{!-- Accent bar with glow bleed --}}
  <div class="ncm-toast__accent"
       {{#if accentColor}}style="background: {{accentColor}};"{{/if}}></div>

  {{!-- Icon circle --}}
  <div class="ncm-toast__icon"
       {{#if accentColor}}style="color: {{accentColor}}; border-color: {{accentColor}}33; background: {{accentColor}}0f;"{{/if}}>
    <i class="{{icon}}"></i>
  </div>

  {{!-- Body --}}
  <div class="ncm-toast__body">
    <div class="ncm-toast__title"
         {{#if accentColor}}style="color: {{accentColor}};"{{/if}}>
      {{#if titleIcon}}<i class="{{titleIcon}}"></i> {{/if}}{{title}}
    </div>
    <div class="ncm-toast__separator"
         {{#if accentColor}}style="background: linear-gradient(90deg, {{accentColor}}33, transparent 70%);"{{/if}}></div>
    {{#if detail}}
      <div class="ncm-toast__detail">{{detail}}</div>
    {{/if}}
  </div>

  {{!-- Action button --}}
  {{#if actionLabel}}
    <button class="ncm-toast__action" data-action="{{actionId}}" data-toast-id="{{id}}">
      {{actionLabel}}
    </button>
  {{/if}}

  {{!-- Dismiss button --}}
  <button class="ncm-toast__dismiss" data-action="dismiss-toast" data-toast-id="{{id}}">
    <i class="fas fa-xmark"></i>
  </button>

  {{!-- Auto-dismiss progress bar --}}
  {{#if duration}}
    <div class="ncm-toast__progress">
      <div class="ncm-toast__progress-fill"
           {{#if accentColor}}style="background: {{accentColor}};"{{/if}}
           data-duration="{{duration}}"></div>
    </div>
  {{/if}}

</div>
