{{!-- Theme Customizer v2 — Tabbed Layout with Mini Preview --}}
{{!-- @file templates/theme-customizer/theme-customizer.hbs --}}

<div class="ncm-tc">

  {{!-- ═══ MINI PREVIEW ═══ --}}
  <div class="ncm-tc__preview">
    <div class="ncm-tc__preview-label"><i class="fas fa-eye"></i> Live Preview — {{currentPresetLabel}}</div>
    <div class="ncm-tc__preview-inbox">
      <div class="ncm-tc__preview-hdr">
        <div class="ncm-tc__preview-av">V</div>
        <div class="ncm-tc__preview-nm">V</div>
        <div class="ncm-tc__preview-nt">CITINET</div>
      </div>
      <div class="ncm-tc__preview-row">
        <div class="ncm-tc__preview-dot"></div>
        <div class="ncm-tc__preview-from">Jackie</div>
        <div class="ncm-tc__preview-subj">Meet at El Coyote — got a gig</div>
        <div class="ncm-tc__preview-time">14:32</div>
      </div>
      <div class="ncm-tc__preview-row">
        <div class="ncm-tc__preview-dot ncm-tc__preview-dot--read"></div>
        <div class="ncm-tc__preview-from">Wakako</div>
        <div class="ncm-tc__preview-subj">New opportunity. Discrete.</div>
        <div class="ncm-tc__preview-badge">PRIORITY</div>
        <div class="ncm-tc__preview-time">12:10</div>
      </div>
      <div class="ncm-tc__preview-row">
        <div class="ncm-tc__preview-dot ncm-tc__preview-dot--read"></div>
        <div class="ncm-tc__preview-from">T-Bug</div>
        <div class="ncm-tc__preview-subj">Backdoor ready. Ping when close.</div>
        <div class="ncm-tc__preview-time">09:44</div>
      </div>
    </div>
  </div>

  {{!-- ═══ TAB BAR ═══ --}}
  <div class="ncm-tc__tabs">
    <button class="ncm-tc__tab {{#if (eq activeTab 'presets')}}ncm-tc__tab--active{{/if}}" data-tc-tab="presets"><i class="fas fa-swatchbook"></i> Presets</button>
    <button class="ncm-tc__tab {{#if (eq activeTab 'colors')}}ncm-tc__tab--active{{/if}}" data-tc-tab="colors"><i class="fas fa-droplet"></i> Colors</button>
    <button class="ncm-tc__tab {{#if (eq activeTab 'fonts')}}ncm-tc__tab--active{{/if}}" data-tc-tab="fonts"><i class="fas fa-font"></i> Fonts</button>
    <button class="ncm-tc__tab {{#if (eq activeTab 'effects')}}ncm-tc__tab--active{{/if}}" data-tc-tab="effects"><i class="fas fa-wand-magic-sparkles"></i> Effects</button>
  </div>

  {{!-- ═══ SCROLLABLE BODY ═══ --}}
  <div class="ncm-tc__body">

    {{!-- ── PRESETS ── --}}
    <div class="ncm-tc__panel {{#if (eq activeTab 'presets')}}ncm-tc__panel--active{{/if}}" data-tc-panel="presets">
      <div class="ncm-tc__slabel">Built-in Presets</div>
      <div class="ncm-tc__preset-grid">
        {{#each presets}}
        <div class="ncm-tc__pcard {{#if isActive}}ncm-tc__pcard--active{{/if}}"
             data-action="selectPreset" data-preset="{{key}}">
          <div class="ncm-tc__pcard-swatch">
            <span style="background:{{primary}};"></span>
            <span style="background:{{secondary}};"></span>
            <span style="background:{{bgBase}};"></span>
          </div>
          <div class="ncm-tc__pcard-name">{{label}}</div>
        </div>
        {{/each}}
      </div>

      <div class="ncm-tc__divider"></div>
      <div class="ncm-tc__slabel">Custom Presets</div>
      <div class="ncm-tc__clist">
        {{#each customPresets}}
        <div class="ncm-tc__citem" data-custom-index="{{@index}}">
          <div class="ncm-tc__citem-swatch">
            <span style="background:{{primary}};"></span>
            <span style="background:{{secondary}};"></span>
            <span style="background:{{bgBase}};"></span>
          </div>
          <span class="ncm-tc__citem-name">{{name}}</span>
          <div class="ncm-tc__citem-actions">
            <button data-action="applyCustomPreset" data-custom-index="{{@index}}" title="Apply"><i class="fas fa-check"></i></button>
            <button data-action="overwriteCustomPreset" data-custom-index="{{@index}}" title="Overwrite"><i class="fas fa-save"></i></button>
            <button class="ncm-tc__citem-del" data-action="deleteCustomPreset" data-custom-index="{{@index}}" title="Delete"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless customPresets.length}}
        <div class="ncm-tc__cempty">No custom presets saved yet.</div>
        {{/unless}}
      </div>
      <div class="ncm-tc__pactions">
        <button class="ncm-tc__paction" data-action="saveAsCustomPreset"><i class="fas fa-plus"></i> Save Current</button>
        <button class="ncm-tc__paction" data-action="importTheme"><i class="fas fa-file-import"></i> Import</button>
        <button class="ncm-tc__paction" data-action="exportTheme"><i class="fas fa-file-export"></i> Export</button>
      </div>
    </div>

    {{!-- ── COLORS ── --}}
    <div class="ncm-tc__panel {{#if (eq activeTab 'colors')}}ncm-tc__panel--active{{/if}}" data-tc-panel="colors">
      <div class="ncm-tc__slabel">Color Overrides</div>
      <div class="ncm-tc__color-grid">
        {{#each colorEntries}}
        <div class="ncm-tc__color-entry" data-color-key="{{key}}">
          <div class="ncm-tc__color-swatch"><input type="color" value="{{value}}" /></div>
          <span class="ncm-tc__color-label">{{label}}</span>
          <span class="ncm-tc__color-hex">{{value}}</span>
          {{#if hasOverride}}<div class="ncm-tc__color-dot"></div>{{/if}}
        </div>
        {{/each}}
      </div>
      <button class="ncm-tc__color-reset" data-action="resetColors"><i class="fas fa-undo"></i> Reset colors to preset defaults</button>
    </div>

    {{!-- ── FONTS ── --}}
    <div class="ncm-tc__panel {{#if (eq activeTab 'fonts')}}ncm-tc__panel--active{{/if}}" data-tc-panel="fonts">
      <div class="ncm-tc__slabel">Font Selection</div>
      <div class="ncm-tc__font-section">
        {{#each fontSelectors}}
        <div class="ncm-tc__font-row">
          <span class="ncm-tc__font-label">{{this.label}}</span>
          <select class="ncm-tc__font-select" data-font-slot="{{this.slot}}">
            {{#each this.options}}
            <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        {{/each}}
        <div class="ncm-tc__font-preview">
          <div class="ncm-tc__fprev-title">NIGHT CITY MESSENGER</div>
          <div class="ncm-tc__fprev-body">Jackie sent you a message about the gig at El Coyote Cojo.</div>
          <div class="ncm-tc__fprev-mono">14:32 // CITINET // 98% signal</div>
        </div>
        <div class="ncm-tc__srow">
          <span class="ncm-tc__srow-label">Text Size</span>
          <input type="range" name="textScale" min="80" max="120" step="5" value="{{textScale}}" class="ncm-tc__slider" />
          <span class="ncm-tc__srow-val ncm-tc__scale-val">{{textScale}}%</span>
        </div>
      </div>
    </div>

    {{!-- ── EFFECTS ── --}}
    <div class="ncm-tc__panel {{#if (eq activeTab 'effects')}}ncm-tc__panel--active{{/if}}" data-tc-panel="effects">
      <div class="ncm-tc__slabel">Visual Effects</div>
      <div class="ncm-tc__fx">
        <div class="ncm-tc__trow">
          <div><div class="ncm-tc__trow-label">CRT Scanlines</div><div class="ncm-tc__trow-desc">Horizontal scan lines over NCM windows</div></div>
          <div class="ncm-tc__switch {{#if scanlines}}ncm-tc__switch--on{{/if}}" data-action="toggleScanlines"></div>
        </div>
        <div class="ncm-tc__trow">
          <div><div class="ncm-tc__trow-label">Neon Glow</div><div class="ncm-tc__trow-desc">Glow effects on primary/secondary elements</div></div>
          <div class="ncm-tc__switch {{#if neonGlow}}ncm-tc__switch--on{{/if}}" data-action="toggleNeonGlow"></div>
        </div>
        <div class="ncm-tc__srow">
          <div><div class="ncm-tc__trow-label">Glitch Intensity</div><div class="ncm-tc__trow-desc">Random glitch animations</div></div>
          <input type="range" name="glitchIntensity" min="0" max="100" value="{{glitchIntensity}}" class="ncm-tc__slider" style="flex:1;" />
          <span class="ncm-tc__srow-val">{{glitchIntensity}}%</span>
        </div>
      </div>

      <div class="ncm-tc__slabel">Animation & Density</div>
      <div class="ncm-tc__fx">
        <div class="ncm-tc__trow">
          <div class="ncm-tc__trow-label">Animation Level</div>
          <div class="ncm-tc__bgroup">
            {{#each animationLevels}}
            <button class="ncm-tc__bopt {{#if active}}ncm-tc__bopt--active{{/if}}" data-action="setAnimationLevel" data-level="{{id}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
        <div class="ncm-tc__trow">
          <div class="ncm-tc__trow-label">Message Density</div>
          <div class="ncm-tc__bgroup">
            {{#each densityOptions}}
            <button class="ncm-tc__bopt {{#if active}}ncm-tc__bopt--active{{/if}}" data-action="setDensity" data-density="{{id}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
      </div>

      <div class="ncm-tc__slabel">Sound</div>
      <div class="ncm-tc__fx">
        <div class="ncm-tc__srow">
          <div class="ncm-tc__trow-label">Volume</div>
          <input type="range" name="soundVolume" min="0" max="100" value="{{soundVolume}}" class="ncm-tc__slider" style="flex:1;" />
          <span class="ncm-tc__srow-val">{{soundVolume}}%</span>
        </div>
      </div>
    </div>

  </div>

  {{!-- ═══ FOOTER ═══ --}}
  <div class="ncm-tc__footer">
    <button class="ncm-tc__fbtn ncm-tc__fbtn--ghost" data-action="resetDefaults"><i class="fas fa-undo"></i> Reset</button>
    <div class="ncm-tc__fspace"></div>
    <button class="ncm-tc__fbtn ncm-tc__fbtn--ghost" data-action="cancel">Cancel</button>
    <button class="ncm-tc__fbtn ncm-tc__fbtn--primary {{#unless isDirty}}ncm-tc__fbtn--disabled{{/unless}}" data-action="save" {{#unless isDirty}}disabled{{/unless}}>
      <i class="fas fa-save"></i> Save
    </button>
  </div>

</div>
