{{!-- Theme Customizer — Live Preview Color Picker --}}
{{!-- @file templates/theme-customizer/theme-customizer.hbs --}}
{{!-- @module cyberpunkred-messenger --}}

<div class="ncm-theme-customizer">

  {{!-- Header --}}
  <div class="ncm-theme-header">
    <h2 class="ncm-theme-title">
      <i class="fas fa-palette"></i> TERMINAL THEME
    </h2>
    <span class="ncm-theme-current">{{currentPresetLabel}}</span>
  </div>

  {{!-- Preset Selector --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Presets</h3>
    <div class="ncm-preset-grid">
      {{#each presets}}
      <button class="ncm-preset-btn {{#if isActive}}ncm-preset-btn--active{{/if}}"
              data-action="selectPreset" data-preset="{{key}}"
              title="{{label}}">
        <div class="ncm-preset-swatch">
          <span class="ncm-swatch-stripe" style="background: {{primary}};"></span>
          <span class="ncm-swatch-stripe" style="background: {{secondary}};"></span>
          <span class="ncm-swatch-bg" style="background: {{bgBase}};"></span>
        </div>
        <span class="ncm-preset-label">{{label}}</span>
      </button>
      {{/each}}
    </div>
  </section>

  {{!-- Color Overrides --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Colors</h3>
    <div class="ncm-color-grid">
      {{#each colorEntries}}
      <div class="ncm-color-entry" data-color-key="{{key}}">
        <label class="ncm-color-label">{{label}}</label>
        <div class="ncm-color-input-group">
          <input type="color" value="{{value}}" class="ncm-color-picker" />
          <span class="ncm-color-hex">{{value}}</span>
          {{#if hasOverride}}
          <span class="ncm-color-override-badge" title="Custom override">*</span>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{!-- Effects --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Effects</h3>

    <div class="ncm-toggle-row">
      <label>CRT Scanlines</label>
      <button class="ncm-toggle {{#if scanlines}}ncm-toggle--on{{/if}}"
              data-action="toggleScanlines">
        {{#if scanlines}}ON{{else}}OFF{{/if}}
      </button>
    </div>

    <div class="ncm-toggle-row">
      <label>Neon Glow</label>
      <button class="ncm-toggle {{#if neonGlow}}ncm-toggle--on{{/if}}"
              data-action="toggleNeonGlow">
        {{#if neonGlow}}ON{{else}}OFF{{/if}}
      </button>
    </div>

    <div class="ncm-slider-row">
      <label>Glitch Intensity</label>
      <input type="range" name="glitchIntensity" min="0" max="100" value="{{glitchIntensity}}"
             class="ncm-slider" />
      <span class="ncm-slider-value">{{glitchIntensity}}%</span>
    </div>
  </section>

  {{!-- Animation Level --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Animation Level</h3>
    <div class="ncm-btn-group">
      {{#each animationLevels}}
      <button class="ncm-btn ncm-btn--small {{#if active}}ncm-btn--primary{{else}}ncm-btn--ghost{{/if}}"
              data-action="setAnimationLevel" data-level="{{id}}">
        {{label}}
      </button>
      {{/each}}
    </div>
  </section>

  {{!-- Density --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Message Density</h3>
    <div class="ncm-btn-group">
      {{#each densityOptions}}
      <button class="ncm-btn ncm-btn--small {{#if active}}ncm-btn--primary{{else}}ncm-btn--ghost{{/if}}"
              data-action="setDensity" data-density="{{id}}">
        {{label}}
      </button>
      {{/each}}
    </div>
  </section>

  {{!-- Fonts --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Fonts</h3>
    {{#each fontSelectors}}
    <div class="ncm-font-row">
      <label class="ncm-font-row__label">{{this.label}}</label>
      <select class="ncm-font-row__select" data-font-slot="{{this.slot}}">
        {{#each this.options}}
        <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}
                style="font-family: {{this.family}};">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    {{/each}}
  </section>

  {{!-- Sound --}}
  <section class="ncm-theme-section">
    <h3 class="ncm-theme-section-title">Sound</h3>
    <div class="ncm-slider-row">
      <label>Volume</label>
      <input type="range" name="soundVolume" min="0" max="100" value="{{soundVolume}}"
             class="ncm-slider" />
      <span class="ncm-slider-value">{{soundVolume}}%</span>
    </div>
  </section>

  {{!-- Footer Actions --}}
  <div class="ncm-theme-footer">
    <button class="ncm-btn ncm-btn--ghost ncm-btn--small" data-action="resetDefaults">
      <i class="fas fa-undo"></i> Reset
    </button>
    <div class="ncm-theme-footer-right">
      <button class="ncm-btn ncm-btn--ghost" data-action="cancel">Cancel</button>
      <button class="ncm-btn ncm-btn--primary {{#unless isDirty}}ncm-btn--disabled{{/unless}}"
              data-action="save" {{#unless isDirty}}disabled{{/unless}}>
        <i class="fas fa-save"></i> Save
      </button>
    </div>
  </div>
</div>
