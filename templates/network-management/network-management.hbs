{{!-- Network Management Main Template --}}
{{!-- File: templates/network-management/network-management.hbs --}}

<div class="ncm-network-management-container">
  {{!-- Header with Stats --}}
  <div class="ncm-management-header">
    <div class="stats-row">
      <div class="stat-card">
        <i class="fas fa-network-wired"></i>
        <div class="stat-content">
          <div class="stat-value">{{stats.totalNetworks}}</div>
          <div class="stat-label">Total Networks</div>
        </div>
      </div>
      <div class="stat-card">
        <i class="fas fa-plus-circle"></i>
        <div class="stat-content">
          <div class="stat-value">{{stats.customNetworks}}</div>
          <div class="stat-label">Custom</div>
        </div>
      </div>
      <div class="stat-card">
        <i class="fas fa-lock"></i>
        <div class="stat-content">
          <div class="stat-value">{{stats.securedNetworks}}</div>
          <div class="stat-label">Secured</div>
        </div>
      </div>
      <div class="stat-card">
        <i class="fas fa-calendar-alt"></i>
        <div class="stat-content">
          <div class="stat-value">{{stats.activeEvents}}</div>
          <div class="stat-label">Active Events</div>
        </div>
      </div>
    </div>
  </div>

  {{!-- Tabs Navigation --}}
  <nav class="tabs" data-group="network-management">
    <a class="item {{#if (eq activeTab 'networks')}}active{{/if}}" data-tab="networks">
      <i class="fas fa-network-wired"></i> Networks
    </a>
    <a class="item {{#if (eq activeTab 'scenes')}}active{{/if}}" data-tab="scenes">
      <i class="fas fa-map"></i> Scenes
    </a>
    <a class="item {{#if (eq activeTab 'events')}}active{{/if}}" data-tab="events">
      <i class="fas fa-calendar-alt"></i> Events
    </a>
    <a class="item {{#if (eq activeTab 'logs')}}active{{/if}}" data-tab="logs">
      <i class="fas fa-clipboard-list"></i> Logs
    </a>
  </nav>

  {{!-- Tab Content --}}
  <div class="tab-content">
    {{!-- Networks Tab --}}
    <div class="tab {{#if (eq activeTab 'networks')}}active{{/if}}" data-tab="networks">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/networks-tab.hbs"}}
    </div>

    {{!-- Scenes Tab --}}
    <div class="tab {{#if (eq activeTab 'scenes')}}active{{/if}}" data-tab="scenes">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/scenes-tab.hbs"}}
    </div>

    {{!-- Events Tab --}}
    <div class="tab {{#if (eq activeTab 'events')}}active{{/if}}" data-tab="events">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/events-tab.hbs"}}
    </div>

    {{!-- Logs Tab --}}
    <div class="tab {{#if (eq activeTab 'logs')}}active{{/if}}" data-tab="logs">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/logs-tab.hbs"}}
    </div>
  </div>
</div>
