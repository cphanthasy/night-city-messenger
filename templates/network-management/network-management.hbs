{{!--
  Network Management Panel — Redesigned v2
  File: templates/network-management/network-management.hbs
  Module: cyberpunkred-messenger
  Description: GM tool for managing custom networks, scene availability,
               authentication, dead zones, and access logs.
               3-tab split-panel layout matching NCM design system.
  Mockup ref: ncm-network-manager-mockup-v2.html
--}}

<div class="ncm-netmgr">

  {{!-- ═══════════════════════════════════════════
       CONDENSED HEADER — Network Status Bar
       ═══════════════════════════════════════════ --}}
  <div class="ncm-netmgr__header">
    <div class="ncm-netmgr__header-icon-ring">
      <i class="fas fa-network-wired"></i>
    </div>
    <div class="ncm-netmgr__header-identity">
      <div class="ncm-netmgr__header-title">Subnet Control</div>
      <div class="ncm-netmgr__header-subtitle">GM Clearance // Network Operations</div>
    </div>
    <div class="ncm-netmgr__header-sep"></div>
    <div class="ncm-netmgr__header-stats">
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--cyan">{{headerStats.totalNetworks}}</span>
        <span class="ncm-netmgr__header-stat-label">Subnets</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--green">{{headerStats.activeCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Active</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--gold">{{headerStats.securedCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Secured</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--red">{{headerStats.deadZoneCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Dead Zones</span>
      </div>
    </div>
    <div class="ncm-netmgr__header-sep"></div>
    {{#if currentNetwork}}
    <div class="ncm-netmgr__header-active-net">
      <div class="ncm-netmgr__header-active-dot"></div>
      <span class="ncm-netmgr__header-active-name">{{currentNetwork.name}}</span>
    </div>
    {{/if}}
  </div>

  {{!-- ═══════════════════════════════════════════
       TAB BAR
       ═══════════════════════════════════════════ --}}
  <nav class="ncm-netmgr__tabs">
    <button class="ncm-netmgr__tab {{#if isNetworksTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="networks">
      <i class="fas fa-network-wired"></i> Subnets
    </button>
    <button class="ncm-netmgr__tab {{#if isScenesTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="scenes">
      <i class="fas fa-map"></i> Scenes
    </button>
    <button class="ncm-netmgr__tab {{#if isLogsTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="logs">
      <i class="fas fa-clipboard-list"></i> Logs
      {{#if logCount}}<span class="ncm-netmgr__tab-count">{{logCount}}</span>{{/if}}
    </button>
  </nav>


  {{!-- ═══════════════════════════════════════════════════════
       TAB 1: SUBNET REGISTRY — Split Panel
       ═══════════════════════════════════════════════════════ --}}
  {{#if isNetworksTab}}
  <div class="ncm-netmgr__content ncm-netmgr__content--no-pad">
    <div class="ncm-netmgr__split">

      {{!-- LEFT: Network List Sidebar --}}
      <div class="ncm-netmgr__split-list">
        <div class="ncm-netmgr__split-list-header">
          <span class="ncm-netmgr__split-list-title">Subnets</span>
          <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary"
                  data-action="quickCreate"
                  title="Quick-create with template presets">
            <i class="fas fa-bolt"></i>
          </button>
          <button class="ncm-netmgr__btn-add" data-action="createNetwork" title="Create custom network (inline)">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        <div class="ncm-netmgr__net-list">
          {{#each networks}}
          <div class="ncm-netmgr__net-item {{#if isSelected}}ncm-netmgr__net-item--selected{{/if}} {{#if isCurrent}}ncm-netmgr__net-item--current{{/if}}"
               data-action="selectNetwork" data-network-id="{{id}}">

            {{!-- Network Icon Badge --}}
            <div class="ncm-netmgr__net-item-icon ncm-netmgr__net-item-icon--{{networkTypeClass}}"
                 {{#if theme.color}}style="--net-color: {{theme.color}};"{{/if}}>
              <i class="fas {{theme.icon}}"></i>
            </div>

            {{!-- Network Info --}}
            <div class="ncm-netmgr__net-item-info">
              <div class="ncm-netmgr__net-item-name {{#if isCurrent}}ncm-netmgr__net-item-name--active{{/if}}">
                {{name}}
              </div>
              <div class="ncm-netmgr__net-item-meta">
                {{typeLabel}}
                {{#if isCore}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--core">Core</span>
                {{else}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--custom">Custom</span>
                {{/if}}
                {{#if security.requiresAuth}}
                  <i class="fas fa-lock ncm-netmgr__net-item-lock"></i>
                {{/if}}
              </div>
            </div>

            {{!-- Signal Strength Bars --}}
            <div class="ncm-netmgr__signal-bars">
              {{#each signalBars}}
              <div class="ncm-netmgr__signal-bar {{#if active}}ncm-netmgr__signal-bar--{{level}}{{/if}}"
                   style="height: {{height}}px;"></div>
              {{/each}}
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- RIGHT: Detail / Editor / Empty State --}}
      <div class="ncm-netmgr__split-detail">

        {{!-- ─── EDITOR MODE (Create or Edit) ─── --}}
        {{#if isEditing}}
        <form class="ncm-netmgr__editor ncm-network-form">
          <div class="ncm-netmgr__editor-body">

          {{!-- Identity Fieldset --}}
          <div class="ncm-netmgr__fieldset">
            <div class="ncm-netmgr__fieldset-legend"><i class="fas fa-id-card"></i> Identity</div>
            <div class="ncm-netmgr__fieldset-body">
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Network Name</label>
                  <input class="ncm-netmgr__input" type="text" name="name"
                         value="{{#unless isCreating}}{{selectedNetwork.name}}{{/unless}}"
                         placeholder="Network name...">
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Type</label>
                  <select class="ncm-netmgr__select" name="type">
                    {{#each networkTypes}}
                    <option value="{{value}}"
                      {{#if (eq value ../selectedNetwork.type)}}selected{{/if}}
                      {{#if (and ../isCreating (eq value "custom"))}}selected{{/if}}>
                      {{label}}
                    </option>
                    {{/each}}
                  </select>
                </div>
              </div>
              <div class="ncm-netmgr__field">
                <label class="ncm-netmgr__field-label">Description</label>
                <input class="ncm-netmgr__input" type="text" name="description"
                       value="{{#unless isCreating}}{{selectedNetwork.description}}{{/unless}}"
                       placeholder="In-world description...">
              </div>
              <div class="ncm-netmgr__field">
                <label class="ncm-netmgr__field-label">Lore / Notes</label>
                <input class="ncm-netmgr__input" type="text" name="lore"
                       value="{{#unless isCreating}}{{selectedNetwork.lore}}{{/unless}}"
                       placeholder="GM-only notes...">
              </div>
            </div>
          </div>

          {{!-- Signal & Reliability Fieldset --}}
          <div class="ncm-netmgr__fieldset">
            <div class="ncm-netmgr__fieldset-legend"><i class="fas fa-signal"></i> Signal</div>
            <div class="ncm-netmgr__fieldset-body">
              <div class="ncm-netmgr__field-row ncm-netmgr__field-row--3">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Signal Strength</label>
                  <input class="ncm-netmgr__input" type="number" name="signalStrength"
                         value="{{#if isCreating}}75{{else}}{{selectedNetwork.signalStrength}}{{/if}}"
                         min="0" max="100">
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Reliability %</label>
                  <input class="ncm-netmgr__input" type="number" name="reliability"
                         value="{{#if isCreating}}85{{else}}{{selectedNetwork.reliability}}{{/if}}"
                         min="0" max="100">
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Message Delay (ms)</label>
                  <input class="ncm-netmgr__input" type="number" name="messageDelay"
                         value="{{#if isCreating}}0{{else}}{{selectedNetwork.effects.messageDelay}}{{/if}}"
                         min="0">
                </div>
              </div>
              <label class="ncm-netmgr__checkbox-row">
                <input type="checkbox" name="globalAvailability" value="true"
                       {{#if selectedNetwork.availability.global}}checked{{/if}}>
                Globally Available (all scenes)
              </label>
            </div>
          </div>

          {{!-- Security Fieldset --}}
          <div class="ncm-netmgr__fieldset">
            <div class="ncm-netmgr__fieldset-legend"><i class="fas fa-shield-halved"></i> Security</div>
            <div class="ncm-netmgr__fieldset-body">

              {{!-- Row 1: Security Level + Auth Required --}}
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Security Level</label>
                  <select class="ncm-netmgr__select" name="securityLevel">
                    {{#each securityLevels}}
                    <option value="{{value}}"
                      {{#if (eq value ../selectedNetwork.security.level)}}selected{{/if}}>
                      {{label}}
                    </option>
                    {{/each}}
                  </select>
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Authentication</label>
                  <select class="ncm-netmgr__select" name="requiresAuth">
                    <option value="false" {{#unless selectedNetwork.security.requiresAuth}}selected{{/unless}}>None (open)</option>
                    <option value="true" {{#if selectedNetwork.security.requiresAuth}}selected{{/if}}>Required</option>
                  </select>
                </div>
              </div>

              {{!-- Auth Methods (which bypass/auth methods are available) --}}
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field" style="flex:2;">
                  <label class="ncm-netmgr__field-label">Auth / Bypass Methods</label>
                  <div class="ncm-netmgr__method-toggles">
                    <label class="ncm-netmgr__checkbox-row">
                      <input type="checkbox" name="allowPassword" value="true"
                             {{#if selectedNetwork.security.allowPassword}}checked{{/if}}>
                      <i class="fas fa-key" style="color:var(--ncm-accent,#f7c948);margin-right:2px;font-size:9px;"></i>
                      Password
                    </label>
                    <label class="ncm-netmgr__checkbox-row">
                      <input type="checkbox" name="allowSkillCheck" value="true"
                             {{#if selectedNetwork.security.allowSkillCheck}}checked{{/if}}>
                      <i class="fas fa-dice-d20" style="color:#a855f7;margin-right:2px;font-size:9px;"></i>
                      Skill Check
                    </label>
                    <label class="ncm-netmgr__checkbox-row">
                      <input type="checkbox" name="allowKeyItem" value="true"
                             {{#if selectedNetwork.security.allowKeyItem}}checked{{/if}}>
                      <i class="fas fa-id-badge" style="color:var(--ncm-secondary,#19f3f7);margin-right:2px;font-size:9px;"></i>
                      Key Item
                    </label>
                  </div>
                </div>
                <div class="ncm-netmgr__field" style="flex:1;">
                  <label class="ncm-netmgr__field-label">Combination Logic</label>
                  <select class="ncm-netmgr__select" name="authLogic">
                    <option value="any" {{#if (eq selectedNetwork.security.authLogic "any")}}selected{{/if}}>
                      ANY method (OR)
                    </option>
                    <option value="all" {{#unless selectedNetwork.security.authLogic}}selected{{/unless}}
                            {{#if (eq selectedNetwork.security.authLogic "all")}}selected{{/if}}>
                      ALL methods (AND)
                    </option>
                  </select>
                  <span class="ncm-netmgr__field-hint">
                    {{#if (eq selectedNetwork.security.authLogic "all")}}
                      Player must pass ALL enabled checks to gain access.
                    {{else}}
                      Player can use any single method to gain access.
                    {{/if}}
                  </span>
                </div>
              </div>

              {{!-- Password Config --}}
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Password</label>
                  <input class="ncm-netmgr__input" type="text" name="password"
                         value="{{selectedNetwork.security.password}}"
                         placeholder="Network password...">
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Max Attempts / Lockout (min)</label>
                  <div class="ncm-netmgr__field-pair">
                    <input class="ncm-netmgr__input" type="number" name="maxAttempts"
                           value="{{#if isCreating}}3{{else}}{{selectedNetwork.security.maxAttempts}}{{/if}}"
                           min="1">
                    <input class="ncm-netmgr__input" type="number" name="lockoutMinutes"
                           value="{{#if isCreating}}60{{else}}{{selectedNetwork.lockoutMinutes}}{{/if}}"
                           min="1">
                  </div>
                </div>
              </div>

              {{!-- Skill Check Config --}}
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Bypass Skills (comma-separated)</label>
                  <input class="ncm-netmgr__input" type="text" name="bypassSkills"
                         value="{{#if selectedNetwork.security.bypassSkills}}{{join selectedNetwork.security.bypassSkills ","}}{{/if}}"
                         placeholder="Interface, Electronics/Security Tech">
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Bypass DV</label>
                  <input class="ncm-netmgr__input" type="number" name="bypassDC"
                         value="{{#if isCreating}}15{{else}}{{selectedNetwork.security.bypassDC}}{{/if}}"
                         min="1">
                </div>
              </div>

              {{!-- Key Item Config --}}
              <div class="ncm-netmgr__field-row">
                <div class="ncm-netmgr__field" style="flex:2;">
                  <label class="ncm-netmgr__field-label">Key Item Name (match by name in inventory)</label>
                  <div style="display:flex;gap:4px;align-items:center;">
                    <input class="ncm-netmgr__input" type="text" name="keyItemName"
                           value="{{selectedNetwork.security.keyItemName}}"
                           placeholder="e.g. Arasaka Access Card"
                           style="flex:1;">
                    <button type="button" class="ncm-netmgr__btn-sm" data-action="browseKeyItem"
                            title="Browse world items">
                      <i class="fas fa-search"></i>
                    </button>
                  </div>
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Key Item Tag (optional)</label>
                  <input class="ncm-netmgr__input" type="text" name="keyItemTag"
                         value="{{selectedNetwork.security.keyItemTag}}"
                         placeholder="e.g. arasaka_keycard">
                </div>
              </div>
              <label class="ncm-netmgr__checkbox-row">
                <input type="checkbox" name="keyItemConsume" value="true"
                       {{#if selectedNetwork.security.keyItemConsume}}checked{{/if}}>
                Consume key item on use (removes from inventory)
              </label>

              {{!-- Effects Toggles --}}
              <div class="ncm-netmgr__field-row" style="margin-top:8px;">
                <label class="ncm-netmgr__checkbox-row">
                  <input type="checkbox" name="traced" value="true"
                         {{#if selectedNetwork.effects.traced}}checked{{/if}}>
                  Traced (messages can be monitored)
                </label>
                <label class="ncm-netmgr__checkbox-row">
                  <input type="checkbox" name="anonymity" value="true"
                         {{#if selectedNetwork.effects.anonymity}}checked{{/if}}>
                  Anonymous (hide sender identity)
                </label>
              </div>
              <label class="ncm-netmgr__checkbox-row">
                <input type="checkbox" name="canRoute" value="true"
                       {{#unless isCreating}}
                         {{#if selectedNetwork.effects.canRoute}}checked{{/if}}
                       {{else}}
                         checked
                       {{/unless}}>
                Can Route to Other Networks
              </label>
              <label class="ncm-netmgr__checkbox-row">
                <input type="checkbox" name="restrictedAccess" value="true"
                       {{#if selectedNetwork.effects.restrictedAccess}}checked{{/if}}>
                Restricted Access (messages only readable on this network)
              </label>
              <div class="ncm-netmgr__field">
                <label class="ncm-netmgr__field-label">Allowed Recipient Networks (comma-separated IDs)</label>
                <input class="ncm-netmgr__input" type="text" name="allowedRecipientNetworks"
                       value="{{#if selectedNetwork.effects.allowedRecipientNetworks}}{{join selectedNetwork.effects.allowedRecipientNetworks ","}}{{/if}}"
                       placeholder="Leave empty for unrestricted">
              </div>
            </div>
          </div>

          {{!-- Theme Fieldset --}}
          <div class="ncm-netmgr__fieldset">
            <div class="ncm-netmgr__fieldset-legend"><i class="fas fa-palette"></i> Theme</div>
            <div class="ncm-netmgr__fieldset-body">
              <div class="ncm-netmgr__field-row ncm-netmgr__field-row--3">
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Color</label>
                  <div class="ncm-netmgr__color-picker">
                    <input type="color" name="themeColor" class="ncm-netmgr__color-swatch"
                           value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}">
                    <input class="ncm-netmgr__input" type="text" name="themeColorText"
                           value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}"
                           style="width:80px;">
                  </div>
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Icon</label>
                  <select class="ncm-netmgr__select" name="themeIcon">
                    {{#each iconOptions}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="ncm-netmgr__field">
                  <label class="ncm-netmgr__field-label">Glitch Intensity</label>
                  <input class="ncm-netmgr__input" type="number" name="glitchIntensity"
                         value="{{#if isCreating}}0.1{{else}}{{selectedNetwork.theme.glitchIntensity}}{{/if}}"
                         min="0" max="1" step="0.1">
                </div>
              </div>
            </div>
          </div>{{!-- /.ncm-netmgr__editor-body --}}

          {{!-- Editor Actions --}}
          <div class="ncm-netmgr__editor-actions">
            <button type="button" class="ncm-netmgr__btn-sm" data-action="cancelEdit">
              <i class="fas fa-times"></i> Cancel
            </button>
            {{#unless isCreating}}
              {{#unless selectedNetwork.isCore}}
              <button type="button" class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="deleteNetwork">
                <i class="fas fa-trash"></i> Delete
              </button>
              {{/unless}}
            {{/unless}}
            <div class="ncm-netmgr__editor-spacer"></div>
            <button type="button" class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary" data-action="saveNetwork">
              <i class="fas fa-save"></i> {{#if isCreating}}Create Network{{else}}Save Network{{/if}}
            </button>
          </div>
        </form>

        {{!-- ─── DETAIL VIEW (Read-only) ─── --}}
        {{else if selectedNetwork}}
        <div class="ncm-netmgr__detail">

          {{!-- Detail Header --}}
          <div class="ncm-netmgr__detail-header">
            <div class="ncm-netmgr__detail-header-icon ncm-netmgr__net-item-icon--{{selectedNetwork.networkTypeClass}}"
                 {{#if selectedNetwork.theme.color}}style="--net-color: {{selectedNetwork.theme.color}};"{{/if}}>
              <i class="fas {{selectedNetwork.theme.icon}}"></i>
            </div>
            <div class="ncm-netmgr__detail-header-info">
              <div class="ncm-netmgr__detail-header-name">{{selectedNetwork.name}}</div>
              <div class="ncm-netmgr__detail-header-type">
                {{selectedNetwork.typeLabel}} Subnet
                {{#if selectedNetwork.isCore}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--core">Core</span>
                {{else}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--custom">Custom</span>
                {{/if}}
                <span class="ncm-netmgr__auth-badge ncm-netmgr__auth-badge--{{selectedNetwork.authBadgeClass}}">
                  <i class="fas {{selectedNetwork.authIcon}}"></i> {{selectedNetwork.authLabel}}
                </span>
              </div>
            </div>
            <div class="ncm-netmgr__detail-header-actions">
              <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary"
                      data-action="editNetwork">
                <i class="fas fa-pen"></i> Edit
              </button>
            </div>
          </div>

          {{!-- Stats Grid --}}
          <div class="ncm-netmgr__stats-grid">
            <div class="ncm-netmgr__stat ncm-netmgr__stat--cyan">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--cyan">
                {{selectedNetwork.signalStrength}}<span class="ncm-netmgr__stat-unit">%</span>
              </div>
              <div class="ncm-netmgr__signal-meter">
                <div class="ncm-netmgr__signal-meter-fill ncm-netmgr__signal-meter-fill--{{selectedNetwork.signalMeterClass}}"
                     style="width: {{selectedNetwork.signalStrength}}%;"></div>
              </div>
              <div class="ncm-netmgr__stat-label">Signal</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--green">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--green">
                {{selectedNetwork.reliability}}<span class="ncm-netmgr__stat-unit">%</span>
              </div>
              <div class="ncm-netmgr__signal-meter">
                <div class="ncm-netmgr__signal-meter-fill ncm-netmgr__signal-meter-fill--{{selectedNetwork.reliabilityMeterClass}}"
                     style="width: {{selectedNetwork.reliability}}%;"></div>
              </div>
              <div class="ncm-netmgr__stat-label">Reliability</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--gold">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--gold">
                {{selectedNetwork.effects.messageDelay}}
              </div>
              <div class="ncm-netmgr__stat-label">Delay (ms)</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--red">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--red">
                {{selectedNetwork.sceneCount}}
              </div>
              <div class="ncm-netmgr__stat-label">Scenes</div>
            </div>
          </div>

          {{!-- Properties --}}
          <div class="ncm-netmgr__props">

            {{!-- Security & Auth --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-shield-halved"></i> Security & Auth</div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Authentication</span>
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--{{selectedNetwork.authValueColor}}">
                  {{selectedNetwork.authLabel}}
                </span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Security Level</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.security.level}}</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Auth Methods</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if selectedNetwork.security.allowPassword}}
                    <i class="fas fa-key" style="color:var(--ncm-accent,#f7c948);margin-right:2px;" title="Password"></i>
                  {{/if}}
                  {{#if selectedNetwork.security.allowSkillCheck}}
                    <i class="fas fa-dice-d20" style="color:#a855f7;margin-right:2px;" title="Skill Check"></i>
                  {{/if}}
                  {{#if selectedNetwork.security.allowKeyItem}}
                    <i class="fas fa-id-badge" style="color:var(--ncm-secondary,#19f3f7);margin-right:2px;" title="Key Item"></i>
                  {{/if}}
                  {{#unless selectedNetwork.security.allowPassword}}
                    {{#unless selectedNetwork.security.allowSkillCheck}}
                      {{#unless selectedNetwork.security.allowKeyItem}}
                        <span style="color:var(--ncm-text-muted);">None configured</span>
                      {{/unless}}
                    {{/unless}}
                  {{/unless}}
                </span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Combination</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if (eq selectedNetwork.security.authLogic "all")}}
                    <span style="color:var(--ncm-primary);">ALL required</span>
                  {{else}}
                    <span style="color:var(--ncm-success,#00ff41);">ANY method</span>
                  {{/if}}
                </span>
              </div>
              {{#if selectedNetwork.security.allowKeyItem}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Key Item</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if selectedNetwork.security.keyItemName}}
                    {{selectedNetwork.security.keyItemName}}
                    {{#if selectedNetwork.security.keyItemConsume}}
                      <span style="color:var(--ncm-primary);font-size:9px;margin-left:4px;">(consumed)</span>
                    {{/if}}
                  {{else}}
                    <span style="color:var(--ncm-text-muted);">Not set</span>
                  {{/if}}
                </span>
              </div>
              {{/if}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Max Auth Attempts</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.security.maxAttempts}}</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Lockout Duration</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.lockoutMinutes}} min</span>
              </div>
            </div>

            {{!-- Effects --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-bolt"></i> Effects</div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Message Delay</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.effects.messageDelay}} ms</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Traced</span>
                {{#if selectedNetwork.effects.traced}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--red">
                  <i class="fas fa-eye"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Anonymous</span>
                {{#if selectedNetwork.effects.anonymity}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--purple">
                  <i class="fas fa-user-secret"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Can Route</span>
                {{#if selectedNetwork.effects.canRoute}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">
                  <i class="fas fa-check"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--red">
                  <i class="fas fa-times"></i> No
                </span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Restricted Access</span>
                {{#if selectedNetwork.effects.restrictedAccess}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--gold">
                  <i class="fas fa-lock"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              {{#if selectedNetwork.effects.allowedRecipientNetworks.length}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Allowed Recipients</span>
                <span class="ncm-netmgr__prop-value">
                  {{join selectedNetwork.effects.allowedRecipientNetworks ", "}}
                </span>
              </div>
              {{/if}}
            </div>

            {{!-- Availability --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-map-marker-alt"></i> Availability</div>
              <div class="ncm-netmgr__prop-group-body-pad">
                <div class="ncm-netmgr__scene-pills">
                  {{#if selectedNetwork.availability.global}}
                  <span class="ncm-netmgr__scene-pill ncm-netmgr__scene-pill--global">
                    <i class="fas fa-globe"></i> Global
                  </span>
                  {{/if}}
                  {{#each selectedNetwork.scenePills}}
                  <span class="ncm-netmgr__scene-pill {{#if isCurrent}}ncm-netmgr__scene-pill--current{{/if}}">
                    {{name}}
                  </span>
                  {{/each}}
                  {{#unless selectedNetwork.availability.global}}
                    {{#unless selectedNetwork.scenePills.length}}
                    <span class="ncm-netmgr__scene-pill ncm-netmgr__scene-pill--none">No scenes assigned</span>
                    {{/unless}}
                  {{/unless}}
                </div>
              </div>
            </div>

            {{!-- Lore (if any) --}}
            {{#if selectedNetwork.lore}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-book"></i> Lore</div>
              <div class="ncm-netmgr__prop-group-body-pad">
                <span class="ncm-netmgr__lore-text">{{selectedNetwork.lore}}</span>
              </div>
            </div>
            {{/if}}
          </div>

          {{!-- Detail Footer --}}
          <div class="ncm-netmgr__detail-footer">
            {{#if selectedNetwork.isCore}}
            <span class="ncm-netmgr__detail-footer-note">
              <i class="fas fa-shield-halved"></i> Core network — editable, cannot be deleted
            </span>
            {{else}}
            <span class="ncm-netmgr__detail-footer-note">
              <i class="fas fa-cube"></i> Custom network — fully editable
            </span>
            {{/if}}
          </div>
        </div>

        {{!-- ─── EMPTY STATE ─── --}}
        {{else}}
        <div class="ncm-netmgr__empty-state">
          <i class="fas fa-network-wired ncm-netmgr__empty-state-icon"></i>
          <span class="ncm-netmgr__empty-state-text">Select a subnet to inspect</span>
          <span class="ncm-netmgr__empty-state-sub">Or press [N] to create a new custom network.</span>
        </div>
        {{/if}}

      </div>
    </div>
  </div>

  {{!-- Subnet Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">↑↓</span> Navigate</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Enter</span> Select</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">N</span> New network</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Del</span> Delete</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}


  {{!-- ═══════════════════════════════════════════════════════
       TAB 2: SCENE CONFIGURATION
       ═══════════════════════════════════════════════════════ --}}
  {{#if isScenesTab}}
  <div class="ncm-netmgr__content">
    <div class="ncm-netmgr__section-title">
      <i class="fas fa-map"></i> Scene Network Configuration
      <button class="ncm-netmgr__section-action" data-action="refreshScenes">
        <i class="fas fa-sync"></i> Refresh
      </button>
    </div>

    {{#if scenes.length}}
    <div class="ncm-netmgr__scene-grid">
      {{#each scenes}}
      <div class="ncm-netmgr__scene-card {{#if isViewed}}ncm-netmgr__scene-card--current{{/if}} {{#if deadZone}}ncm-netmgr__scene-card--dead{{/if}}"
           data-scene-id="{{id}}">

        {{!-- Scene Card Header --}}
        <div class="ncm-netmgr__scene-card-header">
          <div class="ncm-netmgr__scene-card-dot {{#if deadZone}}ncm-netmgr__scene-card-dot--dead{{else if isViewed}}ncm-netmgr__scene-card-dot--live{{else}}ncm-netmgr__scene-card-dot--inactive{{/if}}"></div>
          <span class="ncm-netmgr__scene-card-name {{#if deadZone}}ncm-netmgr__scene-card-name--dead{{/if}}">
            {{name}}
          </span>
          {{#if deadZone}}
          <span class="ncm-netmgr__scene-card-dead-tag">
            <i class="fas fa-ban"></i> Dead Zone
          </span>
          {{/if}}
          <button class="ncm-netmgr__scene-toggle-dead {{#if deadZone}}ncm-netmgr__scene-toggle-dead--on{{else}}ncm-netmgr__scene-toggle-dead--off{{/if}}"
                  data-action="toggleDeadZone">
            {{#if deadZone}}
            <i class="fas fa-signal"></i> Restore Signal
            {{else}}
            <i class="fas fa-signal"></i> Signal OK
            {{/if}}
          </button>
        </div>

        {{!-- Scene Card Body --}}
        <div class="ncm-netmgr__scene-card-body {{#if deadZone}}ncm-netmgr__scene-card-body--disabled{{/if}}">

          {{!-- Default Network --}}
          <div>
            <div class="ncm-netmgr__scene-card-field-label">Default Network</div>
            {{#if deadZone}}
            <select class="ncm-netmgr__select" disabled style="width:100%;">
              <option>— Dead Zone — No Networks —</option>
            </select>
            {{else}}
            <select class="ncm-netmgr__select" name="defaultNetwork" style="width:100%;">
              <option value="">— None —</option>
              {{#each ../allNetworks}}
              <option value="{{id}}" {{#if (eq id ../defaultNetwork)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
            {{/if}}
          </div>

          {{!-- Available Networks --}}
          <div>
            <div class="ncm-netmgr__scene-card-field-label">Available Networks</div>
            {{#if deadZone}}
            <div class="ncm-netmgr__scene-dead-notice">
              <i class="fas fa-ban"></i> All signals jammed — Dead Zone active
            </div>
            {{else}}
            <div class="ncm-netmgr__scene-net-list">
              {{#each ../allNetworks}}
              {{#if availability.global}}
              <label class="ncm-netmgr__scene-net-check ncm-netmgr__scene-net-check--active ncm-netmgr__scene-net-check--global">
                <input type="checkbox" name="netAvail_{{id}}" checked disabled>
                <span class="ncm-netmgr__scene-net-check-icon" style="color: {{theme.color}};">
                  <i class="fas {{theme.icon}}"></i>
                </span>
                {{name}}
                <span class="ncm-netmgr__tag ncm-netmgr__tag--core" style="font-size:6px; margin-left:2px;">GLOBAL</span>
              </label>
              {{else}}
              <label class="ncm-netmgr__scene-net-check {{#if (lookup ../networkAvailability id)}}ncm-netmgr__scene-net-check--active{{/if}}">
                <input type="checkbox" name="netAvail_{{id}}"
                       {{#if (lookup ../networkAvailability id)}}checked{{/if}}>
                <span class="ncm-netmgr__scene-net-check-icon" style="color: {{theme.color}};">
                  <i class="fas {{theme.icon}}"></i>
                </span>
                {{name}}
              </label>
              {{/if}}
              {{/each}}
            </div>
            {{/if}}
          </div>
        </div>

        {{!-- Scene Card Footer --}}
        {{#unless deadZone}}
        <div class="ncm-netmgr__scene-card-footer">
          <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary" data-action="saveSceneConfig">
            <i class="fas fa-save"></i> Save
          </button>
        </div>
        {{/unless}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="ncm-netmgr__empty-state">
      <i class="fas fa-map ncm-netmgr__empty-state-icon"></i>
      <span class="ncm-netmgr__empty-state-text">No scenes found</span>
      <span class="ncm-netmgr__empty-state-sub">Create scenes in Foundry to configure network availability.</span>
    </div>
    {{/if}}
  </div>

  {{!-- Scene Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Ctrl+S</span> Save all</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}


  {{!-- ═══════════════════════════════════════════════════════
       TAB 3: ACCESS LOGS
       ═══════════════════════════════════════════════════════ --}}
  {{#if isLogsTab}}
  <div class="ncm-netmgr__content">

    {{!-- Lockout Banner --}}
    {{#if hasLockouts}}
    <div class="ncm-netmgr__lockout-banner">
      <i class="fas fa-lock ncm-netmgr__lockout-banner-icon"></i>
      <span class="ncm-netmgr__lockout-banner-text">
        Active lockouts detected — players blocked from network access
      </span>
      <span class="ncm-netmgr__lockout-banner-count">{{lockouts.length}}</span>
      <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="resetSecurity">
        <i class="fas fa-unlock"></i> Clear All
      </button>
    </div>
    {{/if}}

    {{!-- Log Toolbar --}}
    <div class="ncm-netmgr__log-toolbar">
      <div class="ncm-netmgr__log-filter-group">
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'all')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="all">All</button>
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'auth')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="auth">Auth</button>
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'switch')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="switch">Switch</button>
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'lockout')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="lockout">Lockout</button>
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'hack')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="hack">Hack</button>
        <button class="ncm-netmgr__log-filter-btn {{#if (eq logFilter 'manual')}}ncm-netmgr__log-filter-btn--active{{/if}}"
                data-action="filterLogs" data-filter="manual">Manual</button>
      </div>
      {{!-- Network filter --}}
      <select class="ncm-netmgr__log-network-filter" data-action="filterLogNetwork">
        <option value="">All Networks</option>
        {{#each networks}}
        <option value="{{this.id}}" {{#if (eq this.id ../logNetworkFilter)}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
      <div class="ncm-netmgr__log-toolbar-spacer"></div>
      <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--accent" data-action="toggleAddLogForm">
        <i class="fas fa-plus"></i> Add Entry
      </button>
      <button class="ncm-netmgr__btn-sm" data-action="exportLogs">
        <i class="fas fa-file-export"></i> Export
      </button>
      <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="clearLogs">
        <i class="fas fa-trash"></i> Clear
      </button>
    </div>

    {{!-- Add Manual Entry Form --}}
    {{#if showAddLogForm}}
    <div class="ncm-netmgr__add-log-form">
      <div class="ncm-netmgr__add-log-field">
        <label>Network</label>
        <select name="logNetwork">
          {{#each networks}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="ncm-netmgr__add-log-field">
        <label>Actor</label>
        <input type="text" name="logActor" placeholder="Unknown" style="width:80px;">
      </div>
      <div class="ncm-netmgr__add-log-field">
        <label>Type</label>
        <select name="logType">
          <option value="connect">Connect</option>
          <option value="disconnect">Disconnect</option>
          <option value="auth_success">Auth Success</option>
          <option value="auth_failure">Auth Failure</option>
          <option value="hack">Hack Attempt</option>
          <option value="lockout">Lockout</option>
          <option value="manual">Trace / Manual</option>
          <option value="malware">Malware</option>
          <option value="system">System</option>
        </select>
      </div>
      <div class="ncm-netmgr__add-log-field ncm-netmgr__add-log-field--message">
        <label>Message</label>
        <input type="text" name="logMessage" placeholder="[TRACE] Unauthorized access from...">
      </div>
      <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--accent" data-action="addManualLogEntry">
        <i class="fas fa-plus"></i> Add
      </button>
    </div>
    {{/if}}

    {{!-- Log Entries --}}
    <div class="ncm-netmgr__log-list">
      {{#if logEntries.length}}
        {{#each logEntries}}
        <div class="ncm-netmgr__log-entry {{#if this.manual}}ncm-netmgr__log-entry--manual{{/if}}"
             data-entry-id="{{this.id}}">
          <div class="ncm-netmgr__log-entry-row1">
            <span class="ncm-netmgr__log-entry-icon ncm-netmgr__log-entry-icon--{{typeClass}}">
              <i class="fas {{typeIcon}}"></i>
            </span>
            <span class="ncm-netmgr__log-entry-type">{{typeLabel}}</span>
            <span class="ncm-netmgr__log-entry-network">{{networkName}}</span>
            <span class="ncm-netmgr__log-entry-time">{{displayDate}} {{displayTime}}</span>
            <div class="ncm-netmgr__log-entry-actions">
              <button class="ncm-netmgr__log-entry-btn" data-action="editLogEntry" data-entry-id="{{this.id}}" title="Edit">
                <i class="fas fa-pen"></i>
              </button>
              <button class="ncm-netmgr__log-entry-btn ncm-netmgr__log-entry-btn--danger" data-action="deleteLogEntry" data-entry-id="{{this.id}}" title="Delete">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
          <div class="ncm-netmgr__log-entry-row2">
            <span class="ncm-netmgr__log-entry-actor">{{actorName}}</span>
            <span class="ncm-netmgr__log-entry-action">{{message}}</span>
          </div>
        </div>
        {{/each}}
      {{else}}
        <div class="ncm-netmgr__empty-state" style="padding: 40px 0;">
          <i class="fas fa-clipboard-list ncm-netmgr__empty-state-icon"></i>
          <span class="ncm-netmgr__empty-state-text">No log entries</span>
          <span class="ncm-netmgr__empty-state-sub">Network activity will appear here.</span>
        </div>
      {{/if}}
    </div>
  </div>

  {{!-- Log Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">F</span> Filter</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">A</span> Add Entry</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Ctrl+E</span> Export</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}

</div>
