{{!-- 
  Network Management Main Template
  Simplified two-tab interface:
  - Networks Tab: Define properties
  - Scenes Tab: Configure availability
--}}

<div class="network-management-container">
  {{!-- Tab Navigation --}}
  <nav class="tabs" data-group="network-management">
    <a class="item {{#if (eq activeTab 'networks')}}active{{/if}}" data-tab="networks">
      <i class="fas fa-network-wired"></i> Networks
    </a>
    <a class="item {{#if (eq activeTab 'scenes')}}active{{/if}}" data-tab="scenes">
      <i class="fas fa-map-marked-alt"></i> Scene Configuration
    </a>
  </nav>

  {{!-- Tab Content --}}
  <div class="tab-content">
    {{!-- NETWORKS TAB --}}
    <div class="tab {{#if (eq activeTab 'networks')}}active{{/if}}" data-tab="networks">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/networks-tab.hbs"}}
    </div>

    {{!-- SCENES TAB --}}
    <div class="tab {{#if (eq activeTab 'scenes')}}active{{/if}}" data-tab="scenes">
      {{> "modules/cyberpunkred-messenger/templates/network-management/partials/scenes-tab.hbs"}}
    </div>
  </div>
</div>

<style>
.network-management-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--ncm-background, #1a1a1a);
  color: var(--ncm-text, #ffffff);
}

.tabs {
  display: flex;
  gap: 0;
  background: var(--ncm-surface, #2a2a2a);
  border-bottom: 2px solid var(--ncm-primary, #F65261);
  padding: 0;
  margin: 0;
}

.tabs .item {
  flex: 1;
  padding: 12px 20px;
  text-align: center;
  cursor: pointer;
  background: transparent;
  border: none;
  color: var(--ncm-text-dim, #888);
  font-family: 'Rajdhani', sans-serif;
  font-size: 16px;
  font-weight: 600;
  text-transform: uppercase;
  transition: all 0.3s ease;
  position: relative;
}

.tabs .item:hover {
  background: rgba(246, 82, 97, 0.1);
  color: var(--ncm-primary, #F65261);
}

.tabs .item.active {
  background: var(--ncm-primary, #F65261);
  color: #ffffff;
}

.tabs .item.active::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--ncm-secondary, #19f3f7);
}

.tabs .item i {
  margin-right: 8px;
}

.tab-content {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.tab-content > .tab {
  display: none;
  height: 100%;
  overflow-y: auto;
  padding: 20px;
}

.tab-content > .tab.active {
  display: block;
}

/* Scrollbar styling */
.tab-content > .tab::-webkit-scrollbar {
  width: 8px;
}

.tab-content > .tab::-webkit-scrollbar-track {
  background: var(--ncm-background, #1a1a1a);
}

.tab-content > .tab::-webkit-scrollbar-thumb {
  background: var(--ncm-primary, #F65261);
  border-radius: 4px;
}

.tab-content > .tab::-webkit-scrollbar-thumb:hover {
  background: var(--ncm-secondary, #19f3f7);
}
</style>
