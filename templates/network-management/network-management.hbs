{{!--
  Network Management Panel — Redesigned v2
  File: templates/network-management/network-management.hbs
  Module: cyberpunkred-messenger
  Description: GM tool for managing custom networks, scene availability,
               authentication, dead zones, and access logs.
               3-tab split-panel layout matching NCM design system.
  Mockup ref: ncm-network-manager-mockup-v2.html
--}}

<div class="ncm-netmgr">

  {{!-- ═══════════════════════════════════════════
       CONDENSED HEADER — Network Status Bar
       ═══════════════════════════════════════════ --}}
  <div class="ncm-netmgr__header">
    <div class="ncm-netmgr__header-icon-ring">
      <i class="fas fa-network-wired"></i>
    </div>
    <div class="ncm-netmgr__header-identity">
      <div class="ncm-netmgr__header-title">Subnet Control</div>
      <div class="ncm-netmgr__header-subtitle">GM Clearance // Network Operations</div>
    </div>
    <div class="ncm-netmgr__header-sep"></div>
    <div class="ncm-netmgr__header-stats">
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--cyan">{{headerStats.totalNetworks}}</span>
        <span class="ncm-netmgr__header-stat-label">Subnets</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--green">{{headerStats.activeCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Active</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--gold">{{headerStats.securedCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Secured</span>
      </div>
      <div class="ncm-netmgr__header-stat">
        <span class="ncm-netmgr__header-stat-value ncm-netmgr__header-stat-value--red">{{headerStats.deadZoneCount}}</span>
        <span class="ncm-netmgr__header-stat-label">Dead Zones</span>
      </div>
    </div>
    <div class="ncm-netmgr__header-sep"></div>
    {{#if currentNetwork}}
    <div class="ncm-netmgr__header-active-net">
      <div class="ncm-netmgr__header-active-dot"></div>
      <span class="ncm-netmgr__header-active-name">{{currentNetwork.name}}</span>
    </div>
    {{/if}}
  </div>

  {{!-- ═══════════════════════════════════════════
       TAB BAR
       ═══════════════════════════════════════════ --}}
  <nav class="ncm-netmgr__tabs">
    <button class="ncm-netmgr__tab {{#if isNetworksTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="networks">
      <i class="fas fa-network-wired"></i> Subnets
    </button>
    <button class="ncm-netmgr__tab {{#if isScenesTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="scenes">
      <i class="fas fa-map"></i> Scenes
    </button>
    <button class="ncm-netmgr__tab {{#if isLogsTab}}ncm-netmgr__tab--active{{/if}}"
            data-action="switchTab" data-tab="logs">
      <i class="fas fa-clipboard-list"></i> Logs
      {{#if logCount}}<span class="ncm-netmgr__tab-count">{{logCount}}</span>{{/if}}
    </button>
  </nav>


  {{!-- ═══════════════════════════════════════════════════════
       TAB 1: SUBNET REGISTRY — Split Panel
       ═══════════════════════════════════════════════════════ --}}
  {{#if isNetworksTab}}
  <div class="ncm-netmgr__content ncm-netmgr__content--no-pad">
    <div class="ncm-netmgr__split">

      {{!-- LEFT: Network List Sidebar --}}
      <div class="ncm-netmgr__split-list">
        <div class="ncm-netmgr__split-list-header">
          <span class="ncm-netmgr__split-list-title">Subnets</span>
          <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary"
                  data-action="quickCreate"
                  title="Quick-create with template presets">
            <i class="fas fa-bolt"></i>
          </button>
          <button class="ncm-netmgr__btn-add" data-action="createNetwork" title="Create custom network (inline)">
            <i class="fas fa-plus"></i>
          </button>
        </div>

        {{!-- Search --}}
        <div class="ncm-netmgr__sidebar-search-wrap">
          <i class="fas fa-search ncm-netmgr__sidebar-search-icon"></i>
          <input class="ncm-netmgr__sidebar-search" type="text"
                 placeholder="Filter subnets..." value="{{networkSearch}}">
        </div>

        <div class="ncm-netmgr__net-list">
          {{#each networkGroups}}
          {{!-- Group Header --}}
          <div class="ncm-netmgr__net-group-header" data-action="toggleSidebarGroup" data-group-key="{{this.key}}">
            <i class="fas {{this.icon}} ncm-netmgr__net-group-icon ncm-netmgr__net-group-icon{{this.iconClass}}"></i>
            <span class="ncm-netmgr__net-group-name">{{this.name}}</span>
            <span class="ncm-netmgr__net-group-count">{{this.count}}</span>
            <span class="ncm-netmgr__net-group-arrow">{{#if this.collapsed}}▶{{else}}▼{{/if}}</span>
          </div>
          {{#unless this.collapsed}}
          {{#each this.networks}}
          <div class="ncm-netmgr__net-item {{#if isSelected}}ncm-netmgr__net-item--selected{{/if}} {{#if isCurrent}}ncm-netmgr__net-item--current{{/if}}"
               data-action="selectNetwork" data-network-id="{{id}}">

            {{!-- Network Icon Badge --}}
            <div class="ncm-netmgr__net-item-icon ncm-netmgr__net-item-icon--{{networkTypeClass}}"
                 {{#if theme.color}}style="--net-color: {{theme.color}};"{{/if}}>
              {{{ncm-net-icon theme}}}
            </div>

            {{!-- Network Info --}}
            <div class="ncm-netmgr__net-item-info">
              <div class="ncm-netmgr__net-item-name {{#if isCurrent}}ncm-netmgr__net-item-name--active{{/if}}">
                {{name}}
              </div>
              <div class="ncm-netmgr__net-item-meta">
                {{typeLabel}}
                {{#if isCore}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--core">Core</span>
                {{else}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--custom">Custom</span>
                {{/if}}
                {{#if security.requiresAuth}}
                  <i class="fas fa-lock ncm-netmgr__net-item-lock"></i>
                {{/if}}
              </div>
            </div>

            {{!-- Signal Strength Bars --}}
            <div class="ncm-netmgr__signal-bars">
              {{#each signalBars}}
              <div class="ncm-netmgr__signal-bar {{#if active}}ncm-netmgr__signal-bar--{{level}}{{/if}}"
                   style="height: {{height}}px;"></div>
              {{/each}}
            </div>
          </div>
          {{/each}}
          {{/unless}}
          {{/each}}
        </div>
      </div>

      {{!-- RIGHT: Detail / Editor / Empty State --}}
      <div class="ncm-netmgr__split-detail">

        {{!-- ─── EDITOR MODE (Create or Edit) ─── --}}
        {{#if isEditing}}
        <form class="ncm-netmgr__editor ncm-network-form">
          <div class="ncm-netmgr__editor-body">

          {{!-- Presets (create mode only) --}}
          {{#if isCreating}}
          <div class="preset-section">
            <div class="preset-section-header"><i class="fas fa-bolt"></i><span class="preset-section-title">Presets</span></div>
            <div class="preset-bar">
              {{#each presets}}
              <div class="preset-pill" data-action="applyPreset" data-preset="{{key}}">
                <i class="fas {{icon}}" style="color:{{color}};"></i> {{label}}
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}

          {{!-- ═══ IDENTITY ═══ --}}
          <div class="cfg-section">
            <div class="cfg-section-header"><i class="fas fa-id-badge cfg-section-icon" style="color:#19f3f7"></i><div class="cfg-section-title">Identity</div></div>
            <div class="cfg-desc">The name and description players see when browsing available networks.</div>
            <div class="cfg-row"><span class="cfg-label">Name</span><input class="cfg-input cfg-flex" type="text" name="name" value="{{#unless isCreating}}{{selectedNetwork.name}}{{/unless}}" placeholder="e.g. Militech Staging"></div>
            <div class="cfg-row"><span class="cfg-label">Type</span>
              <select class="cfg-select cfg-flex" name="type">
                {{#each networkTypes}}<option value="{{value}}" {{#if (eq value ../selectedNetwork.type)}}selected{{/if}} {{#if (and ../isCreating (eq value "custom"))}}selected{{/if}}>{{label}}</option>{{/each}}
              </select>
            </div>
            <div class="cfg-row cfg-row--col"><span class="cfg-label cfg-label--col">Description</span><input class="cfg-input" type="text" name="description" value="{{#unless isCreating}}{{selectedNetwork.description}}{{/unless}}" placeholder="In-world description..."></div>
            <div class="cfg-hint">Visible to players when they inspect the network.</div>
            <div class="cfg-row cfg-row--col"><span class="cfg-label cfg-label--col">Lore / Notes</span><input class="cfg-input" type="text" name="lore" value="{{#unless isCreating}}{{selectedNetwork.lore}}{{/unless}}" placeholder="GM-only notes..."></div>
            <div class="cfg-row cfg-row--col"><span class="cfg-label cfg-label--col">Group / Folder</span>
              <div class="netmgr-group-pills" data-group-pills>
                {{#each existingGroups}}<div class="netmgr-group-pill {{#if (eq this ../selectedNetwork.group)}}active{{/if}}" data-group-value="{{this}}">{{this}}</div>{{/each}}
                <div class="netmgr-group-add" data-group-add title="Add new group"><i class="fas fa-plus"></i></div>
              </div>
              <input class="cfg-input" type="text" name="group" value="{{#unless isCreating}}{{selectedNetwork.group}}{{/unless}}" placeholder="Type a new group name or click above..." data-group-input style="margin-top:4px;">
            </div>
          </div>

          {{!-- ═══ SIGNAL & PERFORMANCE ═══ --}}
          <div class="cfg-section">
            <div class="cfg-section-header"><i class="fas fa-sliders-h cfg-section-icon" style="color:#f7c948"></i><div class="cfg-section-title">Signal & Performance</div></div>
            <div class="cfg-desc">Signal affects data shard DV modifiers. Reliability is message delivery chance. Delay adds message latency.</div>
            <div class="cfg-row--3">
              <div><span class="cfg-label cfg-label--col">Signal %</span><input class="cfg-input" type="number" name="signalStrength" value="{{#if isCreating}}75{{else}}{{selectedNetwork.signalStrength}}{{/if}}" min="0" max="100"></div>
              <div><span class="cfg-label cfg-label--col">Reliability %</span><input class="cfg-input" type="number" name="reliability" value="{{#if isCreating}}85{{else}}{{selectedNetwork.reliability}}{{/if}}" min="0" max="100"></div>
              <div><span class="cfg-label cfg-label--col">Delay (ms)</span><input class="cfg-input" type="number" name="messageDelay" value="{{#if isCreating}}0{{else}}{{selectedNetwork.effects.messageDelay}}{{/if}}" min="0"></div>
            </div>
          </div>

          {{!-- ═══ AUTHENTICATION ═══ --}}
          <div class="cfg-section">
            <div class="cfg-section-header"><i class="fas fa-lock cfg-section-icon" style="color:#a855f7"></i><div class="cfg-section-title">Authentication</div></div>
            <div class="cfg-desc">How players gain access. Configure security level, bypass methods, passwords, skill checks, key items, and ICE protection.</div>

            <div class="cfg-row--2">
              <div><span class="cfg-label cfg-label--col">Security Level</span>
                <select class="cfg-select" name="securityLevel">{{#each securityLevels}}<option value="{{value}}" {{#if (eq value ../selectedNetwork.security.level)}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              </div>
              <div><span class="cfg-label cfg-label--col">Authentication</span>
                <select class="cfg-select" name="requiresAuth">
                  <option value="false" {{#unless selectedNetwork.security.requiresAuth}}selected{{/unless}}>None (open)</option>
                  <option value="true" {{#if selectedNetwork.security.requiresAuth}}selected{{/if}}>Required</option>
                </select>
              </div>
            </div>

            {{!-- Auth Methods --}}
            <div class="cfg-divider"></div>
            <span class="cfg-label cfg-label--col">Auth / Bypass Methods</span>
            <div class="cfg-flag-cards" style="margin-bottom:8px;">
              <label class="cfg-flag-card"><input type="checkbox" name="allowPassword" value="true" {{#if selectedNetwork.security.allowPassword}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title"><i class="fas fa-key" style="color:#f7c948;margin-right:3px;font-size:9px;"></i> Password</span><span class="cfg-flag-desc">Passphrase entry</span></div></label>
              <label class="cfg-flag-card"><input type="checkbox" name="allowSkillCheck" value="true" {{#if selectedNetwork.security.allowSkillCheck}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title"><i class="fas fa-dice-d20" style="color:#a855f7;margin-right:3px;font-size:9px;"></i> Skill Check</span><span class="cfg-flag-desc">Roll vs DV</span></div></label>
              <label class="cfg-flag-card"><input type="checkbox" name="allowKeyItem" value="true" {{#if selectedNetwork.security.allowKeyItem}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title"><i class="fas fa-id-badge" style="color:#19f3f7;margin-right:3px;font-size:9px;"></i> Key Item</span><span class="cfg-flag-desc">Inventory item</span></div></label>
            </div>

            <div class="cfg-row"><span class="cfg-label">Logic</span>
              <select class="cfg-select cfg-flex" name="authLogic">
                <option value="any" {{#if (eq selectedNetwork.security.authLogic "any")}}selected{{/if}}>ANY method (OR)</option>
                <option value="all" {{#if (eq selectedNetwork.security.authLogic "all")}}selected{{/if}}>ALL methods (AND)</option>
              </select>
            </div>
            <div class="cfg-hint">{{#if (eq selectedNetwork.security.authLogic "all")}}Player must pass ALL enabled checks.{{else}}Player can use any single method.{{/if}}</div>

            {{!-- Password --}}
            <div class="cfg-divider"></div>
            <div class="cfg-row--2">
              <div><span class="cfg-label cfg-label--col">Password</span><input class="cfg-input" type="text" name="password" value="{{selectedNetwork.security.password}}" placeholder="Network password..."></div>
              <div><span class="cfg-label cfg-label--col">Max Attempts / Lockout (min)</span>
                <div style="display:flex;gap:6px;">
                  <input class="cfg-input" type="number" name="maxAttempts" value="{{#if isCreating}}3{{else}}{{selectedNetwork.security.maxAttempts}}{{/if}}" min="1" style="flex:1;">
                  <input class="cfg-input" type="number" name="lockoutMinutes" value="{{#if isCreating}}60{{else}}{{selectedNetwork.lockoutMinutes}}{{/if}}" min="1" style="flex:1;">
                </div>
              </div>
            </div>

            {{!-- Skill Check --}}
            <div class="cfg-row--2">
              <div><span class="cfg-label cfg-label--col">Bypass Skills (comma-separated)</span><input class="cfg-input" type="text" name="bypassSkills" value="{{#if selectedNetwork.security.bypassSkills}}{{join selectedNetwork.security.bypassSkills ","}}{{/if}}" placeholder="Interface, Electronics/Security Tech"></div>
              <div><span class="cfg-label cfg-label--col">Bypass DV</span><input class="cfg-input" type="number" name="bypassDC" value="{{#if isCreating}}15{{else}}{{selectedNetwork.security.bypassDC}}{{/if}}" min="1"></div>
            </div>

            {{!-- Key Item Picker --}}
            <div class="cfg-divider"></div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><i class="fas fa-id-badge" style="color:#f7c948;font-size:13px;"></i><span style="font-family:var(--font-body,'Rajdhani',sans-serif);font-size:13px;font-weight:700;color:#e8e8f0;text-transform:uppercase;letter-spacing:0.04em;">Key Item</span></div>
            <div class="cfg-hint" style="margin-bottom:8px;">Requires the player to have a specific item in their inventory to connect.</div>

            <div class="ncm-netmgr__key-item-filled" data-key-item-filled {{#unless hasKeyItem}}style="display:none"{{/unless}}>
              <div class="ncm-netmgr__ki-img" data-key-item-img-slot>{{#if keyItemImg}}<img src="{{keyItemImg}}" alt="">{{else}}<i class="fas fa-cube"></i>{{/if}}</div>
              <div class="ncm-netmgr__ki-meta">
                <div class="ncm-netmgr__ki-name" data-key-item-name-slot>{{keyItemName}}</div>
                <div class="ncm-netmgr__ki-actions">
                  <button type="button" class="ncm-netmgr__btn-sm" data-action="searchKeyItem"><i class="fas fa-magnifying-glass"></i> Change</button>
                  <button type="button" class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="clearKeyItem"><i class="fas fa-times"></i> Clear</button>
                </div>
              </div>
            </div>
            <div class="ncm-netmgr__key-item-empty" data-key-item-empty data-action="searchKeyItem" {{#if hasKeyItem}}style="display:none"{{/if}}>
              <div class="ncm-netmgr__kie-icon"><i class="fas fa-magnifying-glass"></i></div>
              <div class="ncm-netmgr__kie-text">Click to search items</div>
            </div>
            <input type="hidden" name="keyItemName" value="{{selectedNetwork.security.keyItemName}}" />
            <input type="hidden" name="keyItemImg" value="{{keyItemImg}}" />

            <div class="cfg-row" style="margin-top:6px;"><span class="cfg-label">Tag</span><input class="cfg-input cfg-flex" type="text" name="keyItemTag" value="{{selectedNetwork.security.keyItemTag}}" placeholder="e.g. arasaka_keycard"></div>
            <label class="cfg-flag-card" style="max-width:320px;"><input type="checkbox" name="keyItemConsume" value="true" {{#if selectedNetwork.security.keyItemConsume}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title">Consume</span><span class="cfg-flag-desc">Removes from inventory after use</span></div></label>

            {{!-- ICE Protection --}}
            <div class="cfg-divider"></div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><i class="fas fa-shield-halved" style="color:#ff0033;font-size:13px;"></i><span style="font-family:var(--font-body,'Rajdhani',sans-serif);font-size:13px;font-weight:700;color:#e8e8f0;text-transform:uppercase;letter-spacing:0.04em;">ICE Protection</span></div>
            <div class="cfg-desc">Intrusion Countermeasures — determines what happens when a skill check breach fails. <strong>BLACK ICE</strong> and <strong>RED ICE</strong> deal direct HP damage.</div>

            <div class="cfg-row--2">
              <div><span class="cfg-label cfg-label--col">ICE Type</span>
                <select class="cfg-select" name="encryptionType">
                  <option value="ICE" {{#if (eq selectedNetwork.security.encryptionType "ICE")}}selected{{/if}}>Standard ICE</option>
                  <option value="BLACK_ICE" {{#if (eq selectedNetwork.security.encryptionType "BLACK_ICE")}}selected{{/if}}>BLACK ICE</option>
                  <option value="RED_ICE" {{#if (eq selectedNetwork.security.encryptionType "RED_ICE")}}selected{{/if}}>RED ICE</option>
                </select>
              </div>
              <div><span class="cfg-label cfg-label--col">On Failure</span>
                <select class="cfg-select" name="failureMode">
                  <option value="nothing" {{#if (eq selectedNetwork.security.failureMode "nothing")}}selected{{/if}}>Nothing</option>
                  <option value="lockout" {{#if (eq selectedNetwork.security.failureMode "lockout")}}selected{{/if}}>Lockout</option>
                  <option value="permanent" {{#if (eq selectedNetwork.security.failureMode "permanent")}}selected{{/if}}>Permanent Lockout</option>
                  <option value="damage" {{#if (eq selectedNetwork.security.failureMode "damage")}}selected{{/if}}>Damage (ICE)</option>
                </select>
              </div>
            </div>
            <div class="cfg-hint">When set to <strong>Damage</strong>, failed breaches trigger ICE retaliation.</div>

            {{!-- ICE Source — always in DOM, toggled by JS --}}
            <div class="cfg-conditional cfg-conditional-border--danger" data-ice-source {{#unless isLethalICE}}style="display:none"{{else}}style="display:block"{{/unless}}>
              <span class="cfg-label cfg-label--col">ICE Source</span>
              <div class="cfg-hint" style="margin-bottom:6px;">Where the ICE's combat stats come from when it retaliates.</div>

              <div class="ice-source-cards">
                <div class="ice-source-card {{#if iceSourceDefault}}active{{/if}}" data-action="selectIceSource" data-mode="default">
                  <i class="fas fa-dice"></i><div class="isc-info"><span class="isc-title">Default</span><span class="isc-desc">Generic dice (3d6 / 5d6)</span></div>
                </div>
                <div class="ice-source-card {{#if iceSourceCustom}}active{{/if}}" data-action="selectIceSource" data-mode="custom">
                  <i class="fas fa-pen-fancy"></i><div class="isc-info"><span class="isc-title">Custom</span><span class="isc-desc">Your own name + formula</span></div>
                </div>
                <div class="ice-source-card {{#if iceSourceActor}}active{{/if}}" data-action="selectIceSource" data-mode="actor">
                  <i class="fas fa-robot"></i><div class="isc-info"><span class="isc-title">Actor</span><span class="isc-desc">ATK stat from Black ICE actor</span></div>
                </div>
              </div>
              <input type="hidden" name="iceSource" value="{{iceSource}}" />

              {{!-- Default panel --}}
              <div class="ice-panel {{#if iceSourceDefault}}ice-panel--on{{/if}}" data-ice-panel="default">
                <div class="ice-formula-info">Damage: <strong>3d6</strong> (BLACK ICE) or <strong>5d6</strong> (RED ICE)</div>
              </div>
              {{!-- Custom panel --}}
              <div class="ice-panel {{#if iceSourceCustom}}ice-panel--on{{/if}}" data-ice-panel="custom">
                <div class="cfg-row--2" style="margin-top:6px;">
                  <div><span class="cfg-label cfg-label--col">ICE Name</span><input class="cfg-input" type="text" name="iceCustomName" value="{{selectedNetwork.security.ice.customName}}" placeholder="e.g. HELLHOUND"></div>
                  <div><span class="cfg-label cfg-label--col">Damage Formula</span><input class="cfg-input" type="text" name="iceCustomDamage" value="{{selectedNetwork.security.ice.customDamage}}" placeholder="e.g. 4d6+2"></div>
                </div>
                <div class="cfg-row cfg-row--col"><span class="cfg-label cfg-label--col">Portrait</span><input class="cfg-input" type="text" name="iceCustomPortrait" value="{{selectedNetwork.security.ice.customPortrait}}" placeholder="Image path (optional)"></div>
              </div>
              {{!-- Actor panel --}}
              <div class="ice-panel {{#if iceSourceActor}}ice-panel--on{{/if}}" data-ice-panel="actor">
                <div class="cfg-hint" style="margin:6px 0;">Select a Black ICE actor — damage will be <strong>ATK + 1d10</strong>.</div>
                <div class="ice-actor-grid">
                  {{#each blackIceActors}}
                  <div class="ice-actor-card {{#if selected}}active{{/if}}" data-action="selectIceActor" data-actor-id="{{id}}">
                    {{#if img}}<img src="{{img}}" alt="{{name}}">{{else}}<i class="fas fa-robot"></i>{{/if}}
                    <span class="ice-actor-name">{{name}}</span>
                    {{#if atk}}<span class="ice-actor-atk">ATK {{atk}}</span>{{/if}}
                  </div>
                  {{else}}<span class="cfg-hint">No Black ICE actors found.</span>{{/each}}
                </div>
                <input type="hidden" name="iceActorId" value="{{selectedNetwork.security.ice.actorId}}" />
              </div>
            </div>
          </div>

          {{!-- ═══ NETWORK FLAGS ═══ --}}
          <div class="cfg-section">
            <div class="cfg-section-header"><i class="fas fa-flag cfg-section-icon" style="color:#00ff41"></i><div class="cfg-section-title">Network Flags</div></div>
            <div class="cfg-desc">Behavioral properties that affect how messages are handled on this network.</div>
            <div class="cfg-flag-cards">
              <label class="cfg-flag-card"><input type="checkbox" name="traced" value="true" {{#if selectedNetwork.effects.traced}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title">Traced</span><span class="cfg-flag-desc">Messages are logged and sender identity is recorded</span></div></label>
              <label class="cfg-flag-card"><input type="checkbox" name="anonymity" value="true" {{#if selectedNetwork.effects.anonymity}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title">Anonymous</span><span class="cfg-flag-desc">Sender identity is hidden from recipients</span></div></label>
              <label class="cfg-flag-card"><input type="checkbox" name="globalAvailability" value="true" {{#if selectedNetwork.availability.global}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title">Global</span><span class="cfg-flag-desc">Available in all scenes</span></div></label>
            </div>
            <div class="cfg-divider"></div>
            <label class="cfg-flag-card" style="max-width:320px;"><input type="checkbox" name="canRoute" value="true" {{#unless isCreating}}{{#if selectedNetwork.effects.canRoute}}checked{{/if}}{{else}}checked{{/unless}}><div class="cfg-flag-info"><span class="cfg-flag-title">Can Route</span><span class="cfg-flag-desc">Messages can route to other networks</span></div></label>
            <label class="cfg-flag-card" style="max-width:320px;"><input type="checkbox" name="restrictedAccess" value="true" {{#if selectedNetwork.effects.restrictedAccess}}checked{{/if}}><div class="cfg-flag-info"><span class="cfg-flag-title">Restricted Access</span><span class="cfg-flag-desc">Messages only readable on this network</span></div></label>
            <div class="cfg-row cfg-row--col" style="margin-top:4px;"><span class="cfg-label cfg-label--col">Allowed Recipient Networks (comma-separated)</span><input class="cfg-input" type="text" name="allowedRecipientNetworks" value="{{#if selectedNetwork.effects.allowedRecipientNetworks}}{{join selectedNetwork.effects.allowedRecipientNetworks ","}}{{/if}}" placeholder="Leave empty for unrestricted"></div>
          </div>

          {{!-- ═══ APPEARANCE ═══ --}}
          <div class="cfg-section">
            <div class="cfg-section-header"><i class="fas fa-palette cfg-section-icon" style="color:#F65261"></i><div class="cfg-section-title">Appearance</div></div>
            <div class="cfg-desc">Icon and color shown in the network selector and status bars.</div>

            <span class="cfg-label cfg-label--col">Icon Source</span>
            <div class="icon-mode-tabs">
              <div class="icon-mode-tab {{#if isIconModeFa}}active{{/if}}" data-action="selectIconMode" data-mode="fa">FA Icon</div>
              <div class="icon-mode-tab {{#if isIconModeImage}}active{{/if}}" data-action="selectIconMode" data-mode="image">Custom Image</div>
            </div>
            <input type="hidden" name="iconMode" value="{{iconMode}}" />

            {{!-- FA Icon mode --}}
            <div class="icon-mode-section" data-icon-mode="fa" {{#unless isIconModeFa}}style="display:none"{{/unless}}>
              <div class="appearance-row">
                <div class="icon-preview" data-icon-preview style="background:{{#if isCreating}}rgba(25,243,247,0.12){{else}}{{selectedNetwork.theme.color}}14{{/if}}; color:{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}; border:1px solid {{#if isCreating}}rgba(25,243,247,0.2){{else}}{{selectedNetwork.theme.color}}26{{/if}};">
                  <i class="fas {{#if isCreating}}fa-wifi{{else}}{{selectedNetwork.theme.icon}}{{/if}}" data-icon-preview-i></i>
                </div>
                <div style="flex:1;">
                  <span class="cfg-label cfg-label--col">Icon</span>
                  <div class="netmgr-icon-grid" data-icon-grid>
                    {{#each iconOptions}}<div class="netmgr-icon-grid__item {{#if selected}}active{{/if}}" data-action="selectIcon" data-icon-value="{{value}}" title="{{label}}"><i class="fas {{value}}"></i></div>{{/each}}
                  </div>
                  <input type="hidden" name="themeIcon" value="{{#if isCreating}}fa-wifi{{else}}{{selectedNetwork.theme.icon}}{{/if}}" />
                </div>
                <div>
                  <span class="cfg-label cfg-label--col">Color</span>
                  <div class="color-row">
                    <input type="color" name="themeColor" class="color-swatch" data-color-swatch value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}">
                    <input class="cfg-input cfg-input--mono" type="text" name="themeColorText" data-color-text value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}" style="width:80px;">
                  </div>
                </div>
              </div>
              <div class="cfg-row" style="margin-top:6px;"><span class="cfg-label">Glitch</span><input class="cfg-input cfg-input--mono" type="number" name="glitchIntensity" value="{{#if isCreating}}0.1{{else}}{{selectedNetwork.theme.glitchIntensity}}{{/if}}" min="0" max="1" step="0.1" style="max-width:80px;"></div>
            </div>

            {{!-- Custom Image mode --}}
            <div class="icon-mode-section" data-icon-mode="image" {{#unless isIconModeImage}}style="display:none"{{/unless}}>
              <div class="appearance-row">
                <div class="icon-custom-preview" data-custom-img-preview>
                  {{#if selectedNetwork.theme.customImage}}<img src="{{selectedNetwork.theme.customImage}}" alt="">{{else}}<i class="fas fa-image"></i>{{/if}}
                </div>
                <div style="flex:1;">
                  <span class="cfg-label cfg-label--col">Image Path</span>
                  <div style="display:flex;gap:6px;align-items:center;">
                    <input class="cfg-input" type="text" name="customImage" data-custom-img-input value="{{selectedNetwork.theme.customImage}}" placeholder="Path to image..." style="flex:1;">
                    <button type="button" class="netmgr-browse-btn" data-action="browseCustomImage" title="Browse"><i class="fas fa-folder-open"></i></button>
                  </div>
                  <div class="cfg-hint">SVG images can be tinted with the color value. Raster images display as-is.</div>
                </div>
              </div>
              <div class="cfg-row" style="margin-top:8px;">
                <span class="cfg-label">Color</span>
                <div class="color-row">
                  <input type="color" name="themeColorImg" class="color-swatch" value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}">
                  <input class="cfg-input cfg-input--mono" type="text" name="themeColorImgText" value="{{#if isCreating}}#19f3f7{{else}}{{selectedNetwork.theme.color}}{{/if}}" style="width:80px;">
                </div>
              </div>
              <div class="cfg-row" style="margin-top:6px;"><span class="cfg-label">Glitch</span><input class="cfg-input cfg-input--mono" type="number" name="glitchIntensityImg" value="{{#if isCreating}}0.1{{else}}{{selectedNetwork.theme.glitchIntensity}}{{/if}}" min="0" max="1" step="0.1" style="max-width:80px;"></div>
            </div>
          </div>

          </div>{{!-- /.ncm-netmgr__editor-body --}}

          {{!-- Editor Actions --}}
          <div class="ncm-netmgr__editor-actions">
            <button type="button" class="ncm-netmgr__btn-sm" data-action="cancelEdit">
              <i class="fas fa-times"></i> Cancel
            </button>
            {{#unless isCreating}}
              {{#unless selectedNetwork.isCore}}
              <button type="button" class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="deleteNetwork">
                <i class="fas fa-trash"></i> Delete
              </button>
              {{/unless}}
            {{/unless}}
            <div class="ncm-netmgr__editor-spacer"></div>
            <button type="button" class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary" data-action="saveNetwork">
              <i class="fas fa-save"></i> {{#if isCreating}}Create Network{{else}}Save Network{{/if}}
            </button>
          </div>
        </form>

        {{!-- ─── DETAIL VIEW (Read-only) ─── --}}
        {{else if selectedNetwork}}
        <div class="ncm-netmgr__detail">

          {{!-- Detail Header --}}
          <div class="ncm-netmgr__detail-header">
            <div class="ncm-netmgr__detail-header-icon ncm-netmgr__net-item-icon--{{selectedNetwork.networkTypeClass}}"
                 {{#if selectedNetwork.theme.color}}style="--net-color: {{selectedNetwork.theme.color}};"{{/if}}>
              {{{ncm-net-icon selectedNetwork.theme}}}
            </div>
            <div class="ncm-netmgr__detail-header-info">
              <div class="ncm-netmgr__detail-header-name">{{selectedNetwork.name}}</div>
              <div class="ncm-netmgr__detail-header-type">
                {{selectedNetwork.typeLabel}} Subnet
                {{#if selectedNetwork.isCore}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--core">Core</span>
                {{else}}
                  <span class="ncm-netmgr__tag ncm-netmgr__tag--custom">Custom</span>
                {{/if}}
                <span class="ncm-netmgr__auth-badge ncm-netmgr__auth-badge--{{selectedNetwork.authBadgeClass}}">
                  <i class="fas {{selectedNetwork.authIcon}}"></i> {{selectedNetwork.authLabel}}
                </span>
              </div>
            </div>
            <div class="ncm-netmgr__detail-header-actions">
              <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary"
                      data-action="editNetwork">
                <i class="fas fa-pen"></i> Edit
              </button>
            </div>
          </div>

          {{!-- Stats Grid --}}
          <div class="ncm-netmgr__stats-grid">
            <div class="ncm-netmgr__stat ncm-netmgr__stat--cyan">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--cyan">
                {{selectedNetwork.signalStrength}}<span class="ncm-netmgr__stat-unit">%</span>
              </div>
              <div class="ncm-netmgr__signal-meter">
                <div class="ncm-netmgr__signal-meter-fill ncm-netmgr__signal-meter-fill--{{selectedNetwork.signalMeterClass}}"
                     style="width: {{selectedNetwork.signalStrength}}%;"></div>
              </div>
              <div class="ncm-netmgr__stat-label">Signal</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--green">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--green">
                {{selectedNetwork.reliability}}<span class="ncm-netmgr__stat-unit">%</span>
              </div>
              <div class="ncm-netmgr__signal-meter">
                <div class="ncm-netmgr__signal-meter-fill ncm-netmgr__signal-meter-fill--{{selectedNetwork.reliabilityMeterClass}}"
                     style="width: {{selectedNetwork.reliability}}%;"></div>
              </div>
              <div class="ncm-netmgr__stat-label">Reliability</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--gold">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--gold">
                {{selectedNetwork.effects.messageDelay}}
              </div>
              <div class="ncm-netmgr__stat-label">Delay (ms)</div>
            </div>
            <div class="ncm-netmgr__stat ncm-netmgr__stat--red">
              <div class="ncm-netmgr__stat-value ncm-netmgr__stat-value--red">
                {{selectedNetwork.sceneCount}}
              </div>
              <div class="ncm-netmgr__stat-label">Scenes</div>
            </div>
          </div>

          {{!-- Properties --}}
          <div class="ncm-netmgr__props">

            {{!-- Security & Auth --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-shield-halved"></i> Security & Auth</div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Authentication</span>
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--{{selectedNetwork.authValueColor}}">
                  {{selectedNetwork.authLabel}}
                </span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Security Level</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.security.level}}</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Auth Methods</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if selectedNetwork.security.allowPassword}}
                    <i class="fas fa-key" style="color:var(--ncm-accent,#f7c948);margin-right:2px;" title="Password"></i>
                  {{/if}}
                  {{#if selectedNetwork.security.allowSkillCheck}}
                    <i class="fas fa-dice-d20" style="color:#a855f7;margin-right:2px;" title="Skill Check"></i>
                  {{/if}}
                  {{#if selectedNetwork.security.allowKeyItem}}
                    <i class="fas fa-id-badge" style="color:var(--ncm-secondary,#19f3f7);margin-right:2px;" title="Key Item"></i>
                  {{/if}}
                  {{#unless selectedNetwork.security.allowPassword}}
                    {{#unless selectedNetwork.security.allowSkillCheck}}
                      {{#unless selectedNetwork.security.allowKeyItem}}
                        <span style="color:var(--ncm-text-muted);">None configured</span>
                      {{/unless}}
                    {{/unless}}
                  {{/unless}}
                </span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Combination</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if (eq selectedNetwork.security.authLogic "all")}}
                    <span style="color:var(--ncm-primary);">ALL required</span>
                  {{else}}
                    <span style="color:var(--ncm-success,#00ff41);">ANY method</span>
                  {{/if}}
                </span>
              </div>
              {{#if selectedNetwork.security.allowKeyItem}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Key Item</span>
                <span class="ncm-netmgr__prop-value">
                  {{#if selectedNetwork.security.keyItemName}}
                    {{selectedNetwork.security.keyItemName}}
                    {{#if selectedNetwork.security.keyItemConsume}}
                      <span style="color:var(--ncm-primary);font-size:9px;margin-left:4px;">(consumed)</span>
                    {{/if}}
                  {{else}}
                    <span style="color:var(--ncm-text-muted);">Not set</span>
                  {{/if}}
                </span>
              </div>
              {{/if}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Max Auth Attempts</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.security.maxAttempts}}</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Lockout Duration</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.lockoutMinutes}} min</span>
              </div>
            </div>

            {{!-- Effects --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-bolt"></i> Effects</div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Message Delay</span>
                <span class="ncm-netmgr__prop-value">{{selectedNetwork.effects.messageDelay}} ms</span>
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Traced</span>
                {{#if selectedNetwork.effects.traced}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--red">
                  <i class="fas fa-eye"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Anonymous</span>
                {{#if selectedNetwork.effects.anonymity}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--purple">
                  <i class="fas fa-user-secret"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Can Route</span>
                {{#if selectedNetwork.effects.canRoute}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">
                  <i class="fas fa-check"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--red">
                  <i class="fas fa-times"></i> No
                </span>
                {{/if}}
              </div>
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Restricted Access</span>
                {{#if selectedNetwork.effects.restrictedAccess}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--gold">
                  <i class="fas fa-lock"></i> Yes
                </span>
                {{else}}
                <span class="ncm-netmgr__prop-value ncm-netmgr__prop-value--green">No</span>
                {{/if}}
              </div>
              {{#if selectedNetwork.effects.allowedRecipientNetworks.length}}
              <div class="ncm-netmgr__prop-row">
                <span class="ncm-netmgr__prop-label">Allowed Recipients</span>
                <span class="ncm-netmgr__prop-value">
                  {{join selectedNetwork.effects.allowedRecipientNetworks ", "}}
                </span>
              </div>
              {{/if}}
            </div>

            {{!-- Availability --}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-map-marker-alt"></i> Availability</div>
              <div class="ncm-netmgr__prop-group-body-pad">
                <div class="ncm-netmgr__scene-pills">
                  {{#if selectedNetwork.availability.global}}
                  <span class="ncm-netmgr__scene-pill ncm-netmgr__scene-pill--global">
                    <i class="fas fa-globe"></i> Global
                  </span>
                  {{/if}}
                  {{#each selectedNetwork.scenePills}}
                  <span class="ncm-netmgr__scene-pill {{#if isCurrent}}ncm-netmgr__scene-pill--current{{/if}}">
                    {{name}}
                  </span>
                  {{/each}}
                  {{#unless selectedNetwork.availability.global}}
                    {{#unless selectedNetwork.scenePills.length}}
                    <span class="ncm-netmgr__scene-pill ncm-netmgr__scene-pill--none">No scenes assigned</span>
                    {{/unless}}
                  {{/unless}}
                </div>
              </div>
            </div>

            {{!-- Lore (if any) --}}
            {{#if selectedNetwork.lore}}
            <div class="ncm-netmgr__prop-group">
              <div class="ncm-netmgr__prop-group-title"><i class="fas fa-book"></i> Lore</div>
              <div class="ncm-netmgr__prop-group-body-pad">
                <span class="ncm-netmgr__lore-text">{{selectedNetwork.lore}}</span>
              </div>
            </div>
            {{/if}}
          </div>

          {{!-- Detail Footer --}}
          <div class="ncm-netmgr__detail-footer">
            {{#if selectedNetwork.isCore}}
            <span class="ncm-netmgr__detail-footer-note">
              <i class="fas fa-shield-halved"></i> Core network — editable, cannot be deleted
            </span>
            {{else}}
            <span class="ncm-netmgr__detail-footer-note">
              <i class="fas fa-cube"></i> Custom network — fully editable
            </span>
            {{/if}}
          </div>
        </div>

        {{!-- ─── EMPTY STATE ─── --}}
        {{else}}
        <div class="ncm-netmgr__empty-state">
          <i class="fas fa-network-wired ncm-netmgr__empty-state-icon"></i>
          <span class="ncm-netmgr__empty-state-text">Select a subnet to inspect</span>
          <span class="ncm-netmgr__empty-state-sub">Or press [N] to create a new custom network.</span>
        </div>
        {{/if}}

      </div>
    </div>
  </div>

  {{!-- Subnet Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">↑↓</span> Navigate</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Enter</span> Select</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">N</span> New network</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Del</span> Delete</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}


  {{!-- ═══════════════════════════════════════════════════════
       TAB 2: SCENE CONFIGURATION
       ═══════════════════════════════════════════════════════ --}}
  {{#if isScenesTab}}
  <div class="ncm-netmgr__content">

    {{!-- Scene Summary Strip --}}
    <div class="ncm-netmgr__scene-summary">
      <div class="ncm-netmgr__scene-summary-stat">
        <span class="ncm-netmgr__scene-summary-value">{{sceneSummary.total}}</span>
        <span class="ncm-netmgr__scene-summary-label">Scenes</span>
      </div>
      <div class="ncm-netmgr__scene-summary-stat">
        <span class="ncm-netmgr__scene-summary-value ncm-netmgr__scene-summary-value--configured">{{sceneSummary.configured}}</span>
        <span class="ncm-netmgr__scene-summary-label">Configured</span>
      </div>
      <div class="ncm-netmgr__scene-summary-stat">
        <span class="ncm-netmgr__scene-summary-value ncm-netmgr__scene-summary-value--dead">{{sceneSummary.deadZones}}</span>
        <span class="ncm-netmgr__scene-summary-label">Dead Zones</span>
      </div>
    </div>

    {{!-- Scene Selector --}}
    {{#if scenes.length}}
    <div class="ncm-netmgr__scene-picker">
      <div class="ncm-netmgr__scene-picker-row">
        <label class="ncm-netmgr__scene-picker-label"><i class="fas fa-map"></i> Scene</label>
        <select class="ncm-netmgr__scene-selector">
          {{#each scenes}}
          <option value="{{this.id}}" {{#if (eq this.id ../selectedSceneId)}}selected{{/if}}>
            {{this.name}}{{#if this.isCurrent}} (Active){{/if}}{{#if this.deadZone}} ☠ Dead Zone{{/if}}
          </option>
          {{/each}}
        </select>
        <button class="ncm-netmgr__scene-refresh" data-action="refreshScenes" title="Refresh scenes">
          <i class="fas fa-sync"></i>
        </button>
      </div>

      {{!-- Quick Dead Zone Chips --}}
      <div class="ncm-netmgr__scene-chip-strip">
        {{#each scenes}}
        <div class="ncm-netmgr__scene-chip {{#if this.deadZone}}ncm-netmgr__scene-chip--dead{{/if}} {{#if this.isCurrent}}ncm-netmgr__scene-chip--current{{/if}}"
             title="{{this.name}}{{#if this.deadZone}} — Dead Zone{{/if}}">
          <span class="ncm-netmgr__scene-chip-dot"></span>
          <span class="ncm-netmgr__scene-chip-name">{{this.name}}</span>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Selected Scene Detail --}}
    {{#if selectedScene}}
    <div class="ncm-netmgr__scene-detail" data-scene-id="{{selectedScene.id}}">

      {{!-- Header --}}
      <div class="ncm-netmgr__scene-detail-header">
        <div class="ncm-netmgr__scene-detail-dot {{#if selectedScene.deadZone}}ncm-netmgr__scene-detail-dot--dead{{else if selectedScene.isCurrent}}ncm-netmgr__scene-detail-dot--live{{else}}ncm-netmgr__scene-detail-dot--inactive{{/if}}"></div>
        <span class="ncm-netmgr__scene-detail-name">{{selectedScene.name}}</span>
        {{#if selectedScene.isCurrent}}<span class="ncm-netmgr__tag ncm-netmgr__tag--core">Active</span>{{/if}}
        {{#if selectedScene.deadZone}}<span class="ncm-netmgr__scene-detail-dead-tag"><i class="fas fa-ban"></i> Dead Zone</span>{{/if}}

        <button class="ncm-netmgr__scene-toggle-dead {{#if selectedScene.deadZone}}ncm-netmgr__scene-toggle-dead--on{{else}}ncm-netmgr__scene-toggle-dead--off{{/if}}"
                data-action="toggleDeadZone">
          {{#if selectedScene.deadZone}}
          <i class="fas fa-signal"></i> Restore Signal
          {{else}}
          <i class="fas fa-signal-slash"></i> Jam Signal
          {{/if}}
        </button>
      </div>

      {{!-- Config Body --}}
      <div class="ncm-netmgr__scene-detail-body {{#if selectedScene.deadZone}}ncm-netmgr__scene-detail-body--disabled{{/if}}">

        {{!-- Default Network --}}
        <div class="ncm-netmgr__scene-detail-field">
          <label class="ncm-netmgr__field-label">Default Network</label>
          {{#if selectedScene.deadZone}}
          <select class="ncm-netmgr__select" disabled>
            <option>— Dead Zone — No Networks —</option>
          </select>
          {{else}}
          <select class="ncm-netmgr__select" name="defaultNetwork">
            <option value="">— None —</option>
            {{#each allNetworks}}
            <option value="{{id}}" {{#if (eq id ../selectedScene.defaultNetwork)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
          {{/if}}
        </div>

        {{!-- Available Networks --}}
        <div class="ncm-netmgr__scene-detail-field">
          <label class="ncm-netmgr__field-label">Available Networks</label>
          {{#if selectedScene.deadZone}}
          <div class="ncm-netmgr__scene-dead-notice">
            <i class="fas fa-ban"></i> All signals jammed — Dead Zone active
          </div>
          {{else}}
          <div class="ncm-netmgr__scene-net-list">
            {{#each allNetworks}}
            {{#if availability.global}}
            <label class="ncm-netmgr__scene-net-check ncm-netmgr__scene-net-check--active ncm-netmgr__scene-net-check--global">
              <input type="checkbox" name="netAvail_{{id}}" checked disabled>
              <span class="ncm-netmgr__scene-net-check-icon" style="color: {{theme.color}};">
                {{{ncm-net-icon theme}}}
              </span>
              {{name}}
              <span class="ncm-netmgr__tag ncm-netmgr__tag--core" style="font-size:6px; margin-left:2px;">GLOBAL</span>
            </label>
            {{else}}
            <label class="ncm-netmgr__scene-net-check {{#if (lookup ../selectedScene.networkAvailability id)}}ncm-netmgr__scene-net-check--active{{/if}}">
              <input type="checkbox" name="netAvail_{{id}}"
                     {{#if (lookup ../selectedScene.networkAvailability id)}}checked{{/if}}>
              <span class="ncm-netmgr__scene-net-check-icon" style="color: {{theme.color}};">
                {{{ncm-net-icon theme}}}
              </span>
              {{name}}
            </label>
            {{/if}}
            {{/each}}
          </div>
          {{/if}}
        </div>
      </div>

      {{!-- Save Footer --}}
      {{#unless selectedScene.deadZone}}
      <div class="ncm-netmgr__scene-detail-footer">
        <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--primary" data-action="saveSceneConfig">
          <i class="fas fa-save"></i> Save
        </button>
      </div>
      {{/unless}}
    </div>
    {{/if}}

    {{else}}
    <div class="ncm-netmgr__empty-state">
      <i class="fas fa-map ncm-netmgr__empty-state-icon"></i>
      <span class="ncm-netmgr__empty-state-text">No scenes found</span>
      <span class="ncm-netmgr__empty-state-sub">Create scenes in Foundry to configure network availability.</span>
    </div>
    {{/if}}
  </div>

  {{!-- Scene Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Ctrl+S</span> Save</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}


  {{!-- ═══════════════════════════════════════════════════════
       TAB 3: ACCESS LOGS
       ═══════════════════════════════════════════════════════ --}}
  {{#if isLogsTab}}
  <div class="ncm-netmgr__content" style="padding-bottom: 0;">

    {{!-- Lockout Banner --}}
    {{#if hasLockouts}}
    <div class="ncm-netmgr__lockout-banner">
      <i class="fas fa-lock ncm-netmgr__lockout-banner-icon"></i>
      <span class="ncm-netmgr__lockout-banner-text">
        Active lockouts detected — players blocked from network access
      </span>
      <span class="ncm-netmgr__lockout-banner-count">{{lockouts.length}}</span>
      <button class="ncm-netmgr__btn-sm ncm-netmgr__btn-sm--danger" data-action="resetSecurity">
        <i class="fas fa-unlock"></i> Clear All
      </button>
    </div>
    {{/if}}

    {{!-- Log Toolbar --}}
    <div class="ncm-actlog__toolbar">
      <div class="ncm-actlog__toolbar-row">
        <div class="ncm-actlog__filter-group">
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'all')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="all">All</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'connect')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="connect">Connect</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'auth')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="auth">Auth</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'hack')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="hack">Hack</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'lockout')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="lockout">Lockout</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'trace')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="trace">Trace</button>
          <button class="ncm-actlog__filter-btn {{#if (eq logFilter 'manual')}}ncm-actlog__filter-btn--active{{/if}}"
                  data-action="filterLogs" data-filter="manual">Manual</button>
        </div>
        <select class="ncm-actlog__net-filter" data-action="filterLogNetwork">
          <option value="">All Networks</option>
          {{#each networks}}
          <option value="{{this.id}}" {{#if (eq this.id ../logNetworkFilter)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
        <div class="ncm-actlog__spacer"></div>
        <button class="ncm-actlog__btn ncm-actlog__btn--accent" data-action="toggleAddLogForm">
          <i class="fas fa-plus"></i> Add
        </button>
        <button class="ncm-actlog__btn" data-action="importLogs" title="Import log entries">
          <i class="fas fa-file-import"></i>
        </button>
        <button class="ncm-actlog__btn" data-action="exportLogs" title="Export as JSON">
          <i class="fas fa-file-export"></i>
        </button>
        <button class="ncm-actlog__btn ncm-actlog__btn--danger" data-action="clearLogs" title="Clear all entries">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>

    {{!-- Log Entries --}}
    <div class="ncm-actlog__list">
      {{#if logEntries.length}}
        {{#each logEntries}}
        <div class="ncm-actlog__entry {{#if this.isTrace}}ncm-actlog__entry--trace{{/if}} {{#if this.manual}}ncm-actlog__entry--manual{{/if}}"
             data-entry-id="{{this.id}}">
          <div class="ncm-actlog__badge ncm-actlog__badge--{{this.badgeClass}}">
            {{#if this.actorImg}}
            <img class="ncm-actlog__badge-img" src="{{this.actorImg}}" alt="">
            <span class="ncm-actlog__badge-overlay ncm-actlog__badge-overlay--{{this.badgeClass}}"><i class="fas {{this.badgeIcon}}"></i></span>
            {{else}}
            <i class="fas {{this.badgeIcon}}"></i>
            {{/if}}
          </div>
          <div class="ncm-actlog__body">
            <div class="ncm-actlog__line1">
              <span class="ncm-actlog__actor">{{this.actorName}}</span>
              <span class="ncm-actlog__verb">{{this.actionVerb}}</span>
              <span class="ncm-actlog__network ncm-actlog__network--{{this.networkColor}}">{{this.networkName}}</span>
            </div>
            <div class="ncm-actlog__line2">
              <span class="ncm-actlog__tag ncm-actlog__tag--{{this.typeTagClass}}">{{this.typeTag}}</span>
              {{#if this.message}}
              <span class="ncm-actlog__message">{{this.message}}</span>
              {{/if}}
              {{#if this.hasLink}}
              <span class="ncm-actlog__link {{#if (eq this.linkType 'shard')}}ncm-actlog__link--shard{{/if}}"
                    data-action="openLogReference"
                    data-link-type="{{this.linkType}}"
                    data-message-id="{{this.linkMessageId}}"
                    data-actor-id="{{this.linkActorId}}"
                    data-item-id="{{this.linkItemId}}">
                <i class="fas {{this.linkIcon}}"></i> {{this.linkLabel}}
              </span>
              {{/if}}
              <span class="ncm-actlog__time">
                <span class="ncm-actlog__time-date">{{this.displayDate}} //</span> {{this.displayTime}}
              </span>
            </div>
          </div>
          <div class="ncm-actlog__actions">
            <button class="ncm-actlog__act" data-action="editLogEntry" data-entry-id="{{this.id}}" title="Edit">
              <i class="fas fa-pen"></i>
            </button>
            <button class="ncm-actlog__act ncm-actlog__act--danger" data-action="deleteLogEntry" data-entry-id="{{this.id}}" title="Delete">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </div>
        {{/each}}
      {{else}}
        <div class="ncm-actlog__empty">
          <i class="fas fa-clipboard-list"></i> No log entries — network activity will appear here.
        </div>
      {{/if}}
    </div>
  </div>

  {{!-- Add Manual Entry Form — Below content, before footer --}}
  {{#if showAddLogForm}}
  <div class="ncm-actlog__add-form">
    <div class="ncm-actlog__add-field ncm-actlog__add-field--net">
      <label>Network</label>
      <select name="logNetwork">
        {{#each networks}}
        <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="ncm-actlog__add-field ncm-actlog__add-field--actor">
      <label>Actor</label>
      <input type="text" name="logActor" placeholder="Name">
    </div>
    <div class="ncm-actlog__add-field ncm-actlog__add-field--type">
      <label>Type</label>
      <select name="logType">
        <option value="connect">Connect</option>
        <option value="disconnect">Disconnect</option>
        <option value="auth_success">Auth Success</option>
        <option value="auth_failure">Auth Failure</option>
        <option value="hack">Hack Attempt</option>
        <option value="lockout">Lockout</option>
        <option value="trace">Trace</option>
        <option value="manual">Manual</option>
        <option value="malware">Malware</option>
        <option value="system">System</option>
      </select>
    </div>
    <div class="ncm-actlog__add-field ncm-actlog__add-field--msg">
      <label>Message</label>
      <input type="text" name="logMessage" placeholder="[TRACE] Unauthorized access from...">
    </div>
    <button class="ncm-actlog__add-btn" data-action="addManualLogEntry">
      <i class="fas fa-plus"></i> Add
    </button>
  </div>
  {{/if}}

  {{!-- Log Tab Shortcuts --}}
  <div class="ncm-netmgr__shortcuts">
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">F</span> Filter</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">A</span> Add Entry</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Ctrl+E</span> Export</div>
    <div class="ncm-netmgr__shortcut"><span class="ncm-netmgr__shortcut-key">Esc</span> Close</div>
  </div>
  {{/if}}

</div>
