{{!-- Scene Network Card - Individual network configuration for a scene --}}
<div class="ncm-scene-network-card {{#unless sceneConfig.available}}ncm-scene-network-card--disabled{{/unless}}"
     data-network-id="{{id}}">
  
  <div class="ncm-scene-network-card__header">
    <div class="ncm-scene-network-card__title">
      <div class="ncm-scene-network-card__icon" style="color: {{theme.color}}">
        <i class="{{theme.icon}}"></i>
      </div>
      <div class="ncm-scene-network-card__name-group">
        <h5 class="ncm-scene-network-card__name">{{name}}</h5>
        <span class="ncm-scene-network-card__security {{securityLevelClass}}">
          <i class="fas fa-shield-alt"></i> {{security.level}}
        </span>
      </div>
    </div>

    {{!-- NEW: Sync Status Indicator --}}
    <div class="ncm-sync-status">
      {{#if syncStatus.inSync}}
        {{#if (eq syncStatus.type 'both-enabled')}}
          <div class="ncm-sync-badge ncm-sync-badge--success">
            <i class="fas fa-check-circle"></i>
            <span>In Sync: Network allows scene, scene flag is ON</span>
          </div>
        {{else if (eq syncStatus.type 'both-disabled')}}
          <div class="ncm-sync-badge ncm-sync-badge--neutral">
            <i class="fas fa-check-circle"></i>
            <span>In Sync: Network blocks scene, scene flag is OFF</span>
          </div>
        {{/if}}
      {{else}}
        {{#if (eq syncStatus.type 'network-allows-scene-disabled')}}
          <div class="ncm-sync-badge ncm-sync-badge--warning">
            <i class="fas fa-exclamation-triangle"></i>
            <span>Network allows this scene, but scene flag is OFF</span>
            <button class="ncm-btn ncm-btn--xs ncm-btn--primary" 
                    data-action="sync-from-network" 
                    data-network-id="{{id}}">
              <i class="fas fa-sync"></i> Fix: Turn ON
            </button>
          </div>
        {{else if (eq syncStatus.type 'scene-enabled-network-blocks')}}
          <div class="ncm-sync-badge ncm-sync-badge--error">
            <i class="fas fa-times-circle"></i>
            <span>Scene flag is ON, but network doesn't include this scene</span>
            <button class="ncm-btn ncm-btn--xs ncm-btn--secondary" 
                    data-action="add-scene-to-network" 
                    data-network-id="{{id}}">
              <i class="fas fa-plus"></i> Add Scene to Network
            </button>
            <button class="ncm-btn ncm-btn--xs ncm-btn--ghost" 
                    data-action="sync-from-network" 
                    data-network-id="{{id}}">
              <i class="fas fa-times"></i> Or Turn OFF
            </button>
          </div>
        {{/if}}
      {{/if}}
    </div>
    
    <div class="ncm-scene-network-card__toggle">
      <label class="ncm-toggle ncm-toggle--sm">
        <input type="checkbox" 
               data-action="toggle-network-availability" 
               data-network-id="{{id}}"
               {{#if sceneConfig.available}}checked{{/if}}>
        <span class="ncm-toggle__slider"></span>
      </label>
    </div>
  </div>
  
  {{#if sceneConfig.available}}
    <div class="ncm-scene-network-card__body">
      {{!-- Network Info --}}
      <div class="ncm-scene-network-card__info">
        {{#if hidden}}
          <div class="ncm-info-row">
            <span class="ncm-info-label">Visibility:</span>
            <span class="ncm-info-value ncm-text-warning">
              <i class="fas fa-eye-slash"></i> Hidden (GM Override Active)
            </span>
          </div>
        {{/if}}
      {{!-- Signal Strength --}}
      <div class="ncm-scene-network-card__signal">
        <div class="ncm-scene-network-card__signal-header">
          <label class="ncm-label">
            <i class="fas fa-signal"></i> Signal Strength
          </label>
          <span class="ncm-scene-network-card__signal-value">
            {{sceneConfig.signalStrength}}%
          </span>
        </div>
        
        <div class="ncm-scene-network-card__signal-slider">
          <input type="range" 
                 class="ncm-range ncm-signal-range" 
                 min="0" 
                 max="100" 
                 step="5" 
                 value="{{sceneConfig.signalStrength}}"
                 data-action="update-signal-strength"
                 data-network-id="{{id}}">
          
          <div class="ncm-signal-bars">
            {{#each (signalBars sceneConfig.signalStrength)}}
              <div class="ncm-signal-bar {{#if this.active}}ncm-signal-bar--active{{/if}}"
                   style="height: {{this.height}}%"></div>
            {{/each}}
          </div>
        </div>
        
        <div class="ncm-scene-network-card__signal-status">
          {{#if (gte sceneConfig.signalStrength 80)}}
            <span class="ncm-badge ncm-badge--success">
              <i class="fas fa-signal"></i> Excellent
            </span>
          {{else if (gte sceneConfig.signalStrength 60)}}
            <span class="ncm-badge ncm-badge--info">
              <i class="fas fa-signal"></i> Good
            </span>
          {{else if (gte sceneConfig.signalStrength 40)}}
            <span class="ncm-badge ncm-badge--warning">
              <i class="fas fa-signal"></i> Fair
            </span>
          {{else if (gte sceneConfig.signalStrength 20)}}
            <span class="ncm-badge ncm-badge--warning">
              <i class="fas fa-signal"></i> Weak
            </span>
          {{else}}
            <span class="ncm-badge ncm-badge--danger">
              <i class="fas fa-exclamation-triangle"></i> Very Weak
            </span>
          {{/if}}
        </div>
      </div>
      
      {{!-- Override Indicator --}}
      {{#if sceneConfig.override}}
        <div class="ncm-scene-network-card__override">
          <span class="ncm-badge ncm-badge--accent">
            <i class="fas fa-exclamation-circle"></i> Scene Overrides Active
          </span>
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" 
                  data-action="view-overrides"
                  data-network-id="{{id}}">
            <i class="fas fa-eye"></i> View
          </button>
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" 
                  data-action="clear-overrides"
                  data-network-id="{{id}}">
            <i class="fas fa-times"></i> Clear
          </button>
        </div>
      {{/if}}
      
      {{!-- Quick Actions --}}
      <div class="ncm-scene-network-card__actions">
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm ncm-btn--block" 
                data-action="configure-network-override"
                data-network-id="{{id}}">
          <i class="fas fa-cog"></i> Configure Overrides
        </button>
      </div>
      
    </div>
  {{else}}
    <div class="ncm-scene-network-card__disabled-state">
      <p class="ncm-hint">
        <i class="fas fa-ban"></i> Network unavailable in this scene
      </p>
    </div>
  {{/if}}
  
</div>
