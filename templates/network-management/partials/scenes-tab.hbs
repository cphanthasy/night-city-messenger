{{!-- Scenes Tab - Scene-Based Network Configuration --}}
{{!-- FIXED VERSION: Uses sceneNetworks instead of networks --}}
<div class="ncm-scenes-tab">
  
  {{!-- Toolbar --}}
  <div class="ncm-scenes-tab__toolbar">
    <div class="ncm-scenes-tab__toolbar-left">
      <label for="scene-selector" class="ncm-label">
        <i class="fas fa-map-marked-alt"></i> Scene:
      </label>
      <select id="scene-selector" class="ncm-select ncm-scene-selector">
        <option value="">-- Select Scene --</option>
        {{#each scenes}}
          <option value="{{this.id}}" {{#if this.active}}selected{{/if}}>
            {{this.name}} {{#if this.active}}(Active){{/if}}
          </option>
        {{/each}}
      </select>
      
      {{#if currentScene}}
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="configure-scene">
          <i class="fas fa-cog"></i> Configure
        </button>
      {{/if}}
    </div>
    
    <div class="ncm-scenes-tab__toolbar-right">
      {{#if currentScene}}
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="copy-to-scenes">
          <i class="fas fa-copy"></i> Copy To Scenes
        </button>
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" data-action="apply-template">
          <i class="fas fa-magic"></i> Apply Template
        </button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" data-action="reset-scene">
          <i class="fas fa-undo"></i> Reset
        </button>
      {{/if}}
    </div>
  </div>
  
  {{#if currentScene}}
    {{!-- Scene Info --}}
    <div class="ncm-scene-info">
      <div class="ncm-scene-info__header">
        <h3 class="ncm-scene-info__title">
          <i class="fas fa-map-marker-alt ncm-glow"></i>
          {{currentScene.name}}
        </h3>
        <div class="ncm-scene-info__meta">
          {{#if currentScene.active}}
            <span class="ncm-badge ncm-badge--success">
              <i class="fas fa-check-circle"></i> Active Scene
            </span>
          {{/if}}
          <span class="ncm-scene-info__dimension">
            {{currentScene.width}} × {{currentScene.height}}
          </span>
        </div>
      </div>
    </div>
    
    {{!-- Network Grid --}}
    <div class="ncm-network-grid">
      <div class="ncm-network-grid__header">
        <h4 class="ncm-section-title">
          <i class="fas fa-network-wired"></i>
          Available Networks
        </h4>
        <div class="ncm-network-grid__actions">
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" data-action="enable-all">
            <i class="fas fa-check-double"></i> Enable All
          </button>
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" data-action="disable-all">
            <i class="fas fa-ban"></i> Disable All
          </button>
        </div>
      </div>
      
      {{!-- FIXED: Use sceneNetworks instead of networks --}}
      {{#if sceneNetworks.length}}
        <div class="ncm-network-cards">
          {{#each sceneNetworks}}
            {{> "modules/cyberpunkred-messenger/templates/network-management/partials/scene-network-card.hbs" this}}
          {{/each}}
        </div>
      {{else}}
        <div class="ncm-empty-state">
          <i class="fas fa-network-wired ncm-empty-state__icon"></i>
          <p class="ncm-empty-state__text">No networks available</p>
          <p class="ncm-empty-state__hint">Create networks in the Networks tab first</p>
        </div>
      {{/if}}
    </div>
    
    {{!-- Auto-Switch Settings --}}
    <div class="ncm-scene-settings">
      <h4 class="ncm-section-title">
        <i class="fas fa-exchange-alt"></i>
        Scene Settings
      </h4>
      
      <div class="ncm-setting-row">
        <div class="ncm-setting-row__info">
          <label class="ncm-label">Auto-Switch Network</label>
          <p class="ncm-hint">Automatically switch to strongest network when entering this scene</p>
        </div>
        <div class="ncm-setting-row__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   data-action="toggle-auto-switch" 
                   {{#if sceneSettings.autoSwitch}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
        </div>
      </div>
      
      <div class="ncm-setting-row">
        <div class="ncm-setting-row__info">
          <label class="ncm-label">Preferred Network</label>
          <p class="ncm-hint">If multiple networks available, prefer this one</p>
        </div>
        <div class="ncm-setting-row__control">
          {{!-- FIXED: Use sceneNetworks for dropdown, sceneSettings for selected value --}}
          <select class="ncm-select" data-action="set-preferred-network">
            <option value="">Auto (Strongest)</option>
            {{#each sceneNetworks}}
              <option value="{{this.id}}" 
                      {{#if (eq this.id ../sceneSettings.preferredNetwork)}}selected{{/if}}>
                {{this.name}}
              </option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>
    
  {{else}}
    {{!-- No Scene Selected --}}
    <div class="ncm-empty-state ncm-empty-state--large">
      <i class="fas fa-map-marked-alt ncm-empty-state__icon"></i>
      <h3 class="ncm-empty-state__title">No Scene Selected</h3>
      <p class="ncm-empty-state__text">Select a scene from the dropdown above to configure its network availability</p>
    </div>
  {{/if}}
  
</div>
