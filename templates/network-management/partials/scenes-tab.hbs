{{!-- 
  Scenes Tab Partial
  File: templates/network-management/partials/scenes-tab.hbs
  Module: cyberpunkred-messenger
  Description: Configure which networks are available in each scene
  
  Data Flow:
  - Scene flags are the SINGLE SOURCE OF TRUTH
  - Changes here update scene.flags['cyberpunkred-messenger'].networks
  - Signal strength is per-scene override of network default
--}}

<div class="ncm-scenes-tab">
  
  {{!-- Info Banner --}}
  <div class="ncm-scenes-tab__info">
    <i class="fas fa-info-circle"></i>
    <div>
      <strong>Scene Network Configuration</strong>
      <p>Configure which networks are available in each scene and their signal strength. 
         Changes are saved automatically to scene flags.</p>
    </div>
  </div>
  
  {{!-- Toolbar --}}
  <div class="ncm-scenes-tab__toolbar">
    
    <div class="ncm-scenes-tab__toolbar-left">
      {{!-- Scene Filter --}}
      <div class="ncm-scenes-tab__search">
        <i class="fas fa-search"></i>
        <input type="text" 
               class="scene-filter-input" 
               placeholder="Filter scenes..." 
               value="{{sceneFilter}}">
      </div>
      
      {{!-- Show Only Active --}}
      <label class="ncm-scenes-tab__toggle-filter">
        <input type="checkbox" 
               class="show-active-only" 
               {{#if showActiveOnly}}checked{{/if}}>
        <span>Active scene only</span>
      </label>
    </div>
    
    <div class="ncm-scenes-tab__toolbar-right">
      {{!-- Quick Actions --}}
      <div class="ncm-scenes-tab__quick-actions">
        <button type="button" class="ncm-nm__btn ncm-nm__btn--small apply-to-all-btn" 
                title="Apply current scene config to all scenes">
          <i class="fas fa-copy"></i>
          Copy Current to All
        </button>
        <button type="button" class="ncm-nm__btn ncm-nm__btn--small reset-signals-btn"
                title="Reset all signal strengths to defaults">
          <i class="fas fa-undo"></i>
          Reset Signals
        </button>
      </div>
    </div>
  </div>

  {{!-- Main Content --}}
  <div class="ncm-scenes-tab__content">
    
    {{#if scenes.length}}
    
      {{!-- Scene Cards --}}
      <div class="ncm-scenes-tab__scenes">
        
        {{#each scenes}}
          <div class="ncm-scene-config {{#if this.isActive}}ncm-scene-config--active{{/if}}" 
               data-scene-id="{{this.id}}">
            
            {{!-- Scene Header --}}
            <header class="ncm-scene-config__header">
              <div class="ncm-scene-config__title">
                {{#if this.thumbnail}}
                  <img src="{{this.thumbnail}}" alt="{{this.name}}" class="ncm-scene-config__thumb">
                {{else}}
                  <div class="ncm-scene-config__thumb ncm-scene-config__thumb--placeholder">
                    <i class="fas fa-map"></i>
                  </div>
                {{/if}}
                <div class="ncm-scene-config__title-text">
                  <h3>{{this.name}}</h3>
                  {{#if this.isActive}}
                    <span class="ncm-scene-config__active-badge">
                      <i class="fas fa-broadcast-tower"></i> CURRENT SCENE
                    </span>
                  {{/if}}
                </div>
              </div>
              
              <div class="ncm-scene-config__actions">
                <span class="ncm-scene-config__network-count">
                  {{this.enabledNetworkCount}}/{{../networks.length}} networks
                </span>
                <button type="button" class="action-btn enable-all-scene-btn" 
                        data-scene-id="{{this.id}}" title="Enable all networks">
                  <i class="fas fa-check-double"></i>
                </button>
                <button type="button" class="action-btn disable-all-scene-btn" 
                        data-scene-id="{{this.id}}" title="Disable all networks">
                  <i class="fas fa-ban"></i>
                </button>
                <button type="button" class="action-btn copy-config-btn" 
                        data-scene-id="{{this.id}}" title="Copy to other scenes">
                  <i class="fas fa-copy"></i>
                </button>
              </div>
            </header>
            
            {{!-- Network Grid --}}
            <div class="ncm-scene-config__networks">
              
              {{#each ../networks}}
                {{!-- Get scene-specific config for this network --}}
                {{#with (lookup ../../sceneConfigs (concat ../id "_" this.id))}}
                  
                  <div class="ncm-network-toggle {{#if this.enabled}}ncm-network-toggle--enabled{{/if}}"
                       data-scene-id="{{../id}}"
                       data-network-id="{{this.networkId}}"
                       style="--network-color: {{@root.networks.[0].theme.color}}">
                    
                    {{!-- Network Icon & Name --}}
                    <div class="ncm-network-toggle__info">
                      <i class="fas {{this.icon}}" style="color: {{this.color}}"></i>
                      <span class="ncm-network-toggle__name">{{this.networkName}}</span>
                    </div>
                    
                    {{!-- Enable Toggle --}}
                    <label class="ncm-network-toggle__switch">
                      <input type="checkbox" 
                             class="scene-network-checkbox"
                             data-scene-id="{{../id}}"
                             data-network-id="{{this.networkId}}"
                             {{#if this.enabled}}checked{{/if}}>
                      <span class="toggle-slider"></span>
                    </label>
                    
                    {{!-- Signal Strength (only if enabled) --}}
                    {{#if this.enabled}}
                      <div class="ncm-network-toggle__signal">
                        <div class="signal-bars" data-strength="{{this.signalStrength}}">
                          <span class="bar {{#if (gte this.signalStrength 20)}}bar--active{{/if}}"></span>
                          <span class="bar {{#if (gte this.signalStrength 40)}}bar--active{{/if}}"></span>
                          <span class="bar {{#if (gte this.signalStrength 60)}}bar--active{{/if}}"></span>
                          <span class="bar {{#if (gte this.signalStrength 80)}}bar--active{{/if}}"></span>
                        </div>
                        <input type="range" 
                               class="signal-slider"
                               data-scene-id="{{../id}}"
                               data-network-id="{{this.networkId}}"
                               min="0" max="100" step="5"
                               value="{{this.signalStrength}}">
                        <span class="signal-value">{{this.signalStrength}}%</span>
                      </div>
                    {{else}}
                      <div class="ncm-network-toggle__signal ncm-network-toggle__signal--disabled">
                        <span class="signal-disabled">--</span>
                      </div>
                    {{/if}}
                    
                  </div>
                  
                {{else}}
                  {{!-- No config yet, show with defaults --}}
                  <div class="ncm-network-toggle"
                       data-scene-id="{{../id}}"
                       data-network-id="{{this.id}}">
                    
                    <div class="ncm-network-toggle__info">
                      <i class="fas {{this.theme.icon}}" style="color: {{this.theme.color}}"></i>
                      <span class="ncm-network-toggle__name">{{this.name}}</span>
                    </div>
                    
                    <label class="ncm-network-toggle__switch">
                      <input type="checkbox" 
                             class="scene-network-checkbox"
                             data-scene-id="{{../id}}"
                             data-network-id="{{this.id}}">
                      <span class="toggle-slider"></span>
                    </label>
                    
                    <div class="ncm-network-toggle__signal ncm-network-toggle__signal--disabled">
                      <span class="signal-disabled">--</span>
                    </div>
                    
                  </div>
                {{/with}}
              {{/each}}
              
            </div>
            
            {{!-- Quick Notes (collapsed by default) --}}
            <details class="ncm-scene-config__notes">
              <summary>
                <i class="fas fa-sticky-note"></i>
                Scene Notes
              </summary>
              <div class="notes-content">
                <textarea class="scene-notes-input" 
                          data-scene-id="{{this.id}}"
                          placeholder="Add notes about network conditions in this scene...">{{this.networkNotes}}</textarea>
              </div>
            </details>
            
          </div>
        {{/each}}
        
      </div>
      
    {{else}}
      {{!-- Empty State --}}
      <div class="ncm-scenes-tab__empty">
        <div class="empty-icon">
          <i class="fas fa-map-marked-alt"></i>
        </div>
        <h3>No Scenes Found</h3>
        <p>Create scenes in your world to configure network availability.</p>
      </div>
    {{/if}}
    
  </div>
  
  {{!-- Floating Legend --}}
  <div class="ncm-scenes-tab__legend">
    <h4><i class="fas fa-question-circle"></i> Legend</h4>
    <div class="legend-items">
      <div class="legend-item">
        <div class="signal-bars signal-bars--demo" data-strength="100">
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
        </div>
        <span>Excellent (80-100%)</span>
      </div>
      <div class="legend-item">
        <div class="signal-bars signal-bars--demo" data-strength="60">
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
          <span class="bar"></span>
        </div>
        <span>Good (60-79%)</span>
      </div>
      <div class="legend-item">
        <div class="signal-bars signal-bars--demo" data-strength="40">
          <span class="bar bar--active"></span>
          <span class="bar bar--active"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </div>
        <span>Fair (40-59%)</span>
      </div>
      <div class="legend-item">
        <div class="signal-bars signal-bars--demo" data-strength="20">
          <span class="bar bar--active"></span>
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </div>
        <span>Poor (1-39%)</span>
      </div>
    </div>
  </div>
  
</div>
