{{!-- Scenes Tab - Network availability per scene --}}
<div class="ncm-scenes-tab">
  
  {{!-- Toolbar --}}
  <div class="ncm-scenes-tab__toolbar">
    <div class="ncm-scenes-tab__toolbar-left">
      <div class="ncm-form-group ncm-form-group--inline">
        <label class="ncm-label">
          <i class="fas fa-map-marker-alt"></i> Scene:
        </label>
        <select class="ncm-select ncm-scene-selector" 
                id="scene-selector" 
                data-action="select-scene">
          <option value="">-- Select a scene --</option>
          {{#each scenes}}
            <option value="{{this.id}}" 
                    {{#if (eq this.id ../currentScene.id)}}selected{{/if}}>
              {{this.name}}
            </option>
          {{/each}}
        </select>
      </div>
    </div>
    
    {{#if currentScene}}
      <div class="ncm-scenes-tab__toolbar-right">
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" 
                data-action="copy-to-scenes"
                title="Copy this scene's network configuration to other scenes">
          <i class="fas fa-copy"></i> Copy Config To...
        </button>
        <button class="ncm-btn ncm-btn--secondary ncm-btn--sm" 
                data-action="apply-template"
                title="Apply a preset template to this scene">
          <i class="fas fa-magic"></i> Apply Template
        </button>
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm" 
                data-action="reset-scene"
                title="Reset all networks to default configuration">
          <i class="fas fa-undo"></i> Reset Scene
        </button>
      </div>
    {{/if}}
  </div>
  
  {{!-- Scene Content --}}
  {{#if currentScene}}
    
    {{!-- Scene Info Card --}}
    <div class="ncm-scene-info">
      <div class="ncm-scene-info__header">
        <h3 class="ncm-scene-info__title">
          <i class="fas fa-map-marked-alt"></i> {{currentScene.name}}
        </h3>
        <div class="ncm-scene-info__actions">
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" 
                  data-action="enable-all"
                  title="Enable all networks for this scene">
            <i class="fas fa-toggle-on"></i> Enable All
          </button>
          <button class="ncm-btn ncm-btn--ghost ncm-btn--xs" 
                  data-action="disable-all"
                  title="Disable all networks for this scene">
            <i class="fas fa-toggle-off"></i> Disable All
          </button>
        </div>
      </div>
    </div>
    
    {{!-- Network Grid --}}
    <div class="ncm-network-grid">
      <div class="ncm-network-grid__header">
        <h4 class="ncm-section-title">
          <i class="fas fa-network-wired"></i>
          Network Availability
        </h4>
        <p class="ncm-hint">
          Configure which networks are available in this scene and their signal strength
        </p>
      </div>
      
      <div class="ncm-network-cards">
        {{#each sceneNetworks}}
          {{> "modules/cyberpunkred-messenger/templates/network-management/partials/scene-network-card.hbs"}}
        {{/each}}
      </div>
    </div>
    
    {{!-- Scene Settings --}}
    <div class="ncm-scene-settings">
      <h4 class="ncm-section-title">
        <i class="fas fa-cog"></i>
        Scene Settings
      </h4>
      
      <div class="ncm-setting-row">
        <div class="ncm-setting-row__info">
          <label class="ncm-label">Auto-Switch Network</label>
          <p class="ncm-hint">Automatically switch to strongest network when entering this scene</p>
        </div>
        <div class="ncm-setting-row__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   id="scene-auto-switch"
                   {{#if sceneSettings.autoSwitch}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
        </div>
      </div>
      
      <div class="ncm-setting-row">
        <div class="ncm-setting-row__info">
          <label class="ncm-label">Preferred Network</label>
          <p class="ncm-hint">If multiple networks available, prefer this one</p>
        </div>
        <div class="ncm-setting-row__control">
          <select class="ncm-select" id="scene-preferred-network">
            <option value="">Auto (Strongest)</option>
            {{#each sceneNetworks}}
              <option value="{{this.id}}" 
                      {{#if (eq this.id ../sceneSettings.preferredNetwork)}}selected{{/if}}>
                {{this.name}}
              </option>
            {{/each}}
          </select>
        </div>
      </div>
      
      {{!-- Save/Reset Actions --}}
      <div class="ncm-scene-settings__actions">
        <button class="ncm-btn ncm-btn--primary" 
                data-action="save-scene-settings">
          <i class="fas fa-save"></i> Save Scene Settings
        </button>
        <button class="ncm-btn ncm-btn--ghost" 
                data-action="reset-scene-settings">
          <i class="fas fa-undo"></i> Reset to Defaults
        </button>
      </div>
    </div>
    
  {{else}}
    {{!-- No Scene Selected --}}
    <div class="ncm-empty-state ncm-empty-state--large">
      <i class="fas fa-map-marked-alt ncm-empty-state__icon"></i>
      <h3 class="ncm-empty-state__title">No Scene Selected</h3>
      <p class="ncm-empty-state__text">Select a scene from the dropdown above to configure its network availability</p>
    </div>
  {{/if}}
  
</div>
