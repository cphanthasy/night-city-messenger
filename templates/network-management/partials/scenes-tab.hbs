{{!-- 
  Scenes Tab - REFACTORED  
  CHANGES: Removed sync indicators, removed sync action buttons
  Scene flags are the single source of truth for availability
--}}

<div class="ncm-scenes-tab">
  
  {{!-- Scene Selector --}}
  <div class="ncm-scene-selector-header">
    <div class="ncm-form-group">
      <label for="scene-selector">
        <i class="fas fa-map"></i> Scene:
      </label>
      <select id="scene-selector" class="ncm-select">
        <option value="">-- Select Scene --</option>
        {{#each scenes}}
          <option value="{{this.id}}" {{#if (eq this.id ../currentSceneId)}}selected{{/if}}>
            {{this.name}}
          </option>
        {{/each}}
      </select>
    </div>
    
    {{#if currentScene}}
      <div class="ncm-scene-actions">
        <button class="ncm-btn ncm-btn--sm ncm-btn--primary" data-action="enable-all">
          <i class="fas fa-check-double"></i> Enable All
        </button>
        <button class="ncm-btn ncm-btn--sm ncm-btn--secondary" data-action="disable-all">
          <i class="fas fa-ban"></i> Disable All
        </button>
        <button class="ncm-btn ncm-btn--sm ncm-btn--secondary" data-action="copy-to-scenes">
          <i class="fas fa-copy"></i> Copy to Other Scenes
        </button>
        <button class="ncm-btn ncm-btn--sm ncm-btn--secondary" data-action="reset-scene">
          <i class="fas fa-undo"></i> Reset
        </button>
      </div>
    {{/if}}
  </div>
  
  {{#if currentScene}}
    
    {{!-- Scene Settings --}}
    <div class="ncm-scene-settings">
      <h3><i class="fas fa-cog"></i> Scene Settings</h3>
      
      <div class="ncm-scene-settings-grid">
        <div class="ncm-setting">
          <label>
            <input 
              type="checkbox" 
              data-action="toggle-auto-switch"
              {{#if sceneSettings.autoSwitch}}checked{{/if}}>
            <span>Auto-switch to available network when entering scene</span>
          </label>
        </div>
        
        <div class="ncm-setting">
          <label for="preferred-network">Preferred Network:</label>
          <select 
            id="preferred-network" 
            class="ncm-select"
            data-action="set-preferred-network">
            <option value="">None</option>
            {{#each sceneNetworks}}
              {{#if sceneConfig.available}}
                <option 
                  value="{{id}}"
                  {{#if (eq id ../sceneSettings.preferredNetwork)}}selected{{/if}}>
                  {{name}}
                </option>
              {{/if}}
            {{/each}}
          </select>
        </div>
      </div>
    </div>
    
    {{!-- Network List - SIMPLIFIED (no sync indicators) --}}
    <div class="ncm-scene-networks-list">
      <h3><i class="fas fa-wifi"></i> Network Availability</h3>
      
      {{#if sceneNetworks.length}}
        <div class="ncm-scene-networks-grid">
          {{#each sceneNetworks}}
            {{> "modules/cyberpunkred-messenger/templates/network-management/partials/scene-network-card.hbs"}}
          {{/each}}
        </div>
      {{else}}
        <div class="ncm-empty-state">
          <i class="fas fa-network-wired"></i>
          <p>No networks configured. Create networks in the Networks tab.</p>
        </div>
      {{/if}}
    </div>
    
  {{else}}
    
    {{!-- No Scene Selected --}}
    <div class="ncm-empty-state">
      <i class="fas fa-map-marked-alt"></i>
      <h3>No Scene Selected</h3>
      <p>Select a scene from the dropdown above to configure network availability.</p>
    </div>
    
  {{/if}}
  
</div>

<style>
.ncm-scenes-tab {
  padding: 1rem;
}

.ncm-scene-selector-header {
  display: flex;
  align-items: flex-end;
  gap: 1rem;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 2px solid var(--ncm-border);
}

.ncm-scene-selector-header .ncm-form-group {
  flex: 1;
}

.ncm-scene-actions {
  display: flex;
  gap: 0.5rem;
}

.ncm-scene-settings {
  background: var(--ncm-surface);
  border: 1px solid var(--ncm-border);
  border-radius: 4px;
  padding: 1rem;
  margin-bottom: 1.5rem;
}

.ncm-scene-settings h3 {
  margin: 0 0 1rem 0;
  color: var(--ncm-primary);
  font-size: 1rem;
  font-weight: 600;
}

.ncm-scene-settings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.ncm-setting label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.ncm-scene-networks-list h3 {
  margin: 0 0 1rem 0;
  color: var(--ncm-primary);
  font-size: 1rem;
  font-weight: 600;
}

.ncm-scene-networks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

.ncm-empty-state {
  text-align: center;
  padding: 3rem 1rem;
  color: var(--ncm-text-secondary);
}

.ncm-empty-state i {
  font-size: 3rem;
  margin-bottom: 1rem;
  opacity: 0.5;
}

.ncm-empty-state h3 {
  margin: 0 0 0.5rem 0;
  font-size: 1.2rem;
}

.ncm-empty-state p {
  margin: 0;
  font-size: 0.9rem;
}
</style>
