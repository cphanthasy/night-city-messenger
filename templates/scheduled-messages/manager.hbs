{{!-- 
  Scheduled Messages Manager Template
  File: templates/scheduled-messages/manager.hbs
--}}

<div class="ncm-scheduled-manager">
  {{!-- Header with stats --}}
  <div class="ncm-scheduled-manager__header">
    <div class="ncm-scheduled-manager__stats">
      <div class="ncm-scheduled-manager__stat">
        <span class="ncm-scheduled-manager__stat-value">{{stats.total}}</span>
        <span class="ncm-scheduled-manager__stat-label">Total</span>
      </div>
      <div class="ncm-scheduled-manager__stat ncm-scheduled-manager__stat--upcoming">
        <span class="ncm-scheduled-manager__stat-value">{{stats.upcoming}}</span>
        <span class="ncm-scheduled-manager__stat-label">Upcoming</span>
      </div>
      <div class="ncm-scheduled-manager__stat ncm-scheduled-manager__stat--pastdue">
        <span class="ncm-scheduled-manager__stat-value">{{stats.pastDue}}</span>
        <span class="ncm-scheduled-manager__stat-label">Past Due</span>
      </div>
      <div class="ncm-scheduled-manager__stat ncm-scheduled-manager__stat--sent">
        <span class="ncm-scheduled-manager__stat-value">{{stats.sent}}</span>
        <span class="ncm-scheduled-manager__stat-label">Sent</span>
      </div>
    </div>
    
    <div class="ncm-scheduled-manager__current-time">
      <i class="fas fa-clock"></i>
      <span>Current: <strong>{{currentTime}}</strong></span>
    </div>
  </div>
  
  {{!-- Controls --}}
  <div class="ncm-scheduled-manager__controls">
    <div class="ncm-scheduled-manager__controls-left">
      <label class="ncm-scheduled-manager__filter-label">
        Show:
        <select name="filterStatus" class="ncm-scheduled-manager__filter">
          <option value="all" {{#if (eq filterStatus "all")}}selected{{/if}}>All Messages</option>
          <option value="upcoming" {{#if (eq filterStatus "upcoming")}}selected{{/if}}>Upcoming</option>
          <option value="pastdue" {{#if (eq filterStatus "pastdue")}}selected{{/if}}>Past Due</option>
          <option value="sent" {{#if (eq filterStatus "sent")}}selected{{/if}}>Sent</option>
        </select>
      </label>
    </div>
    
    <div class="ncm-scheduled-manager__controls-right">
      <button class="ncm-btn ncm-btn--small" data-action="refresh" title="Refresh">
        <i class="fas fa-sync-alt"></i>
      </button>
      <button class="ncm-btn ncm-btn--small" data-action="force-check" title="Check & Send Due Messages">
        <i class="fas fa-paper-plane"></i> Check Now
      </button>
      <button class="ncm-btn ncm-btn--small" data-action="export" title="Export to JSON">
        <i class="fas fa-download"></i> Export
      </button>
    </div>
  </div>
  
  {{!-- Message list --}}
  <div class="ncm-scheduled-manager__content">
    {{#if hasScheduled}}
      <table class="ncm-scheduled-manager__table">
        <thead>
          <tr>
            <th>
              <button class="ncm-scheduled-manager__sort-btn" 
                      data-action="sort" 
                      data-sort-by="time">
                Scheduled Time
                {{#if (eq sortBy "time")}}
                  <i class="fas fa-sort-{{#if (eq sortOrder "asc")}}up{{else}}down{{/if}}"></i>
                {{else}}
                  <i class="fas fa-sort"></i>
                {{/if}}
              </button>
            </th>
            <th>
              <button class="ncm-scheduled-manager__sort-btn" 
                      data-action="sort" 
                      data-sort-by="from">
                From
                {{#if (eq sortBy "from")}}
                  <i class="fas fa-sort-{{#if (eq sortOrder "asc")}}up{{else}}down{{/if}}"></i>
                {{else}}
                  <i class="fas fa-sort"></i>
                {{/if}}
              </button>
            </th>
            <th>
              <button class="ncm-scheduled-manager__sort-btn" 
                      data-action="sort" 
                      data-sort-by="to">
                To
                {{#if (eq sortBy "to")}}
                  <i class="fas fa-sort-{{#if (eq sortOrder "asc")}}up{{else}}down{{/if}}"></i>
                {{else}}
                  <i class="fas fa-sort"></i>
                {{/if}}
              </button>
            </th>
            <th>
              <button class="ncm-scheduled-manager__sort-btn" 
                      data-action="sort" 
                      data-sort-by="subject">
                Subject
                {{#if (eq sortBy "subject")}}
                  <i class="fas fa-sort-{{#if (eq sortOrder "asc")}}up{{else}}down{{/if}}"></i>
                {{else}}
                  <i class="fas fa-sort"></i>
                {{/if}}
              </button>
            </th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each scheduled}}
            <tr class="ncm-scheduled-manager__row ncm-scheduled-manager__row--{{statusClass}}" 
                data-schedule-id="{{id}}">
              <td class="ncm-scheduled-manager__time">
                <div class="ncm-scheduled-manager__time-main">{{displayTime}}</div>
                <div class="ncm-scheduled-manager__time-relative">{{relativeTime}}</div>
                {{#if useSimpleCalendar}}
                  <span class="ncm-scheduled-manager__badge" title="Using Simple Calendar">
                    <i class="fas fa-calendar-alt"></i> SC
                  </span>
                {{/if}}
              </td>
              <td class="ncm-scheduled-manager__from">{{from}}</td>
              <td class="ncm-scheduled-manager__to">{{to}}</td>
              <td class="ncm-scheduled-manager__subject">{{subject}}</td>
              <td class="ncm-scheduled-manager__status">
                {{#if sent}}
                  <span class="ncm-scheduled-manager__status-badge ncm-scheduled-manager__status-badge--sent">
                    <i class="fas fa-check"></i> Sent
                  </span>
                {{else if isPastDue}}
                  <span class="ncm-scheduled-manager__status-badge ncm-scheduled-manager__status-badge--pastdue">
                    <i class="fas fa-exclamation-triangle"></i> Past Due
                  </span>
                {{else}}
                  <span class="ncm-scheduled-manager__status-badge ncm-scheduled-manager__status-badge--upcoming">
                    <i class="fas fa-clock"></i> Scheduled
                  </span>
                {{/if}}
              </td>
              <td class="ncm-scheduled-manager__actions">
                {{#unless sent}}
                  <button class="ncm-btn ncm-btn--icon ncm-btn--small" 
                          data-action="send-now" 
                          title="Send Now">
                    <i class="fas fa-paper-plane"></i>
                  </button>
                  <button class="ncm-btn ncm-btn--icon ncm-btn--small" 
                          data-action="reschedule" 
                          title="Reschedule">
                    <i class="fas fa-calendar-alt"></i>
                  </button>
                {{/unless}}
                <button class="ncm-btn ncm-btn--icon ncm-btn--small" 
                        data-action="view-details" 
                        title="View Details">
                  <i class="fas fa-eye"></i>
                </button>
                {{#unless sent}}
                  <button class="ncm-btn ncm-btn--icon ncm-btn--small ncm-btn--danger" 
                          data-action="delete" 
                          title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                {{/unless}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="ncm-scheduled-manager__empty">
        <i class="fas fa-clock"></i>
        <p>No scheduled messages</p>
        <p class="ncm-scheduled-manager__empty-hint">
          Messages can be scheduled from the composer using the "Schedule" button.
        </p>
      </div>
    {{/if}}
  </div>
  
  {{#if stats.nextDelivery}}
    <div class="ncm-scheduled-manager__footer">
      <i class="fas fa-info-circle"></i>
      Next delivery: <strong>{{stats.nextDelivery}}</strong>
    </div>
  {{/if}}
</div>