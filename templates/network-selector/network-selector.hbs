{{!-- Network Selector Template (Simplified) --}}
{{!-- File: templates/network-selector.hbs --}}

<div class="ncm-network-selector-content">
  
  {{!-- Current Status Header --}}
  <div class="network-header">
    {{#if connected}}
      <div class="current-connection">
        <i class="fas {{currentNetwork.icon}}" style="color: {{currentNetwork.color}}"></i>
        <div class="connection-info">
          <span class="label">Connected</span>
          <span class="network-name">{{currentNetwork.name}}</span>
        </div>
        <button class="disconnect-btn" title="Disconnect">
          <i class="fas fa-plug"></i>
        </button>
      </div>
    {{else}}
      <div class="no-connection">
        <i class="fas fa-exclamation-triangle"></i>
        <span>No Network Connection</span>
      </div>
    {{/if}}
    
    <div class="header-actions">
      <button class="refresh-btn" title="Scan for networks">
        <i class="fas fa-sync-alt"></i>
      </button>
      {{#if isGM}}
        <button class="manage-btn" title="Manage Networks">
          <i class="fas fa-cog"></i>
        </button>
      {{/if}}
    </div>
  </div>

  {{!-- Network List --}}
  <div class="network-list">
    {{#if networks}}
      {{#each networks}}
        <div class="network-item {{#if isConnected}}connected{{/if}} {{#unless canConnect}}unavailable{{/unless}}"
             data-network-id="{{id}}">
          
          <div class="network-icon" style="color: {{color}}">
            <i class="fas {{icon}}"></i>
          </div>
          
          <div class="network-info">
            <div class="network-name">
              {{name}}
              {{#if isConnected}}
                <i class="fas fa-check-circle connected-badge"></i>
              {{/if}}
            </div>
            
            <div class="network-meta">
              {{#if requiresAuth}}
                {{#if isAuthenticated}}
                  <span class="auth-badge authenticated">
                    <i class="fas fa-key"></i>
                  </span>
                {{else}}
                  <span class="auth-badge locked">
                    <i class="fas fa-lock"></i>
                  </span>
                {{/if}}
              {{/if}}
              
              <span class="signal-quality {{signalQuality.class}}">
                {{signalQuality.label}}
              </span>
            </div>
            
            {{#if description}}
              <div class="network-description">{{description}}</div>
            {{/if}}
          </div>
          
          <div class="network-signal">
            {{{signalBars}}}
            <span class="signal-percent">{{signal}}%</span>
          </div>
        </div>
      {{/each}}
    {{else}}
      <div class="no-networks">
        <i class="fas fa-signal-slash"></i>
        <p>No networks available</p>
        <small>Try moving to a different location</small>
      </div>
    {{/if}}
  </div>

  {{#unless hasCharacter}}
    <div class="character-warning">
      <i class="fas fa-user-slash"></i>
      <small>No character selected - hacking unavailable</small>
    </div>
  {{/unless}}
</div>
