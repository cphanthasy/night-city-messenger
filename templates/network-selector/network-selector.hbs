{{!-- 
  Network Selector Template
  File: templates/network-selector/network-selector.hbs
  Module: cyberpunkred-messenger
  Description: Main network selector UI with expandable network list
--}}

<div class="ncm-network-selector {{#if expanded}}expanded{{/if}} {{#if embedded}}embedded{{/if}}" data-context="{{context}}">
  
  {{#if error}}
    {{!-- Error State --}}
    <div class="ncm-network-error">
      <i class="fas fa-exclamation-triangle"></i>
      <span>{{errorMessage}}</span>
    </div>
  {{else}}
  
    {{!-- Current Network Display --}}
    <div class="ncm-network-current" title="{{#if connected}}Click to view available networks{{else}}Not connected - Click to connect{{/if}}">
      {{#if connected}}
        {{!-- Connected State --}}
        <div class="network-icon" style="color: {{currentNetwork.color}};">
          <i class="fas {{currentNetwork.icon}}"></i>
        </div>
        
        <div class="network-info">
          <div class="network-name">{{currentNetwork.displayName}}</div>
          <div class="network-status">{{currentNetwork.status}}</div>
        </div>
        
        <div class="network-signal">
          {{{currentNetwork.signalBars}}}
          <span class="signal-percentage">{{currentNetwork.signalStrength}}%</span>
        </div>
        
        {{#if currentNetwork.isTraced}}
          <div class="network-warning" title="This network is being traced">
            <i class="fas fa-exclamation-triangle"></i>
          </div>
        {{/if}}
        
        {{#if currentNetwork.isMonitored}}
          <div class="network-monitored" title="This network is monitored">
            <i class="fas fa-eye"></i>
          </div>
        {{/if}}
      {{else}}
        {{!-- Disconnected State --}}
        <div class="network-icon disconnected">
          <i class="fas fa-wifi-slash"></i>
        </div>
        
        <div class="network-info">
          <div class="network-name">NO CONNECTION</div>
          <div class="network-status">Disconnected</div>
        </div>
      {{/if}}
      
      <div class="expand-toggle">
        <i class="fas {{#if expanded}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
      </div>
    </div>

    {{!-- Network List (Expandable) --}}
    {{#if expanded}}
    <div class="ncm-network-list">
      
      {{#if hasNetworks}}
        <div class="network-list-header">
          <span>AVAILABLE NETWORKS</span>
          <span class="network-count">{{availableNetworks.length}}</span>
        </div>
        
        <div class="network-list-items">
          {{#each availableNetworks}}
            {{> "modules/cyberpunkred-messenger/templates/network-selector/partials/network-item.hbs"}}
          {{/each}}
        </div>
      {{else}}
        <div class="network-list-empty">
          <i class="fas fa-satellite-dish"></i>
          <p>{{noNetworksMessage}}</p>
        </div>
      {{/if}}
      
      <div class="ncm-network-actions">
        {{#if canScan}}
          <button class="btn-scan" data-action="scan" title="Scan for networks">
            <i class="fas fa-sync-alt"></i> SCAN
          </button>
        {{/if}}
        
        {{#if canManage}}
          <button class="btn-manage" data-action="manage" title="Manage networks (GM)">
            <i class="fas fa-cog"></i> MANAGE
          </button>
        {{/if}}
      </div>
    </div>
    {{/if}}
    
  {{/if}}
  
</div>
