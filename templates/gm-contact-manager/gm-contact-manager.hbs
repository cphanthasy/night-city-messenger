{{!-- ENHANCED GM Master Contact Manager Template --}}
{{!-- File: templates/gm-contact-manager/gm-contact-manager.hbs --}}
{{!-- 
  ENHANCEMENTS:
  - Sorting controls (multi-field with toggle)
  - Tag filtering dropdown
  - Send As quick action buttons
  - Import/Export CSV buttons
  - Cleaner visual layout
  - Edit actor contacts (with indicators)
--}}

<div class="ncm-gm-contact-manager__container">
  
  {{!-- HEADER --}}
  <div class="ncm-header">
    <div class="ncm-header__top">
      <div class="ncm-header__connection">
        <i class="fas fa-shield-alt"></i> GM ONLY
      </div>
      <div class="ncm-header__title">MASTER CONTACT DIRECTORY</div>
      <div class="ncm-header__time">{{currentTime}}</div>
    </div>
    <div class="ncm-header__bottom">
      <span class="ncm-header__welcome">
        {{#if showingFiltered}}
          {{filteredCount}} of {{contactCount}} Contacts
        {{else}}
          {{contactCount}} Total Contacts
        {{/if}}
        <span style="color: #19f3f7; margin-left: 12px;">
          ({{actorCount}} <i class="fas fa-user"></i> Actors | {{customCount}} <i class="fas fa-plus-circle"></i> Custom)
        </span>
      </span>
    </div>
  </div>
  
  {{!-- INFO BAR --}}
  <div class="ncm-gm-contact-manager__info">
    <i class="fas fa-info-circle"></i>
    <span>Your private directory of all email identities. Edit, organize, and send as any contact.</span>
    <span style="color: #19f3f7; margin-left: auto;">⚡ Now with full editing, sorting & tags!</span>
  </div>
  
  {{!-- TOOLBAR --}}
  <div class="ncm-gm-contact-manager__toolbar">
    {{!-- Row 1: Search and Primary Actions --}}
    <div class="ncm-gm-contact-manager__toolbar-row">
      {{!-- Search --}}
      <div class="ncm-gm-contact-manager__search">
        <i class="fas fa-search"></i>
        <input 
          type="text" 
          class="ncm-gm-contact-manager__search-input" 
          placeholder="Search name, email, organization, tags..."
          value="{{searchTerm}}"
          data-action="search"
        />
      </div>
      
      {{!-- Primary Actions --}}
      <button class="ncm-btn ncm-btn--primary" data-action="add-contact" title="Add Custom Contact">
        <i class="fas fa-plus"></i> Add Contact
      </button>
      
      <button class="ncm-btn ncm-btn--secondary" data-action="import-csv" title="Import from CSV">
        <i class="fas fa-file-import"></i> Import CSV
      </button>
      
      <button class="ncm-btn ncm-btn--secondary" data-action="export-csv" title="Export to CSV">
        <i class="fas fa-file-export"></i> Export CSV
      </button>
      
      <button class="ncm-btn ncm-btn--ghost" data-action="refresh" title="Refresh">
        <i class="fas fa-sync"></i>
      </button>
    </div>
    
    {{!-- Row 2: Filters and Sorting --}}
    <div class="ncm-gm-contact-manager__toolbar-row">
      {{!-- Type Filter --}}
      <div class="ncm-gm-contact-manager__filter-group">
        <label><i class="fas fa-filter"></i> Type:</label>
        <select class="ncm-gm-contact-manager__filter" data-filter="type">
          <option value="all" {{#if (eq typeFilter 'all')}}selected{{/if}}>All Contacts</option>
          <option value="actor" {{#if (eq typeFilter 'actor')}}selected{{/if}}>Actors Only</option>
          <option value="custom" {{#if (eq typeFilter 'custom')}}selected{{/if}}>Custom Only</option>
        </select>
      </div>
      
      {{!-- Tag Filter --}}
      <div class="ncm-gm-contact-manager__filter-group">
        <label><i class="fas fa-tags"></i> Tag:</label>
        <select class="ncm-gm-contact-manager__filter" data-filter="tag">
          <option value="all" {{#if (eq tagFilter 'all')}}selected{{/if}}>All Tags</option>
          {{#each allTags}}
            <option value="{{this}}" {{#if (eq ../tagFilter this)}}selected{{/if}}>{{this}}</option>
          {{/each}}
          {{#unless allTags.length}}
            <option disabled>No tags yet</option>
          {{/unless}}
        </select>
      </div>
      
      {{!-- Sort Controls --}}
      <div class="ncm-gm-contact-manager__filter-group">
        <label><i class="fas fa-sort"></i> Sort:</label>
        <select class="ncm-gm-contact-manager__filter" data-action="sort-by">
          <option value="name" {{#if (eq sortBy 'name')}}selected{{/if}}>Name</option>
          <option value="email" {{#if (eq sortBy 'email')}}selected{{/if}}>Email</option>
          <option value="organization" {{#if (eq sortBy 'organization')}}selected{{/if}}>Organization</option>
          <option value="role" {{#if (eq sortBy 'role')}}selected{{/if}}>Role</option>
          <option value="type" {{#if (eq sortBy 'type')}}selected{{/if}}>Type</option>
          <option value="createdAt" {{#if (eq sortBy 'createdAt')}}selected{{/if}}>Date Added</option>
        </select>
        
        <button class="ncm-btn ncm-btn--ghost" data-action="toggle-sort-order" title="Toggle Sort Order">
          {{#if (eq sortOrder 'asc')}}
            <i class="fas fa-sort-amount-up"></i>
          {{else}}
            <i class="fas fa-sort-amount-down"></i>
          {{/if}}
        </button>
      </div>
    </div>
  </div>
  
  {{!-- CONTACT LIST --}}
  <div class="ncm-gm-contact-manager__list">
    {{#if contacts.length}}
      
      {{!-- Unified Contact List (sorted) --}}
      <div class="ncm-contact-section">
        <div class="ncm-contact-section__header">
          <i class="fas fa-address-book"></i> 
          {{#if showingFiltered}}
            Filtered Results ({{filteredCount}})
          {{else}}
            All Contacts ({{contactCount}})
          {{/if}}
          <span class="ncm-contact-section__hint" style="margin-left: auto; color: #19f3f7;">
            Sorted by: {{sortBy}} 
            {{#if (eq sortOrder 'asc')}}
              (A-Z)
            {{else}}
              (Z-A)
            {{/if}}
          </span>
        </div>
        
        <div class="ncm-contact-section__grid">
          {{#each contacts}}
          <div class="ncm-gm-contact-card {{#if this.isActor}}ncm-gm-contact-card--actor{{/if}}" data-contact-id="{{this.id}}">
            {{!-- Type Indicator --}}
            <div class="ncm-gm-contact-card__type-badge">
              {{#if this.isActor}}
                <i class="fas fa-user" title="Actor-linked"></i>
              {{else}}
                <i class="fas fa-plus-circle" title="Custom"></i>
              {{/if}}
            </div>
            
            {{!-- Avatar --}}
            <div class="ncm-gm-contact-card__avatar" style="background-image: url('{{this.img}}')"></div>
            
            {{!-- Info --}}
            <div class="ncm-gm-contact-card__info">
              <div class="ncm-gm-contact-card__name">
                {{this.name}}
                {{#if this.isActor}}
                  <i class="fas fa-link" style="color: #19f3f7; margin-left: 4px; font-size: 0.8em;" title="Linked to actor"></i>
                {{/if}}
              </div>
              
              <div class="ncm-gm-contact-card__email">
                <i class="fas fa-envelope"></i> {{this.email}}
              </div>
              
              {{#if this.organization}}
              <div class="ncm-gm-contact-card__org">
                <i class="fas fa-building"></i> {{this.organization}}
              </div>
              {{/if}}
              
              {{#if this.role}}
              <div class="ncm-gm-contact-card__role">
                <i class="fas fa-tag"></i> {{this.role}}
              </div>
              {{/if}}
              
              {{#if this.tags}}
              <div class="ncm-gm-contact-card__tags">
                {{#each this.tags}}
                  <span class="ncm-tag">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
              
              {{#if this.notes}}
              <div class="ncm-gm-contact-card__notes">
                <i class="fas fa-sticky-note"></i> {{this.notes}}
              </div>
              {{/if}}
            </div>
            
            {{!-- Actions --}}
            <div class="ncm-gm-contact-card__actions">
              {{!-- Send As Button (NEW) --}}
              <button class="ncm-btn ncm-btn--small ncm-btn--primary" 
                      data-action="send-as"
                      title="Compose message as this contact">
                <i class="fas fa-paper-plane"></i> Send As
              </button>
              
              {{!-- Edit Button (now works for actors too!) --}}
              <button class="ncm-btn ncm-btn--small ncm-btn--ghost" 
                      data-action="edit-contact"
                      title="{{#if this.isActor}}Edit (syncs to actor){{else}}Edit Contact{{/if}}">
                <i class="fas fa-edit"></i>
              </button>
              
              {{!-- Delete Button (disabled for actors) --}}
              <button class="ncm-btn ncm-btn--small ncm-btn--ghost" 
                      data-action="delete-contact"
                      {{#if this.isActor}}
                        disabled
                        title="Cannot delete actor contacts"
                      {{else}}
                        title="Delete Contact"
                      {{/if}}>
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      
    {{else}}
      {{!-- Empty State --}}
      <div class="ncm-gm-contact-manager__empty">
        <div class="ncm-gm-contact-manager__empty-icon">
          <i class="fas fa-address-book"></i>
        </div>
        
        {{#if showingFiltered}}
          <div class="ncm-gm-contact-manager__empty-text">
            No Matching Contacts
          </div>
          <div class="ncm-gm-contact-manager__empty-subtext">
            Try adjusting your filters or search term
          </div>
        {{else}}
          <div class="ncm-gm-contact-manager__empty-text">
            No Contacts Yet
          </div>
          <div class="ncm-gm-contact-manager__empty-subtext">
            Add custom contacts or create actors with email addresses
          </div>
          <button class="ncm-btn ncm-btn--primary ncm-btn--large" data-action="add-contact" style="margin-top: 20px;">
            <i class="fas fa-plus"></i> Add First Contact
          </button>
        {{/if}}
      </div>
    {{/if}}
  </div>
  
  {{!-- FOOTER --}}
  <div class="ncm-gm-contact-manager__footer">
    <div class="ncm-gm-contact-manager__stats">
      <i class="fas fa-database"></i> {{contactCount}} total | 
      <i class="fas fa-user"></i> {{actorCount}} actors | 
      <i class="fas fa-plus-circle"></i> {{customCount}} custom
      {{#if allTags.length}}
        | <i class="fas fa-tags"></i> {{allTags.length}} tags
      {{/if}}
    </div>
    <div class="ncm-gm-contact-manager__hint">
      <i class="fas fa-lightbulb"></i> 
      ⚡ Click "Send As" to compose messages as any contact | Edit even actor emails (syncs to actor)
    </div>
  </div>
  
</div>

{{!-- Additional Styles for Enhanced Features --}}
<style>
/* Toolbar rows */
.ncm-gm-contact-manager__toolbar-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.ncm-gm-contact-manager__toolbar-row:last-child {
  margin-bottom: 0;
}

/* Filter groups */
.ncm-gm-contact-manager__filter-group {
  display: flex;
  align-items: center;
  gap: 6px;
}

.ncm-gm-contact-manager__filter-group label {
  font-size: 0.85em;
  color: #999;
  white-space: nowrap;
}

/* Actor card indicator */
.ncm-gm-contact-card--actor {
  border-left: 3px solid #19f3f7;
}

/* Type badge */
.ncm-gm-contact-card__type-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #19f3f7;
}

/* Tags */
.ncm-gm-contact-card__tags {
  margin-top: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.ncm-tag {
  display: inline-block;
  padding: 2px 8px;
  background: rgba(246, 82, 97, 0.2);
  border: 1px solid rgba(246, 82, 97, 0.4);
  border-radius: 12px;
  font-size: 0.75em;
  color: #F65261;
}

/* Send As button emphasis */
.ncm-gm-contact-card__actions .ncm-btn--primary {
  background: linear-gradient(135deg, #F65261, #d94453);
  box-shadow: 0 0 10px rgba(246, 82, 97, 0.3);
}

.ncm-gm-contact-card__actions .ncm-btn--primary:hover {
  box-shadow: 0 0 15px rgba(246, 82, 97, 0.5);
  transform: translateY(-1px);
}

/* Button secondary style */
.ncm-btn--secondary {
  background: rgba(25, 243, 247, 0.1);
  border: 1px solid rgba(25, 243, 247, 0.3);
  color: #19f3f7;
}

.ncm-btn--secondary:hover {
  background: rgba(25, 243, 247, 0.2);
  border-color: #19f3f7;
}
</style>
