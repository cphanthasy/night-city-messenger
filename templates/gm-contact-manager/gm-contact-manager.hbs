{{!--
  GM Master Contact Directory — Phase 2 Redesign
  @file templates/gm-contact-manager/gm-contact-manager.hbs
  @module cyberpunkred-messenger
  @description Split-view GM interface: scrollable grouped contact list (left 280px)
    + detail/edit panel (right flex). Group-by selector with collapse/expand,
    pagination (10 per page), party trust + per-player relationships in detail,
    inline-styled chips, location field, custom role integration.

  Visual reference: ncm-gm-editor-mockup-v3.html
--}}

{{#if hasService}}
<div class="ncm-gm-contacts">

  {{!-- ═══════════════════════════════════════════
       GM CONTROL BAR — Red-tinted top bar
       ═══════════════════════════════════════════ --}}
  <div class="ncm-gm-bar">
    <span class="ncm-gm-bar__label">
      <i class="fas fa-shield-halved"></i> GM CONTROL
    </span>
    <div class="ncm-gm-bar__actions">
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
              data-action="importContactsJSON" title="Import contacts from JSON file">
        <i class="fas fa-download"></i> Import
      </button>

      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
              data-action="exportContacts" title="Export all contacts as JSON">
        <i class="fas fa-file-export"></i> Export
      </button>

      {{!-- Share All — with target selector --}}
      <select name="pushAllTargetActor" class="ncm-gm-bar__push-select">
        <option value="">Share all to...</option>
        <optgroup label="Players">
          {{#each shareTargetPlayers}}
            <option value="{{id}}">{{name}} (Player)</option>
          {{/each}}
        </optgroup>
        {{#if hasShareNPCs}}
        <optgroup label="NPCs">
          {{#each shareTargetNPCs}}
            <option value="{{id}}">{{name}}</option>
          {{/each}}
        </optgroup>
        {{/if}}
      </select>
      <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
              data-action="pushAllToPlayer" title="Share all filtered contacts to selected player">
        <i class="fas fa-arrow-up-from-bracket"></i> Share All
      </button>

      <button class="ncm-btn ncm-btn--primary ncm-btn--sm"
              data-action="createContact">
        <i class="fas fa-plus"></i> New
      </button>
    </div>
  </div>

  {{!-- ═══════════════════════════════════════════
       TOOLBAR — Search + Tag Filters
       ═══════════════════════════════════════════ --}}
  <div class="ncm-gm-toolbar">
    <div class="ncm-gm-search-row">
      <i class="fas fa-search"></i>
      <input type="text"
             class="ncm-gm-search-input"
             placeholder="Search name, email, org, tag..."
             value="{{searchQuery}}" />
      <span class="ncm-gm-search-count">{{filteredCount}} contacts</span>
    </div>

    {{!-- Filter pills --}}
    <div class="ncm-gm-filter-row">
      <button class="ncm-pill ncm-pill--all {{#unless hasActiveTagFilter}}ncm-pill--active{{/unless}}"
              data-action="clearTagFilters">ALL</button>

      {{#each tagPills}}
        <button class="ncm-pill ncm-pill--custom {{#if isActive}}ncm-pill--active{{/if}}"
                data-action="toggleTagFilter" data-tag="{{value}}">
          {{label}}
          {{#if isActive}}<i class="fas fa-times" style="font-size: 7px; margin-left: 2px;"></i>{{/if}}
        </button>
      {{/each}}

      <button class="ncm-pill ncm-pill--add" data-action="startAddTag"
              title="Create custom tag">
        <i class="fas fa-plus"></i>
      </button>
    </div>
  </div>

  {{!-- ═══════════════════════════════════════════
       SPLIT VIEW — List + Detail
       ═══════════════════════════════════════════ --}}
  <div class="ncm-gm-split">

    {{!-- ─── LEFT: Contact List ─── --}}
    <div class="ncm-gm-split__list">

      {{!-- Group-by selector bar --}}
      <div class="ncm-gm-group-bar">
        <span class="ncm-gm-group-bar__label">Group</span>
        <select class="ncm-gm-group-bar__select">
          <option value="none" {{#if (eq groupBy 'none')}}selected{{/if}}>None</option>
          <option value="organization" {{#if (eq groupBy 'organization')}}selected{{/if}}>Organization</option>
          <option value="role" {{#if (eq groupBy 'role')}}selected{{/if}}>Role</option>
          <option value="tag" {{#if (eq groupBy 'tag')}}selected{{/if}}>Tag</option>
          <option value="folders" {{#if (eq groupBy 'folders')}}selected{{/if}}>Folders</option>
        </select>
        {{#if isFolderMode}}
          <button class="ncm-gm-group-bar__btn ncm-gm-group-bar__btn--active"
                  data-action="createFolder" title="New folder">
            <i class="fas fa-folder-plus"></i>
          </button>
        {{/if}}
        <button class="ncm-gm-group-bar__btn" data-action="collapseAll" title="Collapse all">
          <i class="fas fa-compress-alt"></i>
        </button>
        <button class="ncm-gm-group-bar__btn" data-action="expandAll" title="Expand all">
          <i class="fas fa-expand-alt"></i>
        </button>
      </div>

      {{!-- Scrollable list --}}
      <div class="ncm-gm-list-scroll">
        {{#if groups.length}}
          {{#each groups}}
            {{!-- Group header --}}
            {{#if showHeader}}
              <div class="ncm-gm-group-header {{#if collapsed}}ncm-gm-group-header--collapsed{{/if}}"
                   data-action="toggleGroup" data-group-key="{{key}}">
                <i class="ncm-gm-group-header__chevron fas fa-chevron-down"></i>
                <i class="ncm-gm-group-header__icon fas {{icon}}"></i>
                <span class="ncm-gm-group-header__name">{{label}}</span>
                <span class="ncm-gm-group-header__count">{{totalInGroup}}</span>
                {{#if isFolder}}
                  <i class="ncm-gm-group-header__edit fas fa-pen-to-square"
                     data-action="renameFolder" data-folder="{{key}}" title="Rename folder"></i>
                {{/if}}
              </div>
            {{/if}}

            {{!-- Contact items within this group (hidden if collapsed) --}}
            {{#unless collapsed}}
              {{#each contacts}}
                <div class="ncm-gm-list-item {{#if isSelected}}ncm-gm-list-item--selected{{/if}} {{#if isBurned}}ncm-gm-list-item--burned{{/if}}"
                     data-contact-id="{{id}}" data-action="selectContact">
                  <div class="ncm-gm-list-item__avatar"
                       style="{{#if hasPortrait}}{{else}}color: {{avatarColor}};{{/if}} border-color: {{avatarBorderColor}};">
                    {{#if hasPortrait}}
                      <img src="{{portraitSrc}}" alt="{{initials}}">
                    {{else}}
                      {{initials}}
                    {{/if}}
                  </div>

                  <div class="ncm-gm-list-item__info">
                    <span class="ncm-gm-list-item__name {{#if isBurned}}ncm-gm-list-item__name--burned{{/if}}">
                      {{name}}
                    </span>
                    <span class="ncm-gm-list-item__detail">{{email}}</span>
                  </div>

                  {{#if roleChipStyle}}
                    <span class="ncm-gm-list-item__role" style="{{roleChipStyle}}">{{roleLabel}}</span>
                  {{/if}}
                </div>
              {{/each}}
            {{/unless}}
          {{/each}}
        {{else}}
          <div class="ncm-gm-empty">
            <i class="fas fa-address-book"></i>
            <span class="ncm-gm-empty__text">No contacts found</span>
            <span class="ncm-gm-empty__sub">
              {{#if hasActiveTagFilter}}Try clearing filters{{else}}Import actors or create a new contact{{/if}}
            </span>
          </div>
        {{/if}}
      </div>

      {{!-- Pagination --}}
      {{#if showPagination}}
        <div class="ncm-gm-pagination">
          <button class="ncm-gm-pagination__btn" data-action="prevPage"
                  {{#unless hasPrevPage}}disabled{{/unless}}>
            <i class="fas fa-chevron-left"></i>
          </button>
          <span class="ncm-gm-pagination__info">
            Page <strong>{{currentPage}}</strong> of <strong>{{totalPages}}</strong>
          </span>
          <button class="ncm-gm-pagination__btn" data-action="nextPage"
                  {{#unless hasNextPage}}disabled{{/unless}}>
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>
      {{/if}}
    </div>

    {{!-- ─── RIGHT: Detail / Form Panel ─── --}}
    <div class="ncm-gm-split__detail">

      {{!-- ═══ CREATE FORM ═══ --}}
      {{#if isCreating}}
        <div class="ncm-gm-detail ncm-gm-detail--form">
          <div class="ncm-gm-section" style="margin-top: 0;">
            <i class="fas fa-plus"></i> NEW CONTACT
          </div>
          {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-form.hbs"
              contact=null isCreating=true isGM=true availableActors=availableActors
              playerActors=playerActors roleOptions=roleOptions customRoles=customRoles
              existingFolders=existingFolders }}
        </div>

      {{!-- ═══ EDIT FORM ═══ --}}
      {{else if showForm}}
        <div class="ncm-gm-detail ncm-gm-detail--form">
          <div class="ncm-gm-section" style="margin-top: 0;">
            <i class="fas fa-pen"></i> EDIT — {{selectedContact.name}}
          </div>
          {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-form.hbs"
              contact=selectedContact isCreating=false isGM=true availableActors=availableActors
              playerActors=playerActors roleOptions=roleOptions customRoles=customRoles
              perPlayerRelationships=perPlayerRelationships existingFolders=existingFolders }}
        </div>

      {{!-- ═══ DETAIL VIEW ═══ --}}
      {{else if hasSelection}}
        <div class="ncm-gm-detail">

          {{!-- Detail Header: Avatar + Name + Chips --}}
          <div class="ncm-gm-detail__header">
            <div class="ncm-gm-detail__avatar"
                 style="border-color: {{selectedContact.avatarBorderColor}};">
              {{#if selectedContact.hasPortrait}}
                <img src="{{selectedContact.portraitSrc}}" alt="{{selectedContact.name}}">
              {{else}}
                <span style="color: {{selectedContact.avatarColor}};">{{selectedContact.initials}}</span>
              {{/if}}
              <div class="ncm-gm-detail__avatar-upload" data-action="uploadPortrait">
                <i class="fas fa-camera"></i>
                <span>Upload</span>
              </div>
            </div>

            <div class="ncm-gm-detail__info">
              <div class="ncm-gm-detail__name">{{selectedContact.name}}</div>
              {{#if selectedContact.alias}}
                <div class="ncm-gm-detail__subtitle">"{{selectedContact.alias}}"</div>
              {{/if}}

              {{!-- Inline-styled chips (role, org, location, tags) --}}
              <div class="ncm-gm-detail__chips">
                {{#each selectedContact.chips}}
                  <span class="ncm-chip" style="{{style}}">
                    {{#if icon}}<i class="fas fa-{{icon}}"></i> {{/if}}{{label}}
                  </span>
                {{/each}}

                {{#if selectedContact.isBurned}}
                  <span class="ncm-chip" style="color:#ff0033;border-color:rgba(255,0,51,0.35);background:rgba(255,0,51,0.08);">
                    <i class="fas fa-fire"></i> BURNED
                  </span>
                {{/if}}
              </div>

              {{#if selectedContact.actorId}}
                <div class="ncm-linked-badge">
                  <i class="fas fa-link"></i> LINKED: {{selectedContact.actorName}}
                  {{#if selectedContact.playerOwnerName}}
                    <span class="ncm-linked-badge__player">
                      <i class="fas fa-user"></i> {{selectedContact.playerOwnerName}}
                    </span>
                  {{/if}}
                </div>
              {{/if}}
            </div>
          </div>

          {{!-- ── Party Trust ── --}}
          <div class="ncm-gm-section">
            <i class="fas fa-shield-halved"></i> Party Trust
            <span class="ncm-gm-section__hint">(group-wide baseline)</span>
          </div>
          <div class="ncm-trust-row">
            <div class="ncm-trust-bar ncm-trust-bar--interactive" data-contact-id="{{selectedContact.id}}">
              {{#each selectedContact.trustSegmentsDetail}}
                <div class="ncm-trust-seg ncm-trust-seg--{{value}} {{#if active}}ncm-trust-seg--active{{/if}}"
                     data-action="setTrustLevel" data-trust-value="{{value}}" data-contact-id="{{../selectedContact.id}}"></div>
              {{/each}}
            </div>
            <div class="ncm-trust-label">{{selectedContact.trust}} — {{selectedContact.trustLabel}}</div>
          </div>

          {{!-- ── Contact Info Grid ── --}}
          <div class="ncm-gm-section"><i class="fas fa-address-card"></i> Contact Info</div>
          <div class="ncm-info-grid">
            <span class="ncm-info-label">Email</span>
            <span class="ncm-info-value ncm-info-value--mono">{{selectedContact.email}}</span>

            {{#if selectedContact.phone}}
              <span class="ncm-info-label">Phone</span>
              <span class="ncm-info-value ncm-info-value--mono" style="color: var(--ncm-accent, #f7c948);">{{selectedContact.phone}}</span>
            {{/if}}

            {{#if selectedContact.organization}}
              <span class="ncm-info-label">Org</span>
              <span class="ncm-info-value">{{selectedContact.organization}}</span>
            {{/if}}

            {{#if selectedContact.location}}
              <span class="ncm-info-label">Location</span>
              <span class="ncm-info-value">{{selectedContact.location}}</span>
            {{/if}}

            {{#if selectedContact.network}}
              <span class="ncm-info-label">Network</span>
              <span class="ncm-info-value ncm-info-value--mono">{{selectedContact.network}}</span>
            {{/if}}

            {{#if selectedContact.tags.length}}
              <span class="ncm-info-label">Tags</span>
              <span class="ncm-info-value">
                {{#each selectedContact.tags}}
                  <span class="ncm-tag-chip-inline">{{this}}</span>
                {{/each}}
              </span>
            {{/if}}
          </div>

          {{!-- ── Per-Player Relationships ── --}}
          {{#if selectedContact.playerRelationships.length}}
            <div class="ncm-gm-section">
              <i class="fas fa-users"></i> Player Relationships
              <span class="ncm-gm-section__hint">(per-player trust overrides party baseline)</span>
            </div>
            <div class="ncm-rel-grid">
              {{#each selectedContact.playerRelationships}}
                <div class="ncm-rel-row">
                  <div class="ncm-rel-row__avatar">{{initial}}</div>
                  <div class="ncm-rel-row__info">
                    <div class="ncm-rel-row__name">{{characterName}}</div>
                    <div class="ncm-rel-row__player">player: {{playerName}}</div>
                  </div>
                  {{#if relBadgeLabel}}
                    <span class="ncm-rel-badge" style="{{relBadgeStyle}}">
                      <i class="fas {{relIcon}}"></i> {{relBadgeLabel}}
                    </span>
                  {{/if}}
                  <div class="ncm-rel-trust-mini" title="Trust: {{displayTrust}}{{#if isOverride}} (OVERRIDE — party is {{partyTrust}}){{/if}}">
                    {{#each trustSegments}}
                      <div class="ncm-rel-trust-mini__seg {{#if active}}ncm-rel-trust-mini__seg--active s{{value}}{{/if}}"></div>
                    {{/each}}
                  </div>
                  {{#if isOverride}}
                    <span class="ncm-rel-trust-override" title="Trust differs from party baseline">OVR</span>
                  {{/if}}
                  <button class="ncm-rel-row__note-btn {{#if hasNote}}ncm-rel-row__note-btn--has-note{{/if}}"
                          title="{{#if hasNote}}View note{{else}}Add note{{/if}}"
                          data-action="toggleRelNote" data-actor-id="{{actorId}}">
                    <i class="fas fa-sticky-note"></i>
                  </button>
                </div>
                {{#if showNote}}
                  <div class="ncm-rel-note">{{note}}</div>
                {{/if}}
              {{/each}}
            </div>
          {{/if}}

          {{!-- ── GM Notes ── --}}
          <div class="ncm-gm-section"><i class="fas fa-eye-slash"></i> GM Notes</div>
          <textarea class="ncm-gm-notes__textarea"
                    placeholder="Private GM notes... (auto-saves on blur)"
                    rows="2">{{selectedContact.notes}}</textarea>
          <div class="ncm-gm-notes__hint">GM only — auto-saves on blur</div>

          {{!-- ── Share to Character ── --}}
          <div class="ncm-gm-section"><i class="fas fa-arrow-up-from-bracket"></i> Share</div>
          <div class="ncm-push-row">
            <select name="pushTargetActor" class="ncm-push-select">
              <option value="">Select character...</option>
              <optgroup label="Players">
                {{#each ../shareTargetPlayers}}
                  <option value="{{id}}">{{name}} (Player)</option>
                {{/each}}
              </optgroup>
              {{#if ../hasShareNPCs}}
              <optgroup label="NPCs">
                {{#each ../shareTargetNPCs}}
                  <option value="{{id}}">{{name}}</option>
                {{/each}}
              </optgroup>
              {{/if}}
            </select>
            <button class="ncm-btn ncm-btn--accent ncm-btn--sm"
                    data-action="pushToPlayer">
              <i class="fas fa-arrow-up-from-bracket"></i> Share
            </button>
            <label class="ncm-push-portrait-toggle" title="Include portrait">
              <input type="checkbox" name="pushIncludePortrait" checked>
              <i class="fas fa-image"></i>
            </label>
          </div>

          {{!-- ── Action Buttons ── --}}
          <div class="ncm-gm-detail__actions">
            <button class="ncm-btn ncm-btn--secondary" data-action="composeToContact">
              <i class="fas fa-envelope"></i> Message
            </button>
            <button class="ncm-btn ncm-btn--secondary" data-action="sendAsContact" title="Open composer as this contact">
              <i class="fas fa-paper-plane"></i> Send As
            </button>
            <button class="ncm-btn ncm-btn--ghost" data-action="openContactInbox" title="View this contact's virtual inbox">
              <i class="fas fa-inbox"></i> Inbox
            </button>
            <button class="ncm-btn ncm-btn--ghost" data-action="editContact">
              <i class="fas fa-pen"></i> Edit
            </button>
            <button class="ncm-btn ncm-btn--ghost" data-action="linkActor" title="Link or relink to Foundry actor">
              <i class="fas fa-link"></i> {{#if selectedContact.actorId}}Relink{{else}}Link Actor{{/if}}
            </button>
            {{#if selectedContact.actorId}}
              <button class="ncm-btn ncm-btn--ghost" data-action="unlinkActor" title="Remove actor link">
                <i class="fas fa-link-slash"></i> Unlink
              </button>
            {{/if}}

            {{#if selectedContact.isBurned}}
              <button class="ncm-btn ncm-btn--success ncm-btn--sm" data-action="restoreContact" title="Remove burned status">
                <i class="fas fa-heart-pulse"></i> Restore
              </button>
            {{else}}
              <button class="ncm-btn ncm-btn--ghost" data-action="burnContact"
                      style="color:#ff0033;border-color:rgba(255,0,51,0.3);" title="Mark contact as burned/compromised">
                <i class="fas fa-fire"></i> Burn
              </button>
            {{/if}}

            <button class="ncm-btn ncm-btn--ghost" data-action="deleteContact"
                    style="color:var(--ncm-primary,#F65261);border-color:rgba(246,82,97,0.3);">
              <i class="fas fa-trash"></i> Delete
            </button>
          </div>
        </div>

      {{!-- ═══ EMPTY STATE ═══ --}}
      {{else}}
        <div class="ncm-gm-detail ncm-gm-detail--empty">
          <i class="fas fa-user-shield"></i>
          <span class="ncm-gm-empty__text">Select a contact</span>
          <span class="ncm-gm-empty__sub">Or create a new one with <kbd>N</kbd></span>
        </div>
      {{/if}}

    </div>
  </div>

  {{!-- ═══════════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════════ --}}
  <div class="ncm-gm-footer">
    <div class="ncm-gm-footer__info">
      <span><i class="fas fa-shield-halved"></i> GM MODE</span>
      <span><i class="fas fa-address-book"></i> {{contactCount}} CONTACTS</span>
      <span><i class="fas fa-link"></i> {{linkedCount}} LINKED</span>
    </div>
    <div class="ncm-gm-footer__shortcuts">
      <kbd>/</kbd> SEARCH &nbsp;
      <kbd>↑↓</kbd> NAV &nbsp;
      <kbd>E</kbd> EDIT &nbsp;
      <kbd>N</kbd> NEW &nbsp;
      <kbd>DEL</kbd> REMOVE
    </div>
  </div>

</div>

{{else}}
  <div class="ncm-gm-contacts ncm-gm-contacts--error">
    <div class="ncm-gm-empty" style="padding: 60px 20px;">
      <i class="fas fa-triangle-exclamation" style="font-size: 36px; color: var(--ncm-primary, #F65261);"></i>
      <span class="ncm-gm-empty__text">Master Contact Service Unavailable</span>
      <span class="ncm-gm-empty__sub">Check console for initialization errors.</span>
    </div>
  </div>
{{/if}}
