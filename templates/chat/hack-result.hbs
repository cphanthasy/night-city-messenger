{{!-- Chat Card: Skill Check / Hack Result --}}
<div class="ncm-chat-card ncm-hack-result {{#if success}}ncm-success{{else}}ncm-failure{{/if}}">
  <div class="ncm-chat-header">
    {{#if actorImg}}<img src="{{actorImg}}" class="ncm-chat-avatar" alt="{{actorName}}" />{{/if}}
    <div class="ncm-chat-header-text">
      <span class="ncm-chat-actor">{{actorName}}</span>
      {{#if context}}<span class="ncm-chat-context">{{context}}</span>{{/if}}
    </div>
    <span class="ncm-chat-result-badge {{#if success}}ncm-badge-success{{else}}ncm-badge-fail{{/if}}">
      {{#if success}}SUCCESS{{else}}FAILED{{/if}}
    </span>
  </div>
  <div class="ncm-chat-body">
    <div class="ncm-chat-skill-name">{{skillName}}</div>
    <div class="ncm-chat-roll-breakdown">
      <span class="ncm-roll-component">{{statName}}: {{statValue}}</span>
      <span class="ncm-roll-component">Skill: {{skillLevel}}</span>
      <span class="ncm-roll-component ncm-roll-die {{#if isCritical}}ncm-crit{{/if}} {{#if isFumble}}ncm-fumble{{/if}}">
        1d10: {{rollValue}}{{#if isCritical}} → {{processedRoll}} ⚡{{/if}}{{#if isFumble}} → {{processedRoll}} 💀{{/if}}
      </span>
      {{#if luckSpent}}<span class="ncm-roll-component ncm-roll-luck">Luck: +{{luckSpent}}</span>{{/if}}
    </div>
    <div class="ncm-chat-total">
      <span class="ncm-total-label">Total:</span>
      <span class="ncm-total-value">{{total}}</span>
      <span class="ncm-total-vs">vs DV</span>
      <span class="ncm-total-dc">{{dc}}</span>
      {{#if success}}<span class="ncm-margin">(+{{margin}})</span>{{/if}}
    </div>
    {{#if isCritical}}<div class="ncm-chat-special ncm-crit-text">⚡ CRITICAL HIT — Exploding 10!</div>{{/if}}
    {{#if isFumble}}<div class="ncm-chat-special ncm-fumble-text">💀 FUMBLE — Subtractive 1!</div>{{/if}}
    {{#if flavor}}<div class="ncm-chat-flavor">{{flavor}}</div>{{/if}}
  </div>
</div>
