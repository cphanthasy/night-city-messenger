{{!-- Player Email Setup — Email Address Dialog --}}
{{!-- @file templates/dialogs/player-email-setup.hbs --}}
{{!-- @module cyberpunkred-messenger --}}

<div class="ncm-email-setup">
  {{!-- Header --}}
  <div class="ncm-email-setup-header">
    {{#if actorImg}}
    <img class="ncm-email-setup-avatar" src="{{actorImg}}" alt="" />
    {{/if}}
    <div class="ncm-email-setup-header-text">
      <h3>Set Up Net-Mail</h3>
      <p class="ncm-text-muted">Configure email address for <strong>{{actorName}}</strong></p>
    </div>
  </div>

  {{!-- Email Input --}}
  <div class="ncm-email-setup-body">
    <div class="ncm-form-row">
      <label>
        <i class="fas fa-at"></i> Email Address
      </label>
      <input type="text" name="email" value="{{emailValue}}"
             placeholder="handle@nightcity.net"
             class="ncm-input ncm-input--mono"
             autocomplete="off" spellcheck="false" />
    </div>

    {{!-- Error Message --}}
    {{#if errorMessage}}
    <div class="ncm-email-error">
      <i class="fas fa-exclamation-triangle"></i> {{errorMessage}}
    </div>
    {{/if}}

    {{!-- Suggestions --}}
    {{#if suggestions.length}}
    <div class="ncm-email-suggestions">
      <span class="ncm-suggestions-label">Suggestions:</span>
      {{#each suggestions}}
      <button class="ncm-suggestion-btn" data-action="useSuggestion" data-suggestion="{{this}}">
        {{this}}
      </button>
      {{/each}}
    </div>
    {{/if}}
  </div>

  {{!-- Footer --}}
  <div class="ncm-email-setup-footer">
    <button class="ncm-btn ncm-btn--ghost" data-action="cancel">Cancel</button>
    <button class="ncm-btn ncm-btn--primary" data-action="confirm">
      <i class="fas fa-check"></i> Set Email
    </button>
  </div>
</div>
