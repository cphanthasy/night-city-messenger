{{!-- 
  Network Editor Dialog - REFACTORED
  CHANGES: Removed Network Availability section
  Network Tab now only handles properties, Scene Tab handles availability
--}}

<form class="ncm-network-editor-form">
  
  {{!-- Basic Info --}}
  <section class="form-section">
    <h3><i class="fas fa-info-circle"></i> Basic Information</h3>
    
    <div class="form-group">
      <label for="network-id">Network ID *</label>
      <input 
        type="text" 
        id="network-id" 
        name="id" 
        value="{{network.id}}" 
        {{#if isEdit}}disabled{{/if}}
        required
        pattern="[A-Z0-9_]+"
        title="Uppercase letters, numbers, and underscores only">
      <small>Unique identifier (e.g., CITINET, CORPNET)</small>
    </div>
    
    <div class="form-group">
      <label for="network-name">Display Name *</label>
      <input 
        type="text" 
        id="network-name" 
        name="name" 
        value="{{network.name}}" 
        required>
      <small>User-friendly name shown in interfaces</small>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="network-type">Type</label>
        <select id="network-type" name="type">
          <option value="public" {{#if (eq network.type 'public')}}selected{{/if}}>Public</option>
          <option value="corporate" {{#if (eq network.type 'corporate')}}selected{{/if}}>Corporate</option>
          <option value="underground" {{#if (eq network.type 'underground')}}selected{{/if}}>Underground</option>
          <option value="custom" {{#if (eq network.type 'custom')}}selected{{/if}}>Custom</option>
          <option value="none" {{#if (eq network.type 'none')}}selected{{/if}}>None (Dead Zone)</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="network-reliability">Reliability (%)</label>
        <input 
          type="number" 
          id="network-reliability" 
          name="reliability" 
          value="{{network.reliability}}" 
          min="0" 
          max="100">
        <small>Chance of successful transmission</small>
      </div>
    </div>
    
    <div class="form-group">
      <label for="network-description">Description</label>
      <textarea 
        id="network-description" 
        name="description" 
        rows="3">{{network.description}}</textarea>
      <small>Visible to players</small>
    </div>
    
    <div class="form-group">
      <label for="network-gm-notes">GM Notes</label>
      <textarea 
        id="network-gm-notes" 
        name="gmNotes" 
        rows="2">{{network.gmNotes}}</textarea>
      <small>Only visible to GM</small>
    </div>
  </section>
  
  {{!-- Security --}}
  <section class="form-section">
    <h3><i class="fas fa-shield-alt"></i> Security</h3>
    
    <div class="form-row">
      <div class="form-group">
        <label for="security-level">Security Level</label>
        <select id="security-level" name="security.level">
          <option value="none" {{#if (eq network.security.level 'none')}}selected{{/if}}>None</option>
          <option value="low" {{#if (eq network.security.level 'low')}}selected{{/if}}>Low</option>
          <option value="medium" {{#if (eq network.security.level 'medium')}}selected{{/if}}>Medium</option>
          <option value="high" {{#if (eq network.security.level 'high')}}selected{{/if}}>High</option>
          <option value="black-ice" {{#if (eq network.security.level 'black-ice')}}selected{{/if}}>BLACK ICE</option>
        </select>
      </div>
      
      <div class="form-group">
        <label>
          <input type="checkbox" name="security.requiresAuth" {{#if network.security.requiresAuth}}checked{{/if}}>
          <span>Requires Authentication</span>
        </label>
      </div>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="security-password">Password</label>
        <input 
          type="text" 
          id="security-password" 
          name="security.password" 
          value="{{network.security.password}}"
          placeholder="Leave blank for no password">
        <small>Players must enter this to connect</small>
      </div>
      
      <div class="form-group">
        <label for="security-bypass-dc">Bypass DC</label>
        <input 
          type="number" 
          id="security-bypass-dc" 
          name="security.bypassDC" 
          value="{{network.security.bypassDC}}" 
          min="0">
        <small>Skill check DC to hack in</small>
      </div>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="security-attempts">Max Attempts</label>
        <input 
          type="number" 
          id="security-attempts" 
          name="security.attempts" 
          value="{{network.security.attempts}}" 
          min="0">
        <small>Failed attempts before lockout</small>
      </div>
      
      <div class="form-group">
        <label for="security-lockout">Lockout Duration (seconds)</label>
        <input 
          type="number" 
          id="security-lockout" 
          name="security.lockoutDuration" 
          value="{{network.security.lockoutDuration}}" 
          min="0">
        <small>How long lockout lasts</small>
      </div>
    </div>
  </section>
  
  {{!-- Effects --}}
  <section class="form-section">
    <h3><i class="fas fa-magic"></i> Network Effects</h3>
    
    <div class="form-row">
      <div class="form-group">
        <label for="effects-delay">Message Delay (ms)</label>
        <input 
          type="number" 
          id="effects-delay" 
          name="effects.messageDelay" 
          value="{{network.effects.messageDelay}}" 
          min="0" 
          step="100">
        <small>Artificial delay for messages</small>
      </div>
    </div>
    
    <div class="checkbox-group">
      <label>
        <input type="checkbox" name="effects.anonymity" {{#if network.effects.anonymity}}checked{{/if}}>
        <span><i class="fas fa-user-secret"></i> Anonymous Routing</span>
      </label>
      <label>
        <input type="checkbox" name="effects.canRoute" {{#if network.effects.canRoute}}checked{{/if}}>
        <span><i class="fas fa-random"></i> Can Route to Other Networks</span>
      </label>
      <label>
        <input type="checkbox" name="effects.traced" {{#if network.effects.traced}}checked{{/if}}>
        <span><i class="fas fa-route"></i> Connection Tracing</span>
      </label>
      <label>
        <input type="checkbox" name="effects.monitored" {{#if network.effects.monitored}}checked{{/if}}>
        <span><i class="fas fa-eye"></i> Monitored by NetWatch</span>
      </label>
    </div>
  </section>
  
  {{!-- REMOVED: Network Availability Section --}}
  {{!-- Availability is now managed in Scene Tab only --}}
  
  {{!-- Theme --}}
  <section class="form-section">
    <h3><i class="fas fa-palette"></i> Visual Theme</h3>
    
    <div class="form-row">
      <div class="form-group">
        <label for="theme-color">Primary Color</label>
        <div class="color-picker-group">
          <input 
            type="color" 
            name="theme.color" 
            id="theme-color" 
            value="{{network.theme.color}}">
          <span class="color-preview" style="background-color: {{network.theme.color}}"></span>
          <input 
            type="text" 
            value="{{network.theme.color}}" 
            readonly 
            class="color-hex">
        </div>
      </div>
      
      <div class="form-group">
        <label for="theme-icon">Icon Class</label>
        <input 
          type="text" 
          id="theme-icon" 
          name="theme.icon" 
          value="{{network.theme.icon}}"
          placeholder="fa-wifi">
        <small>FontAwesome icon class</small>
      </div>
    </div>
    
    <div class="form-group">
      <label for="theme-glitch">Glitch Intensity</label>
      <input 
        type="range" 
        id="theme-glitch" 
        name="theme.glitchIntensity" 
        value="{{network.theme.glitchIntensity}}" 
        min="0" 
        max="1" 
        step="0.1">
      <span class="range-value">{{network.theme.glitchIntensity}}</span>
    </div>
  </section>
  
  {{!-- Actions --}}
  <footer class="dialog-buttons">
    <button type="submit" class="ncm-btn ncm-btn--primary">
      <i class="fas fa-save"></i> 
      {{#if isEdit}}Update{{else}}Create{{/if}} Network
    </button>
    <button type="button" class="ncm-btn ncm-btn--secondary" data-action="cancel">
      <i class="fas fa-times"></i> Cancel
    </button>
  </footer>
  
</form>

<style>
.ncm-network-editor-form {
  padding: 1rem;
  max-height: 80vh;
  overflow-y: auto;
}

.form-section {
  margin-bottom: 2rem;
  padding: 1rem;
  background: var(--ncm-surface);
  border: 1px solid var(--ncm-border);
  border-radius: 4px;
}

.form-section h3 {
  margin: 0 0 1rem 0;
  color: var(--ncm-primary);
  font-size: 1rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.form-group {
  margin-bottom: 1rem;
}

.form-group label {
  display: block;
  margin-bottom: 0.5rem;
  font-weight: 600;
  font-size: 0.9rem;
}

.form-group input[type="text"],
.form-group input[type="number"],
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 0.5rem;
  background: var(--ncm-background);
  border: 1px solid var(--ncm-border);
  border-radius: 3px;
  color: var(--ncm-text);
  font-family: inherit;
}

.form-group small {
  display: block;
  margin-top: 0.25rem;
  font-size: 0.75rem;
  color: var(--ncm-text-secondary);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.checkbox-group label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
}

.checkbox-group label:hover {
  color: var(--ncm-primary);
}

.color-picker-group {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.color-picker-group input[type="color"] {
  width: 50px;
  height: 40px;
  border: none;
  cursor: pointer;
}

.color-preview {
  width: 40px;
  height: 40px;
  border-radius: 3px;
  border: 1px solid var(--ncm-border);
}

.color-hex {
  flex: 1;
  font-family: monospace;
}

input[type="range"] {
  flex: 1;
}

.range-value {
  margin-left: 0.5rem;
  font-weight: 600;
  color: var(--ncm-primary);
}

.dialog-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 0.5rem;
  padding: 1rem;
  border-top: 2px solid var(--ncm-border);
  background: var(--ncm-surface);
  position: sticky;
  bottom: 0;
}
</style>
