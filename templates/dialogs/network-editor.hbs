{{!-- Network Editor Dialog Template --}}
{{!-- File: templates/dialogs/network-editor.hbs --}}
{{!-- Description: Create and edit network definitions (availability managed in Scenes tab) --}}

<form class="ncm-network-editor-form">
  
  {{!-- Basic Information --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-info-circle"></i> Network Identity</h3>
      <p class="section-description">Define the core properties of this network</p>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="network-id">
          Network ID <span class="required">*</span>
          <span class="help-icon" title="Unique identifier, uppercase only">
            <i class="fas fa-question-circle"></i>
          </span>
        </label>
        <input 
          type="text" 
          name="id" 
          id="network-id" 
          value="{{network.id}}" 
          {{#if (eq mode 'edit')}}readonly{{/if}}
          placeholder="CORP_NET_ALPHA"
          pattern="[A-Z0-9_]+"
          required
          autocomplete="off">
        <small class="field-hint">UPPERCASE, numbers, underscores only</small>
        <span class="field-error" data-field="id"></span>
      </div>
      
      <div class="form-group">
        <label for="network-type">Network Type</label>
        <select name="type" id="network-type">
          {{#each networkTypes}}
            <option value="{{this.value}}" {{#if (eq this.value ../network.type)}}selected{{/if}}>
              {{this.label}}
            </option>
          {{/each}}
        </select>
        <small class="field-hint">Used for filtering and organization</small>
      </div>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="network-name">
          Display Name <span class="required">*</span>
        </label>
        <input 
          type="text" 
          name="name" 
          id="network-name" 
          value="{{network.name}}" 
          placeholder="Arasaka Corporate Grid"
          required>
        <small class="field-hint">Human-readable name shown to users</small>
        <span class="field-error" data-field="name"></span>
      </div>
      
      <div class="form-group">
        <label for="network-enabled">
          <i class="fas fa-power-off"></i> Network Status
        </label>
        <div class="toggle-switch">
          <input 
            type="checkbox" 
            name="enabled" 
            id="network-enabled" 
            {{#if network.enabled}}checked{{/if}}>
          <label for="network-enabled">
            <span class="toggle-slider"></span>
            <span class="toggle-label">{{#if network.enabled}}Enabled{{else}}Disabled{{/if}}</span>
          </label>
        </div>
        <small class="field-hint">Disabled networks don't appear in selectors</small>
      </div>
    </div>
    
    <div class="form-group">
      <label for="network-description">
        Description
        <span class="char-count" data-target="network-description">0/500</span>
      </label>
      <textarea 
        name="description" 
        id="network-description" 
        rows="3"
        maxlength="500"
        placeholder="Describe what this network represents in your world...">{{network.description}}</textarea>
      <small class="field-hint">What players see when examining the network</small>
    </div>
  </section>
  
  {{!-- Visual Theme --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-palette"></i> Visual Theme</h3>
      <p class="section-description">Customize how this network appears</p>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="theme-color">Primary Color</label>
        <div class="color-picker-group">
          <input 
            type="color" 
            name="theme.color" 
            id="theme-color" 
            value="{{network.theme.color}}">
          <div class="color-preview" style="background-color: {{network.theme.color}}">
            <i class="{{network.theme.icon}}"></i>
          </div>
          <input 
            type="text" 
            name="theme.colorHex"
            value="{{network.theme.color}}" 
            class="color-hex"
            pattern="#[0-9A-Fa-f]{6}">
          <button type="button" class="color-preset-btn" data-color="#F65261" title="Cyberpunk Red">
            <span style="background: #F65261"></span>
          </button>
          <button type="button" class="color-preset-btn" data-color="#19f3f7" title="Neon Cyan">
            <span style="background: #19f3f7"></span>
          </button>
          <button type="button" class="color-preset-btn" data-color="#FFD700" title="Corporate Gold">
            <span style="background: #FFD700"></span>
          </button>
          <button type="button" class="color-preset-btn" data-color="#9400D3" title="Darknet Purple">
            <span style="background: #9400D3"></span>
          </button>
        </div>
      </div>
      
      <div class="form-group">
        <label for="theme-icon">Icon</label>
        <div class="icon-picker-group">
          <div class="icon-preview" style="color: {{network.theme.color}}">
            <i class="{{network.theme.icon}}"></i>
          </div>
          <input 
            type="text" 
            name="theme.icon" 
            id="theme-icon" 
            value="{{network.theme.icon}}" 
            placeholder="fa-network-wired"
            readonly>
          <button type="button" class="icon-picker-btn">
            <i class="fas fa-icons"></i> Choose
          </button>
        </div>
        <small class="field-hint">FontAwesome class name</small>
      </div>
    </div>
  </section>
  
  {{!-- Performance & Reliability --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-signal"></i> Performance</h3>
      <p class="section-description">Define network quality and reliability</p>
    </div>
    
    <div class="form-row">
      <div class="form-group">
        <label for="reliability">
          Reliability
          <span class="value-display">{{network.reliability}}%</span>
        </label>
        <div class="slider-container">
          <input 
            type="range" 
            name="reliability" 
            id="reliability" 
            min="0" 
            max="100" 
            value="{{network.reliability}}"
            class="ncm-slider">
          <div class="slider-labels">
            <span>0%</span>
            <span>50%</span>
            <span>100%</span>
          </div>
        </div>
        <small class="field-hint">Chance of successful transmission (messages may fail)</small>
      </div>
      
      <div class="form-group">
        <label for="signalStrength">
          Default Signal Strength
          <span class="value-display">{{network.signalStrength}}%</span>
        </label>
        <div class="slider-container">
          <input 
            type="range" 
            name="signalStrength" 
            id="signalStrength" 
            min="0" 
            max="100" 
            value="{{network.signalStrength}}"
            class="ncm-slider">
          <div class="slider-labels">
            <span>Dead</span>
            <span>Weak</span>
            <span>Strong</span>
          </div>
        </div>
        <small class="field-hint">Default signal when enabled in scenes (can be overridden per scene)</small>
      </div>
    </div>
  </section>
  
  {{!-- Security Settings --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-shield-alt"></i> Security Configuration</h3>
      <p class="section-description">Define authentication and protection measures</p>
    </div>
    
    <div class="security-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="requiresAuth" {{#if network.requiresAuth}}checked{{/if}}>
        <span class="checkbox-custom"></span>
        <strong><i class="fas fa-lock"></i> Requires Authentication</strong>
      </label>
      <small>Players must provide credentials or hack to access</small>
    </div>
    
    <div class="security-settings {{#unless network.requiresAuth}}collapsed{{/unless}}">
      <div class="form-row">
        <div class="form-group">
          <label for="security-level">Security Level</label>
          <select name="security.level" id="security-level">
            {{#each securityLevels}}
              <option value="{{this.value}}" {{#if (eq this.value ../network.security.level)}}selected{{/if}}>
                {{this.label}} (DC {{this.dc}})
              </option>
            {{/each}}
          </select>
        </div>
        
        <div class="form-group">
          <label for="security-password">
            Password (Optional)
            <button type="button" class="toggle-password" tabindex="-1">
              <i class="fas fa-eye"></i>
            </button>
          </label>
          <input 
            type="password" 
            name="security.password" 
            id="security-password" 
            value="{{network.security.password}}"
            placeholder="Leave empty for hack-only"
            autocomplete="new-password">
          <small class="field-hint">If set, players can enter password instead of hacking</small>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="security-dc">Breach DC (Override)</label>
          <input 
            type="number" 
            name="security.breachDC" 
            id="security-dc" 
            value="{{network.security.breachDC}}"
            min="1"
            max="30"
            placeholder="Auto (based on level)">
          <small class="field-hint">Leave empty to use security level default</small>
        </div>
        
        <div class="form-group">
          <label for="security-ice-damage">ICE Damage Roll</label>
          <input 
            type="text" 
            name="security.iceDamage" 
            id="security-ice-damage" 
            value="{{network.security.iceDamage}}"
            placeholder="2d6"
            pattern="[0-9]+d[0-9]+">
          <small class="field-hint">Damage on failed breach attempt (e.g., 2d6)</small>
        </div>
      </div>
      
      <div class="danger-zone">
        <label class="checkbox-label">
          <input type="checkbox" name="security.hasBlackICE" {{#if network.security.hasBlackICE}}checked{{/if}}>
          <span class="checkbox-custom danger"></span>
          <strong><i class="fas fa-skull-crossbones"></i> BLACK ICE Installed</strong>
        </label>
        <small class="danger-text">Critical failure on breach attempt triggers lethal countermeasures</small>
      </div>
    </div>
  </section>
  
  {{!-- Network Effects --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-magic"></i> Special Effects</h3>
      <p class="section-description">Unique behaviors and characteristics</p>
    </div>
    
    <div class="effects-grid">
      <label class="effect-card">
        <input type="checkbox" name="effects.anonymous" {{#if network.effects.anonymous}}checked{{/if}}>
        <div class="effect-content">
          <div class="effect-icon" style="color: #9400D3;">
            <i class="fas fa-user-secret"></i>
          </div>
          <div class="effect-details">
            <strong>Anonymous Routing</strong>
            <small>Sender identity is masked</small>
          </div>
        </div>
      </label>
      
      <label class="effect-card">
        <input type="checkbox" name="effects.encrypted" {{#if network.effects.encrypted}}checked{{/if}}>
        <div class="effect-content">
          <div class="effect-icon" style="color: #19f3f7;">
            <i class="fas fa-lock"></i>
          </div>
          <div class="effect-details">
            <strong>Auto-Encryption</strong>
            <small>All messages encrypted by default</small>
          </div>
        </div>
      </label>
      
      <label class="effect-card">
        <input type="checkbox" name="effects.traced" {{#if network.effects.traced}}checked{{/if}}>
        <div class="effect-content">
          <div class="effect-icon" style="color: #FFD700;">
            <i class="fas fa-route"></i>
          </div>
          <div class="effect-details">
            <strong>Connection Tracing</strong>
            <small>Activity is logged and monitored</small>
          </div>
        </div>
      </label>
      
      <label class="effect-card">
        <input type="checkbox" name="effects.monitored" {{#if network.effects.monitored}}checked{{/if}}>
        <div class="effect-content">
          <div class="effect-icon" style="color: #F65261;">
            <i class="fas fa-eye"></i>
          </div>
          <div class="effect-details">
            <strong>NetWatch Monitoring</strong>
            <small>Suspicious activity alerts authorities</small>
          </div>
        </div>
      </label>
    </div>
    
    <div class="form-group">
      <label for="effects-messageDelay">
        Message Delay
        <span class="value-display">{{network.effects.messageDelay}} seconds</span>
      </label>
      <div class="slider-container">
        <input 
          type="range" 
          name="effects.messageDelay" 
          id="effects-messageDelay" 
          min="0" 
          max="30" 
          value="{{network.effects.messageDelay}}"
          class="ncm-slider">
        <div class="slider-labels">
          <span>Instant</span>
          <span>15s</span>
          <span>30s</span>
        </div>
      </div>
      <small class="field-hint">Artificial delay before messages are delivered</small>
    </div>
  </section>
  
  {{!-- GM Notes --}}
  <section class="form-section">
    <div class="section-header">
      <h3><i class="fas fa-user-secret"></i> GM Notes</h3>
      <p class="section-description">Private notes visible only to Game Master</p>
    </div>
    
    <div class="form-group">
      <textarea 
        name="gmNotes" 
        id="gm-notes" 
        rows="4"
        placeholder="Secret network details, plot hooks, security overrides...">{{network.gmNotes}}</textarea>
      <small class="field-hint">
        <i class="fas fa-lock"></i> These notes are never shown to players
      </small>
    </div>
  </section>
  
  {{!-- Form Actions --}}
  <div class="form-actions">
    <div class="actions-left">
      <button type="button" class="ncm-btn ncm-btn-secondary preview-network-btn">
        <i class="fas fa-eye"></i> Preview
      </button>
      {{#if (eq mode 'edit')}}
        <button type="button" class="ncm-btn ncm-btn-secondary duplicate-network-btn">
          <i class="fas fa-copy"></i> Duplicate
        </button>
        <button type="button" class="ncm-btn ncm-btn-danger delete-network-btn">
          <i class="fas fa-trash"></i> Delete
        </button>
      {{/if}}
    </div>
    
    <div class="actions-right">
      <button type="button" class="ncm-btn cancel-network-btn">
        <i class="fas fa-times"></i> Cancel
      </button>
      <button type="button" class="ncm-btn ncm-btn-primary save-network-btn">
        <i class="fas fa-save"></i> {{#if (eq mode 'edit')}}Update{{else}}Create{{/if}} Network
      </button>
    </div>
  </div>
  
  {{!-- Availability Notice --}}
  <div class="info-banner">
    <i class="fas fa-info-circle"></i>
    <div>
      <strong>Scene Availability:</strong>
      Configure which scenes have access to this network in the <strong>Scenes Tab</strong>.
      By default, new networks are <em>not enabled</em> in any scenes until you configure them.
    </div>
  </div>
</form>
