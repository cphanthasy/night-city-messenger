{{!-- Re-Lock Options Dialog --}}
{{!-- File: templates/dialogs/relock-options.hbs --}}

<form class="ncm-relock-form" style="font-family: 'Rajdhani', sans-serif;">
  
  <div style="background: rgba(246, 82, 97, 0.1); border: 1px solid var(--ncm-primary); padding: 12px; border-radius: 4px; margin-bottom: 15px;">
    <p style="margin: 0; color: var(--ncm-primary); font-weight: bold;">
      <i class="fas fa-exclamation-triangle"></i> Re-Lock Security Layers
    </p>
    <p style="margin: 5px 0 0 0; font-size: 0.9em; color: rgba(255, 255, 255, 0.8);">
      Select which security layers to reset for <strong>{{itemName}}</strong>
    </p>
  </div>
  
  <div class="ncm-form-group" style="margin: 0;">
    
    {{!-- ENCRYPTION LAYER --}}
    {{#if hasEncryption}}
      <label class="ncm-checkbox-label" style="display: flex; align-items: center; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; margin-bottom: 8px; cursor: pointer;">
        <input type="checkbox" name="reset-encryption" checked style="margin-right: 12px; width: 18px; height: 18px; cursor: pointer;">
        <div style="flex: 1;">
          <div style="font-weight: bold; color: var(--ncm-primary); margin-bottom: 3px;">
            <i class="fas fa-lock"></i> Reset Encryption
          </div>
          <div style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">
            Re-lock the data shard - players must hack it again
          </div>
        </div>
      </label>
    {{/if}}
    
    {{!-- NETWORK LAYER --}}
    {{#if hasNetworkReq}}
      <label class="ncm-checkbox-label" style="display: flex; align-items: center; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; margin-bottom: 8px; cursor: pointer;">
        <input type="checkbox" name="reset-network" checked style="margin-right: 12px; width: 18px; height: 18px; cursor: pointer;">
        <div style="flex: 1;">
          <div style="font-weight: bold; color: var(--ncm-secondary); margin-bottom: 3px;">
            <i class="fas fa-network-wired"></i> Clear Network Override
          </div>
          <div style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">
            Remove network breach - require {{requiredNetwork}} again
          </div>
        </div>
      </label>
    {{/if}}
    
    {{!-- LOGIN LAYER --}}
    {{#if hasLogin}}
      <label class="ncm-checkbox-label" style="display: flex; align-items: center; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; margin-bottom: 8px; cursor: pointer;">
        <input type="checkbox" name="reset-login" checked style="margin-right: 12px; width: 18px; height: 18px; cursor: pointer;">
        <div style="flex: 1;">
          <div style="font-weight: bold; color: var(--ncm-secondary); margin-bottom: 3px;">
            <i class="fas fa-user-lock"></i> Clear Login Session
          </div>
          <div style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">
            Log out - players must authenticate again
          </div>
        </div>
      </label>
    {{/if}}
    
    {{!-- DIVIDER --}}
    {{#if hasEncryption}}
      <div style="margin: 15px 0; border-top: 1px solid rgba(255, 255, 255, 0.1);"></div>
    {{/if}}
    
    {{!-- ATTEMPTS --}}
    <label class="ncm-checkbox-label" style="display: flex; align-items: center; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; margin-bottom: 8px; cursor: pointer;">
      <input type="checkbox" name="reset-attempts" checked style="margin-right: 12px; width: 18px; height: 18px; cursor: pointer;">
      <div style="flex: 1;">
        <div style="font-weight: bold; color: #FFD700; margin-bottom: 3px;">
          <i class="fas fa-redo"></i> Reset All Hack Attempts
        </div>
        <div style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">
          Reset both encryption and login attempt counters to 0
        </div>
      </div>
    </label>
    
    {{!-- LOCKOUTS --}}
    <label class="ncm-checkbox-label" style="display: flex; align-items: center; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; margin-bottom: 8px; cursor: pointer;">
      <input type="checkbox" name="reset-lockouts" checked style="margin-right: 12px; width: 18px; height: 18px; cursor: pointer;">
      <div style="flex: 1;">
        <div style="font-weight: bold; color: #FFD700; margin-bottom: 3px;">
          <i class="fas fa-clock"></i> Clear Lockout Timers
        </div>
        <div style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">
          Remove any active lockouts from failed attempts
        </div>
      </div>
    </label>
    
  </div>
  
  {{!-- HELP TEXT --}}
  <div style="background: rgba(25, 243, 247, 0.1); border: 1px