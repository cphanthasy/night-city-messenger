{{!-- Scene Network Configuration Dialog Template --}}
<div class="ncm-scene-config-dialog">
  
  {{!-- Scene/Network Info --}}
  <div class="ncm-scene-config-dialog__info">
    <div class="ncm-info-card">
      <div class="ncm-info-card__row">
        <span class="ncm-info-card__label">
          <i class="fas fa-map-marker-alt"></i> Scene:
        </span>
        <span class="ncm-info-card__value">{{scene.name}}</span>
      </div>
      <div class="ncm-info-card__row">
        <span class="ncm-info-card__label">
          <i class="{{network.theme.icon}}" style="color: {{network.theme.color}}"></i> Network:
        </span>
        <span class="ncm-info-card__value">{{network.name}}</span>
      </div>
    </div>
  </div>
  
  {{!-- Preset Selector --}}
  <div class="ncm-form-group">
    <label class="ncm-label">
      <i class="fas fa-magic"></i> Quick Presets
    </label>
    <select class="ncm-select" data-action="load-preset">
      <option value="">-- Select a preset --</option>
      <option value="combat-zone">Combat Zone (High Security, Monitored)</option>
      <option value="corporate-hq">Corporate HQ (Extreme Security)</option>
      <option value="dead-zone">Dead Zone (No Signal)</option>
      <option value="public-area">Public Area (Low Security)</option>
    </select>
    <p class="ncm-hint">
      <i class="fas fa-info-circle"></i> Presets provide common configurations for different scene types
    </p>
  </div>
  
  <div class="ncm-divider"></div>
  
  {{!-- Security Overrides --}}
  <div class="ncm-override-section">
    <div class="ncm-override-section__header">
      <label class="ncm-checkbox">
        <input type="checkbox" 
               name="override-security" 
               data-toggle-override="security"
               {{#if formData.security.enabled}}checked{{/if}}>
        <span class="ncm-checkbox__label">
          <i class="fas fa-shield-alt"></i> Override Security Settings
        </span>
      </label>
    </div>
    
    <div class="ncm-override-section__body">
      <div class="ncm-form-row">
        <div class="ncm-form-group">
          <label class="ncm-label">Security Level</label>
          <select class="ncm-select" 
                  name="security-level" 
                  data-override-section="security">
            {{#each securityLevels}}
              <option value="{{this}}" {{#if (eq this ../formData.security.level)}}selected{{/if}}>
                {{this}}
              </option>
            {{/each}}
          </select>
        </div>
        
        <div class="ncm-form-group">
          <label class="ncm-label">Breach DC</label>
          <input type="number" 
                 class="ncm-input" 
                 name="breach-dc" 
                 min="1" 
                 max="30" 
                 value="{{formData.security.breachDC}}"
                 data-override-section="security">
          <p class="ncm-hint">Difficulty Class for breach attempts (1-30)</p>
        </div>
      </div>
      
      <div class="ncm-form-group">
        <label class="ncm-label">ICE Damage Formula</label>
        <input type="text" 
               class="ncm-input" 
               name="ice-damage" 
               value="{{formData.security.iceDamage}}"
               placeholder="e.g., 3d6, 5d6+10"
               data-override-section="security">
        <p class="ncm-hint">Damage dice for ICE attacks (e.g., 3d6)</p>
      </div>
    </div>
  </div>
  
  <div class="ncm-divider"></div>
  
  {{!-- Reliability Override --}}
  <div class="ncm-override-section">
    <div class="ncm-override-section__header">
      <label class="ncm-checkbox">
        <input type="checkbox" 
               name="override-reliability" 
               data-toggle-override="reliability"
               {{#if formData.reliability.enabled}}checked{{/if}}>
        <span class="ncm-checkbox__label">
          <i class="fas fa-signal"></i> Override Reliability
        </span>
      </label>
    </div>
    
    <div class="ncm-override-section__body">
      <div class="ncm-form-group">
        <label class="ncm-label">Reliability (%)</label>
        <div class="ncm-input-with-slider">
          <input type="range" 
                 class="ncm-range" 
                 name="reliability-value" 
                 min="0" 
                 max="100" 
                 step="5" 
                 value="{{formData.reliability.value}}"
                 data-override-section="reliability">
          <input type="number" 
                 class="ncm-input ncm-input--sm" 
                 name="reliability-value" 
                 min="0" 
                 max="100" 
                 value="{{formData.reliability.value}}"
                 data-override-section="reliability">
        </div>
        <p class="ncm-hint">Chance of successful connection/transmission (0-100%)</p>
      </div>
    </div>
  </div>
  
  <div class="ncm-divider"></div>
  
  {{!-- Feature Overrides --}}
  <div class="ncm-override-section">
    <div class="ncm-override-section__header">
      <h4 class="ncm-section-title">
        <i class="fas fa-cog"></i> Network Feature Overrides
      </h4>
      <p class="ncm-hint">Override specific network features for this scene</p>
    </div>
    
    <div class="ncm-override-section__body">
      
      {{!-- Encrypted --}}
      <div class="ncm-feature-override">
        <label class="ncm-checkbox">
          <input type="checkbox" 
                 name="override-encrypted" 
                 data-toggle-override="encrypted"
                 {{#if formData.features.encrypted.enabled}}checked{{/if}}>
          <span class="ncm-checkbox__label">
            <i class="fas fa-lock"></i> Override Encryption
          </span>
        </label>
        <div class="ncm-feature-override__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   name="encrypted-value" 
                   data-override-section="encrypted"
                   {{#if formData.features.encrypted.value}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
          <span class="ncm-feature-override__status">
            {{#if formData.features.encrypted.value}}Enabled{{else}}Disabled{{/if}}
          </span>
        </div>
      </div>
      
      {{!-- Monitored --}}
      <div class="ncm-feature-override">
        <label class="ncm-checkbox">
          <input type="checkbox" 
                 name="override-monitored" 
                 data-toggle-override="monitored"
                 {{#if formData.features.monitored.enabled}}checked{{/if}}>
          <span class="ncm-checkbox__label">
            <i class="fas fa-video"></i> Override Monitoring
          </span>
        </label>
        <div class="ncm-feature-override__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   name="monitored-value" 
                   data-override-section="monitored"
                   {{#if formData.features.monitored.value}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
          <span class="ncm-feature-override__status">
            {{#if formData.features.monitored.value}}Monitored{{else}}Not Monitored{{/if}}
          </span>
        </div>
      </div>
      
      {{!-- Anonymized --}}
      <div class="ncm-feature-override">
        <label class="ncm-checkbox">
          <input type="checkbox" 
                 name="override-anonymized" 
                 data-toggle-override="anonymized"
                 {{#if formData.features.anonymized.enabled}}checked{{/if}}>
          <span class="ncm-checkbox__label">
            <i class="fas fa-user-secret"></i> Override Anonymization
          </span>
        </label>
        <div class="ncm-feature-override__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   name="anonymized-value" 
                   data-override-section="anonymized"
                   {{#if formData.features.anonymized.value}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
          <span class="ncm-feature-override__status">
            {{#if formData.features.anonymized.value}}Anonymous{{else}}Not Anonymous{{/if}}
          </span>
        </div>
      </div>
      
      {{!-- Traced --}}
      <div class="ncm-feature-override">
        <label class="ncm-checkbox">
          <input type="checkbox" 
                 name="override-traced" 
                 data-toggle-override="traced"
                 {{#if formData.features.traced.enabled}}checked{{/if}}>
          <span class="ncm-checkbox__label">
            <i class="fas fa-route"></i> Override Connection Tracing
          </span>
        </label>
        <div class="ncm-feature-override__control">
          <label class="ncm-toggle">
            <input type="checkbox" 
                   name="traced-value" 
                   data-override-section="traced"
                   {{#if formData.features.traced.value}}checked{{/if}}>
            <span class="ncm-toggle__slider"></span>
          </label>
          <span class="ncm-feature-override__status">
            {{#if formData.features.traced.value}}Traced{{else}}Not Traced{{/if}}
          </span>
        </div>
      </div>
      
    </div>
  </div>
  
  <div class="ncm-divider"></div>
  
  {{!-- Preview --}}
  <div class="ncm-form-group">
    <button class="ncm-btn ncm-btn--secondary ncm-btn--block" data-action="preview-overrides">
      <i class="fas fa-eye"></i> Preview Override Configuration
    </button>
    <p class="ncm-hint">Sends a whispered chat message showing the override settings</p>
  </div>
  
</div>
