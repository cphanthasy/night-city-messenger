{{!--
  Create Network Dialog
  File: templates/dialogs/create-network.hbs
  Module: cyberpunkred-messenger

  Quick-create dialog with template presets and condensed form.
  3 sections: Identity, Configuration, Appearance.
  Two save modes: Create & Close, Create & Open in Manager.
--}}

<div class="ncm-create-net">

  {{!-- ═══ Template Presets ═══ --}}
  <div class="ncm-create-net__presets-section">
    <div class="ncm-create-net__presets-label">Quick Templates</div>
    <div class="ncm-create-net__presets">
      {{#each presets}}
      <div class="ncm-create-net__preset {{#if isActive}}ncm-create-net__preset--active{{/if}}"
           data-action="selectPreset"
           data-preset="{{key}}">
        <i class="fas {{icon}}" style="color: {{color}};"></i>
        {{label}}
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- ═══ Identity Section ═══ --}}
  <div class="ncm-create-net__section">
    <div class="ncm-create-net__section-title">
      <i class="fas fa-id-card"></i> Identity
    </div>
    <div class="ncm-create-net__section-body">
      <div class="ncm-create-net__row">
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Network Name</label>
          <input class="ncm-create-net__input" type="text" name="name"
                 value="{{data.name}}"
                 placeholder="e.g. Militech Staging">
        </div>
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Type</label>
          <select class="ncm-create-net__select" name="type">
            {{#each typeOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
      <div class="ncm-create-net__field">
        <label class="ncm-create-net__label">Description</label>
        <input class="ncm-create-net__input" type="text" name="description"
               value="{{data.description}}"
               placeholder="In-world flavor text shown to players...">
        <div class="ncm-create-net__hint">Visible to players when they inspect the network.</div>
      </div>
    </div>
  </div>

  {{!-- ═══ Configuration Section ═══ --}}
  <div class="ncm-create-net__section">
    <div class="ncm-create-net__section-title">
      <i class="fas fa-sliders-h"></i> Configuration
    </div>
    <div class="ncm-create-net__section-body">

      {{!-- Signal / Reliability / Delay --}}
      <div class="ncm-create-net__row ncm-create-net__row--3">
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Signal %</label>
          <input class="ncm-create-net__input" type="number" name="signalStrength"
                 value="{{data.signalStrength}}" min="0" max="100">
        </div>
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Reliability %</label>
          <input class="ncm-create-net__input" type="number" name="reliability"
                 value="{{data.reliability}}" min="0" max="100">
        </div>
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Delay (ms)</label>
          <input class="ncm-create-net__input" type="number" name="messageDelay"
                 value="{{data.messageDelay}}" min="0">
        </div>
      </div>
      <div class="ncm-create-net__hint">Signal affects data shard DV modifiers. Reliability determines message delivery chance. Delay adds latency.</div>

      {{!-- ─── Auth Type ─── --}}
      <div class="ncm-create-net__subsection-label"><i class="fas fa-lock"></i> Authentication</div>
      <div class="ncm-create-net__row">
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Auth Type</label>
          <select class="ncm-create-net__select" name="authType">
            {{#each authTypeOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <div class="ncm-create-net__hint">
            {{#if showPassword}}Players must enter the correct password to connect.{{/if}}
            {{#if showBypassDC}}Players must pass a skill check to breach network security.{{/if}}
            {{#unless showPassword}}{{#unless showBypassDC}}No authentication required — anyone can connect.{{/unless}}{{/unless}}
          </div>
        </div>

        {{#if showPassword}}
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Password</label>
          <input class="ncm-create-net__input" type="text" name="password"
                 value="{{data.security.password}}"
                 placeholder="Network password...">
        </div>
        {{/if}}

        {{#if showBypassDC}}
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Bypass DV</label>
          <input class="ncm-create-net__input" type="number" name="bypassDC"
                 value="{{data.security.bypassDC}}" min="1" max="30">
          <div class="ncm-create-net__hint">Difficulty value for the skill check.</div>
        </div>
        {{/if}}
      </div>

      {{!-- ─── ICE Configuration ─── --}}
      {{#if showICE}}
        <div class="ncm-create-net__subsection-label"><i class="fas fa-shield-halved"></i> ICE Protection</div>
        <div class="ncm-create-net__hint">Intrusion Countermeasures Electronics — determines what happens when a breach attempt fails.</div>
        <div class="ncm-create-net__row">
          <div class="ncm-create-net__field">
            <label class="ncm-create-net__label">ICE Type</label>
            <select class="ncm-create-net__select" name="encryptionType">
              {{#each iceTypeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <div class="ncm-create-net__hint">
              {{#if isLethalICE}}Lethal ICE — failed breaches deal direct HP damage to the hacker.{{else}}Standard ICE — no damage on failure.{{/if}}
            </div>
          </div>
          <div class="ncm-create-net__field">
            <label class="ncm-create-net__label">On Failure</label>
            <select class="ncm-create-net__select" name="failureMode">
              {{#each failureModeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        {{#if isLethalICE}}
          <div class="ncm-create-net__ice-section">
            <label class="ncm-create-net__label">ICE Source</label>
            <div class="ncm-create-net__hint">Where the ICE's combat stats come from.</div>
            <div class="ncm-create-net__ice-cards">
              <div class="ncm-create-net__ice-card {{#if iceSourceDefault}}ncm-create-net__ice-card--sel{{/if}}" data-ice-mode="default">
                <i class="fas fa-dice"></i>
                <div class="ncm-create-net__ice-card-info">
                  <span class="ncm-create-net__ice-card-title">Default</span>
                  <span class="ncm-create-net__ice-card-desc">Generic dice formula</span>
                </div>
              </div>
              <div class="ncm-create-net__ice-card {{#if iceSourceCustom}}ncm-create-net__ice-card--sel{{/if}}" data-ice-mode="custom">
                <i class="fas fa-pen-fancy"></i>
                <div class="ncm-create-net__ice-card-info">
                  <span class="ncm-create-net__ice-card-title">Custom</span>
                  <span class="ncm-create-net__ice-card-desc">Your own name + formula</span>
                </div>
              </div>
              <div class="ncm-create-net__ice-card {{#if iceSourceActor}}ncm-create-net__ice-card--sel{{/if}}" data-ice-mode="actor">
                <i class="fas fa-robot"></i>
                <div class="ncm-create-net__ice-card-info">
                  <span class="ncm-create-net__ice-card-title">Actor</span>
                  <span class="ncm-create-net__ice-card-desc">Uses ATK from Black ICE actor</span>
                </div>
              </div>
            </div>
            <input type="hidden" name="iceSource" value="{{iceSource}}" />

            {{#if iceSourceDefault}}
              <div class="ncm-create-net__ice-default-info">
                Damage: <strong>3d6</strong> (BLACK ICE) or <strong>5d6</strong> (RED ICE)
              </div>
            {{/if}}

            {{#if iceSourceCustom}}
              <div class="ncm-create-net__row" style="margin-top:8px;">
                <div class="ncm-create-net__field">
                  <label class="ncm-create-net__label">ICE Name</label>
                  <input class="ncm-create-net__input" type="text" name="iceCustomName"
                         value="{{iceConfig.customName}}" placeholder="e.g. HELLHOUND">
                </div>
                <div class="ncm-create-net__field">
                  <label class="ncm-create-net__label">Damage Formula</label>
                  <input class="ncm-create-net__input" type="text" name="iceCustomDamage"
                         value="{{iceConfig.customDamage}}" placeholder="e.g. 4d6+2">
                  <div class="ncm-create-net__hint">Any valid Foundry roll formula.</div>
                </div>
              </div>
              <div class="ncm-create-net__field">
                <label class="ncm-create-net__label">Portrait</label>
                <input class="ncm-create-net__input" type="text" name="iceCustomPortrait"
                       value="{{iceConfig.customPortrait}}" placeholder="Image path (optional)">
              </div>
            {{/if}}

            {{#if iceSourceActor}}
              <div class="ncm-create-net__hint" style="margin-top:6px;">Select a Black ICE actor — damage will be ATK + 1d10.</div>
              <div class="ncm-create-net__ice-actors">
                {{#each blackIceActors}}
                  <div class="ncm-create-net__ice-actor {{#if selected}}ncm-create-net__ice-actor--sel{{/if}}" data-ice-actor="{{id}}">
                    {{#if img}}<img src="{{img}}" alt="{{name}}">{{else}}<i class="fas fa-robot"></i>{{/if}}
                    <span class="ncm-create-net__ice-actor-name">{{name}}</span>
                    {{#if atk}}<span class="ncm-create-net__ice-atk">ATK {{atk}}</span>{{/if}}
                  </div>
                {{else}}
                  <div class="ncm-create-net__hint" style="text-align:center;padding:12px;">No Black ICE actors found in world. Create a <strong>blackIce</strong> type actor first.</div>
                {{/each}}
              </div>
              <input type="hidden" name="iceActorId" value="{{iceConfig.actorId}}" />
            {{/if}}
          </div>
        {{/if}}
      {{/if}}

      {{!-- ─── Network Flags ─── --}}
      <div class="ncm-create-net__subsection-label"><i class="fas fa-flag"></i> Network Flags</div>
      <div class="ncm-create-net__flags">
        <label class="ncm-create-net__checkbox">
          <input type="checkbox" name="traced" {{#if data.traced}}checked{{/if}}>
          <div class="ncm-create-net__checkbox-info">
            <span class="ncm-create-net__checkbox-title">Traced</span>
            <span class="ncm-create-net__checkbox-desc">Messages are logged and traceable</span>
          </div>
        </label>
        <label class="ncm-create-net__checkbox">
          <input type="checkbox" name="anonymous" {{#if data.anonymous}}checked{{/if}}>
          <div class="ncm-create-net__checkbox-info">
            <span class="ncm-create-net__checkbox-title">Anonymous</span>
            <span class="ncm-create-net__checkbox-desc">Sender identity is hidden</span>
          </div>
        </label>
        <label class="ncm-create-net__checkbox">
          <input type="checkbox" name="globallyAvailable" {{#if data.globallyAvailable}}checked{{/if}}>
          <div class="ncm-create-net__checkbox-info">
            <span class="ncm-create-net__checkbox-title">Global</span>
            <span class="ncm-create-net__checkbox-desc">Available in all scenes</span>
          </div>
        </label>
      </div>
    </div>
  </div>

  {{!-- ═══ Appearance Section ═══ --}}
  <div class="ncm-create-net__section">
    <div class="ncm-create-net__section-title">
      <i class="fas fa-palette"></i> Appearance
    </div>
    <div class="ncm-create-net__section-body">
      <div class="ncm-create-net__appearance-row">
        <div class="ncm-create-net__icon-preview"
             style="background: {{data.theme.color}}14; color: {{data.theme.color}}; border: 1px solid {{data.theme.color}}26;">
          <i class="fas {{data.theme.icon}}"></i>
        </div>
        <div class="ncm-create-net__field" style="flex: 1;">
          <label class="ncm-create-net__label">Icon</label>
          <select class="ncm-create-net__select" name="themeIcon">
            {{#each iconOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}} ({{value}})</option>
            {{/each}}
          </select>
        </div>
        <div class="ncm-create-net__field">
          <label class="ncm-create-net__label">Color</label>
          <div class="ncm-create-net__color-row">
            <div class="ncm-create-net__swatch" style="background: {{data.theme.color}};"></div>
            <input class="ncm-create-net__input ncm-create-net__input--color" type="text"
                   name="themeColor" value="{{data.theme.color}}">
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{!-- ═══ Footer Actions ═══ --}}
<div class="ncm-create-net__footer">
  <button type="button" class="ncm-create-net__btn ncm-create-net__btn--ghost"
          data-action="cancel">
    Cancel
  </button>
  <div class="ncm-create-net__footer-spacer"></div>
  <button type="button" class="ncm-create-net__btn ncm-create-net__btn--ghost"
          data-action="createAndClose">
    <i class="fas fa-save"></i> Create &amp; Close
  </button>
  <button type="button" class="ncm-create-net__btn ncm-create-net__btn--primary"
          data-action="createAndOpen">
    <i class="fas fa-save"></i> Create &amp; Open in Manager
  </button>
</div>
