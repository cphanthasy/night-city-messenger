{{!--
  Network Authentication Dialog — Sprint 1.5.7 Atmosphere
  @file templates/dialogs/network-auth-dialog.hbs
  @module cyberpunkred-messenger
  @description Player-facing dialog for authenticating to secured networks.
    Supports password entry and skill check bypass modes.
    Sprint 1.5.7: bracket header, terminal-styled password field with
    blinking cursor, design-system typography, depth layering.
--}}

<div class="ncm-network-auth">

  {{!-- ═══ Bracket Header ═══ --}}
  {{> "modules/cyberpunkred-messenger/templates/partials/section-header.hbs"
      title="AUTHENTICATE" size="small" align="left" }}

  {{!-- ═══ Network Identity ═══ --}}
  <div class="ncm-network-auth__identity">
    <div class="ncm-network-auth__icon" style="color: {{network.color}}; border-color: {{network.color}}">
      <i class="fas {{network.icon}}"></i>
    </div>
    <div class="ncm-network-auth__title-group">
      <h2 class="ncm-network-auth__title ncm-accent-title">{{network.name}}</h2>
      <span class="ncm-network-auth__subtitle ncm-metadata">
        SECURITY: <span class="ncm-text-warning">{{network.securityLevel}}</span>
      </span>
    </div>
  </div>

  {{#if network.description}}
  <p class="ncm-network-auth__description ncm-data">{{network.description}}</p>
  {{/if}}

  {{!-- ═══ Lockout State ═══ --}}
  {{#if isLockedOut}}
  <div class="ncm-alert ncm-alert--danger">
    <i class="fas fa-ban"></i>
    <div>
      <strong>SYSTEM LOCKED</strong>
      <p>Too many failed attempts. Retry in <span class="ncm-data--bright">{{lockoutRemaining}}</span>.</p>
    </div>
  </div>
  {{else}}

  {{!-- ═══ Auth Method: Password ═══ --}}
  {{#if showPasswordField}}
  <div class="ncm-network-auth__section">
    <label class="ncm-label">ACCESS KEY</label>
    <div class="ncm-terminal-input-wrap">
      <span class="ncm-terminal-input-prompt">&gt;</span>
      <input type="password" name="password" class="ncm-input ncm-terminal-input"
             placeholder="Enter access key..." autocomplete="off" spellcheck="false"
             autofocus />
    </div>
    {{#if authError}}
    <div class="ncm-network-auth__error">
      <i class="fas fa-exclamation-triangle"></i>
      <span>{{authError}}</span>
    </div>
    {{/if}}
    <div class="ncm-network-auth__attempts ncm-metadata">
      ATTEMPTS: <span class="ncm-data--bright">{{attempts}}</span> / {{maxAttempts}}
    </div>
  </div>
  {{/if}}

  {{!-- ═══ Auth Method: Skill Check ═══ --}}
  {{#if showSkillCheck}}
  <div class="ncm-network-auth__section">
    <label class="ncm-label">SKILL BYPASS</label>
    <p class="ncm-data">Attempt to bypass security using {{skillName}} (DV {{skillDV}}).</p>
    <button class="ncm-btn ncm-btn--secondary" data-action="attemptSkillCheck">
      <i class="fas fa-terminal"></i>
      <span>Attempt {{skillName}} Check</span>
    </button>
  </div>
  {{/if}}

  {{!-- ═══ Auth Actions ═══ --}}
  <div class="ncm-network-auth__actions">
    <button class="ncm-btn ncm-btn--ghost" data-action="cancel">
      <i class="fas fa-times"></i> Disconnect
    </button>
    {{#if showPasswordField}}
    <button class="ncm-btn ncm-btn--primary" data-action="submitPassword"
            {{#if isSubmitting}}disabled{{/if}}>
      {{#if isSubmitting}}
      <i class="fas fa-spinner fa-spin"></i> Authenticating...
      {{else}}
      <i class="fas fa-key"></i> Authenticate
      {{/if}}
    </button>
    {{/if}}
    {{#if isGM}}
    <button class="ncm-btn ncm-btn--ghost" data-action="gmBypass"
            data-ncm-tooltip="GM: Bypass authentication">
      <i class="fas fa-shield-halved"></i> GM Override
    </button>
    {{/if}}
  </div>

  {{/if}}
</div>
