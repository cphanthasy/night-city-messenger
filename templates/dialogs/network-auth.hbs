{{!-- 
  Network Authentication Dialog Template
  File: templates/dialogs/network-auth.hbs
  Module: cyberpunkred-messenger
  Description: Dialog for authenticating to secured networks
--}}

<div class="ncm-network-auth-dialog">
  
  {{!-- Network Header --}}
  <div class="auth-header">
    <div class="auth-network-icon" style="color: {{network.color}};">
      <i class="fas {{network.icon}}"></i>
    </div>
    <div class="auth-network-info">
      <h2 class="auth-network-name">{{network.name}}</h2>
      <p class="auth-network-type">{{network.type}} Network</p>
    </div>
  </div>

  {{!-- Security Information --}}
  <div class="auth-security-info">
    <div class="security-level {{network.securityLevel}}">
      <i class="fas fa-shield-alt"></i>
      <span>Security Level: {{network.securityLevel}}</span>
    </div>
    <p class="security-description">{{network.securityDescription}}</p>
  </div>

  {{!-- Warnings --}}
  {{#if showTracedWarning}}
    <div class="auth-warning traced">
      <i class="fas fa-exclamation-triangle"></i>
      <strong>WARNING:</strong> This network connection is being traced by NetWatch.
    </div>
  {{/if}}

  {{#if showMonitoredWarning}}
    <div class="auth-warning monitored">
      <i class="fas fa-eye"></i>
      <strong>ALERT:</strong> All traffic on this network is actively monitored.
    </div>
  {{/if}}

  {{#if showBlackICEWarning}}
    <div class="auth-warning blackice">
      <i class="fas fa-skull-crossbones"></i>
      <strong>DANGER:</strong> This network is protected by BLACK ICE. Unauthorized access may be LETHAL.
    </div>
  {{/if}}

  {{!-- Lockout Display --}}
  {{#if isLocked}}
    <div class="auth-lockout">
      <i class="fas fa-lock"></i>
      <h3>ACCESS DENIED</h3>
      <p>Too many failed attempts. Network access is temporarily locked.</p>
      <p class="lockout-timer">Retry in: {{lockoutTime}} seconds</p>
    </div>
  {{else}}
  
    {{!-- Password Input --}}
    <div class="auth-form">
      <div class="auth-input-group">
        <label for="auth-password">
          <i class="fas fa-key"></i> Access Code
        </label>
        <input type="password" 
               id="auth-password" 
               name="password" 
               placeholder="Enter network password"
               autocomplete="off"
               {{#if passwordDisabled}}disabled{{/if}}>
      </div>

      {{!-- Attempt Counter --}}
      <div class="auth-attempts">
        <span>Attempts Remaining: <strong>{{attemptsRemaining}}/{{maxAttempts}}</strong></span>
      </div>
    </div>

    {{!-- Action Buttons --}}
    <div class="auth-actions">
      <button class="btn-primary" data-action="connect" {{#if passwordDisabled}}disabled{{/if}}>
        <i class="fas fa-plug"></i> Connect
      </button>

      {{#if canBreach}}
        <button class="btn-breach" data-action="breach" {{#if breachDisabled}}disabled{{/if}}>
          <i class="fas fa-user-secret"></i> Attempt Breach (DV{{breachDV}})
        </button>
        
        {{#if actor}}
          <div class="breach-info">
            <small>
              <i class="fas fa-info-circle"></i>
              Using {{breachSkill.name}} skill
            </small>
          </div>
        {{/if}}
      {{else}}
        {{#if actor}}
          <div class="breach-unavailable">
            <i class="fas fa-ban"></i>
            <small>You lack the necessary skills to attempt a breach.</small>
          </div>
        {{else}}
          <div class="breach-unavailable">
            <i class="fas fa-user-slash"></i>
            <small>No character selected. Breaching requires Interface, Electronics, or Basic Tech skills.</small>
          </div>
        {{/if}}
      {{/if}}

      <button class="btn-secondary" data-action="cancel">
        <i class="fas fa-times"></i> Cancel
      </button>
    </div>

    {{!-- Breach Information --}}
    {{#if canBreach}}
      <div class="auth-breach-note">
        <i class="fas fa-lightbulb"></i>
        <p><strong>Breach Attempt:</strong> Roll {{breachSkill.name}} check against DV{{breachDV}}. 
        Success grants temporary access. Failure counts as a failed attempt and may trigger alerts.</p>
      </div>
    {{/if}}
  {{/if}}

  {{!-- Description --}}
  {{#if network.description}}
    <div class="auth-description">
      <p>{{network.description}}</p>
    </div>
  {{/if}}

</div>
