{{!--
  Encrypted Overlay — ICE / BLACK ICE animated display (v6 redesign)
  @file templates/contact-manager/partials/encrypted-overlay.hbs
  @module cyberpunkred-messenger
  @description Conic-gradient ring animation, no DOM injection needed.
    Click target is the breach button only, not the entire overlay.
--}}

<div class="ncm-ice ncm-ice--{{#if blackIce}}black{{else}}standard{{/if}}"
     data-contact-id="{{contactId}}">
  <div class="ncm-ice__grid"></div>
  <div class="ncm-ice__scan"></div>

  <div class="ncm-ice__icon-wrap">
    <div class="ncm-ice__icon">
      {{#if icePortrait}}
        <img src="{{icePortrait}}" alt="ICE" class="ncm-ice__portrait" />
      {{else}}
        <i class="fas fa-{{#if blackIce}}skull-crossbones{{else}}lock{{/if}}"></i>
      {{/if}}
    </div>
  </div>

  <div class="ncm-ice__title">
    {{#if blackIce}}BLACK ICE Detected{{else}}ICE Protected{{/if}}
  </div>

  <div class="ncm-ice__status"></div>

  <div class="ncm-ice__dv">
    <span class="ncm-ice__dv-label">Difficulty</span>
    <span class="ncm-ice__dv-value">{{encryptionDV}}</span>
    <span class="ncm-ice__dv-skill">{{encryptionSkill}}</span>
  </div>

  {{#if blackIce}}
    <div class="ncm-ice__damage">
      <i class="fas fa-bolt"></i>
      Failure: {{blackIceDamage}} damage to netrunner
    </div>
  {{/if}}

  <div class="ncm-ice__meta">
    {{#if blackIce}}
      Hostile countermeasure. Breach failure is lethal.
    {{else}}
      Intrusion countermeasure active. Breach required.
    {{/if}}
  </div>

  {{!-- Attempt dots --}}
  {{#if maxBreachAttempts}}
    <div class="ncm-ice__attempts">
      <span class="ncm-ice__attempts-label">Attempts</span>
      {{#each attemptDots}}
        <div class="ncm-ice__attempt-dot {{#if used}}ncm-ice__attempt-dot--used{{/if}} {{#if current}}ncm-ice__attempt-dot--current{{/if}}"></div>
      {{/each}}
    </div>
  {{/if}}

  {{#if isLockedOut}}
    <div class="ncm-ice__lockout">
      <i class="fas fa-clock"></i> LOCKED OUT — System in cooldown
    </div>
  {{else}}
    <button class="ncm-ice__breach" data-action="breachContact" data-contact-id="{{contactId}}">
      <i class="fas fa-terminal"></i>
      {{#if blackIce}}Breach at Your Own Risk{{else}}Attempt Breach{{/if}}
    </button>
  {{/if}}

  <button class="ncm-ice__share-btn" data-action="shareContact" data-contact-id="{{contactId}}">
    <i class="fas fa-share-nodes"></i> Share Contact (ICE intact)
  </button>

  {{#if isGM}}
    <button class="ncm-ice__breach ncm-ice__breach--gm"
            data-action="forceDecrypt" data-contact-id="{{contactId}}">
      <i class="fas fa-shield-halved"></i> GM Bypass
    </button>
  {{/if}}

  {{!-- Result overlay (always in DOM, toggled via class) --}}
  <div class="ncm-ice__result"></div>
</div>
