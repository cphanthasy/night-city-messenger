{{!--
  Encrypted Overlay — ICE / BLACK ICE animated display (v5.1 redesign)
  @file templates/contact-manager/partials/encrypted-overlay.hbs
  @module cyberpunkred-messenger
  @description Animated overlay with drifting grid, scanning line, pulsing icon
    with rotating dashed ring, large DV readout. BLACK ICE variant has faster
    animations, red tint, and damage warning. All CSS-only, gated by animation
    preference attribute.

  @param {number}  encryptionDV       — Difficulty value for the hack check
  @param {string}  encryptionSkill    — Required skill (e.g. "Interface")
  @param {boolean} [blackIce]         — Whether this is BLACK ICE (lethal on failure)
  @param {string}  [blackIceDamage]   — Damage formula (e.g. "3d6", "5d6")
  @param {boolean} [isGM]             — Whether current user is GM (shows bypass)
  @param {string}  [contactId]        — Contact ID (for force-decrypt data attribute)

  @example
    {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/encrypted-overlay.hbs"
        encryptionDV=15 encryptionSkill="Interface" blackIce=blackIce
        blackIceDamage=blackIceDamage isGM=../isGM contactId=id }}
--}}

<div class="ncm-ice ncm-ice--{{#if blackIce}}black{{else}}standard{{/if}}"
     data-action="breachContact">
  <div class="ncm-ice__grid"></div>
  <div class="ncm-ice__scan"></div>

  <div class="ncm-ice__icon">
    {{#if icePortrait}}
      <img src="{{icePortrait}}" alt="ICE" class="ncm-ice__portrait" />
    {{else}}
      <i class="fas fa-{{#if blackIce}}skull-crossbones{{else}}lock{{/if}}"></i>
    {{/if}}
  </div>

  <div class="ncm-ice__title">
    {{#if blackIce}}BLACK ICE Detected{{else}}ICE Protected{{/if}}
  </div>

  <div class="ncm-ice__dv">
    <span class="ncm-ice__dv-label">Difficulty</span>
    <span class="ncm-ice__dv-value">{{encryptionDV}}</span>
    <span class="ncm-ice__dv-skill">{{encryptionSkill}}</span>
  </div>

  {{#if blackIce}}
    <div class="ncm-ice__damage">
      <i class="fas fa-bolt"></i>
      Failure: {{blackIceDamage}} damage to netrunner
    </div>
  {{/if}}

  <div class="ncm-ice__meta">
    {{#if blackIce}}
      Hostile countermeasure. Breach failure is lethal.
    {{else}}
      Intrusion countermeasure active. Breach required.
    {{/if}}
  </div>

  <button class="ncm-ice__breach">
    <i class="fas fa-terminal"></i>
    {{#if blackIce}}Breach at Your Own Risk{{else}}Attempt Breach{{/if}}
  </button>

  {{#if isGM}}
    <button class="ncm-ice__breach ncm-ice__breach--gm"
            data-action="forceDecrypt" data-contact-id="{{contactId}}">
      <i class="fas fa-shield-halved"></i> GM Bypass
    </button>
  {{/if}}
</div>
