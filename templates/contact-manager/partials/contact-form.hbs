{{!--
  Contact Form — Shared Create/Edit partial (Phase 2 Redesign)
  @file templates/contact-manager/partials/contact-form.hbs
  @module cyberpunkred-messenger
  @description Unified form used by both player ContactManagerApp and
    GM GMContactManagerApp for creating/editing contacts.
    GM-only fields (notes, relationships, linked actor, ICE) gated by {{#if isGM}}.

  Phase 2 changes:
    - Role dropdown uses contact.role (not contact.type)
    - Added: Ripperdoc, Civilian, Government, A.I. roles
    - Custom roles from GM settings integrated via roleOptions/customRoles
    - Location field in 3-column row (Role / Org / Location)
    - Per-player relationship rows replace single relationship dropdown
    - Party trust separate from per-player trust
    - Compact ICE layout (DV + BLACK ICE in one row)

  @param {object|null} contact       — Contact data (null for create mode)
  @param {boolean}     isCreating    — True when creating a new contact
  @param {boolean}     isGM          — Whether current user is GM
  @param {Array}       [availableActors] — All actors for linking (GM only)
  @param {Array}       [playerActors] — Player-owned actors (for relationship rows)
  @param {Array}       [roleOptions] — Built-in + custom role options
  @param {Array}       [customRoles] — Custom roles from GM settings
  @param {Array}       [perPlayerRelationships] — Per-player relationship form data
--}}

<form class="ncm-contact-form">

  {{!-- ── Name + Alias ── --}}
  <div class="ncm-form-row ncm-form-row--half">
    <div class="ncm-form-group">
      <label class="ncm-form-label">Name <span class="ncm-form-required">*</span></label>
      <input type="text" name="name" value="{{contact.name}}"
             placeholder="Rogue Amendiares" class="ncm-form-input" required />
    </div>
    <div class="ncm-form-group">
      <label class="ncm-form-label">Alias / Subtitle</label>
      <input type="text" name="alias" value="{{contact.alias}}"
             placeholder="The Queen of the Afterlife" class="ncm-form-input" />
    </div>
  </div>

  {{!-- ── Email + Phone ── --}}
  <div class="ncm-form-row ncm-form-row--half">
    <div class="ncm-form-group">
      <label class="ncm-form-label">Email</label>
      <div class="ncm-form-input-wrapper">
        <input type="text" name="email" value="{{contact.email}}"
               placeholder="rogue@afterlife.nc"
               class="ncm-form-input ncm-form-input--mono ncm-email-verify-input"
               autocomplete="off" />
        <span class="ncm-email-verify-indicator" data-verify-status="{{#if contact.email}}{{#if contact.verified}}verified{{else if contact.verifiedOverride}}verified{{else}}unverified{{/if}}{{else}}unknown{{/if}}">
          {{#if contact.email}}
            {{#if contact.verified}}
              <i class="fas fa-circle-check"></i>
            {{else if contact.verifiedOverride}}
              <i class="fas fa-shield-check"></i>
            {{else}}
              <i class="fas fa-triangle-exclamation"></i>
            {{/if}}
          {{else}}
            <i class="fas fa-circle-question"></i>
          {{/if}}
        </span>
      </div>
    </div>
    <div class="ncm-form-group">
      <label class="ncm-form-label">Phone</label>
      <input type="text" name="phone" value="{{contact.phone}}"
             placeholder="+1-NC-555-0147" class="ncm-form-input ncm-form-input--mono" />
    </div>
  </div>

  {{!-- ── Role / Organization / Location (3-column) ── --}}
  <div class="ncm-form-row ncm-form-row--thirds">
    <div class="ncm-form-group">
      <label class="ncm-form-label">Role</label>
      <select name="role" class="ncm-form-select ncm-form-select--role">
        <option value="npc" {{#if (eq contact.role 'npc')}}selected{{/if}}>NPC</option>
        <option value="" disabled>── Roles ──</option>
        <option value="fixer" {{#if (eq contact.role 'fixer')}}selected{{/if}}>Fixer</option>
        <option value="solo" {{#if (eq contact.role 'solo')}}selected{{/if}}>Solo</option>
        <option value="netrunner" {{#if (eq contact.role 'netrunner')}}selected{{/if}}>Netrunner</option>
        <option value="tech" {{#if (eq contact.role 'tech')}}selected{{/if}}>Tech</option>
        <option value="medtech" {{#if (eq contact.role 'medtech')}}selected{{/if}}>Medtech</option>
        <option value="ripperdoc" {{#if (eq contact.role 'ripperdoc')}}selected{{/if}}>Ripperdoc</option>
        <option value="media" {{#if (eq contact.role 'media')}}selected{{/if}}>Media</option>
        <option value="exec" {{#if (eq contact.role 'exec')}}selected{{/if}}>Exec</option>
        <option value="corp" {{#if (eq contact.role 'corp')}}selected{{/if}}>Corp</option>
        <option value="lawman" {{#if (eq contact.role 'lawman')}}selected{{/if}}>Lawman</option>
        <option value="nomad" {{#if (eq contact.role 'nomad')}}selected{{/if}}>Nomad</option>
        <option value="rockerboy" {{#if (eq contact.role 'rockerboy')}}selected{{/if}}>Rockerboy</option>
        <option value="" disabled>── Types ──</option>
        <option value="gang" {{#if (eq contact.role 'gang')}}selected{{/if}}>Gang</option>
        <option value="civilian" {{#if (eq contact.role 'civilian')}}selected{{/if}}>Civilian</option>
        <option value="government" {{#if (eq contact.role 'government')}}selected{{/if}}>Government</option>
        <option value="ai" {{#if (eq contact.role 'ai')}}selected{{/if}}>A.I.</option>
        {{!-- Custom roles --}}
        {{#if customRoles.length}}
          <option value="" disabled>── Custom ──</option>
          {{#each customRoles}}
            <option value="{{id}}" {{#if (eq id ../contact.role)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        {{/if}}
        {{#if isGM}}
          <option value="" disabled>────────</option>
          <option value="__manage_roles__">Manage Roles...</option>
        {{/if}}
      </select>
    </div>
    <div class="ncm-form-group">
      <label class="ncm-form-label">Organization</label>
      <input type="text" name="organization" value="{{contact.organization}}"
             placeholder="Afterlife Bar" class="ncm-form-input" />
    </div>
    <div class="ncm-form-group">
      <label class="ncm-form-label"><i class="fas fa-location-dot" style="color: #c47a2a; font-size: 8px;"></i> Location</label>
      <input type="text" name="location" value="{{contact.location}}"
             placeholder="Afterlife, Watson" class="ncm-form-input" />
    </div>
  </div>

  {{!-- ── Portrait + Tags ── --}}
  <div class="ncm-form-row ncm-form-row--half">
    <div class="ncm-form-group">
      <label class="ncm-form-label">Portrait</label>
      <div class="ncm-form-input-row">
        <input type="text" name="portrait" value="{{contact.portrait}}"
               placeholder="path/to/image.png" class="ncm-form-input ncm-form-input--mono" />
        <button type="button" class="ncm-form-browse-btn" data-action="browsePortrait" title="Browse files">
          <i class="fas fa-folder-open"></i>
        </button>
      </div>
    </div>
    <div class="ncm-form-group">
      <label class="ncm-form-label">Tags <span class="ncm-form-hint">(comma-separated)</span></label>
      <input type="text" name="tags"
             value="{{#each contact.tags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}"
             placeholder="HEIST CREW, TRUSTED, ARASAKA"
             class="ncm-form-input ncm-form-input--mono" />
    </div>
  </div>

  {{!-- ═══════════════════════════════════════════
       GM-ONLY FIELDS — Hidden for players
       ═══════════════════════════════════════════ --}}
  {{#if isGM}}

    {{!-- GM section divider --}}
    <div class="ncm-form-divider-label"><i class="fas fa-shield-halved"></i> GM-ONLY FIELDS</div>
    <hr class="ncm-form-divider" />

    {{!-- ── Party Trust + Linked Actor ── --}}
    <div class="ncm-form-row ncm-form-row--half">
      <div class="ncm-form-group">
        <label class="ncm-form-label">
          <i class="fas fa-shield-halved" style="color: var(--ncm-success, #00ff41); font-size: 8px;"></i>
          Party Trust
          <span class="ncm-form-hint">(group baseline)</span>
        </label>
        <select name="trust" class="ncm-form-select ncm-form-select--trust">
          <option value="0" {{#if (eq contact.trust 0)}}selected{{/if}}>0 — Unknown</option>
          <option value="1" {{#if (eq contact.trust 1)}}selected{{/if}}>1 — Suspicious</option>
          <option value="2" {{#if (eq contact.trust 2)}}selected{{/if}}>2 — Cautious</option>
          <option value="3" {{#if (eq contact.trust 3)}}selected{{/if}}>3 — Neutral</option>
          <option value="4" {{#if (eq contact.trust 4)}}selected{{/if}}>4 — Trusted</option>
          <option value="5" {{#if (eq contact.trust 5)}}selected{{/if}}>5 — Implicitly Trusted</option>
        </select>
      </div>
      <div class="ncm-form-group">
        <label class="ncm-form-label">Linked Actor</label>
        <select name="actorId" class="ncm-form-select">
          <option value="">— None —</option>
          {{#each availableActors}}
            <option value="{{id}}" {{#if (eq id ../contact.actorId)}}selected{{/if}}>
              {{name}} {{#if hasPlayerOwner}}(Player){{/if}}
            </option>
          {{/each}}
        </select>
      </div>
    </div>

    {{!-- ── Folder assignment ── --}}
    <div class="ncm-form-row">
      <div class="ncm-form-group">
        <label class="ncm-form-label">
          <i class="fas fa-folder" style="color: var(--ncm-accent, #f7c948); font-size: 8px;"></i>
          Folder
          <span class="ncm-form-hint">(for manual grouping — type or pick existing)</span>
        </label>
        <div class="ncm-form-input-row">
          <input type="text" name="folder" value="{{contact.folder}}"
                 placeholder="e.g. Main Story NPCs"
                 class="ncm-form-input"
                 list="ncm-folder-list" autocomplete="off" />
          <button type="button" class="ncm-form-browse-btn" data-action="createFolderInline" title="Create new folder">
            <i class="fas fa-folder-plus"></i>
          </button>
        </div>
        <datalist id="ncm-folder-list">
          {{#each existingFolders}}
            <option value="{{this}}">
          {{/each}}
        </datalist>
      </div>
    </div>

    {{!-- ── ICE / Encryption (compact) ── --}}
    <div class="ncm-form-row ncm-form-row--half">
      <div class="ncm-form-group">
        <label class="ncm-form-label">
          <i class="fas fa-lock" style="color: var(--ncm-accent, #f7c948); font-size: 8px;"></i>
          ICE Encryption
        </label>
        <select name="encrypted" class="ncm-form-select">
          <option value="false" {{#unless contact.encrypted}}selected{{/unless}}>None — Open access</option>
          <option value="true" {{#if contact.encrypted}}selected{{/if}}>ICE Protected</option>
        </select>
      </div>
      <div class="ncm-form-group">
        <label class="ncm-form-label">ICE DV / BLACK ICE</label>
        <div class="ncm-form-ice-compact">
          <input type="number" name="encryptionDV" value="{{contact.encryptionDV}}"
                 placeholder="15" min="8" max="30" step="1"
                 class="ncm-form-input ncm-form-input--mono ncm-form-input--dv" />
          <select name="blackIce" class="ncm-form-select ncm-form-select--ice">
            <option value="false" {{#unless contact.blackIce}}selected{{/unless}}>No BLACK ICE</option>
            <option value="true" {{#if contact.blackIce}}selected{{/if}}>BLACK ICE Active</option>
          </select>
          <input type="text" name="blackIceDamage" value="{{contact.blackIceDamage}}"
                 placeholder="dmg" class="ncm-form-input ncm-form-input--mono ncm-form-input--dmg" />
        </div>
      </div>
    </div>

    {{!-- ── Per-Player Relationships ── --}}
    {{#if perPlayerRelationships.length}}
      <div class="ncm-form-row">
        <div class="ncm-form-group">
          <label class="ncm-form-label">
            <i class="fas fa-users" style="color: var(--ncm-secondary, #19f3f7); font-size: 8px;"></i>
            Per-Player Relationships
            <span class="ncm-form-hint">(leave trust empty = inherit party)</span>
          </label>
          <div class="ncm-rel-form-grid">
            {{#each perPlayerRelationships}}
              <div class="ncm-rel-form-row" data-actor-id="{{actorId}}">
                <div class="ncm-rel-form-row__pip">{{initial}}</div>
                <span class="ncm-rel-form-row__name">{{characterName}}</span>
                <select class="ncm-form-select ncm-rel-select" style="width: 100px; font-size: 9px; padding: 3px 18px 3px 5px;">
                  <option value="">— None —</option>
                  <option value="ally" {{#if (eq relType 'ally')}}selected{{/if}}>Ally</option>
                  <option value="contact" {{#if (eq relType 'contact')}}selected{{/if}}>Contact</option>
                  <option value="neutral" {{#if (eq relType 'neutral')}}selected{{/if}}>Neutral</option>
                  <option value="hostile" {{#if (eq relType 'hostile')}}selected{{/if}}>Hostile</option>
                  <option value="rival" {{#if (eq relType 'rival')}}selected{{/if}}>Rival</option>
                  <option value="owes-you" {{#if (eq relType 'owes-you')}}selected{{/if}}>Owes You</option>
                  <option value="you-owe" {{#if (eq relType 'you-owe')}}selected{{/if}}>You Owe</option>
                  <option value="patron" {{#if (eq relType 'patron')}}selected{{/if}}>Patron</option>
                  <option value="informant" {{#if (eq relType 'informant')}}selected{{/if}}>Informant</option>
                </select>
                <div class="ncm-rel-form-trust" data-trust="{{trustValue}}" title="Player trust (click to set, leave empty = use party baseline)">
                  <div class="ncm-rel-form-trust__pip s1 {{#if (ncm-eq trustLevel1 true)}}ncm-rel-form-trust__pip--active{{/if}}" data-pip="1"></div>
                  <div class="ncm-rel-form-trust__pip s2 {{#if (ncm-eq trustLevel2 true)}}ncm-rel-form-trust__pip--active{{/if}}" data-pip="2"></div>
                  <div class="ncm-rel-form-trust__pip s3 {{#if (ncm-eq trustLevel3 true)}}ncm-rel-form-trust__pip--active{{/if}}" data-pip="3"></div>
                  <div class="ncm-rel-form-trust__pip s4 {{#if (ncm-eq trustLevel4 true)}}ncm-rel-form-trust__pip--active{{/if}}" data-pip="4"></div>
                  <div class="ncm-rel-form-trust__pip s5 {{#if (ncm-eq trustLevel5 true)}}ncm-rel-form-trust__pip--active{{/if}}" data-pip="5"></div>
                </div>
                <span class="ncm-rel-form-row__trust-label {{#if isOverride}}ncm-rel-form-row__trust-label--override{{/if}}">{{trustDisplay}}</span>
                <input type="text" class="ncm-rel-form-row__note-input ncm-rel-note-input"
                       value="{{note}}" placeholder="Relationship note..." />
              </div>
            {{/each}}
          </div>
        </div>
      </div>
    {{/if}}

    {{!-- ── GM Notes ── --}}
    <div class="ncm-form-row">
      <div class="ncm-form-group">
        <label class="ncm-form-label">
          <i class="fas fa-eye-slash" style="font-size: 8px;"></i>
          GM Notes
          <span class="ncm-form-hint ncm-form-hint--danger">(never shared)</span>
        </label>
        <textarea name="notes" rows="2" placeholder="Private GM notes..."
                  class="ncm-form-textarea">{{contact.notes}}</textarea>
      </div>
    </div>

  {{/if}}

  {{!-- ── Form Actions ── --}}
  <div class="ncm-form-actions">
    <button type="button" class="ncm-btn ncm-btn--ghost" data-action="cancelEdit">
      <i class="fas fa-times"></i> Cancel
    </button>
    <button type="button" class="ncm-btn ncm-btn--accent" data-action="saveContact">
      <i class="fas fa-save"></i> {{#if isCreating}}Create Contact{{else}}Save Changes{{/if}}
    </button>
  </div>

</form>
