{{!--
  Contact Manager — v5.1 Split View Rewrite
  @file templates/contact-manager/contact-manager.hbs
  @module cyberpunkred-messenger
  @description Player contact directory with split-view layout:
    Left: quick-dial favorites, sort/group bar, collapsible grouped list
    Right: detail panel with profile, info cards, last interaction, relationship, notes
    Replaces Sprint 3 grid/list-only layout.
--}}

<div class="ncm-contacts-v5">

  {{!-- ═══ Header: Avatar + Name + Stats + Actions ═══ --}}
  <div class="ncm-header">
    <div class="ncm-header__identity">
      <div class="ncm-header__avatar" style="color: {{ownerAvatarColor}};">
        {{#if ownerPortrait}}
          <img src="{{ownerPortrait}}" alt="{{ownerName}}">
        {{else}}
          {{ownerInitials}}
        {{/if}}
      </div>
      <div class="ncm-header__info">
        <span class="ncm-header__name">{{ownerName}}</span>
        <span class="ncm-header__email">{{ownerEmail}}</span>
      </div>
    </div>
    <div class="ncm-header__divider"></div>
    <div class="ncm-header__stats">
      <div class="ncm-stat">
        <span class="ncm-stat__value">{{contactCount}}</span>
        <span class="ncm-stat__label">Contacts</span>
      </div>
      <div class="ncm-stat">
        <span class="ncm-stat__value ncm-stat__value--success">{{onlineCount}}</span>
        <span class="ncm-stat__label">Online</span>
      </div>
      <div class="ncm-stat">
        <span class="ncm-stat__value ncm-stat__value--accent">{{favoriteCount}}</span>
        <span class="ncm-stat__label">Favs</span>
      </div>
    </div>
    <div class="ncm-header__actions">
      {{#if isGM}}
        <button class="ncm-btn ncm-btn--ghost ncm-btn--sm"
                data-action="openGMContacts" title="GM Master Contact Directory">
          <i class="fas fa-shield-halved"></i> GM
        </button>
      {{/if}}
      <button class="ncm-btn ncm-btn--secondary" data-action="addContact">
        <i class="fas fa-user-plus"></i> Add
      </button>
      <button class="ncm-btn ncm-btn--ghost" data-action="openSettings">
        <i class="fas fa-gear"></i>
      </button>
    </div>
  </div>

  {{!-- GM Inspect Banner --}}
  {{#if gmInspectMode}}
    <div class="ncm-gm-inspect-banner">
      <i class="fas fa-shield-halved"></i>
      <span>GM ADMIN — VIEWING:</span>
      <span class="ncm-gm-inspect-banner__name">{{inspectedActorName}}'S CONTACTS</span>
    </div>
  {{/if}}

  {{!-- ═══ Toolbar: Search + Filter Pills + View Toggle ═══ --}}
  <div class="ncm-toolbar">
    <div class="ncm-search-row">
      <i class="fas fa-search"></i>
      <input class="ncm-search-input ncm-contact-search" type="text"
             placeholder="Search contacts..." value="{{searchTerm}}">
      <span class="ncm-search-count">{{filteredCount}} contact{{#if (neq filteredCount 1)}}s{{/if}}</span>
    </div>
    <div class="ncm-filter-row">
      <span class="ncm-pill ncm-pill--all {{#unless hasActiveTagFilter}}ncm-pill--active{{/unless}}"
            data-action="clearTagFilter">ALL</span>
      {{#each allTags}}
        <span class="ncm-pill ncm-pill--tag {{#if this.active}}ncm-pill--active{{/if}}"
              data-action="toggleTagFilter" data-tag="{{this.name}}">
          {{this.name}}
          {{#if this.active}}
            <span class="ncm-pill__remove" data-action="removeTagFilter" data-tag="{{this.name}}">×</span>
          {{/if}}
        </span>
      {{/each}}
      <span class="ncm-pill ncm-pill--add" data-action="startAddTag" title="Create new tag">
        <i class="fas fa-plus"></i>
      </span>
      <div class="ncm-view-toggle">
        <button class="ncm-view-btn {{#if (eq viewMode 'grid')}}ncm-view-btn--active{{/if}}"
                data-action="setViewMode" data-mode="grid" title="Grid view">
          <i class="fas fa-grip"></i>
        </button>
        <button class="ncm-view-btn {{#if (eq viewMode 'list')}}ncm-view-btn--active{{/if}}"
                data-action="setViewMode" data-mode="list" title="List view">
          <i class="fas fa-list"></i>
        </button>
      </div>
    </div>
  </div>

  {{!-- ═══ Content: Form OR Split View OR Grid ═══ --}}

  {{!-- Add/Edit Form (full width, replaces split) --}}
  {{#if isAdding}}
    <div class="ncm-content">
      <div class="ncm-content__form">
        <div class="ncm-gm-section-header">
          <i class="fas fa-plus"></i> NEW CONTACT
        </div>
        {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-form.hbs"
            contact=null isCreating=true isGM=isGM }}
      </div>
    </div>

  {{else if editingContact}}
    <div class="ncm-content">
      <div class="ncm-content__form">
        <div class="ncm-gm-section-header">
          <i class="fas fa-pen"></i> EDIT — {{editingContact.name}}
        </div>
        {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-form.hbs"
            contact=editingContact isCreating=false isGM=isGM }}
      </div>
    </div>

  {{!-- Grid View (full width, original card layout) --}}
  {{else if isGridView}}
    <div class="ncm-content">
      {{#if isEmpty}}
        <div class="ncm-empty">
          {{#if hasSearch}}
            <i class="fas fa-search"></i>
            <div class="ncm-empty__text">No matches found</div>
            <div class="ncm-empty__sub">Try adjusting your search or filters</div>
          {{else}}
            <i class="fas fa-user-slash"></i>
            <div class="ncm-empty__text">No contacts yet</div>
            <div class="ncm-empty__sub">Add contacts to start messaging</div>
          {{/if}}
        </div>
      {{else}}
        <div class="ncm-grid">
          {{#each contacts}}
            {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-card.hbs" }}
          {{/each}}
        </div>
      {{/if}}
    </div>

  {{!-- List/Split View --}}
  {{else}}
    {{#if isEmpty}}
      <div class="ncm-content">
        <div class="ncm-empty">
          {{#if hasSearch}}
            <i class="fas fa-search"></i>
            <div class="ncm-empty__text">No matches found</div>
            <div class="ncm-empty__sub">Try adjusting your search or filters</div>
          {{else}}
            <i class="fas fa-user-slash"></i>
            <div class="ncm-empty__text">No contacts yet</div>
            <div class="ncm-empty__sub">Add contacts to start messaging</div>
          {{/if}}
        </div>
      </div>
    {{else}}
      <div class="ncm-split">

        {{!-- LEFT: List Panel --}}
        <div class="ncm-split__list">

          {{!-- Quick-Dial Favorites --}}
          {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-quickdial.hbs"
              quickDialContacts=quickDialContacts }}

          {{!-- Sort / Group Bar --}}
          <div class="ncm-sort-bar">
            <span class="ncm-sort-bar__label">Group</span>
            <select class="ncm-sort-bar__select ncm-group-select">
              <option value="none" {{#if (eq groupBy 'none')}}selected{{/if}}>None (A–Z)</option>
              <option value="role" {{#if (eq groupBy 'role')}}selected{{/if}}>Role</option>
              <option value="organization" {{#if (eq groupBy 'organization')}}selected{{/if}}>Organization</option>
              <option value="location" {{#if (eq groupBy 'location')}}selected{{/if}}>Location</option>
            </select>
            <span class="ncm-sort-bar__label">Sort</span>
            <select class="ncm-sort-bar__select ncm-sort-select" style="max-width:80px;">
              <option value="name" {{#if (eq sortBy 'name')}}selected{{/if}}>Name</option>
              <option value="recent" {{#if (eq sortBy 'recent')}}selected{{/if}}>Recent</option>
              <option value="trust" {{#if (eq sortBy 'trust')}}selected{{/if}}>Trust</option>
            </select>
            <button class="ncm-sort-bar__btn" data-action="collapseAll" title="Collapse all">
              <i class="fas fa-compress-alt"></i>
            </button>
            <button class="ncm-sort-bar__btn" data-action="expandAll" title="Expand all">
              <i class="fas fa-expand-alt"></i>
            </button>
          </div>

          {{!-- Scrollable Contact List --}}
          <div class="ncm-list-scroll">
            {{#each groups}}
              {{!-- Group header (skip for ungrouped/flat) --}}
              {{#if ../hasGroups}}
                {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-group-header.hbs"
                    groupKey=key groupName=name groupIcon=icon groupCount=contacts.length
                    isCollapsed=isCollapsed isEncryptedGroup=isEncryptedGroup }}
              {{/if}}

              {{!-- Contact items within group --}}
              {{#unless isCollapsed}}
                {{#each contacts}}
                  <div class="ncm-list-item {{#if isSelected}}ncm-list-item--selected{{/if}} {{#if isEncrypted}}ncm-list-item--encrypted{{/if}}"
                       data-action="selectContact" data-contact-id="{{id}}">
                    <div class="ncm-list-item__avatar"
                         style="{{#if isEncrypted}}color:var(--ncm-accent, #F0C55B); border-color:rgba(240,197,91,0.4);{{else}}color: {{avatarColor}}; border-color: {{avatarBorderColor}};{{/if}}">
                      {{#if isEncrypted}}
                        <i class="fas fa-lock" style="font-size:13px;"></i>
                      {{else if hasPortrait}}
                        <img src="{{portraitSrc}}" alt="{{name}}" />
                      {{else}}
                        {{initials}}
                      {{/if}}
                      {{#if (eq status 'online')}}
                        <div class="ncm-list-item__status ncm-list-item__status--online"></div>
                      {{/if}}
                    </div>
                    <div class="ncm-list-item__body">
                      <div class="ncm-list-item__row1">
                        <span class="ncm-list-item__name">
                          {{#if isEncrypted}}████████{{else}}{{name}}{{/if}}
                        </span>
                        <span class="ncm-list-item__seen {{#if (eq status 'online')}}ncm-list-item__seen--online{{/if}}">
                          {{#if isEncrypted}}ICE{{else if (eq status 'online')}}now{{else if lastSeen}}{{lastSeen}}{{/if}}
                        </span>
                      </div>
                      {{#unless isEncrypted}}
                        <div class="ncm-list-item__row2">
                          <span class="ncm-list-item__email">{{email}}</span>
                        </div>
                      {{/unless}}
                    </div>
                    {{#if isFavorite}}
                      <i class="ncm-list-item__fav fas fa-star"></i>
                    {{/if}}
                  </div>
                {{/each}}
              {{/unless}}
            {{/each}}
          </div>
        </div>

        {{!-- RIGHT: Detail Panel --}}
        <div class="ncm-split__detail">
          {{#if selectedContact}}
            <div class="ncm-detail">
              {{> "modules/cyberpunkred-messenger/templates/contact-manager/partials/contact-detail.hbs"
                  selectedContact=selectedContact isGM=isGM
                  lastInteraction=lastInteraction
                  hasRelationship=hasRelationship
                  relationship=selectedRelationship
                  relationshipNote=selectedRelationshipNote }}
            </div>
          {{else}}
            <div class="ncm-detail-empty">
              <i class="fas fa-address-card"></i>
              <div class="ncm-detail-empty__text">Select a contact</div>
              <div class="ncm-detail-empty__sub">Choose from the list to view details</div>
            </div>
          {{/if}}
        </div>

      </div>
    {{/if}}
  {{/if}}

  {{!-- ═══ Footer: Stats + Keyboard Shortcuts ═══ --}}
  <div class="ncm-footer">
    <div class="ncm-footer__info">
      <span><i class="fas fa-address-book"></i> {{filteredCount}} contacts</span>
      <span><i class="fas fa-user"></i> {{ownerName}}</span>
      <span><i class="fas fa-wifi"></i> {{currentNetwork}}</span>
    </div>
    <div class="ncm-footer__shortcuts">
      {{#if selectedContact}}
        <kbd>M</kbd> message <kbd>E</kbd> edit <kbd>F</kbd> fav <kbd>S</kbd> share
      {{else}}
        <kbd>/</kbd> search <kbd>↑↓</kbd> nav <kbd>N</kbd> new <kbd>G</kbd> group
      {{/if}}
    </div>
  </div>
</div>
